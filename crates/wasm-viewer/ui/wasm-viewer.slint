// Browser-side chrome for the slint-mobile-components catalogue.
//
// Structurally a cut-down copy of crates/viewer/ui/viewer.slint without
// the verdict-toggle row (the wasm site is read-only — it's an
// audition surface, not a review tool, so the keep / redo buttons
// would just confuse a first-time visitor).
//
// The grid reflows with the browser viewport so visitors get as many
// 412-px cells per row as their window can hold, with the column count
// computed in `cols` from `root.width`.

import { ScrollView } from "std-widgets.slint";
import { Theme } from "@mobile-theme/theme.slint";

// Statically embed + register every bundled font at chrome-compile
// time so runtime-interpreted pages can reference those families by
// name without re-loading any TTF from disk (the pre-bake stage in
// build.rs strips the matching `import "..ttf";` lines from the
// interpreted pages' source for exactly this reason).
import "../../components/ui/fonts/inter/Inter-Regular.ttf";
import "../../components/ui/fonts/inter/Inter-Bold.ttf";
import "../../components/ui/fonts/ibm-plex-sans/IBMPlexSans-Regular.ttf";
import "../../components/ui/fonts/ibm-plex-sans/IBMPlexSans-Bold.ttf";
import "../../components/ui/fonts/space-grotesk/SpaceGrotesk-Regular.ttf";
import "../../components/ui/fonts/space-grotesk/SpaceGrotesk-Bold.ttf";
import "../../components/ui/fonts/fraunces/Fraunces-Regular.ttf";
import "../../components/ui/fonts/fraunces/Fraunces-Bold.ttf";
import "../../components/ui/fonts/fraunces/Fraunces-Display.ttf";
import "../../components/ui/fonts/jetbrains-mono/JetBrainsMono-Regular.ttf";
import "../../components/ui/fonts/jetbrains-mono/JetBrainsMono-Bold.ttf";

component PageCell inherits Rectangle {
    in property <string> title;
    in property <component-factory> page-factory;

    width: 412px;
    height: 892px + 44px;  // 44 = title strip
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color: Theme.outline;
    clip: true;

    VerticalLayout {
        spacing: 0;
        Rectangle {
            height: 44px;
            background: Theme.surface-2;
            HorizontalLayout {
                padding-left: 12px;
                padding-right: 8px;
                padding-top: 8px;
                padding-bottom: 8px;
                Text {
                    text: root.title;
                    color: Theme.on-surface;
                    font-size: 13px;
                    font-weight: 700;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                }
            }
        }
        ComponentContainer {
            component-factory: root.page-factory;
            width: 412px;
            height: 892px;
        }
    }
}

export component WasmViewer inherits Window {
    title: "slint-mobile-components — catalogue";
    // No preferred-width / preferred-height — on wasm those propagate
    // to the canvas's rendering size and lock the layout at 1740 ×
    // 1080 *logical* px regardless of the actual browser viewport,
    // so the grid would compute its column count against a width that
    // doesn't match what's visible (3 cells "fit" in a 1740-px world
    // even when the user has only 1000 px of real screen). Leaving
    // them out lets Slint fill whatever the canvas's CSS size is, and
    // the column math reflects the actual visible area.
    background: Theme.background;

    in property <[string]> titles;
    in property <[component-factory]> cells;
    in property <int> loaded: 0;
    in property <int> total: 0;
    in property <string> summary;

    private property <length> cell-w: 412px;
    private property <length> cell-h: 892px + 44px;
    // Spacing tunables. `min-gap` is the floor (cells never get closer
    // than this); `max-gap` is the ceiling (cells stop spreading once
    // gaps get this wide — past that the leftover space sits on the
    // outer edges and the cell block centers). The 96-px ceiling
    // keeps a 2-column row from sliding the cells onto opposite
    // edges of a 3000-px window with a sea of nothing between.
    private property <length> min-gap: 16px;
    private property <length> max-gap: 96px;

    private property <length> grid-w: root.width - 2 * root.min-gap - 16px;
    // Column count is computed against the *minimum* gap, so the
    // pack-as-tight-as-possible math doesn't change as gaps expand.
    private property <int> cols: max(1, floor((root.grid-w + root.min-gap) / (root.cell-w + root.min-gap)));
    private property <int> row-count: ceil(root.titles.length / root.cols);

    // Distribute leftover horizontal space across the inter-cell
    // gaps, clamped between min-gap and max-gap. With a single
    // column there are no gaps to widen, so the value's irrelevant
    // and we just pin it to min-gap to keep arithmetic simple.
    private property <length> cell-gap:
        root.cols <= 1
            ? root.min-gap
            : max(root.min-gap, min(root.max-gap,
                (root.grid-w - root.cols * root.cell-w) / (root.cols - 1)));

    // Total width the cell block actually occupies after gaps are
    // chosen. When gaps are at max-gap and the window is still
    // wider, this is < grid-w and the difference centers the block.
    private property <length> content-w: root.cols * root.cell-w + (root.cols - 1) * root.cell-gap;
    private property <length> content-x-offset: (root.grid-w - root.content-w) / 2;

    private property <length> cell-h-stride: root.cell-h + root.min-gap;
    private property <bool> still-loading: root.loaded < root.total;

    VerticalLayout {
        spacing: 0;

        // ----- Status bar -----
        Rectangle {
            height: 56px;
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-1-blur;
            drop-shadow-color: Theme.elevation-1-color;
            drop-shadow-offset-y: Theme.elevation-1-y;
            HorizontalLayout {
                padding-left: 20px;
                padding-right: 20px;
                spacing: 24px;
                Text {
                    text: "slint-mobile-components — " + root.loaded + " / " + root.total + " pages"
                        + (root.still-loading ? "   ·   loading…" : "   ·   ready");
                    color: Theme.on-surface;
                    font-size: 16px;
                    font-weight: 800;
                    vertical-alignment: center;
                }
                Text {
                    text: root.summary;
                    color: Theme.muted;
                    font-size: 14px;
                    font-weight: 600;
                    vertical-alignment: center;
                    horizontal-stretch: 1;
                }
            }
        }

        // ----- Scrollable grid -----
        ScrollView {
            VerticalLayout {
                padding: root.min-gap;
                alignment: start;
                // The grid surface fills the full available width so
                // we can center / space-between the cells inside it.
                // Height grows with the number of loaded rows.
                Rectangle {
                    width: root.grid-w;
                    height: root.row-count * root.cell-h-stride
                        + (root.still-loading ? 80px : 0px);

                    for cell[i] in root.cells: PageCell {
                        x: root.content-x-offset
                            + mod(i, root.cols) * (root.cell-w + root.cell-gap);
                        y: floor(i / root.cols) * root.cell-h-stride;
                        title: root.titles[i];
                        page-factory: cell;
                    }

                    if root.still-loading: Rectangle {
                        x: 0;
                        y: root.row-count * root.cell-h-stride;
                        width: parent.width;
                        height: 80px;
                        Text {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            text: "loading more pages…";
                            color: Theme.muted;
                            font-size: 15px;
                            font-weight: 700;
                        }
                    }
                }
            }
        }
    }
}
