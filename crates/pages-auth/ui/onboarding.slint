// OnboardingPage
// =====================================================================
//
// Hero-style template — one frame of a paginated onboarding flow.
// Shown to new users walking through the app's value props before the
// first interaction. Pages alternate the illustration / headline /
// description; this component renders ONE frame at a time and exposes
// `page-index` so the caller drives advancement.
//
// Specification
// -------------
//
// Geometry
//   - Skip TextButton anchored to the top-right (small, recessive).
//   - Centred illustration — large, ~280-320 px tall on a 412 px wide
//     screen, occupying the upper-third of the page.
//   - Headline below the illustration (`font-size-headline`, weight
//     600, centred).
//   - Description paragraph beneath the headline (`font-size-body-large`,
//     muted, centred, wrap word-wrap).
//   - Page-dot indicator above the CTA (`page-count` dots; the
//     `page-index`'th is the active dot, others are muted).
//   - Primary `Next` CTA pinned to the bottom — full-width.
//
// State
//   - `page-index` (in-out int) + `page-count` (in int) — caller can
//     swap the slot content on each tap and drive the dot indicator.

import { Theme } from "@mobile-theme/theme.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { DotIndicator } from "@mobile-components/dot-indicator.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";

export component OnboardingPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <image> illustration: @image-url("@mobile-components/icons/onboarding-illus.svg");
    in property <string> headline: "Design that travels with your app";
    in property <string> description: "A handcrafted Slint component catalogue for Android — same look on every screen, fully themable from your Rust code.";
    in-out property <int> page-index: 0;
    in property <int> page-count: 4;
    in property <string> primary-label: "Continue";
    in property <string> skip-label: "Skip";
    callback skip-pressed();
    callback primary-pressed();

    background: Theme.background;

    // Top-right Skip
    Rectangle {
        x: parent.width - self.width - Theme.spacing-sm;
        y: Theme.spacing-sm;
        width: 80px;
        height: 40px;
        TextButton {
            text: root.skip-label;
            clicked => { root.skip-pressed(); }
        }
    }

    // The outer VL packs from the top; an explicit `vertical-stretch: 1`
    // spacer below the headline group pushes the dots + CTA to the
    // bottom of the page. Slint's default `alignment: stretch` would
    // otherwise grow the CTA button to fill the surplus, which looks
    // wrong for a one-line primary action.
    VerticalLayout {
        alignment: start;
        padding-top: Theme.spacing-xl;
        padding-bottom: Theme.spacing-xl;
        padding-left: Theme.spacing-lg;
        padding-right: Theme.spacing-lg;
        spacing: Theme.spacing-lg;

        Rectangle {
            height: min(self.width, 320px);
            Image {
                // Fixed square — `min(parent.width, …)` here makes the
                // width depend on the centring layout it also feeds, a
                // binding loop. 320px fits the 412px mobile target.
                width: 320px;
                height: 320px;
                source: root.illustration;
                image-fit: ImageFit.contain;
            }
        }

        // Headline — Fraunces serif-display 28 px 700, romantic /
        // editorial. Pairs with the airy illustration above.
        HorizontalLayout {
            alignment: center;
            Heading {
                text: root.headline;
                style: HeadingStyle.serif-display;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }

        // Description — Inter 400, generous tracking. Calm body that
        // doesn't compete with the Fraunces hero above it.
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.description;
                color: Theme.muted;
                font-family: "Inter";
                font-size: Theme.font-size-body-large;
                font-weight: 400;
                letter-spacing: 0.2px;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
        }

        // Flexible spacer that absorbs surplus vertical space.
        Rectangle {
            vertical-stretch: 1;
        }

        DotIndicator {
            count: root.page-count;
            active: root.page-index;
        }

        MobileButton {
            text: root.primary-label;
            clicked => { root.primary-pressed(); }
        }
    }
}
