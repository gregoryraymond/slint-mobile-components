// TwoFactorAuthPage
// =====================================================================
//
// 6-digit verification-code entry — the screen after `LoginPage` /
// `SignupPage` when 2FA is on. Distinct from `AppLockScreen` (PIN to
// unlock an installed app). Demonstrates a focused single-input
// surface:
//
//   - Headline + masked destination ("Sent to +1 ••• ••• 4291").
//   - 6 single-digit code boxes — filled boxes carry the digit + an
//     info-tone ring; the "active" box (next to fill) gets a primary
//     ring; empty boxes stay outlined.
//   - Resend row with a countdown ("Resend in 0:24") that flips to a
//     tappable "Resend code" link when elapsed.
//   - 3 × 4 numeric keypad (re-using the AppLockScreen keypad idiom).
//   - Verify CTA at the bottom + a "try another way" TextButton.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";

// One code box.
//
// state: 0 empty, 1 filled, 2 active (next to fill)
component CodeBox inherits Rectangle {
    in property <string> digit;
    in property <int> state: 0;

    width: 48px;
    height: 56px;
    border-radius: Theme.radius-md;
    background: root.state == 1 ? Theme.surface-2 : Theme.surface-1;
    border-width: 2px;
    border-color:
          root.state == 2 ? Theme.primary
        : root.state == 1 ? Theme.accent-info
        : Theme.outline;

    Text {
        text: root.state == 1 ? root.digit : (root.state == 2 ? "|" : "");
        color: root.state == 2 ? Theme.primary : Theme.on-surface;
        font-size: 26px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// One keypad digit.
component KeypadDigit inherits Rectangle {
    in property <string> digit;
    callback clicked();

    accessible-role: button;
    accessible-label: root.digit;
    accessible-action-default => { root.clicked(); }

    width: 76px;
    height: 64px;
    border-radius: Theme.radius-md;
    background: touch.pressed ? Theme.surface-pressed : Theme.surface-1;
    animate background { duration: Theme.motion-fast; }

    Text {
        text: root.digit;
        color: Theme.on-background;
        font-size: 26px;
        font-weight: 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TwoFactorAuthPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> destination: "Sent to +1 ••• ••• 4291";
    in property <string> d0: "4";
    in property <string> d1: "8";
    in property <string> d2: "2";
    in property <string> d3: "";
    in property <string> d4: "";
    in property <string> d5: "";
    in property <string> resend: "Resend code in 0:24";
    callback back-pressed();
    callback digit-pressed(int);
    callback delete-pressed();
    callback resend-pressed();
    callback verify-pressed();
    callback another-way-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // AppBar title retypeset to all-caps with wide tracking — reads
        // as a security-procedure label rather than a casual page name.
        AppBar {
            title: "VERIFY IT'S YOU";
            title-style: HeadingStyle.uppercase-spaced;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Hero.
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 64px;
                    height: 64px;
                    border-radius: 16px;
                    background: #4f8cff22;
                    Image {
                        width: 28px;
                        height: 28px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/lock.svg");
                        colorize: Theme.accent-info;
                        image-fit: contain;
                    }
                }
            }
            VerticalLayout {
                spacing: Theme.spacing-xs;
                // Headline — JetBrains Mono. The hero text matches the
                // tabular feel of the code boxes below it (every glyph
                // the same width). Reads as "this is a code-entry screen".
                HorizontalLayout {
                    alignment: center;
                    Heading {
                        text: "Enter the 6-digit code";
                        style: HeadingStyle.mono;
                        horizontal-alignment: center;
                    }
                }
                // Destination line in JetBrains Mono too — the phone-
                // number masking lines up because of the mono advance.
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: root.destination;
                        color: Theme.muted;
                        font-family: "JetBrains Mono";
                        font-size: Theme.font-size-body;
                        font-weight: 400;
                    }
                }
            }

            // Code boxes.
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                CodeBox { digit: root.d0; state: 1; }
                CodeBox { digit: root.d1; state: 1; }
                CodeBox { digit: root.d2; state: 1; }
                CodeBox { digit: root.d3; state: 2; }
                CodeBox { digit: root.d4; state: 0; }
                CodeBox { digit: root.d5; state: 0; }
            }

            // Resend row.
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.resend;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }

            // Verify CTA.
            MobileButton {
                text: "Verify";
                tone: Tone.info;
                max-height: 48px;
                clicked => { root.verify-pressed(); }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Numeric keypad.
        VerticalLayout {
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                KeypadDigit { digit: "1"; clicked => { root.digit-pressed(1); } }
                KeypadDigit { digit: "2"; clicked => { root.digit-pressed(2); } }
                KeypadDigit { digit: "3"; clicked => { root.digit-pressed(3); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                KeypadDigit { digit: "4"; clicked => { root.digit-pressed(4); } }
                KeypadDigit { digit: "5"; clicked => { root.digit-pressed(5); } }
                KeypadDigit { digit: "6"; clicked => { root.digit-pressed(6); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                KeypadDigit { digit: "7"; clicked => { root.digit-pressed(7); } }
                KeypadDigit { digit: "8"; clicked => { root.digit-pressed(8); } }
                KeypadDigit { digit: "9"; clicked => { root.digit-pressed(9); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                // Empty cell for layout symmetry.
                Rectangle { width: 76px; height: 64px; }
                KeypadDigit { digit: "0"; clicked => { root.digit-pressed(0); } }
                Rectangle {
                    width: 76px;
                    height: 64px;
                    Image {
                        width: 26px;
                        height: 26px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/close.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.delete-pressed(); }
                    }
                }
            }
            HorizontalLayout {
                alignment: center;
                TextButton {
                    text: "Try another way";
                    clicked => { root.another-way-pressed(); }
                }
            }
        }
    }
}
