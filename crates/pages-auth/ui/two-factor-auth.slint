// TwoFactorAuthPage
// =====================================================================
//
// Second factor challenge. User has successfully entered their password
// and the server has sent a 6-digit one-time code (SMS / authenticator).
// This screen captures that code and resends or fails over to another
// method.
//
// Layout follows the canonical auth-page rhythm shared with
// `LoginPage` and `SignupPage`:
//
//   - AppBar with back arrow.
//   - Hero block (serif display title + muted subtitle).
//   - A `FormSection` containing the 6-segment code "input" — built as
//     a single HorizontalLayout of fixed-size cells. One row, perfectly
//     symmetric. Cell #1 is filled with a digit, cell #2 is "active"
//     (glowing primary border), the rest are empty. No real input
//     wiring — static demo state only.
//   - A muted caption row "Resend code in 0:42".
//   - Primary `MobileButton` "Verify" + tertiary `TextButton` for the
//     "try another method" affordance.
//
// All paddings / colours / radii / fonts come from `Theme.*`.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";

// One cell of the 6-segment code "input". Three visual states:
//   - filled  → solid surface tinted with primary, digit shown
//   - active  → empty fill, primary-coloured border + glow
//   - empty   → flat surface-1 fill, no digit, no border
//
// All three states share the SAME geometry (48 × 56 px), so the row
// never reflows as state changes.
component CodeCell inherits Rectangle {
    in property <string> digit;
    in property <bool> active: false;

    width: 48px;
    height: 56px;
    border-radius: Theme.radius-md;
    background: root.digit != "" ? Theme.surface-2 : Theme.surface-1;
    border-width: root.active ? 2px : 0px;
    border-color: Theme.primary;
    drop-shadow-blur: root.active ? Theme.elevation-1-blur : 0px;
    drop-shadow-color: root.active ? Theme.primary : transparent;
    drop-shadow-offset-y: 0px;

    Text {
        text: root.digit;
        color: Theme.on-surface;
        font-size: Theme.font-size-headline;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

export component TwoFactorAuthPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in property <string> phone-hint: "••• ••• 4421";
    in property <string> resend-countdown: "0:42";

    callback back-pressed();
    callback verify-pressed();
    callback try-another-method-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        VerticalLayout {
            padding-top: Theme.spacing-sm;
            padding-bottom: Theme.spacing-xl;
            spacing: Theme.spacing-lg;
            alignment: stretch;

            // ----- Hero ----------------------------------------------------
            VerticalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-xs;

                Heading {
                    text: "Two-factor auth";
                    style: HeadingStyle.serif-display;
                    color: Theme.on-background;
                }
                Text {
                    text: "Enter the 6-digit code sent to " + root.phone-hint;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    wrap: word-wrap;
                }
            }

            // ----- Code-input card ----------------------------------------
            FormSection {
                title: "VERIFICATION CODE";

                // Centred 6-cell row. Fixed cell width + fixed spacing,
                // wrapped in a HorizontalLayout with `alignment: center`
                // so the row stays perfectly symmetric inside the card.
                HorizontalLayout {
                    alignment: center;
                    spacing: Theme.spacing-sm;
                    padding-top: Theme.spacing-md;
                    padding-bottom: Theme.spacing-md;

                    CodeCell { digit: "3"; }
                    CodeCell { active: true; }
                    CodeCell { }
                    CodeCell { }
                    CodeCell { }
                    CodeCell { }
                }

                // Countdown caption — muted, centred under the cells.
                HorizontalLayout {
                    alignment: center;
                    padding-bottom: Theme.spacing-md;
                    Text {
                        text: "Resend code in " + root.resend-countdown;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }
            }

            // ----- CTA + secondary action ---------------------------------
            VerticalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                alignment: stretch;

                MobileButton {
                    text: "Verify";
                    primary: true;
                    enabled: true;
                    clicked => { root.verify-pressed(); }
                }

                TextButton {
                    text: "Try another method";
                    clicked => { root.try-another-method-pressed(); }
                }
            }

            // Bottom flex spacer so the content hugs the top while the
            // page still consumes its full 892-px preferred height.
            Rectangle { vertical-stretch: 1; }
        }
    }
}
