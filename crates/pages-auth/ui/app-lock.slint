// AppLockScreen
// =====================================================================
//
// PIN / passcode entry screen — iOS lock-screen / banking-app-style.
// Distinct from `LoginPage` (full credential entry). Demonstrates a
// single-purpose, no-AppBar surface:
//
//   - Big time + date hero at the top, then a user-avatar + name +
//     "Enter passcode" caption.
//   - 4-dot passcode indicator: each dot is empty (outlined) when
//     unfilled, primary-filled once tapped, danger-toned if the
//     previous attempt failed.
//   - 3 × 4 numeric keypad: 1–9, then "biometric" / 0 / "delete".
//     Each digit cell is a round Rectangle with primary text and
//     pressed-state surface tint.
//   - Trailing affordance row: "Forgot passcode?" link + Face ID hint.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { TextButton } from "@mobile-components/button.slint";

// One passcode dot.
component PinDot inherits Rectangle {
    in property <int> state: 0;     // 0 empty, 1 filled, 2 failed
    width: 16px;
    height: 16px;
    border-radius: 8px;
    border-width: 1px;
    border-color:
          root.state == 1 ? Theme.primary
        : root.state == 2 ? Theme.accent-danger
        : Theme.outline;
    background:
          root.state == 1 ? Theme.primary
        : root.state == 2 ? Theme.accent-danger
        : transparent;
}

// One keypad digit.
component KeypadDigit inherits Rectangle {
    in property <string> digit;
    in property <string> letters;
    callback clicked();

    accessible-role: button;
    accessible-label: root.digit;
    accessible-action-default => { root.clicked(); }

    width: 76px;
    height: 76px;
    border-radius: self.width / 2;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    border-width: 1px;
    border-color: Theme.outline;

    animate background { duration: Theme.motion-fast; }

    VerticalLayout {
        spacing: 0;
        alignment: center;
        Text {
            text: root.digit;
            color: Theme.on-background;
            font-size: 30px;
            font-weight: 300;
            horizontal-alignment: center;
        }
        Text {
            text: root.letters;
            color: Theme.muted;
            font-size: 9px;
            font-weight: 800;
            letter-spacing: 1px;
            horizontal-alignment: center;
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A keypad cell that hosts an icon glyph instead of a digit (biometric
// and backspace).
component KeypadGlyph inherits Rectangle {
    in property <image> icon;
    in property <color> tint: Theme.on-background;
    callback clicked();

    width: 76px;
    height: 76px;
    Image {
        width: 28px;
        height: 28px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.tint;
        image-fit: contain;
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component AppLockScreen inherits Rectangle {
    in property <string> time-now: "14:32";
    in property <string> date: "Wednesday, May 14";
    in property <string> user-name: "Greg Raymond";
    in property <int> dot-state-0: 1;
    in property <int> dot-state-1: 1;
    in property <int> dot-state-2: 0;
    in property <int> dot-state-3: 0;
    callback digit-pressed(int);
    callback delete-pressed();
    callback biometric-pressed();
    callback forgot-pressed();
    callback emergency-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Time hero -----
        VerticalLayout {
            padding-top: Theme.spacing-lg;
            spacing: 4px;
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.time-now;
                    color: Theme.on-background;
                    font-size: 72px;
                    font-weight: 200;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.date;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
            }
        }

        // ----- Avatar + name + dots -----
        VerticalLayout {
            padding-top: Theme.spacing-lg;
            spacing: Theme.spacing-sm;
            HorizontalLayout {
                alignment: center;
                Avatar {
                    fallback: "GR";
                    size: 64px;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.user-name;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body-large;
                    font-weight: 600;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "Enter passcode";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                padding-top: Theme.spacing-sm;
                PinDot { state: root.dot-state-0; }
                PinDot { state: root.dot-state-1; }
                PinDot { state: root.dot-state-2; }
                PinDot { state: root.dot-state-3; }
            }
        }

        // ----- Keypad -----
        VerticalLayout {
            padding-top: Theme.spacing-lg;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-md;

            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                KeypadDigit { digit: "1"; letters: ""; clicked => { root.digit-pressed(1); } }
                KeypadDigit { digit: "2"; letters: "ABC"; clicked => { root.digit-pressed(2); } }
                KeypadDigit { digit: "3"; letters: "DEF"; clicked => { root.digit-pressed(3); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                KeypadDigit { digit: "4"; letters: "GHI"; clicked => { root.digit-pressed(4); } }
                KeypadDigit { digit: "5"; letters: "JKL"; clicked => { root.digit-pressed(5); } }
                KeypadDigit { digit: "6"; letters: "MNO"; clicked => { root.digit-pressed(6); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                KeypadDigit { digit: "7"; letters: "PQRS"; clicked => { root.digit-pressed(7); } }
                KeypadDigit { digit: "8"; letters: "TUV"; clicked => { root.digit-pressed(8); } }
                KeypadDigit { digit: "9"; letters: "WXYZ"; clicked => { root.digit-pressed(9); } }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                KeypadGlyph {
                    icon: @image-url("@mobile-components/icons/lock.svg");
                    tint: Theme.accent-info;
                    clicked => { root.biometric-pressed(); }
                }
                KeypadDigit { digit: "0"; letters: ""; clicked => { root.digit-pressed(0); } }
                KeypadGlyph {
                    icon: @image-url("@mobile-components/icons/close.svg");
                    tint: Theme.muted;
                    clicked => { root.delete-pressed(); }
                }
            }
        }

        // ----- Footer affordances -----
        VerticalLayout {
            spacing: Theme.spacing-xs;
            HorizontalLayout {
                alignment: center;
                TextButton {
                    text: "Forgot passcode?";
                    clicked => { root.forgot-pressed(); }
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "Face ID will unlock when ready";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
