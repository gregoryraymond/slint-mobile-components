// SignupPage
// =====================================================================
//
// Account-creation form. Pure showcase of `FormField` discipline:
// every input has the SAME label-above + control + helper-below
// rhythm, so vertically-stacked fields line up at every internal
// edge (label baseline, control top, control bottom, helper baseline)
// without any per-field padding fiddling.
//
// What this screen does
//   - AppBar with back arrow.
//   - Hero block: large display title + supporting subtitle.
//   - Form (4 fields):
//     - Full name (required).
//     - Email (required, with realtime helper text).
//     - Password (required, with strength hint).
//     - Birthday (helper: "We use this to personalise content.").
//   - "I agree to the terms" toggle row (`SettingRow` style for visual
//     consistency with the field stack).
//   - Primary CTA "Create account" — fills the page width.
//   - "Already have an account? Sign in" footer link.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { ScrollView } from "std-widgets.slint";

export component SignupPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> full-name;
    in-out property <string> email;
    in-out property <string> password;
    in-out property <string> birthday;
    in-out property <bool> agreed: false;

    callback back-pressed();
    callback submit-pressed();
    callback sign-in-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-left: 0;
                padding-right: 0;
                padding-top: Theme.spacing-sm;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: stretch;

                // ----- Hero -------------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    Heading {
                        text: "Create account";
                        style: HeadingStyle.serif-display;
                        color: Theme.on-background;
                    }
                    Text {
                        text: "It takes about a minute. You can change everything later.";
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        wrap: word-wrap;
                    }
                }

                // ----- Field stack ------------------------------------------
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    FormField {
                        label: "Full name";
                        required: true;
                        TextField {
                            placeholder: "Ada Lovelace";
                            text <=> root.full-name;
                        }
                    }

                    FormField {
                        label: "Email";
                        required: true;
                        helper: "We'll send a confirmation link.";
                        TextField {
                            placeholder: "you@example.com";
                            text <=> root.email;
                        }
                    }

                    FormField {
                        label: "Password";
                        required: true;
                        helper: "12+ characters with one number or symbol.";
                        TextField {
                            placeholder: "••••••••••••";
                            text <=> root.password;
                            input-type: InputType.password;
                        }
                    }

                    FormField {
                        label: "Birthday";
                        helper: "Used to personalise content. Never shared.";
                        TextField {
                            placeholder: "MM / DD / YYYY";
                            text <=> root.birthday;
                        }
                    }
                }

                // ----- Terms toggle (settings-row visual) -------------------
                FormSection {
                    SettingRow {
                        title: "I agree to the terms";
                        subtitle: "Service agreement and privacy policy.";
                        MobileSwitch { checked <=> root.agreed; }
                    }
                }

                // ----- CTA --------------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Create account";
                        enabled: root.agreed
                                 && root.full-name != ""
                                 && root.email != ""
                                 && root.password != "";
                        clicked => { root.submit-pressed(); }
                    }

                    TextButton {
                        text: "Already have an account?  Sign in";
                        clicked => { root.sign-in-pressed(); }
                    }
                }
            }
        }
    }
}
