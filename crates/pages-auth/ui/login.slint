import { Theme } from "@mobile-theme/theme.slint";
import { LiquidGlassSkin } from "@mobile-theme/skins.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { TextField } from "@mobile-components/text-field.slint";

// Example login page: heading, two TextFields, primary submit button, and
// a secondary "create account" affordance.
//
// Visual treatment: opt-in to `LiquidGlassSkin`. The skin (defined in
// `crates/theme/ui/skins.slint`) supplies the typeface, the warm-bokeh
// page background, all text colours, and the translucent glass fill —
// nothing about the look is hardcoded here. Swap one import to reskin.
export component LoginPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    default-font-family: LiquidGlassSkin.font-family;

    in-out property <string> email;
    in-out property <string> password;
    in property <bool> loading: false;
    callback submit(string, string);
    callback create-account();

    background: LiquidGlassSkin.page-background;

    // ---- z-bottom: full-bleed photo-style background ----
    if LiquidGlassSkin.has-background-image: Image {
        x: 0;
        y: 0;
        width: root.width;
        height: root.height;
        source: LiquidGlassSkin.page-background-image;
        image-fit: cover;
    }

    // ---- z-top: form content ----
    VerticalLayout {
        padding: Theme.spacing-lg;
        spacing: Theme.spacing-lg;
        alignment: center;

        VerticalLayout {
            spacing: Theme.spacing-xs;
            Text {
                text: "Sign in";
                color: LiquidGlassSkin.text-primary;
                font-size: Theme.font-size-headline;
                font-weight: 600;
            }
            Text {
                text: "Welcome back. Use your email to continue.";
                color: LiquidGlassSkin.text-secondary;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
        }

        // Glass card — translucent surface from the skin.
        Rectangle {
            background: LiquidGlassSkin.glass-fill;
            border-radius: Theme.radius-lg;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: #00000066;
            drop-shadow-offset-y: Theme.elevation-2-y;

            VerticalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-md;

                TextField {
                    label: "Email";
                    placeholder: "you@example.com";
                    text <=> root.email;
                }

                TextField {
                    label: "Password";
                    placeholder: "••••••••";
                    input-type: InputType.password;
                    text <=> root.password;
                }
            }
        }

        MobileButton {
            text: root.loading ? "Signing in…" : "Sign in";
            primary: true;
            enabled: !root.loading && root.email != "" && root.password != "";
            clicked => { root.submit(root.email, root.password); }
        }

        TextButton {
            text: "Create an account";
            clicked => { root.create-account(); }
        }
    }
}
