// OnboardingHintPage
// =====================================================================
//
// First-run coachmark / tooltip overlay — the floating "this is where
// you save things" prompts new users see. Distinct from
// `OnboardingPage` (multi-slide welcome) and `FormWizardPage` (multi-
// step form). Demonstrates:
//
//   - Faux app screenshot underneath at half-opacity so the user can
//     see the target UI.
//   - Dark scrim with a "spotlight" cutout — here approximated as a
//     bright Rectangle on top of the scrim that highlights the
//     target's bounding box, surrounded by a thin tone-tinted ring.
//   - Hint card anchored just below the highlighted target with a
//     small triangle / arrow + headline + body + step counter + Skip
//     / Next CTAs.
//
// The scene shows the user at "step 2 of 4" — the spotlight points at
// the bottom-tab FAB on the underlying mockup, and the hint card sits
// beneath it.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";

// One pip in the step indicator.
component StepPip inherits Rectangle {
    in property <bool> active: false;
    width: root.active ? 24px : 8px;
    height: 8px;
    border-radius: 4px;
    background: root.active ? Theme.accent-info : Theme.surface-variant;
    animate width { duration: Theme.motion-fast; }
}

export component OnboardingHintPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> hint-title: "Tap here to save anything for later";
    in property <string> hint-body:
        "We stash articles, photos, voice memos — anything you tap save on — into your library, ready to read offline.";
    in property <int> step-current: 1;
    in property <int> step-total: 4;
    callback skip-pressed();
    callback next-pressed();

    background: Theme.background;

    // ----- Faux mockup background -----
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.background;

        // Fake top bar.
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width;
            height: 56px;
            background: Theme.surface-1;
            HorizontalLayout {
                padding: Theme.spacing-md;
                // Underlying-app fake bar — Plex Sans for a generic
                // "another app" feel that contrasts with the coachmark.
                Text {
                    text: "Reading list";
                    color: Theme.on-surface;
                    font-family: "IBM Plex Sans";
                    font-size: Theme.font-size-body-large;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
            }
        }
        // Fake content cards.
        VerticalLayout {
            x: 0;
            y: 64px;
            width: parent.width;
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            for index in 6 : Rectangle {
                horizontal-stretch: 1;
                height: 88px;
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                HorizontalLayout {
                    padding: Theme.spacing-sm;
                    spacing: Theme.spacing-sm;
                    Rectangle {
                        width: 72px;
                        height: 72px;
                        border-radius: Theme.radius-sm;
                        background: Theme.surface-variant;
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: Theme.spacing-xs;
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 8px;
                            background: Theme.surface-variant;
                            border-radius: 2px;
                            max-width: 200px;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            height: 6px;
                            background: Theme.surface-variant;
                            border-radius: 2px;
                            max-width: 120px;
                        }
                    }
                }
            }
        }

        // Fake FAB target — this is what the coachmark highlights.
        Rectangle {
            x: parent.width - 64px - Theme.spacing-md;
            y: parent.height - 64px - 120px;
            width: 64px;
            height: 64px;
            border-radius: self.width / 2;
            background: Theme.accent-info;
            Image {
                width: 24px;
                height: 24px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: @image-url("@mobile-components/icons/plus.svg");
                colorize: Theme.on-primary;
                image-fit: contain;
            }
        }
    }

    // ----- Dim scrim (full screen) -----
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #0a0d12cc;
    }

    // ----- Spotlight "halo" around the FAB target -----
    Rectangle {
        x: parent.width - 88px - (Theme.spacing-md - 12px);
        y: parent.height - 64px - 120px - 12px;
        width: 88px;
        height: 88px;
        border-radius: self.width / 2;
        background: transparent;
        border-width: 3px;
        border-color: Theme.accent-info;
    }

    // ----- The FAB itself, repainted on top of the scrim so it pops -----
    Rectangle {
        x: parent.width - 64px - Theme.spacing-md;
        y: parent.height - 64px - 120px;
        width: 64px;
        height: 64px;
        border-radius: self.width / 2;
        background: Theme.accent-info;
        drop-shadow-blur: Theme.elevation-3-blur;
        drop-shadow-color: Theme.elevation-3-color;
        drop-shadow-offset-y: Theme.elevation-3-y;
        Image {
            width: 24px;
            height: 24px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: @image-url("@mobile-components/icons/plus.svg");
            colorize: Theme.on-primary;
            image-fit: contain;
        }
    }

    // ----- Hint card -----
    Rectangle {
        x: Theme.spacing-md;
        y: parent.height - 240px;
        width: parent.width - 2 * Theme.spacing-md - 88px;
        height: 200px;
        background: Theme.surface-2;
        border-radius: Theme.radius-md;
        drop-shadow-blur: Theme.elevation-3-blur;
        drop-shadow-color: Theme.elevation-3-color;
        drop-shadow-offset-y: Theme.elevation-3-y;

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            // Step eyebrow — Space Grotesk all-caps with wide tracking
            // for that "tooltip / coachmark" label feel.
            Text {
                text: "TIP · " + (root.step-current + 1) + " OF " + root.step-total;
                color: Theme.accent-info;
                font-family: "Space Grotesk";
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 2px;
            }
            // Punchy hint headline — bespoke Inter bold with tight
            // tracking, sized to fit inside a coachmark bubble.
            Text {
                text: root.hint-title;
                color: Theme.on-surface;
                font-family: "Inter";
                font-size: 19px;
                font-weight: 700;
                letter-spacing: -0.5px;
                wrap: word-wrap;
            }
            // Body in Plex Sans for the soft, conversational tooltip tone.
            Text {
                text: root.hint-body;
                color: Theme.muted;
                font-family: "IBM Plex Sans";
                font-size: Theme.font-size-caption;
                font-weight: 400;
                wrap: word-wrap;
            }
            Rectangle { vertical-stretch: 1; }
            HorizontalLayout {
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    HorizontalLayout {
                        spacing: Theme.spacing-xs;
                        alignment: start;
                        for index in root.step-total : StepPip {
                            active: index == root.step-current;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    TextButton {
                        text: "Skip";
                        clicked => { root.skip-pressed(); }
                    }
                    Rectangle {
                        width: 88px;
                        height: 36px;
                        border-radius: 18px;
                        background: Theme.accent-info;
                        Text {
                            text: "Next";
                            color: Theme.on-primary;
                            font-size: Theme.font-size-caption;
                            font-weight: 800;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                        TouchArea {
                            clicked => { root.next-pressed(); }
                        }
                    }
                }
            }
        }
    }
}
