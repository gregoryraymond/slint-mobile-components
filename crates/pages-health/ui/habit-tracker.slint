// HabitTrackerPage
// =====================================================================
//
// Daily-habits checklist with a 4-column stat strip at the top, a TODAY
// section of toggleable habit rows (`SettingRow` with either a done
// checkmark or a `MobileSwitch` trailing), and a THIS WEEK
// progress block (KeyValueRows showing N / 7).
//
// Alignment discipline
// --------------------
// Stat strip uses the shared `StatTile`. Every row in TODAY and THIS
// WEEK is `SettingRow` / `KeyValueRow` — no hand-rolled rows.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { ScrollView } from "std-widgets.slint";

export component HabitTrackerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> habit-meditate: false;
    in-out property <bool> habit-journal: false;

    callback back-pressed();
    callback add-pressed();
    callback habit-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Habits";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.add-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Stat strip -------------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;

                    StatTile {
                        value: "5";
                        label: "STREAK";
                        tone: Tone.success;
                    }
                    StatTile {
                        value: "92%";
                        label: "MONTH";
                        tone: Tone.info;
                    }
                    StatTile {
                        value: "31";
                        label: "DAYS";
                    }
                    StatTile {
                        value: "4";
                        label: "TODAY";
                        tone: Tone.warning;
                    }
                }

                // ----- TODAY ------------------------------------------------
                FormSection {
                    title: "TODAY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.danger;
                        title: "Morning run";
                        subtitle: "Done at 07:42";
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Read for 30 minutes";
                        subtitle: "Done at 08:15";
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Meditate";
                        subtitle: "Goal: 10 min, no streak today";
                        MobileSwitch { checked <=> root.habit-meditate; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "8 glasses of water";
                        subtitle: "Done at 18:00";
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "Evening journal";
                        subtitle: "Goal: 5 min";
                        MobileSwitch { checked <=> root.habit-journal; }
                    }
                }

                // ----- THIS WEEK --------------------------------------------
                FormSection {
                    title: "THIS WEEK";

                    KeyValueRow {
                        label: "Reading 30 min";
                        value: "6 / 7";
                        value-tone: Tone.success;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Meditation";
                        value: "5 / 7";
                        value-tone: Tone.success;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Walk 10k steps";
                        value: "4 / 7";
                        value-tone: Tone.warning;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "No phone after 10pm";
                        value: "3 / 7";
                        value-tone: Tone.danger;
                    }
                }
            }
        }
    }
}
