// ActivityRingsPage
// =====================================================================
//
// Three concentric activity rings (Move / Exercise / Stand) + a stat
// grid + a recent-workouts list. Demonstrates how to compose a multi-
// arc ring visualisation in pure Slint without an SVG dependency:
// each ring is a circle outline (full ring at low opacity) plus a
// `rotation-angle`-rotated wedge that paints the "progress" arc.
//
// Pure-Slint approximation note
// -----------------------------
// Slint doesn't ship an arc primitive — the visualisation here is a
// stylised three-band concentric ring made of stacked Rectangles with
// circular border-radius. Real activity-ring SVGs would carry the
// arc-segment-by-rotation trick; for this template the goal is
// "looks like the ring at-a-glance" rather than animating progress.
//
// Layout
// ------
//
//   AppBar — "Activity" with profile trailing
//   Rings hero — three concentric rings + ring-legend (Move/Exercise/Stand)
//   Stat grid — 2×2: Steps / Distance / Calories / Heart rate
//   Section header: "RECENT WORKOUTS"
//   Workout row × N

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";

// One concentric ring band. `track-color` sits behind the progress arc;
// `fill-color` is the ring's accent. Since Slint doesn't ship an arc
// primitive, the "incomplete" portion is approximated by clipping the
// fill rectangle with the muted track behind it — the visual reads as
// a ring at-a-glance rather than a precise arc.
component RingBand inherits Rectangle {
    in property <length> radius;
    in property <length> stroke: 18px;
    in property <color> track-color: #ffffff10;
    in property <color> fill-color;
    in property <float> progress: 1.0;

    width: 2 * root.radius;
    height: 2 * root.radius;

    // Track (full ring, low opacity).
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: root.stroke;
        border-color: root.track-color;
        background: transparent;
    }
    // Progress arc — approximated by a clip-rotated bright ring on top
    // (we draw the full circle in the fill colour, then mask the
    // remaining portion with the track via opacity blending). This
    // intentionally renders as a "saturation tinted" ring rather than
    // a strict arc; precise arc rendering needs a path primitive that
    // isn't available in the Slint version this library targets.
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: root.stroke;
        border-color: root.fill-color;
        opacity: root.progress;
        background: transparent;
    }
}

// One small ring-legend row — "● Move  420 / 500".
component RingLegend inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <color> dot-color;

    height: 22px;
    HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: start;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 10px;
                height: 10px;
                border-radius: 5px;
                background: root.dot-color;
            }
        }
        Text {
            text: root.label;
            color: Theme.on-background;
            font-size: Theme.font-size-body;
            font-weight: 600;
            vertical-alignment: center;
            width: 80px;
        }
        Text {
            text: root.value;
            color: Theme.muted;
            font-size: Theme.font-size-body;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }
}

// One stat tile in the 2×2 grid.
component StatTile inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <string> unit;
    in property <Tone> tone: Tone.default;

    height: 96px;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-xs;
        alignment: center;

        Text {
            text: root.label;
            color: Theme.muted;
            font-size: Theme.font-size-caption;
            font-weight: 600;
        }
        HorizontalLayout {
            spacing: 4px;
            alignment: start;
            Text {
                text: root.value;
                color:
                      root.tone == Tone.success ? Theme.accent-success
                    : root.tone == Tone.warning ? Theme.accent-warning
                    : root.tone == Tone.danger  ? Theme.accent-danger
                    : root.tone == Tone.info    ? Theme.accent-info
                    : Theme.on-surface;
                font-size: Theme.font-size-headline;
                font-weight: 700;
            }
            VerticalLayout {
                alignment: end;
                Text {
                    text: root.unit;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    font-weight: 500;
                }
            }
        }
    }
}

// One recent-workout row.
component WorkoutRow inherits Rectangle {
    in property <string> name;
    in property <string> when;
    in property <string> duration;
    in property <string> calories;
    in property <color> accent: Theme.accent-success;

    min-height: 64px;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                border-radius: self.width / 2;
                background: root.accent;
                Image {
                    width: 22px;
                    height: 22px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/play.svg");
                    colorize: Theme.on-primary;
                    image-fit: contain;
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 500;
            }
            Text {
                text: root.when + " · " + root.duration;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }

        VerticalLayout {
            alignment: center;
            Text {
                text: root.calories;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: right;
            }
        }
    }
}

export component ActivityRingsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> greeting: "Good afternoon";
    callback back-pressed();
    callback profile-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Activity";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/profile.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.profile-pressed(); }
        }

        // ----- Rings hero -----
        VerticalLayout {
            padding-top: Theme.spacing-lg;
            padding-bottom: Theme.spacing-lg;
            spacing: Theme.spacing-md;

            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.greeting + ", Greg";
                    color: Theme.on-background;
                    font-size: Theme.font-size-body;
                    font-weight: 500;
                    horizontal-alignment: center;
                }
            }
            // Concentric rings — outer Move, middle Exercise, inner Stand.
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 200px;
                    height: 200px;
                    RingBand {
                        x: 0;
                        y: 0;
                        radius: 100px;
                        stroke: 18px;
                        fill-color: Theme.accent-danger;
                        progress: 0.84;
                    }
                    RingBand {
                        x: 24px;
                        y: 24px;
                        radius: 76px;
                        stroke: 18px;
                        fill-color: Theme.accent-success;
                        progress: 0.62;
                    }
                    RingBand {
                        x: 48px;
                        y: 48px;
                        radius: 52px;
                        stroke: 18px;
                        fill-color: Theme.accent-info;
                        progress: 0.92;
                    }
                }
            }

            // Legend.
            VerticalLayout {
                padding-left: Theme.spacing-lg + Theme.spacing-md;
                padding-right: Theme.spacing-lg + Theme.spacing-md;
                spacing: Theme.spacing-xs;
                RingLegend {
                    label: "Move";
                    value: "420 / 500 kcal";
                    dot-color: Theme.accent-danger;
                }
                RingLegend {
                    label: "Exercise";
                    value: "19 / 30 min";
                    dot-color: Theme.accent-success;
                }
                RingLegend {
                    label: "Stand";
                    value: "11 / 12 hr";
                    dot-color: Theme.accent-info;
                }
            }
        }

        // ----- Stat grid -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                StatTile {
                    horizontal-stretch: 1;
                    label: "STEPS";
                    value: "7,842";
                    unit: "";
                    tone: Tone.default;
                }
                StatTile {
                    horizontal-stretch: 1;
                    label: "DISTANCE";
                    value: "5.4";
                    unit: "km";
                    tone: Tone.info;
                }
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                StatTile {
                    horizontal-stretch: 1;
                    label: "ACTIVE KCAL";
                    value: "420";
                    unit: "";
                    tone: Tone.danger;
                }
                StatTile {
                    horizontal-stretch: 1;
                    label: "AVG HR";
                    value: "94";
                    unit: "bpm";
                    tone: Tone.success;
                }
            }
        }

        // ----- Recent workouts -----
        SectionHeader { text: "RECENT WORKOUTS"; }

        WorkoutRow {
            name: "Morning run";
            when: "today";
            duration: "32 min";
            calories: "284 kcal";
            accent: Theme.accent-danger;
        }
        Divider { }
        WorkoutRow {
            name: "Strength training";
            when: "yesterday";
            duration: "48 min";
            calories: "312 kcal";
            accent: Theme.accent-success;
        }
        Divider { }
        WorkoutRow {
            name: "Yoga · Vinyasa flow";
            when: "Sunday";
            duration: "55 min";
            calories: "190 kcal";
            accent: Theme.accent-info;
        }

        Rectangle { vertical-stretch: 1; }
    }
}
