// WeeklyMealPlanPage
// =====================================================================
//
// 7-day meal plan grid — Plan to Eat / Mealime / Eat This Much style.
// Demonstrates a heterogenous 2D grid layout: day rows × meal columns,
// with each cell a compact "meal pill" carrying:
//
//   - dish name (single line, elided)
//   - calorie count
//   - tone-tinted leading bar (success = on plan, warning = swapped,
//     danger = skipped)
//
// The page header carries a Week-picker chip strip; the footer shows
// the rolled-up weekly stats (total kcal + protein avg + meals planned).

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";

// One meal pill — the unit cell of the grid.
component MealPill inherits Rectangle {
    in property <string> name;
    in property <string> kcal;
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    height: 56px;
    background: Theme.surface-1;
    border-radius: Theme.radius-sm;
    clip: true;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    // Leading tone bar.
    Rectangle {
        x: 0;
        y: 0;
        width: 3px;
        height: parent.height;
        background:
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : transparent;
    }

    VerticalLayout {
        padding-left: Theme.spacing-sm + 3px;
        padding-right: Theme.spacing-sm;
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        spacing: 2px;
        Text {
            text: root.name;
            color: Theme.on-surface;
            font-size: 11px;
            font-weight: 600;
            overflow: elide;
        }
        Text {
            text: root.kcal;
            color: Theme.muted;
            font-size: 10px;
        }
    }
}

// One day row — day label on the left + three meal pills.
component DayRow inherits Rectangle {
    in property <string> day;
    in property <string> when;
    in property <bool> today: false;

    horizontal-stretch: 1;
    height: 76px;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        spacing: Theme.spacing-sm;
        alignment: stretch;

        // Day label column.
        VerticalLayout {
            alignment: center;
            width: 40px;
            spacing: 2px;
            Text {
                text: root.day;
                color: root.today ? Theme.primary : Theme.on-surface;
                font-size: Theme.font-size-caption;
                font-weight: 800;
                horizontal-alignment: center;
            }
            Text {
                text: root.when;
                color: root.today ? Theme.primary : Theme.muted;
                font-size: 10px;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }

        // The 3 meal pills.
        @children
    }
}

export component WeeklyMealPlanPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> week-label: "May 12 – 18";
    callback back-pressed();
    callback prev-week-pressed();
    callback next-week-pressed();
    callback meal-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Meal plan";
            title-style: HeadingStyle.bold-impact;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/queue.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // Week picker + label.
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-sm;
            padding-bottom: Theme.spacing-sm;
            spacing: Theme.spacing-sm;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Heading {
                        text: root.week-label;
                        style: HeadingStyle.grotesk-bold;
                        color: Theme.on-background;
                        font-size: 22px;
                    }
                }
                HorizontalLayout {
                    spacing: Theme.spacing-xs;
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: self.width / 2;
                        background: Theme.surface-1;
                        Image {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("@mobile-components/icons/arrow-left.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        TouchArea {
                            clicked => { root.prev-week-pressed(); }
                        }
                    }
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: self.width / 2;
                        background: Theme.surface-1;
                        Image {
                            width: 14px;
                            height: 14px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        TouchArea {
                            clicked => { root.next-week-pressed(); }
                        }
                    }
                }
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Chip { label: "All meals"; selected: true; }
                Chip { label: "Breakfast"; }
                Chip { label: "Lunch"; }
                Chip { label: "Dinner"; }
            }
        }

        // Column headers (Breakfast / Lunch / Dinner).
        HorizontalLayout {
            padding-left: Theme.spacing-md + 40px + Theme.spacing-sm;
            padding-right: Theme.spacing-md;
            padding-bottom: 2px;
            spacing: Theme.spacing-sm;
            for col in ["BREAKFAST", "LUNCH", "DINNER"] : VerticalLayout {
                horizontal-stretch: 1;
                Text {
                    text: col;
                    color: Theme.muted;
                    font-size: 10px;
                    font-weight: 700;
                    letter-spacing: 0.5px;
                    horizontal-alignment: left;
                }
            }
        }

        // ----- Day rows -----
        DayRow {
            day: "MON";
            when: "12";
            MealPill { name: "Oats + berries"; kcal: "245 kcal"; tone: Tone.success; }
            MealPill { name: "Chicken-rice bowl"; kcal: "542 kcal"; tone: Tone.success; }
            MealPill { name: "Salmon salad"; kcal: "412 kcal"; tone: Tone.success; }
        }
        DayRow {
            day: "TUE";
            when: "13";
            MealPill { name: "Greek yogurt"; kcal: "180 kcal"; tone: Tone.success; }
            MealPill { name: "Bento — sushi"; kcal: "620 kcal"; tone: Tone.warning; }
            MealPill { name: "Tofu stir-fry"; kcal: "380 kcal"; tone: Tone.success; }
        }
        DayRow {
            day: "WED";
            when: "14";
            today: true;
            MealPill { name: "Oats + berries"; kcal: "245 kcal"; tone: Tone.success; }
            MealPill { name: "Chicken-rice bowl"; kcal: "542 kcal"; tone: Tone.success; }
            MealPill { name: "Salmon + quinoa"; kcal: "352 kcal"; tone: Tone.default; }
        }
        DayRow {
            day: "THU";
            when: "15";
            MealPill { name: "Smoothie"; kcal: "210 kcal"; tone: Tone.default; }
            MealPill { name: "Wrap — chicken"; kcal: "480 kcal"; tone: Tone.default; }
            MealPill { name: "Pasta — pesto"; kcal: "560 kcal"; tone: Tone.default; }
        }
        DayRow {
            day: "FRI";
            when: "16";
            MealPill { name: "Oats + berries"; kcal: "245 kcal"; tone: Tone.default; }
            MealPill { name: "Buddha bowl"; kcal: "510 kcal"; tone: Tone.default; }
            MealPill { name: "Takeaway"; kcal: "—"; tone: Tone.warning; }
        }
        DayRow {
            day: "SAT";
            when: "17";
            MealPill { name: "Eggs + toast"; kcal: "420 kcal"; tone: Tone.default; }
            MealPill { name: "Salad + bread"; kcal: "380 kcal"; tone: Tone.default; }
            MealPill { name: "Steak + greens"; kcal: "640 kcal"; tone: Tone.default; }
        }
        DayRow {
            day: "SUN";
            when: "18";
            MealPill { name: "Brunch out"; kcal: "—"; tone: Tone.danger; }
            MealPill { name: "Leftovers"; kcal: "400 kcal"; tone: Tone.default; }
            MealPill { name: "Soup + bread"; kcal: "350 kcal"; tone: Tone.default; }
        }

        Rectangle { vertical-stretch: 1; }

        // Footer stats.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 64px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: "WEEKLY KCAL";
                        color: Theme.muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: "13,920";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                    }
                }
                Rectangle { width: 1px; background: Theme.outline; }
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: "AVG PROTEIN";
                        color: Theme.muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: "112 g / day";
                        color: Theme.accent-success;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                    }
                }
                Rectangle { width: 1px; background: Theme.outline; }
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    Text {
                        text: "MEALS PLANNED";
                        color: Theme.muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: "19 / 21";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                    }
                }
            }
        }
    }
}
