// NutritionLabelPage
// =====================================================================
//
// Read-only nutrition facts for a single product. Hero card (product
// title + serving size), CALORIES block (single highlighted row),
// MACROS block (KeyValueRows with `emphasis` on subtotal rows like
// "Total fat" and "Carbohydrates" — mirrors the FDA label hierarchy),
// and MICROS block (KeyValueRows in mg / %).
//
// Alignment discipline
// --------------------
// Every nutrient row is the same `KeyValueRow` so the value column
// shares one right margin across every section. Subtotals use
// `emphasis: true` for visual hierarchy.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Card } from "@mobile-components/card.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component NutritionLabelPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Nutrition";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Hero card --------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        title: "Whole-grain bread, sliced";
                        subtitle: "Serving size: 2 slices (60 g)";
                    }
                }

                // ----- CALORIES ---------------------------------------------
                FormSection {
                    title: "CALORIES";

                    SettingRow {
                        title: "180 kcal";
                        subtitle: "9 % of 2,000 kcal daily intake";
                    }
                }

                // ----- MACROS -----------------------------------------------
                FormSection {
                    title: "MACROS";

                    KeyValueRow {
                        label: "Total fat";
                        value: "3 g";
                        emphasis: true;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "    Saturated fat";
                        value: "0.5 g";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Carbohydrates";
                        value: "32 g";
                        emphasis: true;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "    Fibre";
                        value: "4 g";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "    Sugars";
                        value: "3 g";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Protein";
                        value: "7 g";
                        emphasis: true;
                    }
                }

                // ----- MICROS -----------------------------------------------
                FormSection {
                    title: "MICROS";

                    KeyValueRow {
                        label: "Sodium";
                        value: "260 mg · 11 %";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Iron";
                        value: "1.4 mg · 8 %";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Calcium";
                        value: "60 mg · 5 %";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Vitamin D";
                        value: "0.4 µg · 2 %";
                    }
                }
            }
        }
    }
}
