// PetAdoptionPage
// =====================================================================
//
// Petfinder / RescueGroups-style adoptable pet card. Distinct from
// `ProductDetailPage` (product e-commerce) and `HotelBookingPage`
// (room reservation). Demonstrates an emotional-product detail
// surface where the trait chips do the heavy lifting:
//
//   - Cover gradient hero with translucent back + share + heart, plus
//     a 2-letter species tag pinned to the lower-left.
//   - Title row (name + meta) + 4-chip trait strip (Age / Sex / Weight
//     / Energy).
//   - "About" prose + "Likes / dislikes" two-column list of bullet
//     points.
//   - Shelter card with location, contact, distance.
//   - Sticky Apply-to-adopt CTA + secondary "Meet at the shelter".

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";

// One trait chip.
component TraitChip inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    height: 64px;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        padding: Theme.spacing-sm;
        spacing: 2px;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.5px;
            horizontal-alignment: center;
        }
        Text {
            text: root.value;
            color:
                  root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.warning ? Theme.accent-warning
                : root.tone == Tone.danger  ? Theme.accent-danger
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 800;
            horizontal-alignment: center;
        }
    }
}

// One bullet in likes/dislikes.
component PetBullet inherits Rectangle {
    in property <string> text;
    in property <Tone> tone: Tone.success;

    min-height: 28px;
    HorizontalLayout {
        spacing: Theme.spacing-xs;
        alignment: start;
        VerticalLayout {
            alignment: start;
            padding-top: 4px;
            Rectangle {
                width: 6px;
                height: 6px;
                border-radius: 3px;
                background:
                      root.tone == Tone.success ? Theme.accent-success
                    : root.tone == Tone.warning ? Theme.accent-warning
                    : root.tone == Tone.danger  ? Theme.accent-danger
                    : root.tone == Tone.info    ? Theme.accent-info
                    : Theme.primary;
            }
        }
        Text {
            text: root.text;
            color: Theme.on-surface;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
    }
}

export component PetAdoptionPage inherits Rectangle {
    in property <string> pet-name: "Mira";
    in property <string> pet-meta: "Border Collie mix · Female";
    in property <string> shelter: "SF SPCA · Mission Adoption Center";
    in property <string> distance: "0.8 mi · open until 18:00";
    callback back-pressed();
    callback share-pressed();
    callback heart-pressed();
    callback apply-pressed();
    callback meet-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // Gradient hero.
        Rectangle {
            height: 240px;
            background: @linear-gradient(135deg, #6b8e50 0%, #1a2d12 100%);
            clip: true;

            // Translucent back / share / heart.
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: 64px;
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                alignment: stretch;
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/arrow-left.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.back-pressed(); }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.share-pressed(); }
                    }
                }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/heart.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.heart-pressed(); }
                    }
                }
            }

            // Species tag bottom-left.
            Rectangle {
                x: Theme.spacing-md;
                y: parent.height - 48px;
                width: 48px;
                height: 32px;
                border-radius: 8px;
                background: Theme.accent-success;
                Text {
                    text: "DOG";
                    color: Theme.on-primary;
                    font-size: 11px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Title + meta.
            VerticalLayout {
                spacing: 2px;
                Text {
                    text: root.pet-name;
                    color: Theme.on-background;
                    font-size: Theme.font-size-headline;
                    font-weight: 800;
                }
                Text {
                    text: root.pet-meta;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                }
            }

            // Trait chips.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                TraitChip { label: "AGE"; value: "2 yr"; }
                TraitChip { label: "SEX"; value: "Female"; tone: Tone.info; }
                TraitChip { label: "WEIGHT"; value: "14 kg"; }
                TraitChip { label: "ENERGY"; value: "Medium"; tone: Tone.warning; }
            }

            Divider { }

            // About.
            Text {
                text: "About Mira";
                color: Theme.on-background;
                font-size: Theme.font-size-body-large;
                font-weight: 800;
            }
            Text {
                text: "Mira came to us in February as a foster transfer from a rural shelter in Sonoma. She's a smart, sensitive Border Collie mix who blossoms with a confident handler. Good leash manners and crate-trained.";
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }

            // Likes / dislikes two-column list.
            HorizontalLayout {
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: Theme.spacing-xs;
                    Text {
                        text: "Likes";
                        color: Theme.accent-success;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    PetBullet { text: "Long walks, off-leash hikes."; tone: Tone.success; }
                    PetBullet { text: "Puzzle toys + treat-finding."; tone: Tone.success; }
                    PetBullet { text: "Older kids (8+)."; tone: Tone.success; }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: Theme.spacing-xs;
                    Text {
                        text: "Not great with";
                        color: Theme.accent-danger;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    PetBullet { text: "Loud noises + crowds."; tone: Tone.danger; }
                    PetBullet { text: "Cats + small dogs."; tone: Tone.danger; }
                    PetBullet { text: "Long alone times (>5 h)."; tone: Tone.warning; }
                }
            }

            Divider { }

            // Shelter card.
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                height: 88px;
                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 44px;
                            height: 44px;
                            border-radius: 10px;
                            background: Theme.accent-info;
                            Image {
                                width: 22px;
                                height: 22px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                source: @image-url("@mobile-components/icons/home.svg");
                                colorize: Theme.on-primary;
                                image-fit: contain;
                            }
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: root.shelter;
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            wrap: word-wrap;
                        }
                        Text {
                            text: root.distance;
                            color: Theme.accent-success;
                            font-size: Theme.font-size-caption;
                            font-weight: 600;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Sticky CTA pair.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 96px;
            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                MobileButton {
                    text: "Apply to adopt Mira";
                    tone: Tone.success;
                    max-height: 44px;
                    clicked => { root.apply-pressed(); }
                }
                MobileButton {
                    text: "Meet at the shelter first";
                    primary: false;
                    max-height: 36px;
                    clicked => { root.meet-pressed(); }
                }
            }
        }
    }
}
