// InsuranceClaimPage
// =====================================================================
//
// Submit-a-claim form. INSURED summary block at the top
// (KeyValueRows), claim-detail FormFields (provider / service date /
// diagnosis code / amount), ATTACHMENTS list with delete affordance
// + "Add another" row, and submit / save-draft actions at the bottom.
//
// Alignment discipline
// --------------------
// Every metadata pair is `KeyValueRow`; every input is wrapped in
// `FormField`; every attachment is `SettingRow`. No hand-rolled rows.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component InsuranceClaimPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> provider;
    in-out property <string> service-date;
    in-out property <string> diagnosis-code;
    in-out property <string> amount;

    callback back-pressed();
    callback submit-pressed();
    callback save-draft-pressed();
    callback delete-attachment(string);
    callback add-attachment();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "New claim";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: start;

                // ----- INSURED ----------------------------------------------
                FormSection {
                    title: "INSURED";

                    KeyValueRow {
                        label: "Name";
                        value: "Greg Raymond";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Policy #";
                        value: "BC-44829-7";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Plan";
                        value: "BlueCross Premium PPO";
                    }
                }

                // ----- Field stack ------------------------------------------
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    FormField {
                        label: "Provider name";
                        required: true;
                        TextField {
                            placeholder: "Riverside Heart Clinic";
                            text <=> root.provider;
                        }
                    }

                    FormField {
                        label: "Service date";
                        required: true;
                        TextField {
                            placeholder: "MM/DD/YYYY";
                            text <=> root.service-date;
                        }
                    }

                    FormField {
                        label: "Diagnosis code";
                        helper: "ICD-10";
                        TextField {
                            placeholder: "e.g. I10";
                            text <=> root.diagnosis-code;
                        }
                    }

                    FormField {
                        label: "Amount";
                        required: true;
                        TextField {
                            placeholder: "0.00";
                            text <=> root.amount;
                            input-type: InputType.decimal;
                        }
                    }
                }

                // ----- ATTACHMENTS ------------------------------------------
                FormSection {
                    title: "ATTACHMENTS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "receipt_05122026.pdf";
                        subtitle: "412 KB · added today";
                        clicked => { root.delete-attachment("receipt_05122026.pdf"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        title: "lab_panel_05112026.pdf";
                        subtitle: "208 KB · added today";
                        clicked => { root.delete-attachment("lab_panel_05112026.pdf"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        title: "+ Add another";
                        clicked => { root.add-attachment(); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Actions ----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Submit claim";
                        enabled: root.provider != "" && root.service-date != "" && root.amount != "";
                        clicked => { root.submit-pressed(); }
                    }
                    TextButton {
                        text: "Save as draft";
                        clicked => { root.save-draft-pressed(); }
                    }
                }
            }
        }
    }
}
