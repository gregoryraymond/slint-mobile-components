// DoctorAppointmentPage
// =====================================================================
//
// Detail view for a single upcoming appointment. Shows the doctor's
// hero card (avatar + name + specialty + confirmation chip), the WHEN
// block (date / time / duration / location as KeyValueRows), a CHECK-IN
// block of advisory rows (SettingRow with chevron trailing), and a
// REMINDERS block (SettingRow with MobileSwitch trailing). Bottom CTAs
// reschedule or cancel.
//
// Alignment discipline
// --------------------
// Every row in the page is one of the shared row primitives —
// `KeyValueRow` for the metadata pairs and `SettingRow` for the
// advisory + toggle rows. The hero is a `Card` with an `Avatar`,
// `Heading` text, and a `Chip` for the status pill.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Card } from "@mobile-components/card.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { ScrollView } from "std-widgets.slint";

export component DoctorAppointmentPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> reminder-24h: true;
    in-out property <bool> reminder-sms: false;

    callback back-pressed();
    callback share-pressed();
    callback reschedule-pressed();
    callback cancel-pressed();
    callback row-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Appointment";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Hero card --------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            Avatar {
                                fallback: "EM";
                                size: 56px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Heading {
                                    text: "Dr. Elena Marquez";
                                    style: HeadingStyle.plex-medium;
                                    color: Theme.on-surface;
                                    font-size: Theme.font-size-body-large;
                                }
                                Text {
                                    text: "Cardiology";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-body;
                                }
                                Text {
                                    text: "Riverside Heart Clinic";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Chip {
                                    label: "CONFIRMED";
                                    selected: true;
                                }
                            }
                        }
                    }
                }

                // ----- WHEN -------------------------------------------------
                FormSection {
                    title: "WHEN";

                    KeyValueRow {
                        label: "Date";
                        value: "Mon, 18 May 2026";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Time";
                        value: "10:30 AM";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Duration";
                        value: "45 min";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Location";
                        value: "Suite 312";
                    }
                }

                // ----- CHECK-IN ---------------------------------------------
                FormSection {
                    title: "CHECK-IN";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.info;
                        title: "Bring your insurance card";
                        subtitle: "BlueCross #BC-44829-7";
                        clicked => { root.row-pressed("insurance"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Arrive 15 min early";
                        subtitle: "Patient intake forms";
                        clicked => { root.row-pressed("arrive"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pencil.svg");
                        title: "Pre-visit questionnaire";
                        subtitle: "5 min · optional";
                        clicked => { root.row-pressed("questionnaire"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- REMINDERS --------------------------------------------
                FormSection {
                    title: "REMINDERS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        title: "24-hour reminder";
                        subtitle: "Push notification one day before";
                        MobileSwitch { checked <=> root.reminder-24h; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        title: "Day-of SMS";
                        subtitle: "Text reminder the morning of";
                        MobileSwitch { checked <=> root.reminder-sms; }
                    }
                }

                // ----- Actions ----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Reschedule";
                        clicked => { root.reschedule-pressed(); }
                    }
                    TextButton {
                        text: "Cancel appointment";
                        clicked => { root.cancel-pressed(); }
                    }
                }
            }
        }
    }
}
