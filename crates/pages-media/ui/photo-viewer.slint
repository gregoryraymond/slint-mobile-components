// PhotoViewerPage
// =====================================================================
//
// Single-photo viewer with EXIF + edit actions — Apple Photos / Google
// Photos "tap into a photo" detail screen. Distinct from
// `PhotoGridPage` (browse) and `PostCreatorPage` (compose). The
// surface is dim by default so the photo content carries the eye;
// the chrome floats on translucent dark backdrops.
//
// Demonstrates:
//
//   - Full-bleed photo placeholder filling the viewport (centred via
//     letterboxing if the photo isn't 4:3).
//   - Top action row (close × / share / overflow) on translucent dark
//     pills.
//   - Capture metadata strip beneath the photo: timestamp + place +
//     EXIF chips (f-stop / shutter / ISO / focal).
//   - Bottom action row: Heart / Edit / Share / Delete each rendered
//     as `MiniAction` (icon + caption), with Heart in danger-tone
//     when liked.

import { Theme, Tone } from "@mobile-theme/theme.slint";

// One bottom action button — vertical icon + caption stack.
component MiniAction inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <Tone> tone: Tone.default;
    in property <bool> active: false;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 60px;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    animate background { duration: Theme.motion-fast; }

    property <color> tint:
          root.active
            ? (
                  root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.warning ? Theme.accent-warning
                : root.tone == Tone.danger  ? Theme.accent-danger
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.primary
              )
            : Theme.on-surface;

    VerticalLayout {
        spacing: 2px;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                width: 22px;
                height: 22px;
                source: root.icon;
                colorize: tint;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: tint;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.3px;
            }
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// One EXIF chip — small label + value.
component ExifChip inherits Rectangle {
    in property <string> label;
    in property <string> value;

    horizontal-stretch: 1;
    height: 44px;
    background: Theme.surface-1;
    border-radius: Theme.radius-sm;
    VerticalLayout {
        spacing: 0;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.muted;
            font-family: "IBM Plex Sans";
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 1.2px;
            horizontal-alignment: center;
        }
        Text {
            text: root.value;
            color: Theme.on-surface;
            font-family: "IBM Plex Sans";
            font-size: Theme.font-size-caption;
            font-weight: 700;
            horizontal-alignment: center;
        }
    }
}

export component PhotoViewerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> captured: "May 12, 2026 · 18:42";
    in property <string> place: "Ocean Beach · San Francisco";
    in-out property <bool> liked: false;
    callback close-pressed();
    callback share-pressed();
    callback more-pressed();
    callback heart-pressed();
    callback edit-pressed();
    callback delete-pressed();

    background: #0a0d12;

    VerticalLayout {
        spacing: 0;

        // ----- Photo area -----
        Rectangle {
            vertical-stretch: 1;
            background: #0a0d12;
            clip: true;

            // Photo placeholder centred at 4:3.
            Rectangle {
                x: 0;
                y: (parent.height - self.height) / 2;
                width: parent.width;
                height: parent.width * 3 / 4;
                background: @linear-gradient(135deg, #f59e0b 0%, #b45309 40%, #1a1d24 100%);
            }

            // Top action row.
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: 64px;
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                alignment: stretch;
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000099;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/close.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.close-pressed(); }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000099;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.share-pressed(); }
                    }
                }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000099;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/more-vertical.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.more-pressed(); }
                    }
                }
            }
        }

        // ----- Metadata strip -----
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            HorizontalLayout {
                Text {
                    text: root.captured;
                    color: #ffffff;
                    font-family: "IBM Plex Sans";
                    font-size: 20px;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                Image {
                    width: 16px;
                    height: 16px;
                    source: @image-url("@mobile-components/icons/heart.svg");
                    colorize: root.liked ? Theme.accent-danger : #ffffff88;
                    image-fit: contain;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.place;
                color: #ffffffcc;
                font-family: "IBM Plex Sans";
                font-size: Theme.font-size-caption;
                font-italic: true;
            }
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                padding-top: Theme.spacing-xs;
                ExifChip { label: "APERTURE"; value: "ƒ/2.8"; }
                ExifChip { label: "SHUTTER"; value: "1/250"; }
                ExifChip { label: "ISO"; value: "200"; }
                ExifChip { label: "FOCAL"; value: "24mm"; }
            }
        }

        // ----- Bottom action row -----
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 76px;
            HorizontalLayout {
                padding: Theme.spacing-xs;
                MiniAction {
                    icon: @image-url("@mobile-components/icons/heart.svg");
                    label: "LIKE";
                    tone: Tone.danger;
                    active: root.liked;
                    clicked => {
                        root.liked = !root.liked;
                        root.heart-pressed();
                    }
                }
                MiniAction {
                    icon: @image-url("@mobile-components/icons/pencil.svg");
                    label: "EDIT";
                    clicked => { root.edit-pressed(); }
                }
                MiniAction {
                    icon: @image-url("@mobile-components/icons/send.svg");
                    label: "SHARE";
                    clicked => { root.share-pressed(); }
                }
                MiniAction {
                    icon: @image-url("@mobile-components/icons/close.svg");
                    label: "DELETE";
                    tone: Tone.danger;
                    clicked => { root.delete-pressed(); }
                }
            }
        }
    }
}
