// LiveStreamPage
// =====================================================================
//
// Twitch / Instagram-Live style watch surface. The top 60% of the page
// is dominated by the "video frame" placeholder (Theme.surface-3 with a
// centred "LIVE" label and a small red dot indicator). The AppBar is
// transparent so it overlays the stream. Below the frame: stream title,
// streamer line, viewer / engagement metadata via `MetaRow`, three
// quick-action buttons (Like / Share / Tip), a `FormSection` of recent
// comments rendered as `SettingRow`s, and a chat composer at the very
// bottom built from a `FormField` + `TextField`.
//
// Alignment discipline
//   - The "rows" are SettingRows in a FormSection — same min-height,
//     same gutters, same leading-tile size. No hand-rolled comment
//     rows.
//   - Metadata uses MetaRow so the icon-text chips share a baseline.
//   - The chat composer wraps a TextField in a FormField for the same
//     reason every other input on the page would: consistent label
//     position and horizontal inset.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { ScrollView } from "std-widgets.slint";

export component LiveStreamPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in property <string> stream-title: "Building a Rust + Slint mobile app — live";
    in property <string> streamer: "@graydevs";
    in-out property <string> chat-draft;
    callback back-pressed();
    callback like-pressed();
    callback share-pressed();
    callback tip-pressed();
    callback comment-pressed(string);
    callback chat-submitted(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Video frame (top 60% of page) with overlay AppBar -----
        Rectangle {
            // 60% of 892px = 535px. Hardcoded to avoid binding loops on
            // parent.height (see video-player.slint for the same trick).
            height: 535px;
            background: Theme.surface-3;
            clip: true;

            // Centred "LIVE" label + red live-indicator dot.
            HorizontalLayout {
                x: (parent.width - self.preferred-width) / 2;
                y: (parent.height - self.preferred-height) / 2;
                spacing: Theme.spacing-sm;
                alignment: center;
                Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: self.width / 2;
                    background: Theme.accent-danger;
                }
                Text {
                    text: "LIVE";
                    color: Theme.on-background;
                    font-family: "Inter";
                    font-size: Theme.font-size-headline;
                    font-weight: 800;
                    letter-spacing: 4px;
                    vertical-alignment: center;
                }
            }

            // Transparent AppBar overlaid at the top of the frame.
            AppBar {
                x: 0;
                y: 0;
                width: parent.width;
                bar-background: transparent;
                text-color: Theme.on-primary;
                leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
                trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
                leading-pressed => { root.back-pressed(); }
            }
        }

        // ----- Scrolling body: title, meta, actions, comments, composer
        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: start;

                // Title + streamer.
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    Heading {
                        style: HeadingStyle.plex-medium;
                        text: root.stream-title;
                        font-size: 18px;
                        color: Theme.on-background;
                        wrap: word-wrap;
                    }
                    Text {
                        text: root.streamer;
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        font-weight: 600;
                    }
                }

                // Meta chips: viewers + likes.
                MetaRow {
                    items: [
                        { icon: @image-url("@mobile-components/icons/profile.svg"), text: "1,247 watching" },
                        { icon: @image-url("@mobile-components/icons/heart.svg"), text: "8.4K" },
                    ];
                }

                // Quick actions — three equal-stretch buttons.
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    MobileButton {
                        text: "Like";
                        primary: false;
                        clicked => { root.like-pressed(); }
                    }
                    MobileButton {
                        text: "Share";
                        primary: false;
                        clicked => { root.share-pressed(); }
                    }
                    MobileButton {
                        text: "Tip";
                        clicked => { root.tip-pressed(); }
                    }
                }

                // Comments — every row is the canonical SettingRow.
                FormSection {
                    title: "LIVE CHAT";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "rustacean42";
                        subtitle: "this build pipeline is so clean";
                        clicked => { root.comment-pressed("rustacean42"); }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "mobile_mara";
                        subtitle: "what theme is that? loving the colours";
                        clicked => { root.comment-pressed("mobile_mara"); }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "slint_fan";
                        subtitle: "first time catching one of these live!";
                        clicked => { root.comment-pressed("slint_fan"); }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "kernel_kira";
                        subtitle: "do the gesture demo next plz";
                        clicked => { root.comment-pressed("kernel_kira"); }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "anon_dev";
                        subtitle: "how do you handle hot reload on android?";
                        clicked => { root.comment-pressed("anon_dev"); }
                    }
                }

                // Composer at the bottom.
                FormField {
                    label: "";
                    TextField {
                        placeholder: "Say something…";
                        text <=> root.chat-draft;
                        accepted(v) => { root.chat-submitted(v); }
                    }
                }
            }
        }
    }
}
