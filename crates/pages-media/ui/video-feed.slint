// VideoFeedPage
// =====================================================================
//
// TikTok / Reels / YouTube Shorts portrait-video feed. Demonstrates:
//
//   - Full-bleed video frame (placeholder gradient) covering the entire
//     viewport, with all UI chrome painted ON TOP of it. Every glyph
//     and label is white so contrast holds over arbitrary frame
//     content.
//   - Vertical action stack on the right edge: heart + count, comment
//     + count, share + count, bookmark + count. Each item is a tappable
//     stack of icon + caption.
//   - Author + description block bottom-left, with caption overflow
//     elided and a hashtag run beneath.
//   - Slim progress bar at the very bottom showing the current video
//     position.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Avatar } from "@mobile-components/avatar.slint";

// One action button — icon disc + count caption, all whites.
component FeedAction inherits Rectangle {
    in property <image> icon;
    in property <string> count;
    in property <bool> active: false;
    callback clicked();

    accessible-role: button;
    accessible-label: root.count;
    accessible-action-default => { root.clicked(); }

    width: 56px;
    height: 64px;

    VerticalLayout {
        spacing: 2px;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 44px;
                height: 44px;
                border-radius: self.width / 2;
                background: root.active ? Theme.accent-danger : #ffffff22;
                Image {
                    width: 22px;
                    height: 22px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: root.icon;
                    colorize: #ffffff;
                    image-fit: contain;
                }
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.count;
                color: #ffffff;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component VideoFeedPage inherits Rectangle {
    in property <string> author: "@anika.ravi";
    in property <string> caption: "Live theme switching with the new Tone enum — every status component re-tints in a single frame.";
    in property <string> hashtags: "#slint #rust #mobiledev #design";
    in property <string> sound: "♪ Original — Anika Ravi";
    in property <float> progress: 0.32;
    in-out property <bool> liked: false;
    callback back-pressed();
    callback like-pressed();
    callback comment-pressed();
    callback share-pressed();
    callback bookmark-pressed();

    background: Theme.background;

    // ----- Video frame (full-bleed gradient placeholder) -----
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: @radial-gradient(circle, #1d3a6e 0%, #0a0d12 90%);
    }

    // Subtle bottom-fade so the chrome at the bottom reads cleanly.
    Rectangle {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        height: 280px;
        background: @linear-gradient(180deg, #00000000 0%, #000000aa 100%);
    }

    // ----- Top overlay (back + search) -----
    // Pinned to the top of the canvas with an explicit height so the
    // HorizontalLayout doesn't stretch to fill the parent.
    HorizontalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        height: 64px;
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: self.width / 2;
            background: #00000066;
            Image {
                width: 18px;
                height: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: @image-url("@mobile-components/icons/arrow-left.svg");
                colorize: #ffffff;
                image-fit: contain;
            }
            TouchArea {
                clicked => { root.back-pressed(); }
            }
        }
        Rectangle { horizontal-stretch: 1; }
        // Tabs "Following · For you · Live".
        HorizontalLayout {
            spacing: Theme.spacing-md;
            VerticalLayout {
                alignment: center;
                Text {
                    text: "Following";
                    color: #ffffffaa;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                Text {
                    text: "For you";
                    color: #ffffff;
                    font-size: Theme.font-size-body;
                    font-weight: 700;
                }
                Rectangle {
                    height: 2px;
                    background: #ffffff;
                    width: 28px;
                    x: (parent.width - self.width) / 2;
                }
            }
            VerticalLayout {
                alignment: center;
                Text {
                    text: "Live";
                    color: #ffffffaa;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
            }
        }
        Rectangle { horizontal-stretch: 1; }
        Rectangle {
            width: 36px;
            height: 36px;
            border-radius: self.width / 2;
            background: #00000066;
            Image {
                width: 18px;
                height: 18px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: @image-url("@mobile-components/icons/search.svg");
                colorize: #ffffff;
                image-fit: contain;
            }
        }
    }

    // ----- Right action stack -----
    VerticalLayout {
        x: parent.width - 76px;
        y: parent.height - 480px;
        spacing: Theme.spacing-sm;
        // Author avatar with + indicator.
        Rectangle {
            width: 56px;
            height: 64px;
            VerticalLayout {
                alignment: center;
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 48px;
                        height: 48px;
                        border-radius: self.width / 2;
                        border-width: 2px;
                        border-color: #ffffff;
                        Avatar {
                            x: 0;
                            y: 0;
                            width: parent.width - 4px;
                            height: parent.height - 4px;
                            fallback: "AR";
                            size: 44px;
                        }
                        // + follow indicator.
                        Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: parent.height - self.height / 2;
                            width: 18px;
                            height: 18px;
                            border-radius: 9px;
                            background: Theme.accent-danger;
                            border-width: 2px;
                            border-color: #ffffff;
                            Text {
                                text: "+";
                                color: #ffffff;
                                font-size: 12px;
                                font-weight: 700;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }
            }
        }

        FeedAction {
            icon: @image-url("@mobile-components/icons/heart.svg");
            count: "24.8K";
            active: root.liked;
            clicked => {
                root.liked = !root.liked;
                root.like-pressed();
            }
        }
        FeedAction {
            icon: @image-url("@mobile-components/icons/inbox.svg");
            count: "412";
            clicked => { root.comment-pressed(); }
        }
        FeedAction {
            icon: @image-url("@mobile-components/icons/send.svg");
            count: "1.2K";
            clicked => { root.share-pressed(); }
        }
        FeedAction {
            icon: @image-url("@mobile-components/icons/queue.svg");
            count: "Save";
            clicked => { root.bookmark-pressed(); }
        }
    }

    // ----- Bottom author block -----
    Rectangle {
        x: Theme.spacing-md;
        y: parent.height - self.height - 60px;
        width: parent.width - 100px;
        height: 120px;
        VerticalLayout {
            spacing: Theme.spacing-xs;
            alignment: end;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: root.author;
                    color: #ffffff;
                    font-size: Theme.font-size-body-large;
                    font-weight: 700;
                }
                Rectangle {
                    width: follow-text.preferred-width + 14px;
                    height: 22px;
                    border-radius: 4px;
                    border-width: 1px;
                    border-color: #ffffff;
                    follow-text := Text {
                        text: "Follow";
                        color: #ffffff;
                        font-size: 11px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
            Text {
                text: root.caption;
                color: #ffffff;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
            Text {
                text: root.hashtags;
                color: #ffffffcc;
                font-size: Theme.font-size-caption;
                font-weight: 600;
            }
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                padding-top: 2px;
                Image {
                    width: 12px;
                    height: 12px;
                    source: @image-url("@mobile-components/icons/play.svg");
                    colorize: #ffffff;
                    image-fit: contain;
                    vertical-alignment: center;
                }
                Text {
                    text: root.sound;
                    color: #ffffffcc;
                    font-size: Theme.font-size-caption;
                }
            }
        }
    }

    // ----- Slim progress bar at the bottom -----
    Rectangle {
        x: 0;
        y: parent.height - 3px;
        width: parent.width;
        height: 3px;
        background: #ffffff22;
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width * root.progress;
            height: parent.height;
            background: #ffffff;
        }
    }
}
