// VideoFeedPage
// =====================================================================
//
// TikTok / Reels / Shorts vertical-scroll feed showing ONE video that
// fills the entire screen. No standard AppBar — instead a tiny
// transparent strip with just a back arrow at the top-left. The right
// side carries a column of round action buttons (heart / comment /
// share / more) overlaid on top of the video; the bottom carries the
// creator + caption + hashtags.
//
// Alignment discipline
//   - Metadata at the bottom (hashtags) uses `MetaRow` so each chip's
//     icon and text share a baseline, matching every other meta-row in
//     the library.
//   - The action column is a single `VerticalLayout` with constant
//     spacing; every action button is the same 48 × 48 round Rectangle
//     wrapping a centred 22 px icon — no hand-rolled per-row sizing.

import { Theme } from "@mobile-theme/theme.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";

// Page-local: a round translucent overlay action button — heart /
// comment / share / more. The library's `IconButton` is a square label-
// below-icon tab atom, the wrong shape for an overlay action.
component FeedActionButton inherits Rectangle {
    in property <image> icon;
    in property <string> a11y-label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.a11y-label;
    accessible-action-default => { root.clicked(); }

    width: 48px;
    height: 48px;
    border-radius: 24px;
    background: touch.pressed
        ? Theme.surface-3.with-alpha(0.75)
        : Theme.surface-3.with-alpha(0.5);

    animate background { duration: Theme.motion-fast; }

    Image {
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: #ffffff;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component VideoFeedPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in property <string> creator: "@brusselskitchen";
    in property <string> caption:
        "Quick midweek mussels — white wine, garlic, parsley, and a stack of fries. Whole thing in under fifteen minutes.";
    callback back-pressed();
    callback like-pressed();
    callback comment-pressed();
    callback share-pressed();
    callback more-pressed();

    background: Theme.background;

    // ----- Full-screen video placeholder -----
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-3;
        clip: true;

        Text {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            text: "VIDEO";
            color: Theme.on-background;
            font-family: "Inter";
            font-size: 32px;
            font-weight: 800;
            letter-spacing: 6px;
        }
    }

    // ----- Tiny top bar: just a back arrow -----
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 56px;
        background: transparent;

        HorizontalLayout {
            padding: Theme.spacing-md;
            alignment: start;
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: self.width / 2;
                background: back-touch.pressed
                    ? Theme.surface-3.with-alpha(0.75)
                    : Theme.surface-3.with-alpha(0.5);
                animate background { duration: Theme.motion-fast; }

                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/arrow-left.svg");
                    colorize: #ffffff;
                    image-fit: contain;
                }

                back-touch := TouchArea {
                    clicked => { root.back-pressed(); }
                }
            }
        }
    }

    // ----- Action column on the right, vertically centred -----
    VerticalLayout {
        x: parent.width - self.preferred-width - Theme.spacing-md;
        y: (parent.height - self.preferred-height) / 2;
        spacing: Theme.spacing-md;
        alignment: center;

        FeedActionButton {
            icon: @image-url("@mobile-components/icons/heart.svg");
            a11y-label: "Like";
            clicked => { root.like-pressed(); }
        }
        FeedActionButton {
            icon: @image-url("@mobile-components/icons/inbox.svg");
            a11y-label: "Comment";
            clicked => { root.comment-pressed(); }
        }
        FeedActionButton {
            icon: @image-url("@mobile-components/icons/send.svg");
            a11y-label: "Share";
            clicked => { root.share-pressed(); }
        }
        FeedActionButton {
            icon: @image-url("@mobile-components/icons/more-vertical.svg");
            a11y-label: "More";
            clicked => { root.more-pressed(); }
        }
    }

    // ----- Bottom overlay: creator + caption + tags -----
    Rectangle {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        // Soft scrim so the white text stays legible regardless of the
        // underlying frame colour.
        background: @linear-gradient(180deg, #00000000 0%, #000000aa 100%);

        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-lg;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            alignment: end;

            Text {
                text: root.creator;
                color: Theme.on-primary;
                font-family: "Inter";
                font-size: Theme.font-size-body-large;
                font-weight: 700;
            }
            Text {
                text: root.caption;
                color: #ffffffcc;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
                overflow: elide;
            }
            MetaRow {
                items: [
                    { icon: @image-url("@mobile-components/icons/pin.svg"), text: "#meals" },
                    { icon: @image-url("@mobile-components/icons/star.svg"), text: "#brussels" },
                ];
            }
        }
    }
}
