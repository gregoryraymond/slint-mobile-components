// MediaPlayerLockscreenPage
// =====================================================================
//
// The "now playing" widget you see on a locked phone — no AppBar, no
// chrome, just a large album-art square, the track text, a progress
// bar, transport controls, and a small grouped FormSection for AirPlay
// + Lyrics. Distinct from `AudiobookPlayerPage` (which has a richer
// chapter list and an AppBar) — this surface is deliberately spare.
//
// Alignment discipline
//   - The two utility rows at the bottom (AirPlay / Lyrics) are
//     `SettingRow`s inside a `FormSection` — exactly the same alignment
//     primitive used by SettingsPage. Trailing slot holds either a
//     value Text or a chevron Image.
//   - Time elapsed / remaining sit in a HorizontalLayout right under
//     the determinate `ProgressBar` from the component library — not a
//     hand-rolled scrubber.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { ProgressBar } from "@mobile-components/progress-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";

// Round transport button — page-local since the only consumer is this
// lockscreen and the size / colour treatment is specific to it.
component TransportButton inherits Rectangle {
    in property <image> icon;
    in property <length> diameter: 56px;
    in property <bool> primary: false;
    in property <string> a11y-label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.a11y-label;
    accessible-action-default => { root.clicked(); }

    width: root.diameter;
    height: root.diameter;
    border-radius: self.width / 2;
    background: root.primary
        ? (touch.pressed ? Theme.primary-pressed : Theme.primary)
        : (touch.pressed ? Theme.surface-pressed : transparent);

    animate background { duration: Theme.motion-fast; }

    Image {
        width: root.primary ? root.diameter * 0.45 : root.diameter * 0.5;
        height: self.width;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.primary ? Theme.on-primary : Theme.on-background;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component MediaPlayerLockscreenPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in property <string> track: "Aero — Vol. III";
    in property <string> artist: "Hidden Orchestra";
    in property <string> elapsed: "1:47";
    in property <string> total: "4:13";
    in property <string> airplay-target: "Living Room";
    in-out property <bool> playing: true;
    callback skip-back-pressed();
    callback play-pause-pressed();
    callback skip-forward-pressed();
    callback airplay-pressed();
    callback lyrics-pressed();

    background: Theme.background;

    VerticalLayout {
        padding-top: Theme.spacing-xl;
        padding-bottom: Theme.spacing-xl;
        spacing: Theme.spacing-lg;
        alignment: stretch;

        // ----- Album art (centred 280×280) -----
        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 280px;
                height: 280px;
                border-radius: Theme.radius-lg;
                background: Theme.surface-2;
                drop-shadow-blur: Theme.elevation-3-blur;
                drop-shadow-color: Theme.elevation-3-color;
                drop-shadow-offset-y: Theme.elevation-3-y;
                clip: true;
                // Soft gradient overlay so the art reads as a real
                // cover rather than a flat tile.
                Rectangle {
                    width: parent.width;
                    height: parent.height;
                    background: @linear-gradient(135deg, #2c3e50 0%, #1a1d24 100%);
                    border-radius: parent.border-radius;
                }
                Image {
                    width: 96px;
                    height: 96px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/play.svg");
                    colorize: #ffffff66;
                    image-fit: contain;
                }
            }
        }

        // ----- Title + artist -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            Heading {
                text: root.track;
                font-size: 22px;
                font-weight: 700;
                color: Theme.on-background;
                horizontal-alignment: center;
                wrap: word-wrap;
            }
            Text {
                text: root.artist;
                color: Theme.muted;
                font-size: Theme.font-size-body-large;
                horizontal-alignment: center;
            }
        }

        // ----- Progress bar + time -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            ProgressBar {
                value: 0.42;
            }
            HorizontalLayout {
                Text {
                    text: root.elapsed;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.total;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                }
            }
        }

        // ----- Transport row -----
        HorizontalLayout {
            alignment: center;
            spacing: Theme.spacing-xl;
            TransportButton {
                icon: @image-url("@mobile-components/icons/skip-back.svg");
                diameter: 56px;
                a11y-label: "Previous";
                clicked => { root.skip-back-pressed(); }
            }
            TransportButton {
                icon: root.playing
                    ? @image-url("@mobile-components/icons/pause.svg")
                    : @image-url("@mobile-components/icons/play.svg");
                diameter: 72px;
                primary: true;
                a11y-label: root.playing ? "Pause" : "Play";
                clicked => {
                    root.playing = !root.playing;
                    root.play-pause-pressed();
                }
            }
            TransportButton {
                icon: @image-url("@mobile-components/icons/skip-forward.svg");
                diameter: 56px;
                a11y-label: "Next";
                clicked => { root.skip-forward-pressed(); }
            }
        }

        // ----- AirPlay + Lyrics -----
        FormSection {
            SettingRow {
                icon: @image-url("@mobile-components/icons/send.svg");
                tone: Tone.info;
                title: "AirPlay";
                clicked => { root.airplay-pressed(); }
                Text {
                    text: root.airplay-target;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    vertical-alignment: center;
                }
            }
            Divider { }
            SettingRow {
                icon: @image-url("@mobile-components/icons/menu.svg");
                title: "Lyrics";
                clicked => { root.lyrics-pressed(); }
                Image {
                    width: 16px;
                    height: 16px;
                    source: @image-url("@mobile-components/icons/chevron-right.svg");
                    colorize: Theme.muted;
                    image-fit: contain;
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
