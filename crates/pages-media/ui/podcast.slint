// PodcastPage
// =====================================================================
//
// Now-playing screen for a podcast / audio player. Showcases how the
// component catalogue composes into a real product surface:
//
//   - AppBar with back arrow + overflow
//   - Hero album-art square (caller-supplied `cover` image)
//   - Title + show / artist meta
//   - `Slider` driving playback position with mm:ss labels either side
//   - Transport row: prev, large play / pause, next
//   - Action row: like (heart), queue, share-via-more
//
// Like the other pages in this directory, `PodcastPage` is a Window
// component so it's instantiable as a Slint preview AND can be embedded
// at full-screen by any host with `width: 100%; height: 100%;` inside
// its own Window.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { IconButton } from "@mobile-components/icon-button.slint";
import { Slider } from "@mobile-components/slider.slint";

component CircleIconButton inherits Rectangle {
    in property <image> icon;
    in property <length> size: 56px;
    in property <length> icon-size: 28px;
    in property <bool> filled: false;
    in property <bool> enabled: true;
    in property <string> a11y-label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.a11y-label;
    accessible-enabled: root.enabled;
    accessible-action-default => { root.clicked(); }

    width: root.size;
    height: root.size;
    border-radius: self.width / 2;
    background: root.filled
        ? (touch.pressed ? Theme.primary-pressed : Theme.primary)
        : (touch.pressed ? Theme.surface-pressed : transparent);
    opacity: root.enabled ? 1.0 : 0.5;

    animate background { duration: Theme.motion-fast; }

    Image {
        width: root.icon-size;
        height: root.icon-size;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.filled ? Theme.on-primary : Theme.on-surface;
        image-fit: contain;
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}

export component PodcastPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> page-title: "The Tail-Recursive Hour";
    in property <string> show-name: "Functional Coffee · Episode 47";
    in property <image> cover: @image-url("@mobile-components/icons/podcast-cover.svg");
    in property <string> current-time: "12:34";
    in property <string> total-time: "48:12";
    in-out property <float> progress: 0.26;
    in-out property <bool> playing: false;
    in-out property <bool> liked: false;
    callback back-pressed();
    callback more-pressed();
    callback play-pause-pressed();
    callback prev-pressed();
    callback next-pressed();
    callback like-toggled();
    callback queue-pressed();
    callback share-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Now Playing";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.more-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-lg;
            vertical-stretch: 1;

            // ----- Cover art -----
            Rectangle {
                height: min(self.width, 320px);
                Rectangle {
                    // Fixed square — a `min(parent.width, …)` here would make
                    // the cover's width depend on the centring layout's width
                    // while also feeding that layout's size info, a binding
                    // loop. 320px fits the 412px mobile target with margin.
                    width: 320px;
                    height: 320px;
                    border-radius: Theme.radius-lg;
                    clip: true;
                    drop-shadow-blur: Theme.elevation-2-blur;
                    drop-shadow-color: Theme.elevation-2-color;
                    drop-shadow-offset-y: Theme.elevation-2-y;
                    Image {
                        width: parent.width;
                        height: parent.height;
                        source: root.cover;
                        image-fit: ImageFit.cover;
                    }
                }
            }

            // ----- Title + show name -----
            VerticalLayout {
                spacing: Theme.spacing-xs;
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: root.page-title;
                        color: Theme.on-background;
                        font-size: Theme.font-size-title;
                        font-weight: 600;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: root.show-name;
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        horizontal-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // ----- Progress slider + time labels -----
            VerticalLayout {
                spacing: Theme.spacing-xs;
                Slider {
                    value <=> root.progress;
                }
                HorizontalLayout {
                    Text {
                        text: root.current-time;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                        horizontal-stretch: 1;
                        horizontal-alignment: left;
                    }
                    Text {
                        text: root.total-time;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                        horizontal-alignment: right;
                    }
                }
            }

            // ----- Transport row -----
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                CircleIconButton {
                    icon: @image-url("@mobile-components/icons/skip-back.svg");
                    size: 56px;
                    icon-size: 28px;
                    a11y-label: "Previous";
                    clicked => { root.prev-pressed(); }
                }
                CircleIconButton {
                    icon: root.playing
                        ? @image-url("@mobile-components/icons/pause.svg")
                        : @image-url("@mobile-components/icons/play.svg");
                    size: 72px;
                    icon-size: 36px;
                    filled: true;
                    a11y-label: root.playing ? "Pause" : "Play";
                    clicked => {
                        root.playing = !root.playing;
                        root.play-pause-pressed();
                    }
                }
                CircleIconButton {
                    icon: @image-url("@mobile-components/icons/skip-forward.svg");
                    size: 56px;
                    icon-size: 28px;
                    a11y-label: "Next";
                    clicked => { root.next-pressed(); }
                }
            }

            // ----- Action row -----
            HorizontalLayout {
                alignment: space-around;
                IconButton {
                    label: root.liked ? "Liked" : "Like";
                    icon: @image-url("@mobile-components/icons/heart.svg");
                    active: root.liked;
                    size: 64px;
                    clicked => {
                        root.liked = !root.liked;
                        root.like-toggled();
                    }
                }
                IconButton {
                    label: "Queue";
                    icon: @image-url("@mobile-components/icons/queue.svg");
                    size: 64px;
                    clicked => { root.queue-pressed(); }
                }
                IconButton {
                    label: "Share";
                    icon: @image-url("@mobile-components/icons/more-vertical.svg");
                    size: 64px;
                    clicked => { root.share-pressed(); }
                }
            }
        }
    }
}