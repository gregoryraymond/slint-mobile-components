// VoiceRecorderPage
// =====================================================================
//
// Voice memo recorder — Apple Voice Memos / Otter / Just Press Record-
// style. Distinct from `TimerPage` (countdown) and `PodcastPage`
// (playback). Demonstrates:
//
//   - Big elapsed time display + recording badge with pulse-like
//     accent-danger dot.
//   - Live waveform strip — a row of variable-height bars (sparkline
//     pattern reused from CryptoPortfolioPage but danger-toned to
//     read as "live mic"). The bar values progress through the array
//     so the strip reads as "recording activity over the last N
//     seconds".
//   - Transport row: pause/stop/discard with a big primary stop
//     button in the centre.
//   - "Recent recordings" list below: name + duration + when, with a
//     mini sparkline icon per item.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";

// One waveform bar.
component WaveBar inherits VerticalLayout {
    in property <int> value;
    in property <color> tint: Theme.accent-danger;

    horizontal-stretch: 1;
    alignment: center;
    Rectangle {
        width: 3px;
        height: 4px + (parent.height - 4px) * value / 100;
        background: root.tint;
        border-radius: 2px;
    }
}

// Live waveform strip — wraps a fixed-length array of integers.
component Waveform inherits Rectangle {
    in property <[int]> bars;
    in property <color> tint: Theme.accent-danger;

    HorizontalLayout {
        spacing: 2px;
        for value in root.bars : WaveBar {
            value: value;
            tint: root.tint;
        }
    }
}

// Mini waveform shown inside a list row.
component MiniWave inherits Rectangle {
    in property <[int]> bars;
    width: 64px;
    height: 24px;
    HorizontalLayout {
        spacing: 1px;
        for value in root.bars : VerticalLayout {
            alignment: center;
            Rectangle {
                width: 2px;
                height: 3px + 18px * value / 100;
                background: Theme.muted;
                border-radius: 1px;
            }
        }
    }
}

// One past-recording row.
component RecordingRow inherits Rectangle {
    in property <string> name;
    in property <string> when;
    in property <string> duration;
    in property <[int]> wave;

    horizontal-stretch: 1;
    min-height: 56px;
    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.when + " · " + root.duration;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            MiniWave { bars: root.wave; }
        }
    }
}

export component VoiceRecorderPage inherits Rectangle {
    in property <string> elapsed: "00:42";
    in-out property <bool> recording: true;
    in-out property <bool> paused: false;
    callback back-pressed();
    callback record-pressed();
    callback pause-pressed();
    callback stop-pressed();
    callback discard-pressed();
    callback recording-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Voice memo";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // ----- Hero: elapsed + REC dot -----
        VerticalLayout {
            padding-top: Theme.spacing-lg;
            spacing: Theme.spacing-sm;

            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-sm;
                if root.recording: Rectangle {
                    width: 12px;
                    height: 12px;
                    border-radius: 6px;
                    background: Theme.accent-danger;
                    y: 8px;
                }
                Text {
                    text:
                          root.recording && !root.paused ? "REC"
                        : root.paused ? "PAUSED"
                        : "READY";
                    color:
                          root.recording && !root.paused ? Theme.accent-danger
                        : root.paused ? Theme.accent-warning
                        : Theme.muted;
                    font-size: 12px;
                    font-weight: 800;
                    letter-spacing: 1px;
                    vertical-alignment: center;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.elapsed;
                    color: Theme.on-background;
                    font-size: 72px;
                    font-weight: 200;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "Untitled memo · " + (root.recording ? "live" : "draft");
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                }
            }
        }

        // ----- Waveform strip -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            Rectangle {
                height: 120px;
                Waveform {
                    horizontal-stretch: 1;
                    height: parent.height;
                    tint:
                          root.recording && !root.paused ? Theme.accent-danger
                        : root.paused ? Theme.accent-warning
                        : Theme.muted;
                    bars: [
                        20, 32, 48, 28, 55, 42, 70, 38, 62, 80, 58, 44,
                        66, 52, 78, 90, 64, 50, 72, 48, 84, 60, 38, 58,
                        72, 88, 50, 62, 76, 42, 68, 80, 54, 46, 72, 64,
                        58, 70, 42, 36, 50, 62, 78, 88, 70, 56, 44, 62
                    ];
                }
            }
        }

        // ----- Transport row -----
        Rectangle {
            height: 120px;
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-lg;
                // Discard.
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 56px;
                        height: 56px;
                        border-radius: self.width / 2;
                        background: Theme.surface-1;
                        Image {
                            width: 22px;
                            height: 22px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                        TouchArea {
                            clicked => { root.discard-pressed(); }
                        }
                    }
                }
                // Big Stop (centre).
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 88px;
                        height: 88px;
                        border-radius: self.width / 2;
                        background: Theme.accent-danger;
                        drop-shadow-blur: Theme.elevation-2-blur;
                        drop-shadow-color: Theme.elevation-2-color;
                        drop-shadow-offset-y: Theme.elevation-2-y;
                        // Stop square inside.
                        Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 32px;
                            height: 32px;
                            border-radius: 4px;
                            background: #ffffff;
                        }
                        TouchArea {
                            clicked => { root.stop-pressed(); }
                        }
                    }
                }
                // Pause / resume.
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 56px;
                        height: 56px;
                        border-radius: self.width / 2;
                        background: Theme.surface-1;
                        Image {
                            width: 22px;
                            height: 22px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: root.paused
                                ? @image-url("@mobile-components/icons/play.svg")
                                : @image-url("@mobile-components/icons/pause.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        TouchArea {
                            clicked => {
                                root.paused = !root.paused;
                                root.pause-pressed();
                            }
                        }
                    }
                }
            }
        }

        SectionHeader { text: "RECENT MEMOS"; }
        RecordingRow {
            name: "Standup notes · Tuesday";
            when: "yesterday, 09:48";
            duration: "2:14";
            wave: [40, 28, 56, 72, 48, 62, 36, 78, 52, 44, 68, 30];
        }
        Divider { }
        RecordingRow {
            name: "Slint Conf venue walkthrough";
            when: "Mon, 11:32";
            duration: "8:42";
            wave: [60, 48, 72, 88, 64, 50, 76, 42, 58, 80, 66, 54];
        }
        Divider { }
        RecordingRow {
            name: "Voicemail · Mum";
            when: "Sun, 18:14";
            duration: "0:48";
            wave: [22, 35, 28, 50, 32, 26, 42, 28, 35, 30, 24, 32];
        }

        Rectangle { vertical-stretch: 1; }
    }
}
