// CheckoutPage
// =====================================================================
//
// Composite-screen template — a single-page checkout: order summary,
// shipping address, payment method, totals, and a pinned bottom CTA.
// Exercises a different composition than the other pages — multiple
// distinct sections stacked vertically, with money-typography emphasis
// on the bottom-line total.
//
// Specification
// -------------
//
// Geometry
//   - AppBar with back, "Checkout".
//   - Scrollable body with 4 sections:
//       1. ITEMS — `Card` containing a stack of line-item rows.
//       2. SHIPPING TO — `ListItem` with `chevron-right` trailing icon.
//       3. PAYMENT — `ListItem` with `chevron-right` trailing icon.
//       4. TOTAL — `Card` with subtotal / shipping / tax rows, a
//          `Divider`, and the bold total line.
//   - Pinned bottom bar: full-width primary `MobileButton` reading
//     "Place order · $TOTAL" with elevation-1 shadow upward.
//
// Slots
//   - `items` (`[OrderLineItem]`): the model driving the ITEMS card.
//   - `ship-name`, `ship-address`, `payment-card`, `subtotal`,
//     `shipping`, `tax`, `total`: strings for the section content.
//   - Callbacks for back, edit-shipping, change-payment, place-order.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { BottomBar } from "@mobile-components/bottom-bar.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { Card } from "@mobile-components/card.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ListItem } from "@mobile-components/list-item.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { ScrollView } from "std-widgets.slint";

export struct OrderLineItem {
    name: string,
    detail: string,
    qty: int,
    price: string,
}

component LineItem inherits Rectangle {
    in property <OrderLineItem> entry;

    horizontal-stretch: 1;
    min-height: 60px;

    HorizontalLayout {
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Thumbnail placeholder — squares with the surface-variant tone
        // so they read as "image not shown" without claiming to be one.
        Rectangle {
            width: 44px;
            height: 44px;
            border-radius: Theme.radius-sm;
            background: Theme.surface-variant;
            Text {
                width: parent.width;
                height: parent.height;
                text: root.entry.qty;
                color: Theme.muted;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;
            Text {
                text: root.entry.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 500;
                overflow: elide;
            }
            Text {
                text: root.entry.detail;
                color: Theme.muted;
                font-size: Theme.font-size-body;
                overflow: elide;
            }
        }

        VerticalLayout {
            alignment: center;
            Text {
                text: root.entry.price;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 600;
            }
        }
    }
}

component TotalRow inherits Rectangle {
    in property <string> label;
    in property <string> amount;
    in property <bool> emphasized: false;

    horizontal-stretch: 1;
    height: 28px;

    HorizontalLayout {
        Text {
            text: root.label;
            color: root.emphasized ? Theme.on-surface : Theme.muted;
            font-size: root.emphasized ? Theme.font-size-body-large : Theme.font-size-body;
            font-weight: root.emphasized ? 600 : 400;
            horizontal-stretch: 1;
            vertical-alignment: center;
        }
        Text {
            text: root.amount;
            color: root.emphasized ? Theme.primary : Theme.on-surface;
            font-size: root.emphasized ? Theme.font-size-title : Theme.font-size-body;
            font-weight: root.emphasized ? 600 : 500;
            vertical-alignment: center;
        }
    }
}

export component CheckoutPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <[OrderLineItem]> items: [
        { name: "Slint Mobile Components", detail: "1-year license", qty: 1, price: "$199.00" },
        { name: "Source access pack",      detail: "+ private fork",  qty: 1, price: "$49.00"  },
        { name: "Annual support",          detail: "Up to 5 seats",   qty: 1, price: "$99.00"  },
    ];
    in property <string> ship-name: "Petra Lindquist";
    in property <string> ship-address: "Vasagatan 12, 113 20 Stockholm";
    in property <string> payment-card: "Visa · ending 4242";
    in property <string> subtotal: "$347.00";
    in property <string> shipping-cost: "$8.00";
    in property <string> tax: "$28.40";
    in property <string> total: "$383.40";
    callback back-pressed();
    callback edit-shipping-pressed();
    callback change-payment-pressed();
    callback place-order-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "CHECKOUT";
            title-style: HeadingStyle.uppercase-spaced;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                alignment: start;
                padding-top: Theme.spacing-sm;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;

                SectionHeader { text: "ITEMS"; }
                Rectangle {
                    horizontal-stretch: 1;
                    HorizontalLayout {
                        padding-left: Theme.spacing-md;
                        padding-right: Theme.spacing-md;
                        Card {
                            VerticalLayout {
                                spacing: 0;
                                for entry[idx] in root.items: VerticalLayout {
                                    spacing: 0;
                                    LineItem { entry: entry; }
                                    if idx < root.items.length - 1: Divider { }
                                }
                            }
                        }
                    }
                }

                SectionHeader { text: "SHIPPING TO"; }
                ListItem {
                    title: root.ship-name;
                    subtitle: root.ship-address;
                    trailing-icon: @image-url("@mobile-components/icons/chevron-right.svg");
                    clicked => { root.edit-shipping-pressed(); }
                }

                SectionHeader { text: "PAYMENT"; }
                ListItem {
                    title: root.payment-card;
                    trailing-icon: @image-url("@mobile-components/icons/chevron-right.svg");
                    clicked => { root.change-payment-pressed(); }
                }

                SectionHeader { text: "TOTAL"; }
                Rectangle {
                    horizontal-stretch: 1;
                    HorizontalLayout {
                        padding-left: Theme.spacing-md;
                        padding-right: Theme.spacing-md;
                        Card {
                            VerticalLayout {
                                spacing: Theme.spacing-xs;
                                TotalRow { label: "Subtotal"; amount: root.subtotal; }
                                TotalRow { label: "Shipping"; amount: root.shipping-cost; }
                                TotalRow { label: "Tax";      amount: root.tax; }
                                Divider { }
                                TotalRow { label: "Total"; amount: root.total; emphasized: true; }
                            }
                        }
                    }
                }
            }
        }

        BottomBar {
            HorizontalLayout {
                padding: Theme.spacing-md;
                MobileButton {
                    text: "Place order · " + root.total;
                    primary: true;
                    clicked => { root.place-order-pressed(); }
                }
            }
        }
    }
}
