// StoreLocatorPage
// =====================================================================
//
// Find a physical store. Demonstrates the search-bar + `SettingRow`
// list pattern — each result obeys the SAME 56 px floor, 32 px leading
// tile, and 16 px gutters, so locations line up no matter how long the
// address subtitle is.
//
// What this screen does
//   - AppBar "Stores" + back + search trailing icon.
//   - Top search field (TextField inside a FormField with no label).
//   - NEARBY FormSection containing 5 store SettingRows; each one has
//       - leading icon = home.svg tinted Tone.info,
//       - title  = "<store name> · <neighbourhood>",
//       - subtitle = "<address> · <distance> · open until <time>",
//       - trailing = chevron.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MapEmbed, Tile, Layer } from "@mapping/map.slint";
import { ScrollView } from "std-widgets.slint";

export component StoreLocatorPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> query;

    callback back-pressed();
    callback search-pressed();
    callback store-pressed(string);

    // Map camera — bind from Rust via slint_mapping::MapController, or
    // leave at defaults for a static demo. A small map strip sits between
    // the AppBar and the search field to show the locations on a map.
    in-out property <float> map-latitude: 51.5074;
    in-out property <float> map-longitude: -0.1276;
    in-out property <float> map-zoom: 13.0;
    in property <[Tile]> map-tiles;
    in property <[Layer]> map-layers;
    callback map-pan(length, length);
    callback map-zoom-by(float, length, length);
    out property <length> map-viewport-width: map.width;
    out property <length> map-viewport-height: map.height;

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Stores";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/search.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.search-pressed(); }
        }

        // ----- Map strip -----------------------------------------------
        Rectangle {
            height: 220px;
            background: Theme.surface-2;
            clip: true;

            map := MapEmbed {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                latitude <=> root.map-latitude;
                longitude <=> root.map-longitude;
                zoom <=> root.map-zoom;
                tiles: root.map-tiles;
                layers: root.map-layers;
                pan(dx, dy) => { root.map-pan(dx, dy); }
                zoom-by(d, ax, ay) => { root.map-zoom-by(d, ax, ay); }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                // alignment: start: pin children at the top, let the
                // ScrollView handle overflow. `stretch` distributes
                // leftover space into each child, which inflated the
                // search TextField into a tall textarea-sized box.
                alignment: start;

                // ----- Search ------------------------------------------
                FormField {
                    TextField {
                        placeholder: "Search city or postcode";
                        text <=> root.query;
                    }
                }

                // ----- NEARBY ------------------------------------------
                FormSection {
                    title: "NEARBY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · Sablon";
                        subtitle: "Rue Lebeau 14 · 1.2 km · open until 19:00";
                        clicked => { root.store-pressed("sablon"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · Châtelain";
                        subtitle: "Place du Châtelain 3 · 1.8 km · open until 20:00";
                        clicked => { root.store-pressed("chatelain"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · Flagey";
                        subtitle: "Place Eugène Flagey 22 · 2.4 km · open until 18:00";
                        clicked => { root.store-pressed("flagey"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · Saint-Gilles";
                        subtitle: "Chaussée de Waterloo 88 · 3.1 km · open until 19:30";
                        clicked => { root.store-pressed("saint-gilles"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · Schaerbeek";
                        subtitle: "Avenue Louis Bertrand 41 · 4.7 km · open until 18:00";
                        clicked => { root.store-pressed("schaerbeek"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
