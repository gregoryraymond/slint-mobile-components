// ProductDetailPage
// =====================================================================
//
// E-commerce single-product screen — hero image + alternates + meta +
// variant pickers + sticky Add-to-cart. The canonical Shopify /
// Amazon-style product surface. Demonstrates:
//
//   - Full-width hero image area (200 px tall) with translucent back
//     and heart buttons overlaying, plus a small image-counter pill
//     bottom-right ("1 / 5") to telegraph that the hero is swipeable.
//   - Inline alternate-thumbnail strip below the hero so the user can
//     skim variants without entering the full-screen gallery.
//   - Variant pickers as `Chip` strips (size + colour) where the
//     selected chip carries `selected: true`.
//   - "Frequently bought together" mini horizontal card rail.
//   - Sticky bottom Add-to-cart with a quantity stepper inline.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { Stepper } from "@mobile-components/stepper.slint";
import { ScrollView } from "std-widgets.slint";

// Star-rating row — 5 stars, the leading `filled` count painted in
// warning tone, the rest in muted; trailing review count text.
component StarRating inherits Rectangle {
    in property <int> filled: 4;
    in property <string> review-count: "238";

    HorizontalLayout {
        spacing: 2px;
        alignment: start;
        for index in 5 : VerticalLayout {
            alignment: center;
            Image {
                width: 14px;
                height: 14px;
                source: @image-url("@mobile-components/icons/star.svg");
                colorize: index < root.filled ? Theme.accent-warning : Theme.muted;
                image-fit: contain;
            }
        }
        Rectangle { width: Theme.spacing-xs; }
        Text {
            text: root.review-count + " reviews";
            color: Theme.muted;
            font-size: Theme.font-size-caption;
            vertical-alignment: center;
        }
    }
}

// "Frequently bought together" mini card — 120 px wide product card.
component BundleCard inherits Rectangle {
    in property <string> name;
    in property <string> price;
    in property <brush> thumb-fill;

    width: 128px;
    height: 168px;

    VerticalLayout {
        spacing: Theme.spacing-xs;
        Rectangle {
            height: 100px;
            background: root.thumb-fill;
            border-radius: Theme.radius-md;
            clip: true;
        }
        Text {
            text: root.name;
            color: Theme.on-surface;
            font-size: Theme.font-size-caption;
            font-weight: 600;
            wrap: word-wrap;
            overflow: elide;
        }
        Text {
            text: root.price;
            color: Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 700;
        }
    }
}

export component ProductDetailPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> brand: "PATAGONIA";
    in property <string> name: "Houdini windbreaker — slate blue";
    in property <string> price: "$129.00";
    in property <string> old-price: "$149.00";
    in property <string> description:
        "A go-anywhere shell that packs into its own pocket. Recycled ripstop nylon, DWR-finished, weighs under 100 g. Sized for layering over a fleece.";
    in property <int> rating-filled: 4;
    in property <string> reviews: "238";
    in property <int> image-count: 5;
    in property <int> current-image: 1;
    in-out property <int> qty: 1;
    callback back-pressed();
    callback heart-pressed();
    callback add-to-cart-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Hero image with overlays -----
        Rectangle {
            height: 280px;
            background: @linear-gradient(135deg, #506b8e 0%, #1f2a3b 100%);
            clip: true;

            // Back button (translucent disc).
            Rectangle {
                x: Theme.spacing-md;
                y: Theme.spacing-md;
                width: 40px;
                height: 40px;
                border-radius: self.width / 2;
                background: #00000066;
                Image {
                    width: 20px;
                    height: 20px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/arrow-left.svg");
                    colorize: #ffffff;
                    image-fit: contain;
                }
                TouchArea {
                    clicked => { root.back-pressed(); }
                }
            }
            // Heart button.
            Rectangle {
                x: parent.width - self.width - Theme.spacing-md;
                y: Theme.spacing-md;
                width: 40px;
                height: 40px;
                border-radius: self.width / 2;
                background: #00000066;
                Image {
                    width: 20px;
                    height: 20px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/heart.svg");
                    colorize: #ffffff;
                    image-fit: contain;
                }
                TouchArea {
                    clicked => { root.heart-pressed(); }
                }
            }
            // Image-counter pill.
            Rectangle {
                x: parent.width - self.width - Theme.spacing-md;
                y: parent.height - self.height - Theme.spacing-md;
                width: counter-text.preferred-width + 16px;
                height: 24px;
                border-radius: Theme.radius-md;
                background: #00000099;
                counter-text := Text {
                    text: root.current-image + " / " + root.image-count;
                    color: Theme.on-primary;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }

        // ----- Alternate thumbnails strip -----
        HorizontalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: @linear-gradient(135deg, #506b8e 0%, #1f2a3b 100%);
                border-width: 2px;
                border-color: Theme.primary;
            }
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: @linear-gradient(135deg, #6b8e50 0%, #2a3b1f 100%);
            }
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: @linear-gradient(135deg, #8e506b 0%, #3b1f2a 100%);
            }
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: @linear-gradient(135deg, #8e8e50 0%, #3b3b1f 100%);
            }
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-sm;
                background: @linear-gradient(135deg, #506b6b 0%, #1f2a2a 100%);
            }
        }

        // ----- Meta -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-xs;

            Text {
                text: root.brand;
                color: Theme.muted;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1px;
            }
            Heading {
                text: root.name;
                style: HeadingStyle.plex-medium;
                font-family: "Fraunces 9pt";
                font-size: 26px;
                font-weight: 400;
                wrap: word-wrap;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-xs;
                Text {
                    text: root.price;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-headline;
                    font-weight: 700;
                }
                VerticalLayout {
                    alignment: end;
                    padding-bottom: Theme.spacing-xs;
                    Text {
                        text: root.old-price;
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        // Strike-through approximation handled below.
                    }
                }
                Rectangle {
                    width: save-text.preferred-width + 14px;
                    height: 22px;
                    border-radius: 4px;
                    background: Theme.accent-success;
                    save-text := Text {
                        text: "SAVE 13%";
                        color: Theme.on-primary;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
                Rectangle { horizontal-stretch: 1; }
            }
            StarRating {
                filled: root.rating-filled;
                review-count: root.reviews;
            }
            Text {
                text: root.description;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
        }

        // ----- Variant pickers -----
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            Text {
                text: "Size";
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Chip { label: "XS"; }
                Chip { label: "S"; }
                Chip { label: "M"; selected: true; }
                Chip { label: "L"; }
                Chip { label: "XL"; }
            }
            Rectangle { height: Theme.spacing-xs; }
            Text {
                text: "Colour";
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Chip { label: "Slate blue"; selected: true; }
                Chip { label: "Forest"; }
                Chip { label: "Coral"; }
                Chip { label: "Sand"; }
            }
        }

        SectionHeader { text: "FREQUENTLY BOUGHT TOGETHER"; }
        ScrollView {
            height: 200px;
            horizontal-stretch: 1;
            viewport-width: 4 * 128px + 5 * Theme.spacing-sm;
            viewport-height: 184px;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                BundleCard {
                    name: "Capilene base layer";
                    price: "$45.00";
                    thumb-fill: @linear-gradient(135deg, #6b8e50 0%, #2a3b1f 100%);
                }
                BundleCard {
                    name: "Black hole 25L";
                    price: "$129.00";
                    thumb-fill: @linear-gradient(135deg, #3a3a3a 0%, #1a1a1a 100%);
                }
                BundleCard {
                    name: "Wool buff";
                    price: "$22.00";
                    thumb-fill: @linear-gradient(135deg, #8e506b 0%, #3b1f2a 100%);
                }
                BundleCard {
                    name: "Trail crew socks";
                    price: "$18.00";
                    thumb-fill: @linear-gradient(135deg, #506b8e 0%, #1f2a3b 100%);
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // ----- Sticky Add-to-cart footer -----
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: stretch;
                Stepper {
                    value <=> root.qty;
                    horizontal-stretch: 0;
                }
                MobileButton {
                    text: "Add to cart · " + root.price;
                    tone: Tone.info;
                    horizontal-stretch: 1;
                    clicked => { root.add-to-cart-pressed(); }
                }
            }
        }
    }
}
