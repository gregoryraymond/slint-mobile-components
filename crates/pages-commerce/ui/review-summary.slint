// ReviewSummaryPage
// =====================================================================
//
// Product / venue review aggregate page — the "tap All reviews" surface
// inside Amazon / Google Maps / Yelp / Steam. Sister to
// `WriteReviewPage` (composer). Demonstrates:
//
//   - Average-rating hero on the left + 5-bar distribution histogram on
//     the right (each bar tone-tinted so high-scores read green and
//     1-star bars read danger).
//   - Verified-buyers / photos-only / sentiment chip strip.
//   - Per-review card: author avatar + 5-star rating + author + tone-
//     tinted "VERIFIED PURCHASE" pill + body + helpful counter row.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";

// 5-star rating display.
component StarRow inherits Rectangle {
    in property <int> filled: 5;
    in property <length> size: 14px;
    in property <color> tint: Theme.accent-warning;

    HorizontalLayout {
        spacing: 2px;
        for index in 5 : Image {
            width: root.size;
            height: root.size;
            source: @image-url("@mobile-components/icons/star.svg");
            colorize: index < root.filled ? root.tint : Theme.surface-variant;
            image-fit: contain;
        }
    }
}

// One row in the distribution histogram (label + horizontal bar + count).
component DistroRow inherits Rectangle {
    in property <int> stars;
    in property <float> share;
    in property <int> count;
    in property <Tone> tone;

    horizontal-stretch: 1;
    height: 24px;

    HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            width: 32px;
            HorizontalLayout {
                alignment: start;
                spacing: 2px;
                Text {
                    text: root.stars;
                    color: Theme.on-surface;
                    font-size: 11px;
                    font-weight: 700;
                }
                Image {
                    width: 10px;
                    height: 10px;
                    source: @image-url("@mobile-components/icons/star.svg");
                    colorize: Theme.accent-warning;
                    image-fit: contain;
                    vertical-alignment: center;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Rectangle {
                height: 8px;
                background: Theme.surface-variant;
                border-radius: 4px;
                Rectangle {
                    x: 0;
                    y: 0;
                    width: parent.width * root.share;
                    height: parent.height;
                    background:
                          root.tone == Tone.success ? Theme.accent-success
                        : root.tone == Tone.warning ? Theme.accent-warning
                        : root.tone == Tone.danger  ? Theme.accent-danger
                        : root.tone == Tone.info    ? Theme.accent-info
                        : Theme.primary;
                    border-radius: 4px;
                }
            }
        }
        VerticalLayout {
            alignment: center;
            width: 44px;
            Text {
                text: root.count;
                color: Theme.muted;
                font-size: 11px;
                font-weight: 700;
                horizontal-alignment: right;
            }
        }
    }
}

// One review card.
component ReviewCard inherits Rectangle {
    in property <string> initials;
    in property <string> author;
    in property <int> stars;
    in property <string> when;
    in property <bool> verified: true;
    in property <string> title;
    in property <string> body;
    in property <int> helpful;

    horizontal-stretch: 1;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-sm;

        // Header row.
        HorizontalLayout {
            spacing: Theme.spacing-sm;
            alignment: stretch;
            VerticalLayout {
                alignment: center;
                Avatar {
                    fallback: root.initials;
                    size: 36px;
                }
            }
            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                spacing: 2px;
                HorizontalLayout {
                    spacing: Theme.spacing-xs;
                    Text {
                        text: root.author;
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    if root.verified: Rectangle {
                        width: vp-text.preferred-width + 12px;
                        height: 18px;
                        border-radius: 4px;
                        background: Theme.accent-success;
                        vp-text := Text {
                            text: "VERIFIED";
                            color: Theme.on-primary;
                            font-size: 9px;
                            font-weight: 800;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
                HorizontalLayout {
                    spacing: Theme.spacing-xs;
                    StarRow { filled: root.stars; size: 13px; }
                    Text {
                        text: "·  " + root.when;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                        vertical-alignment: center;
                    }
                }
            }
        }

        Text {
            text: root.title;
            color: Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 700;
        }
        Text {
            text: root.body;
            color: Theme.on-surface;
            font-size: Theme.font-size-body;
            wrap: word-wrap;
        }

        // Helpful counter row.
        HorizontalLayout {
            spacing: Theme.spacing-sm;
            padding-top: 2px;
            Rectangle {
                width: helpful-text.preferred-width + 24px;
                height: 28px;
                border-radius: 14px;
                background: Theme.surface-2;
                border-width: 1px;
                border-color: Theme.outline;
                helpful-text := Text {
                    text: "Helpful · " + root.helpful;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
            Text {
                text: "Report";
                color: Theme.muted;
                font-size: Theme.font-size-caption;
                font-weight: 600;
                vertical-alignment: center;
            }
        }
    }
}

export component ReviewSummaryPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> product: "Houdini windbreaker";
    in property <string> rating: "4.6";
    in property <int> rating-int: 4;
    in property <string> review-count: "238 reviews · 412 buyers";
    callback back-pressed();
    callback write-review-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Reviews";
            title-style: HeadingStyle.serif-display;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/pencil.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.write-review-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Hero: product + rating + distribution.
            Heading {
                text: root.product;
                style: HeadingStyle.serif-light;
            }
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                height: 160px;
                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    // Big number + stars.
                    VerticalLayout {
                        alignment: center;
                        spacing: 4px;
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: root.rating;
                                color: Theme.on-surface;
                                font-family: "Fraunces 9pt";
                                font-size: 64px;
                                font-weight: 300;
                                letter-spacing: -2px;
                            }
                        }
                        HorizontalLayout {
                            alignment: center;
                            StarRow { filled: root.rating-int; size: 14px; }
                        }
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: root.review-count;
                                color: Theme.muted;
                                font-size: 10px;
                                font-weight: 700;
                                letter-spacing: 0.3px;
                            }
                        }
                    }

                    // Distribution bars on the right.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 4px;
                        DistroRow { stars: 5; share: 0.68; count: 162; tone: Tone.success; }
                        DistroRow { stars: 4; share: 0.21; count: 50; tone: Tone.success; }
                        DistroRow { stars: 3; share: 0.06; count: 14; tone: Tone.warning; }
                        DistroRow { stars: 2; share: 0.03; count: 8; tone: Tone.danger; }
                        DistroRow { stars: 1; share: 0.02; count: 4; tone: Tone.danger; }
                    }
                }
            }

            // Filters.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Chip { label: "All"; selected: true; }
                Chip { label: "Verified · 218"; }
                Chip { label: "Photos · 64"; }
                Chip { label: "5★ · 162"; }
                Chip { label: "1★ · 4"; }
            }
        }

        SectionHeader { text: "HIGHLIGHTED REVIEWS"; }
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;

            ReviewCard {
                initials: "AR";
                author: "Anika Ravi";
                stars: 5;
                when: "2 days ago";
                verified: true;
                title: "Lives in my daypack now";
                body: "Lighter than I expected — packs into its own pocket and disappears in a daypack. DWR holds up in light rain; wouldn't trust it in a downpour. Sizing runs slim; I'd size up if you plan to layer.";
                helpful: 24;
            }
            ReviewCard {
                initials: "DV";
                author: "Devika Sharma";
                stars: 4;
                when: "1 week ago";
                verified: true;
                title: "Great wind, mediocre rain";
                body: "Cuts wind like a champ on the bike commute. Treated finish soaks through after 10 minutes of real rain — for that, look at the Torrentshell.";
                helpful: 8;
            }
            ReviewCard {
                initials: "MK";
                author: "Marco Kovač";
                stars: 2;
                when: "2 weeks ago";
                verified: false;
                title: "Cuff hooks fall off";
                body: "Returned after a month — the wrist cuff hooks had detached and the seam tape was peeling. Yours might be fine but mine wasn't QC'd well.";
                helpful: 3;
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Sticky write-a-review CTA.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                MobileButton {
                    text: "Write a review";
                    tone: Tone.info;
                    max-height: 48px;
                    clicked => { root.write-review-pressed(); }
                }
            }
        }
    }
}
