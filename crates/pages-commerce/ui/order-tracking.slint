// OrderTrackingPage
// =====================================================================
//
// Live shipping progress for one order. Demonstrates that a "timeline"
// is just a `FormSection` full of `SettingRow`s — each milestone row
// shares the SAME 56 px floor, the SAME 32 px tinted leading tile, and
// the SAME title/subtitle rhythm. No bespoke timeline widget.
//
// What this screen does
//   - AppBar "Order #2147" + back.
//   - Hero "map" Card — surface-2 background with centred "EN ROUTE"
//     placeholder text (no real map renderer).
//   - PROGRESS FormSection with 4 SettingRows (one per milestone).
//   - TOTALS FormSection with KeyValueRows (subtotal / shipping /
//     total).
//   - Two stacked action buttons at the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component OrderTrackingPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback contact-pressed();
    callback invoice-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Order #2147";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Hero map card -----------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Rectangle {
                        height: 168px;
                        background: Theme.surface-2;
                        border-radius: Theme.radius-md;
                        drop-shadow-blur: Theme.elevation-1-blur;
                        drop-shadow-color: Theme.elevation-1-color;
                        drop-shadow-offset-y: Theme.elevation-1-y;
                        clip: true;

                        VerticalLayout {
                            alignment: center;
                            spacing: Theme.spacing-xs;

                            Text {
                                text: "EN ROUTE";
                                color: Theme.on-surface;
                                font-size: Theme.font-size-headline;
                                font-weight: 700;
                                letter-spacing: 1px;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Arriving today, 16:00–18:00";
                                color: Theme.muted;
                                font-size: Theme.font-size-body;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // ----- Progress timeline -------------------------------
                FormSection {
                    title: "PROGRESS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "Order placed";
                        subtitle: "May 12 · 09:11";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "Picked, packed";
                        subtitle: "May 12 · 14:02";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        tone: Tone.info;
                        title: "Out for delivery";
                        subtitle: "May 13 · 08:45";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Estimated arrival";
                        subtitle: "Today, 16:00–18:00";
                    }
                }

                // ----- Totals -----------------------------------------
                FormSection {
                    title: "TOTALS";

                    KeyValueRow {
                        label: "Subtotal";
                        value: "€ 38.15";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Shipping";
                        value: "€  3.95";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Total";
                        value: "€ 42.10";
                        emphasis: true;
                    }
                }

                // ----- Actions -----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Contact courier";
                        clicked => { root.contact-pressed(); }
                    }
                    TextButton {
                        text: "View invoice";
                        clicked => { root.invoice-pressed(); }
                    }
                }
            }
        }
    }
}
