// OrderHistoryPage
// =====================================================================
//
// List of past orders, grouped by month. Demonstrates the
// `SettingRow` + `FormSection` alignment discipline applied to a
// commerce list: every order row shares the SAME 56 px floor, the
// SAME 32 px leading tile, the SAME 16 px gutters, so order titles
// line up no matter what status `Chip` sits on the right.
//
// What this screen does
//   - AppBar "Orders" + back arrow.
//   - SegmentedControl filter "All / Active / Delivered".
//   - Two month sections (FormSection title "MAY 2026" /
//     "APRIL 2026"), each containing a stack of SettingRows with:
//       - leading icon tile (queue/inbox) tinted by Tone,
//       - title  = merchant + #order-id,
//       - subtitle = "N items · €X.XX",
//       - trailing = status Chip + chevron.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component OrderHistoryPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> filter-index: 0;

    callback back-pressed();
    callback order-pressed(string);
    callback filter-changed(int);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Orders";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Filter -------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["All", "Active", "Delivered"];
                        selected-index <=> root.filter-index;
                        changed(i) => { root.filter-changed(i); }
                    }
                }

                // ----- MAY 2026 -----------------------------------------
                FormSection {
                    title: "MAY 2026";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee · #2147";
                        subtitle: "3 items · €42.10";
                        clicked => { root.order-pressed("2147"); }
                        Chip { label: "In transit"; selected: true; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Patagonia · #2138";
                        subtitle: "1 item · €129.00";
                        clicked => { root.order-pressed("2138"); }
                        Chip { label: "Delivered"; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.warning;
                        title: "Tartine Manufactory · #2131";
                        subtitle: "5 items · €34.50";
                        clicked => { root.order-pressed("2131"); }
                        Chip { label: "Processing"; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- APRIL 2026 ---------------------------------------
                FormSection {
                    title: "APRIL 2026";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Atlas Coffee · #2099";
                        subtitle: "2 items · €28.50";
                        clicked => { root.order-pressed("2099"); }
                        Chip { label: "Delivered"; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Muji · #2087";
                        subtitle: "4 items · €76.30";
                        clicked => { root.order-pressed("2087"); }
                        Chip { label: "Delivered"; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Uniqlo · #2061";
                        subtitle: "3 items · €54.00";
                        clicked => { root.order-pressed("2061"); }
                        Chip { label: "Delivered"; }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
