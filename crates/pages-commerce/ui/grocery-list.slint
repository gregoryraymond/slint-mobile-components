// GroceryListPage
// =====================================================================
//
// Shared grocery list — AnyList / Bring! / Apple Reminders-grocery
// style. Distinct from `TaskListPage` (to-dos) and `MealLogPage`
// (calorie tracking). Demonstrates a collaborative checklist:
//
//   - Progress hero: "8 of 21 in cart" + a thin progress bar + the
//     two collaborators' avatars.
//   - Aisle-grouped SectionHeaders (Produce / Dairy / Pantry / …).
//   - Per-item row: checkbox + name + qty pill + assignee avatar.
//     Checked items dim + strike-through (re-using the TaskListPage
//     pattern).
//   - "Add item" inline row at the bottom of the last section + a Fab
//     for quick-add.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Checkbox } from "@mobile-components/checkbox.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Fab } from "@mobile-components/button.slint";

// One grocery item row.
component GroceryRow inherits Rectangle {
    in property <string> name;
    in property <string> qty;
    in property <string> assignee;
    in-out property <bool> done: false;
    callback toggled();

    horizontal-stretch: 1;
    min-height: 52px;
    opacity: root.done ? 0.5 : 1.0;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;

        VerticalLayout {
            alignment: center;
            Checkbox {
                checked: root.done;
                toggled => {
                    root.done = self.checked;
                    root.toggled();
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Rectangle {
                height: 22px;
                Text {
                    text: root.name;
                    color: root.done ? Theme.muted : Theme.on-surface;
                    font-size: Theme.font-size-body;
                    font-weight: 500;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
                if root.done: Rectangle {
                    x: 0;
                    y: parent.height / 2;
                    width: parent.width;
                    height: 1px;
                    background: Theme.muted;
                }
            }
        }

        // Qty pill.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: qty-text.preferred-width + 14px;
                height: 20px;
                border-radius: 10px;
                background: Theme.surface-variant;
                qty-text := Text {
                    text: root.qty;
                    color: Theme.muted;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 0.3px;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }

        // Assignee avatar.
        VerticalLayout {
            alignment: center;
            Avatar {
                fallback: root.assignee;
                size: 24px;
            }
        }
    }
}

export component GroceryListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> list-name: "weekend shop";
    callback back-pressed();
    callback share-pressed();
    callback add-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.list-name;
            title-style: HeadingStyle.lowercase-soft;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        // Progress hero.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-1-blur;
            drop-shadow-color: Theme.elevation-1-color;
            drop-shadow-offset-y: Theme.elevation-1-y;
            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: stretch;
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 2px;
                        Heading {
                            text: "8 of 21 in cart";
                            style: HeadingStyle.serif-display;
                            color: Theme.on-surface;
                            font-size: 22px;
                        }
                        Text {
                            text: "Shared with Léa · last edited 4 min ago";
                            color: Theme.muted;
                            font-size: Theme.font-size-caption;
                        }
                    }
                    HorizontalLayout {
                        spacing: 4px;
                        alignment: end;
                        Avatar { fallback: "GR"; size: 32px; }
                        Avatar { fallback: "LE"; size: 32px; }
                    }
                }
                Rectangle {
                    height: 6px;
                    background: Theme.surface-variant;
                    border-radius: 3px;
                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width * 0.38;
                        height: parent.height;
                        background: Theme.accent-success;
                        border-radius: 3px;
                    }
                }
            }
        }

        SectionHeader { text: "PRODUCE"; }
        GroceryRow { name: "Avocados"; qty: "×4"; assignee: "GR"; done: true; }
        Divider { }
        GroceryRow { name: "Baby spinach"; qty: "1 bag"; assignee: "LE"; }
        Divider { }
        GroceryRow { name: "Lemons"; qty: "×6"; assignee: "GR"; done: true; }
        Divider { }
        GroceryRow { name: "Cherry tomatoes"; qty: "2 punnets"; assignee: "LE"; }

        SectionHeader { text: "DAIRY & EGGS"; }
        GroceryRow { name: "Whole milk"; qty: "2 L"; assignee: "GR"; done: true; }
        Divider { }
        GroceryRow { name: "Greek yogurt"; qty: "1 tub"; assignee: "LE"; }
        Divider { }
        GroceryRow { name: "Pasture eggs"; qty: "1 dozen"; assignee: "GR"; }
        Divider { }
        GroceryRow { name: "Aged cheddar"; qty: "200 g"; assignee: "LE"; done: true; }

        SectionHeader { text: "PANTRY"; }
        GroceryRow { name: "Sourdough loaf"; qty: "×1"; assignee: "GR"; }
        Divider { }
        GroceryRow { name: "Olive oil"; qty: "500 ml"; assignee: "LE"; done: true; }
        Divider { }
        GroceryRow { name: "Quinoa"; qty: "1 kg"; assignee: "GR"; }
        Divider { }
        // Inline add-item row.
        Rectangle {
            min-height: 48px;
            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 22px;
                        height: 22px;
                        border-radius: 6px;
                        border-width: 1px;
                        border-color: Theme.outline;
                        background: transparent;
                        Image {
                            width: 12px;
                            height: 12px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("@mobile-components/icons/plus.svg");
                            colorize: Theme.accent-info;
                            image-fit: contain;
                        }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: "Add item to Pantry…";
                        color: Theme.accent-info;
                        font-size: Theme.font-size-body;
                        font-weight: 600;
                    }
                }
            }
            TouchArea {
                clicked => { root.add-pressed(); }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }

    Fab {
        x: root.width - self.width - Theme.spacing-md;
        y: root.height - self.height - Theme.spacing-md;
        accessible-label: "Quick add item";
        clicked => { root.add-pressed(); }
    }
}
