// WriteReviewPage
// =====================================================================
//
// User writes a review of a recently-purchased product. Demonstrates
// FormField + SettingRow + FormSection composed together: every input
// shares the SAME 16 px gutter, the SAME label rhythm, and the SAME
// helper-text baseline.
//
// What this screen does
//   - AppBar with back + "Post" trailing TextButton.
//   - Product summary Card (title = product name, subtitle = "merchant
//     · variant").
//   - RATING FormSection — one SettingRow "Overall" with a 5-star
//     trailing strip (4 stars filled with accent-warning, 1 muted).
//   - "Title" FormField (TextField).
//   - "Review" FormField (TextField + min-character helper).
//   - RECOMMEND FormSection — two SettingRows each with a
//     MobileSwitch in the trailing slot.
//   - Primary "Post review" MobileButton at the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Card } from "@mobile-components/card.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component WriteReviewPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> review-title;
    in-out property <string> review-body;
    in-out property <bool> would-buy-again: true;
    in-out property <bool> allow-attribution: false;

    callback back-pressed();
    callback post-pressed();
    callback submit-pressed();
    callback star-pressed(int);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Write a review";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Product summary --------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        title: "Single-origin Yirgacheffe · 250 g";
                        subtitle: "Atlas Coffee · House blend";
                    }
                }

                // ----- RATING -----------------------------------------
                FormSection {
                    title: "RATING";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Overall";
                        subtitle: "Tap a star";
                        HorizontalLayout {
                            spacing: Theme.spacing-xs;
                            alignment: end;

                            Image {
                                width: 18px;
                                height: 18px;
                                source: @image-url("@mobile-components/icons/star.svg");
                                colorize: Theme.accent-warning;
                                image-fit: contain;
                                TouchArea { clicked => { root.star-pressed(1); } }
                            }
                            Image {
                                width: 18px;
                                height: 18px;
                                source: @image-url("@mobile-components/icons/star.svg");
                                colorize: Theme.accent-warning;
                                image-fit: contain;
                                TouchArea { clicked => { root.star-pressed(2); } }
                            }
                            Image {
                                width: 18px;
                                height: 18px;
                                source: @image-url("@mobile-components/icons/star.svg");
                                colorize: Theme.accent-warning;
                                image-fit: contain;
                                TouchArea { clicked => { root.star-pressed(3); } }
                            }
                            Image {
                                width: 18px;
                                height: 18px;
                                source: @image-url("@mobile-components/icons/star.svg");
                                colorize: Theme.accent-warning;
                                image-fit: contain;
                                TouchArea { clicked => { root.star-pressed(4); } }
                            }
                            Image {
                                width: 18px;
                                height: 18px;
                                source: @image-url("@mobile-components/icons/star.svg");
                                colorize: Theme.muted;
                                image-fit: contain;
                                TouchArea { clicked => { root.star-pressed(5); } }
                            }
                        }
                    }
                }

                // ----- Title field ------------------------------------
                FormField {
                    label: "Title";
                    TextField {
                        placeholder: "Short and punchy";
                        text <=> root.review-title;
                    }
                }

                // ----- Review body field ------------------------------
                FormField {
                    label: "Review";
                    helper: "Min 30 characters.";
                    TextField {
                        placeholder: "What did you love? What could be better?";
                        text <=> root.review-body;
                    }
                }

                // ----- RECOMMEND --------------------------------------
                FormSection {
                    title: "RECOMMEND";

                    SettingRow {
                        title: "Would you buy this again?";
                        subtitle: "Helps other shoppers decide.";
                        MobileSwitch { checked <=> root.would-buy-again; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Allow public attribution";
                        subtitle: "Show your display name next to the review.";
                        MobileSwitch { checked <=> root.allow-attribution; }
                    }
                }

                // ----- Submit ------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Post review";
                        clicked => { root.submit-pressed(); }
                    }
                    TextButton {
                        text: "Post";
                        clicked => { root.post-pressed(); }
                    }
                }
            }
        }
    }
}
