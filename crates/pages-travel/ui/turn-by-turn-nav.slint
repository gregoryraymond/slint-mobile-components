// TurnByTurnNavPage
// =====================================================================
//
// Active turn-by-turn navigation overlay. The page is map-first — no
// AppBar — with a bright primary-tinted maneuver banner at the top
// telling the driver the next instruction, a large map area below it,
// and a 3-up StatTile bar + 3-up control bar pinned at the bottom for
// trip stats and mute / alt-route / end controls.
//
// What this screen does
//   - Transparent overlay strip carries a single back / close button
//     pinned over the maneuver banner.
//   - Hero maneuver banner: large arrow + "300 m" / "Turn left onto Rue
//     de la Loi" caption, filled with Theme.primary.
//   - Map placeholder: a surface-3 Rectangle that fills the rest of the
//     vertical space.
//   - Stats bar: 3 StatTiles ("8 MIN" / "5.2 KM" / "16:24") — uses the
//     shared `StatTile` so each column is equal width and the value
//     baselines line up.
//   - Controls bar: 3 round icon buttons (mute / alt routes / end) in a
//     centred row.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { MapEmbed, Tile, Layer } from "@mapping/map.slint";

// Round icon button used in the controls strip.
component NavIconButton inherits Rectangle {
    in property <image> icon;
    in property <Tone> tone: Tone.default;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    width: 48px;
    height: 48px;
    border-radius: self.width / 2;
    background:
          touch.pressed                ? Theme.surface-pressed
        : root.tone == Tone.danger     ? Theme.accent-danger
        :                                Theme.surface-2;
    animate background { duration: Theme.motion-fast; }

    Image {
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.tone == Tone.danger ? Theme.on-primary : Theme.on-surface;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TurnByTurnNavPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback close-pressed();
    callback mute-pressed();
    callback alt-routes-pressed();
    callback end-pressed();

    // Map camera — bind from Rust via slint_mapping::MapController, or
    // leave at defaults for a static demo.
    in-out property <float> map-latitude: 51.5074;
    in-out property <float> map-longitude: -0.1276;
    in-out property <float> map-zoom: 13.0;
    in property <[Tile]> map-tiles;
    in property <[Layer]> map-layers;
    callback map-pan(length, length);
    callback map-zoom-by(float, length, length);
    out property <length> map-viewport-width: map.width;
    out property <length> map-viewport-height: map.height;

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Maneuver banner (hero) ---------------------------------
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-lg;
            padding-bottom: Theme.spacing-sm;

            Rectangle {
                background: Theme.primary;
                border-radius: Theme.radius-lg;
                horizontal-stretch: 1;
                min-height: 128px;
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;

                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    // Maneuver glyph.
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 56px;
                            height: 56px;
                            source: @image-url("@mobile-components/icons/arrow-left.svg");
                            colorize: Theme.on-primary;
                            image-fit: contain;
                        }
                    }

                    // Distance + instruction.
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: Theme.spacing-xs;

                        Text {
                            text: "300 m";
                            color: Theme.on-primary;
                            font-size: 32px;
                            font-weight: 800;
                        }
                        Text {
                            text: "Turn left onto Rue de la Loi";
                            color: Theme.on-primary;
                            font-size: Theme.font-size-body;
                            font-weight: 500;
                            wrap: word-wrap;
                        }
                    }

                    // Close button.
                    VerticalLayout {
                        alignment: start;
                        Rectangle {
                            width: 36px;
                            height: 36px;
                            border-radius: self.width / 2;
                            background: close-touch.pressed ? Theme.surface-pressed : #ffffff33;

                            Image {
                                width: 16px;
                                height: 16px;
                                x: (parent.width - self.width) / 2;
                                y: (parent.height - self.height) / 2;
                                source: @image-url("@mobile-components/icons/close.svg");
                                colorize: Theme.on-primary;
                                image-fit: contain;
                            }
                            close-touch := TouchArea {
                                clicked => { root.close-pressed(); }
                            }
                        }
                    }
                }
            }
        }

        // ----- Map area (fills remaining space) -----------------------
        Rectangle {
            background: Theme.surface-3;
            vertical-stretch: 1;
            clip: true;

            map := MapEmbed {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                latitude <=> root.map-latitude;
                longitude <=> root.map-longitude;
                zoom <=> root.map-zoom;
                tiles: root.map-tiles;
                layers: root.map-layers;
                pan(dx, dy) => { root.map-pan(dx, dy); }
                zoom-by(d, ax, ay) => { root.map-zoom-by(d, ax, ay); }
            }
        }

        // ----- Stats bar ----------------------------------------------
        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-md;

            StatTile {
                value: "8 MIN";
                label: "ETA";
            }
            StatTile {
                value: "5.2 KM";
                label: "DISTANCE";
            }
            StatTile {
                value: "16:24";
                label: "ARRIVAL";
            }
        }

        // ----- Controls bar -------------------------------------------
        HorizontalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-lg;
            alignment: center;

            NavIconButton {
                icon: @image-url("@mobile-components/icons/pause.svg");
                clicked => { root.mute-pressed(); }
            }
            NavIconButton {
                icon: @image-url("@mobile-components/icons/queue.svg");
                clicked => { root.alt-routes-pressed(); }
            }
            NavIconButton {
                icon: @image-url("@mobile-components/icons/close.svg");
                tone: Tone.danger;
                clicked => { root.end-pressed(); }
            }
        }
    }
}
