// CarpoolSearchPage
// =====================================================================
//
// Carpool / BlaBlaCar-style rideshare search-and-pick screen. Distinct
// from `RideShareBookingPage` (full-bleed-map taxi booking) and
// `FlightSearchPage` (multi-leg air search). Pure showcase of the
// `FormSection` + `SettingRow` / `KeyValueRow` alignment primitives —
// every list row on the page (origin / destination, trip parameters,
// match list) goes through ONE of those components so leading tiles,
// titles, subtitles and trailing values sit on identical baselines.
//
// What this screen does
//   - AppBar "Find a ride" with back leading.
//   - WHERE section: from + to SettingRows (green / red pin tiles), and
//     a tiny "swap" SettingRow no title between them.
//   - WHEN section: date / time / passengers KeyValueRows.
//   - MATCHES section: 5 SettingRows, one per matching driver, each
//     showing avatar-substitute tile + driver name + trip blurb + fare.
//   - Bottom: primary "Search again" + text-button "Save search".

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component CarpoolSearchPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback swap-pressed();
    callback edit-when-pressed(string);
    callback match-pressed(string);
    callback search-again-pressed();
    callback save-search-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Find a ride";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- WHERE ------------------------------------------------
                FormSection {
                    title: "WHERE";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.success;
                        title: "From";
                        Text {
                            text: "Sablon";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        title: "Swap";
                        clicked => { root.swap-pressed(); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.danger;
                        title: "To";
                        Text {
                            text: "Louvain-la-Neuve";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }

                // ----- WHEN -------------------------------------------------
                FormSection {
                    title: "WHEN";

                    KeyValueRow {
                        label: "Date";
                        value: "Sat, May 17";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Time";
                        value: "after 09:00";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Passengers";
                        value: "1 adult";
                    }
                }

                // ----- MATCHES ----------------------------------------------
                FormSection {
                    title: "MATCHES";
                    caption: "5 drivers leaving within the next two hours.";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Marie · BMW i3";
                        subtitle: "departs 09:30 · arrives 10:25 · 3 seats";
                        clicked => { root.match-pressed("marie"); }
                        Text {
                            text: "€ 8.50";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "Tom · Tesla Model 3";
                        subtitle: "departs 09:45 · arrives 10:40 · 2 seats";
                        clicked => { root.match-pressed("tom"); }
                        Text {
                            text: "€ 9.00";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "Sofia · VW Golf";
                        subtitle: "departs 10:00 · arrives 10:55 · 1 seat";
                        clicked => { root.match-pressed("sofia"); }
                        Text {
                            text: "€ 7.50";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "Karim · Renault Zoé";
                        subtitle: "departs 10:15 · arrives 11:10 · 3 seats";
                        clicked => { root.match-pressed("karim"); }
                        Text {
                            text: "€ 8.00";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Anne · Citroën C3";
                        subtitle: "departs 10:30 · arrives 11:25 · 2 seats";
                        clicked => { root.match-pressed("anne"); }
                        Text {
                            text: "€ 7.00";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                }

                // ----- Actions ----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Search again";
                        clicked => { root.search-again-pressed(); }
                    }
                    TextButton {
                        text: "Save search";
                        clicked => { root.save-search-pressed(); }
                    }
                }
            }
        }
    }
}
