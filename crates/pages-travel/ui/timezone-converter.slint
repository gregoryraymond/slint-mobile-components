// TimezoneConverterPage
// =====================================================================
//
// World-clock / timezone-converter screen. Pure showcase of the
// `FormSection` + `SettingRow` discipline — the reference time and the
// six world cities all use the SAME SettingRow shape, so leading icon
// tiles, title baselines, subtitle captions, and trailing value text
// line up in tight columns regardless of city name length.
//
// What this screen does
//   - AppBar "Time zones" with back leading and a + trailing.
//   - REFERENCE TIME section: a single SettingRow showing "Now in
//     Brussels" / "Saturday, May 17" / "15:42 CEST" as trailing big text.
//   - A library `Slider` below the section that lets the user drag a
//     reference time across all zones; reading the slider's value would
//     ordinarily shift the values below.
//   - WORLD section: six SettingRows, one per city, identical leading
//     tile + title + subtitle + trailing value. Cities span tones
//     (info / success / warning / danger / default) so the leading-tile
//     colours read as a visual key.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Slider } from "@mobile-components/slider.slint";
import { ScrollView } from "std-widgets.slint";

export component TimezoneConverterPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <float> reference-position: 0.64;

    callback back-pressed();
    callback add-zone-pressed();
    callback city-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Time zones";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.add-zone-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- REFERENCE TIME -------------------------------------
                FormSection {
                    title: "REFERENCE TIME";

                    SettingRow {
                        title: "Now in Brussels";
                        subtitle: "Saturday, May 17";
                        Text {
                            text: "15:42 CEST";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                }

                // Slider for shifting the reference time across all zones.
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    Slider {
                        value <=> root.reference-position;
                    }
                    Text {
                        text: "Drag to preview across all zones.";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }

                // ----- WORLD ----------------------------------------------
                FormSection {
                    title: "WORLD";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Tokyo";
                        subtitle: "tomorrow · JST";
                        clicked => { root.city-pressed("tokyo"); }
                        Text {
                            text: "22:42";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.success;
                        title: "Sydney";
                        subtitle: "tomorrow · AEST";
                        clicked => { root.city-pressed("sydney"); }
                        Text {
                            text: "23:42";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.warning;
                        title: "San Francisco";
                        subtitle: "today · PDT";
                        clicked => { root.city-pressed("sf"); }
                        Text {
                            text: "06:42";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.danger;
                        title: "New York";
                        subtitle: "today · EDT";
                        clicked => { root.city-pressed("nyc"); }
                        Text {
                            text: "09:42";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        title: "London";
                        subtitle: "today · BST";
                        clicked => { root.city-pressed("london"); }
                        Text {
                            text: "14:42";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Bangalore";
                        subtitle: "today · IST";
                        clicked => { root.city-pressed("bangalore"); }
                        Text {
                            text: "19:12";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
