// RideShareBookingPage
// =====================================================================
//
// Uber / Lyft-style ride booking — full-bleed map with origin /
// destination pins + a bottom panel containing destination input,
// ride-tier cards, and a Confirm CTA. Demonstrates:
//
//   - Map placeholder via the existing `icons/map-bg.svg` (consistent
//     with `MapPage`), with two anchored pin glyphs.
//   - Bottom-anchored "info card" containing the destination input
//     pill ("Pickup · Home" → "Destination · Patagonia store"), and
//     a vertical stack of ride-tier rows where one tier is visually
//     selected (info-tone outline + filled radio).
//   - Bottom sticky Confirm button.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { Avatar } from "@mobile-components/avatar.slint";

// One ride-tier row.
component TierRow inherits Rectangle {
    in property <string> name;
    in property <string> capacity;
    in property <string> eta;
    in property <string> price;
    in property <bool> selected: false;
    in property <color> car-color: Theme.on-surface;
    callback clicked();

    accessible-role: button;
    accessible-label: root.name;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-height: 72px;
    background: root.selected ? Theme.surface-2 : transparent;
    border-radius: Theme.radius-md;
    border-width: root.selected ? 1px : 0px;
    border-color: Theme.accent-info;

    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Car icon placeholder.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 56px;
                height: 40px;
                border-radius: 6px;
                background: root.car-color;
                // Stylised car silhouette via two stacked rectangles.
                Rectangle {
                    x: 8px;
                    y: 4px;
                    width: parent.width - 16px;
                    height: 16px;
                    border-radius: 4px;
                    background: #ffffff44;
                }
            }
        }

        // Name + capacity + eta.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                Text {
                    text: root.name;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body-large;
                    font-weight: root.selected ? 700 : 500;
                }
                Rectangle {
                    width: cap-text.preferred-width + 12px;
                    height: 18px;
                    border-radius: 4px;
                    background: Theme.surface-variant;
                    cap-text := Text {
                        text: root.capacity;
                        color: Theme.muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.3px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
            Text {
                text: root.eta;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }

        // Price + selected radio.
        VerticalLayout {
            alignment: center;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: end;
                Text {
                    text: root.price;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body-large;
                    font-weight: 700;
                    horizontal-alignment: right;
                }
                Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: 10px;
                    border-width: 2px;
                    border-color: root.selected ? Theme.accent-info : Theme.outline;
                    background: transparent;
                    if root.selected: Rectangle {
                        width: 10px;
                        height: 10px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        border-radius: 5px;
                        background: Theme.accent-info;
                    }
                }
            }
        }
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component RideShareBookingPage inherits Rectangle {
    in property <string> pickup: "Pickup · Home";
    in property <string> destination: "Patagonia · Hayes Valley";
    in-out property <int> selected-tier: 1;
    callback back-pressed();
    callback edit-destination-pressed();
    callback confirm-pressed();

    background: Theme.background;

    // Map (full-bleed; the bottom panel overlays).
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-variant;
        clip: true;
        Image {
            width: parent.width * 1.5;
            height: parent.height * 1.2;
            x: -parent.width * 0.25;
            y: -parent.height * 0.1;
            source: @image-url("@mobile-components/icons/map-bg.svg");
            image-fit: cover;
            colorize: Theme.muted;
            opacity: 0.4;
        }

        // Origin pin (top-left quadrant).
        Rectangle {
            x: parent.width * 0.32;
            y: parent.height * 0.28;
            width: 28px;
            height: 28px;
            border-radius: self.width / 2;
            background: Theme.primary;
            border-width: 4px;
            border-color: #ffffff;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: Theme.elevation-2-y;
        }
        // Destination pin (bottom-right quadrant).
        Rectangle {
            x: parent.width * 0.62;
            y: parent.height * 0.42;
            width: 36px;
            height: 36px;
            border-radius: self.width / 2;
            background: Theme.accent-danger;
            border-width: 4px;
            border-color: #ffffff;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: Theme.elevation-2-y;
            Image {
                width: 16px;
                height: 16px;
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                source: @image-url("@mobile-components/icons/pin.svg");
                colorize: #ffffff;
                image-fit: contain;
            }
        }
    }

    // Translucent back button.
    Rectangle {
        x: Theme.spacing-md;
        y: Theme.spacing-md + 24px;
        width: 40px;
        height: 40px;
        border-radius: self.width / 2;
        background: Theme.surface-1;
        drop-shadow-blur: Theme.elevation-1-blur;
        drop-shadow-color: Theme.elevation-1-color;
        drop-shadow-offset-y: Theme.elevation-1-y;
        Image {
            width: 20px;
            height: 20px;
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            source: @image-url("@mobile-components/icons/arrow-left.svg");
            colorize: Theme.on-surface;
            image-fit: contain;
        }
        TouchArea {
            clicked => { root.back-pressed(); }
        }
    }

    // Bottom panel.
    Rectangle {
        x: 0;
        y: root.height - self.height;
        width: parent.width;
        height: 460px;
        background: Theme.surface-2;
        border-top-left-radius: Theme.radius-lg;
        border-top-right-radius: Theme.radius-lg;
        drop-shadow-blur: Theme.elevation-2-blur;
        drop-shadow-color: Theme.elevation-2-color;
        drop-shadow-offset-y: -4px;
        clip: true;

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;

            // Drag handle.
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 36px;
                    height: 4px;
                    border-radius: 2px;
                    background: Theme.muted;
                    opacity: 0.5;
                }
            }

            // Pickup/destination stacked pills.
            VerticalLayout {
                spacing: 0;
                Rectangle {
                    background: Theme.surface-1;
                    border-top-left-radius: Theme.radius-md;
                    border-top-right-radius: Theme.radius-md;
                    height: 56px;
                    HorizontalLayout {
                        padding: Theme.spacing-md;
                        spacing: Theme.spacing-md;
                        alignment: stretch;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 12px;
                                height: 12px;
                                border-radius: 6px;
                                background: Theme.primary;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: root.pickup;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-body;
                                overflow: elide;
                            }
                        }
                    }
                }
                Rectangle {
                    height: 1px;
                    background: Theme.outline;
                }
                Rectangle {
                    background: Theme.surface-1;
                    border-bottom-left-radius: Theme.radius-md;
                    border-bottom-right-radius: Theme.radius-md;
                    height: 56px;
                    HorizontalLayout {
                        padding: Theme.spacing-md;
                        spacing: Theme.spacing-md;
                        alignment: stretch;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 12px;
                                height: 12px;
                                border-radius: 2px;
                                background: Theme.accent-danger;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            horizontal-stretch: 1;
                            Text {
                                text: root.destination;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-body;
                                font-weight: 600;
                                overflow: elide;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Image {
                                width: 16px;
                                height: 16px;
                                source: @image-url("@mobile-components/icons/pencil.svg");
                                colorize: Theme.muted;
                                image-fit: contain;
                            }
                            TouchArea {
                                clicked => { root.edit-destination-pressed(); }
                            }
                        }
                    }
                }
            }

            // Tier list.
            VerticalLayout {
                spacing: 0;
                TierRow {
                    name: "Standard";
                    capacity: "4";
                    eta: "3 min · arriving 14:18";
                    price: "$12.40";
                    car-color: #4a5568;
                    clicked => { root.selected-tier = 0; }
                }
                Divider { }
                TierRow {
                    name: "Comfort";
                    capacity: "4";
                    eta: "5 min · arriving 14:20";
                    price: "$18.10";
                    selected: true;
                    car-color: Theme.accent-info;
                    clicked => { root.selected-tier = 1; }
                }
                Divider { }
                TierRow {
                    name: "XL";
                    capacity: "6";
                    eta: "8 min · arriving 14:23";
                    price: "$24.80";
                    car-color: #6b3a78;
                    clicked => { root.selected-tier = 2; }
                }
            }

            Rectangle { vertical-stretch: 1; }

            // Confirm CTA.
            MobileButton {
                text: "Confirm Comfort · $18.10";
                tone: Tone.info;
                clicked => { root.confirm-pressed(); }
            }
        }
    }
}
