// MapPage
// =====================================================================
//
// Overlay-shaped template — full-bleed map background, floating search
// Card pinned at the top, BottomSheet of nearby POIs pinned at the
// bottom. The first page to combine surface-1 (the search card) with
// surface-2 (the bottom sheet) over a third visual layer (the map
// "canvas") — exercises the full elevation system.
//
// Specification
// -------------
//
// Geometry
//   - Page root is a plain Rectangle (NOT a VerticalLayout) — children
//     are positioned absolutely so the map covers the whole area and
//     the floating chrome overlays on top.
//   - Map: `MapEmbed` from `slint-mapping` fills the parent. Tiles
//     come from the consumer via `map-tiles`; without them the embed
//     shows its dark background, useful as a snapshot baseline. See
//     `slint-mapping/examples/map_page.rs` for end-to-end wiring with
//     real OpenStreetMap tiles.
//   - Search card: floating at the top, 16 px from each side, ~60 px
//     below the top edge so it clears a typical status bar.
//   - BottomSheet: pinned to the bottom edge, fixed height 360 px,
//     covering roughly the lower 40 % of the viewport.

import { Theme } from "@mobile-theme/theme.slint";
import { BottomSheet } from "@mobile-components/bottom-sheet.slint";
import { Card } from "@mobile-components/card.slint";
import { ListItem } from "@mobile-components/list-item.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { ScrollView } from "std-widgets.slint";
// Map widget — consumers wire `map-tiles` from a `slint_mapping::TileSource`
// and forward `map-pan` / `map-zoom-by` callbacks to a controller, or
// drive the camera directly via `map-latitude` / `map-longitude` / `map-zoom`.
import { MapEmbed, Tile, Layer } from "@mapping/map.slint";

export struct PointOfInterest {
    name: string,
    category: string,
    distance: string,
}

export component MapPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> query;
    in property <[PointOfInterest]> nearby: [
        { name: "Slint HQ",            category: "Office",       distance: "0.2 km" },
        { name: "Functional Coffee",   category: "Coffee shop",  distance: "0.5 km" },
        { name: "Vasagatan Loppis",    category: "Flea market",  distance: "0.8 km" },
        { name: "Greenfield Park",     category: "Park",         distance: "1.2 km" },
    ];
    callback search-edited(string);
    callback poi-pressed(PointOfInterest);

    // Map state — bind from Rust via a slint_mapping::MapController, or
    // (for a static demo) leave at defaults and pass a one-off
    // `map-tiles` model.
    in-out property <float> map-latitude: 51.5074;
    in-out property <float> map-longitude: -0.1276;
    in-out property <float> map-zoom: 13.0;
    in property <[Tile]> map-tiles;
    in property <[Layer]> map-layers;
    callback map-pan(length, length);
    callback map-zoom-by(float, length, length);
    // Measured MapEmbed size — the controller reads these each refresh
    // to project tiles + markers against the page's *actual* viewport
    // (full-bleed here = the page size, but other pages put the map
    // inside a strip / mini-card). Without this surface the controller
    // would have to guess.
    out property <length> map-viewport-width: map.width;
    out property <length> map-viewport-height: map.height;

    background: Theme.background;

    // ----- Map canvas -----
    map := MapEmbed {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        latitude <=> root.map-latitude;
        longitude <=> root.map-longitude;
        zoom <=> root.map-zoom;
        tiles: root.map-tiles;
        layers: root.map-layers;
        pan(dx, dy) => { root.map-pan(dx, dy); }
        zoom-by(d, ax, ay) => { root.map-zoom-by(d, ax, ay); }
    }

    // ----- Floating search bar (top) -----
    Rectangle {
        x: Theme.spacing-md;
        y: Theme.spacing-xl + Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        height: 52px;
        background: Theme.surface-1;
        border-radius: Theme.radius-md;
        drop-shadow-blur: Theme.elevation-2-blur;
        drop-shadow-color: Theme.elevation-2-color;
        drop-shadow-offset-y: Theme.elevation-2-y;

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: stretch;

            VerticalLayout {
                alignment: center;
                Image {
                    width: 22px;
                    height: 22px;
                    source: @image-url("@mobile-components/icons/search.svg");
                    colorize: Theme.muted;
                    image-fit: contain;
                }
            }

            VerticalLayout {
                horizontal-stretch: 1;
                alignment: center;
                Heading {
                    text: root.query == "" ? "search places" : root.query;
                    style: HeadingStyle.lowercase-soft;
                    font-size: Theme.font-size-body-large;
                    color: root.query == "" ? Theme.muted : Theme.on-surface;
                }
            }
        }
    }

    // ----- Bottom sheet of nearby POIs -----
    // Children are inserted directly into BottomSheet's `@children`
    // slot (which sits inside its internal VerticalLayout). Passing
    // them as siblings — not wrapped in another VL — keeps
    // `vertical-stretch` on the ScrollView effective; an extra VL in
    // the middle silently breaks the stretch chain.
    BottomSheet {
        x: 0;
        y: parent.height - self.height;
        width: parent.width;
        height: 360px;

        SectionHeader { text: "NEARBY"; }

        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: start;
                for poi in root.nearby: ListItem {
                    title: poi.name;
                    subtitle: poi.category + " · " + poi.distance;
                    leading-icon: @image-url("@mobile-components/icons/pin.svg");
                    trailing-icon: @image-url("@mobile-components/icons/chevron-right.svg");
                    clicked => { root.poi-pressed(poi); }
                }
            }
        }
    }
}
