// DriverOnTheWayPage
// =====================================================================
//
// Post-booking driver-tracking screen — the user just confirmed a
// rideshare and now watches the driver approach on a half-page "map",
// with a hero card showing driver identity + ETA chip + quick actions,
// followed by the trip recap as KeyValueRows and a destructive "Cancel
// ride" SettingRow at the bottom.
//
// What this screen does
//   - No AppBar — a transparent overlay strip carries a close button
//     pinned over the map.
//   - Map hero: half-page Rectangle (surface-2) standing in for the
//     real map, centred placeholder text.
//   - Driver hero card: avatar + name + car detail + ETA chip
//     (Tone.success) + row of three icon buttons (call / message /
//     share).
//   - TRIP FormSection: pickup / drop-off / distance / ETA / fare as
//     KeyValueRows — value column lines up at one right margin.
//   - Empty-title FormSection holding a destructive Cancel SettingRow.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Card } from "@mobile-components/card.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

// Compact round icon button used in the action row beside the driver
// hero — circular touch target, glyph centred, surface-1 fill.
component RoundIconButton inherits Rectangle {
    in property <image> icon;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    width: 48px;
    height: 48px;
    border-radius: self.width / 2;
    background: touch.pressed ? Theme.surface-pressed : Theme.surface-2;
    animate background { duration: Theme.motion-fast; }

    Image {
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: Theme.on-surface;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

import { MapEmbed, Tile, Layer } from "@mapping/map.slint";

export component DriverOnTheWayPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback close-pressed();
    callback call-pressed();
    callback message-pressed();
    callback share-pressed();
    callback cancel-ride-pressed();

    // Map camera — bind from Rust via slint_mapping::MapController, or
    // leave at defaults for a static demo.
    in-out property <float> map-latitude: 51.5074;
    in-out property <float> map-longitude: -0.1276;
    in-out property <float> map-zoom: 13.0;
    in property <[Tile]> map-tiles;
    in property <[Layer]> map-layers;
    callback map-pan(length, length);
    callback map-zoom-by(float, length, length);
    out property <length> map-viewport-width: map.width;
    out property <length> map-viewport-height: map.height;

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Map hero (with overlay close button) ------------------------
        Rectangle {
            height: 420px;
            background: Theme.surface-2;
            clip: true;

            map := MapEmbed {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                latitude <=> root.map-latitude;
                longitude <=> root.map-longitude;
                zoom <=> root.map-zoom;
                tiles: root.map-tiles;
                layers: root.map-layers;
                pan(dx, dy) => { root.map-pan(dx, dy); }
                zoom-by(d, ax, ay) => { root.map-zoom-by(d, ax, ay); }
            }

            // Translucent top strip — close button only, no title bar.
            Rectangle {
                x: Theme.spacing-md;
                y: Theme.spacing-md + 24px;
                width: 40px;
                height: 40px;
                border-radius: self.width / 2;
                background: Theme.surface-1;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;

                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/close.svg");
                    colorize: Theme.on-surface;
                    image-fit: contain;
                }
                TouchArea {
                    clicked => { root.close-pressed(); }
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                // alignment: start anchors children at the top and lets
                // the ScrollView's natural scroll handle anything that
                // overflows. `stretch` would distribute leftover vertical
                // space as empty growth into each child — the
                // driver-hero Card has fixed content but no fixed
                // height, so it'd inflate into a giant gap below the
                // avatar + chip row.
                alignment: start;

                // ----- Driver hero card --------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            Avatar {
                                fallback: "M";
                                size: 56px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Heading {
                                    text: "Mario · 4.9★";
                                    style: HeadingStyle.plex-medium;
                                    color: Theme.on-surface;
                                    font-size: 18px;
                                }
                                Text {
                                    text: "VW Polo · 1-ABC-234";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Chip {
                                    label: "ARRIVING IN 4 MIN";
                                    selected: true;
                                }
                            }
                        }

                        HorizontalLayout {
                            spacing: Theme.spacing-lg;
                            alignment: center;
                            padding-top: Theme.spacing-sm;

                            RoundIconButton {
                                icon: @image-url("@mobile-components/icons/send.svg");
                                clicked => { root.call-pressed(); }
                            }
                            RoundIconButton {
                                icon: @image-url("@mobile-components/icons/inbox.svg");
                                clicked => { root.message-pressed(); }
                            }
                            RoundIconButton {
                                icon: @image-url("@mobile-components/icons/more-vertical.svg");
                                clicked => { root.share-pressed(); }
                            }
                        }
                    }
                }

                // ----- TRIP -----------------------------------------------
                FormSection {
                    title: "TRIP";

                    KeyValueRow {
                        label: "Pickup";
                        value: "Sablon";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Drop-off";
                        value: "Louvain-la-Neuve";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Distance";
                        value: "32 km";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "ETA";
                        value: "10:25";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Fare";
                        value: "€ 8.50";
                        emphasis: true;
                    }
                }

                // ----- Danger zone ----------------------------------------
                FormSection {
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/close.svg");
                        tone: Tone.danger;
                        title: "Cancel ride";
                        subtitle: "Charges may apply if the driver is already on the way.";
                        destructive: true;
                        clicked => { root.cancel-ride-pressed(); }
                    }
                }
            }
        }
    }
}
