// PollResultsPage
// =====================================================================
//
// Voting poll results — the screen you land on after voting in a
// community / Slack / Loomio / X-style poll. Demonstrates:
//
//   - The poll question as a big headline + author + closing-in meta.
//   - Option rows where each option is a horizontal bar whose fill is
//     the percentage of votes. The leading edge of the bar carries the
//     option label + (your vote) chip if applicable, the trailing edge
//     shows the percentage and raw count. Tone tints (warning for
//     leader, default for others) make the leading option pop.
//   - A small "summary" footer below the options: total votes + a CTA
//     to share the poll.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";

// One option row.
//
// The bar fill is a Rectangle anchored to the left with `width =
// parent.width * pct`. The option label is layered ON TOP of the bar
// (left-aligned). This means the label always sits at the left edge of
// the row regardless of the fill ratio.
component PollOption inherits Rectangle {
    in property <string> label;
    in property <int> votes: 0;
    in property <float> percent: 0.0;
    in property <bool> your-vote: false;
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    height: 56px;

    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-1;
        border-radius: Theme.radius-md;
        clip: true;

        // Filled portion behind the text.
        Rectangle {
            x: 0;
            y: 0;
            width: parent.width * root.percent;
            height: parent.height;
            background:
                  root.tone == Tone.warning ? Theme.accent-warning
                : root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.danger  ? Theme.accent-danger
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.primary;
            opacity: 0.85;
        }

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            alignment: stretch;
            VerticalLayout {
                alignment: center;
                horizontal-stretch: 1;
                spacing: 2px;
                HorizontalLayout {
                    spacing: Theme.spacing-xs;
                    alignment: start;
                    Text {
                        text: root.label;
                        color: Theme.on-primary;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                        vertical-alignment: center;
                    }
                    if root.your-vote: Rectangle {
                        width: yv-text.preferred-width + 12px;
                        height: 18px;
                        border-radius: 4px;
                        background: #ffffff44;
                        yv-text := Text {
                            text: "YOUR VOTE";
                            color: Theme.on-primary;
                            font-size: 9px;
                            font-weight: 700;
                            letter-spacing: 0.5px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }
            VerticalLayout {
                alignment: center;
                spacing: 2px;
                Text {
                    text: (100 * root.percent) + "%";
                    color: Theme.on-primary;
                    font-size: Theme.font-size-body;
                    font-weight: 700;
                    horizontal-alignment: right;
                }
                Text {
                    text: root.votes + " votes";
                    color: Theme.on-primary;
                    font-size: 10px;
                    opacity: 0.75;
                    horizontal-alignment: right;
                }
            }
        }
    }
}

export component PollResultsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> question:
        "Which iteration should we ship the Tone enum migration in?";
    in property <string> author: "Posted by Anika · 2 days ago";
    in property <string> closes-in: "Closes in 14 hours · 218 votes";
    callback back-pressed();
    callback share-pressed();
    callback comment-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Poll";
            title-style: HeadingStyle.serif-light;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Question + author. Editorial Fraunces gives the poll a
            // long-form / op-ed feel that matches the serif-light AppBar.
            Heading {
                text: root.question;
                style: HeadingStyle.serif-display;
                color: Theme.on-background;
                wrap: word-wrap;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Text {
                    text: root.author;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    horizontal-stretch: 1;
                }
                Text {
                    text: root.closes-in;
                    color: Theme.accent-warning;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-alignment: right;
                }
            }

            // ----- Options -----
            VerticalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-sm;

                PollOption {
                    label: "Ship now — iteration 17 is the right gate";
                    votes: 96;
                    percent: 0.44;
                    your-vote: true;
                    tone: Tone.warning;
                }
                PollOption {
                    label: "Wait one iteration, add tests";
                    votes: 68;
                    percent: 0.31;
                    tone: Tone.default;
                }
                PollOption {
                    label: "Ship behind a feature flag";
                    votes: 38;
                    percent: 0.17;
                    tone: Tone.info;
                }
                PollOption {
                    label: "Roll back the refactor — too risky";
                    votes: 16;
                    percent: 0.08;
                    tone: Tone.danger;
                }
            }

            Divider { }

            // ----- Summary + CTAs -----
            HorizontalLayout {
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Text {
                        text: "218 votes";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                    }
                    Text {
                        text: "12 comments";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }
                MobileButton {
                    text: "Comment";
                    primary: false;
                    horizontal-stretch: 0;
                    min-width: 120px;
                    clicked => { root.comment-pressed(); }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
