// EventDetailPage
// =====================================================================
//
// Single calendar event detail. Hero card with title + a MetaRow of
// when / where / attendee-count chips. Then KeyValueRows under DETAILS,
// a SettingRow for the description, attendee SettingRows with a status
// Chip in the trailing slot, and a primary "Join meeting" + secondary
// "Decline" pair at the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component EventDetailPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback more-pressed();
    callback join-pressed();
    callback decline-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Event";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.more-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Hero card ----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        VerticalLayout {
                            spacing: Theme.spacing-sm;
                            Heading {
                                text: "Design review · v0.4";
                                style: HeadingStyle.plex-medium;
                                color: Theme.on-surface;
                            }
                            MetaRow {
                                items: [
                                    { text: "Today, 14:00–15:00" },
                                    { text: "Conference Room A" },
                                    { text: "12 attendees" },
                                ];
                            }
                        }
                    }
                }

                // ----- Details ------------------------------------------
                FormSection {
                    title: "DETAILS";

                    KeyValueRow {
                        label: "When";
                        value: "Today · 14:00–15:00";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Where";
                        value: "Conference Room A";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Organizer";
                        value: "Petra Lindquist";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Repeats";
                        value: "Weekly · Mon";
                    }
                }

                // ----- Description --------------------------------------
                FormSection {
                    title: "DESCRIPTION";

                    SettingRow {
                        title: "About this meeting";
                        subtitle: "Walkthrough of the v0.4 design tokens, with time for open Q&A. Bring your component snapshots if you have notes on the new spacing scale.";
                    }
                }

                // ----- Attendees ----------------------------------------
                FormSection {
                    title: "ATTENDEES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Petra Lindquist";
                        subtitle: "Organizer";
                        Chip { label: "ACCEPTED"; selected: false; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Greg Raymond";
                        subtitle: "Engineering";
                        Chip { label: "ACCEPTED"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Ada Lovelace";
                        subtitle: "Design";
                        Chip { label: "TENTATIVE"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Hedy Lamarr";
                        subtitle: "Product";
                        Chip { label: "PENDING"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Grace Hopper";
                        subtitle: "QA";
                        Chip { label: "ACCEPTED"; }
                    }
                }

                // ----- Actions ------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Join meeting";
                        clicked => { root.join-pressed(); }
                    }
                    TextButton {
                        text: "Decline";
                        clicked => { root.decline-pressed(); }
                    }
                }
            }
        }
    }
}
