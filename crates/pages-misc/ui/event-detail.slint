// EventDetailPage
// =====================================================================
//
// Concert / festival / conference event detail — Eventbrite / Dice /
// Songkick-style. Distinct from `HotelBookingPage` (room reservation)
// and `BoardingPassPage` (a single boarding pass). Demonstrates:
//
//   - Cover hero with translucent back / share / heart overlays and
//     a date pill anchored to the lower-left ("MAY 22").
//   - Event title + venue + date/time meta + price-from caption.
//   - Lineup avatar cluster (4 stacked) + "+ 6 more" pill.
//   - Sectioned body: About / Venue / Door policies, each with its
//     own short prose.
//   - Sticky Buy-tickets CTA with the cheapest price inline.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Chip } from "@mobile-components/chip.slint";
import { MobileButton } from "@mobile-components/button.slint";

// One mini section header for the body (smaller than `SectionHeader`
// since it sits inside the page body padding).
component MiniHeader inherits Rectangle {
    in property <string> text;
    height: 32px;
    VerticalLayout {
        alignment: center;
        Text {
            text: root.text;
            color: Theme.on-background;
            font-size: Theme.font-size-body-large;
            font-weight: 700;
        }
    }
}

// Stacked lineup avatar cluster — three discs overlapping with 2px
// background-coloured rings + a trailing "+N" pill.
component LineupCluster inherits Rectangle {
    in property <string> a;
    in property <string> b;
    in property <string> c;
    in property <string> more;

    width: 132px;
    height: 36px;

    Rectangle {
        x: 36px;
        y: 0;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.b;
            size: 32px;
        }
    }
    Rectangle {
        x: 60px;
        y: 0;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.c;
            size: 32px;
        }
    }
    Rectangle {
        x: 0;
        y: 0;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.a;
            size: 32px;
        }
    }
    Rectangle {
        x: 84px;
        y: 0;
        width: 48px;
        height: 36px;
        border-radius: 18px;
        background: Theme.surface-2;
        border-width: 2px;
        border-color: Theme.background;
        Text {
            text: "+ " + root.more;
            color: Theme.on-surface;
            font-size: 11px;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }
    }
}

export component EventDetailPage inherits Rectangle {
    in property <string> event-name: "Slint Conf 2026";
    in property <string> venue: "Fort Mason Center · San Francisco";
    in property <string> when: "Thu, May 22 · 09:00–18:00 PT";
    in property <string> price-from: "From $129";
    in property <string> date-day: "MAY 22";
    in property <string> about:
        "Two days, three tracks, one design system. Talks from the people building Slint, Patagonia, Memmo, and friends — plus the live keynote demoing the new Tone-enum migration. Coffee + lunch covered.";
    in property <string> venue-blurb:
        "Fort Mason Center · Festival Pavilion, 1 km from the Marina BART stop. Wheelchair accessible. Service dogs welcome.";
    in property <string> policies-blurb:
        "Ticket includes admission for both days, lunch, and an after-party at Casements. Refundable until 14 days before the event.";
    callback back-pressed();
    callback share-pressed();
    callback heart-pressed();
    callback buy-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Hero -----
        Rectangle {
            height: 240px;
            background: @linear-gradient(135deg, #4f8cff 0%, #2c1d61 100%);
            clip: true;

            // Translucent header buttons.
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: 64px;
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                alignment: stretch;
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/arrow-left.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.back-pressed(); }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.share-pressed(); }
                    }
                }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/heart.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.heart-pressed(); }
                    }
                }
            }

            // Date pill — lower-left corner of the hero.
            Rectangle {
                x: Theme.spacing-md;
                y: parent.height - self.height - Theme.spacing-md;
                width: 80px;
                height: 80px;
                border-radius: Theme.radius-md;
                background: Theme.surface-1;
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                VerticalLayout {
                    spacing: 0;
                    alignment: center;
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "MAY";
                            color: Theme.accent-danger;
                            font-size: 12px;
                            font-weight: 800;
                            letter-spacing: 0.5px;
                        }
                    }
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "22";
                            color: Theme.on-surface;
                            font-size: 32px;
                            font-weight: 800;
                        }
                    }
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "THU";
                            color: Theme.muted;
                            font-size: 10px;
                            font-weight: 800;
                            letter-spacing: 0.5px;
                        }
                    }
                }
            }
        }

        // ----- Title + meta -----
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            alignment: start;
            Text {
                text: root.event-name;
                color: Theme.on-background;
                font-size: Theme.font-size-headline;
                font-weight: 700;
            }
            Text {
                text: root.venue;
                color: Theme.muted;
                font-size: Theme.font-size-body;
            }
            Text {
                text: root.when;
                color: Theme.accent-warning;
                font-size: Theme.font-size-caption;
                font-weight: 600;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-xs;
                Chip { label: "Tech conf"; selected: true; }
                Chip { label: "In-person"; }
                Chip { label: "2 days"; }
            }
        }

        Divider { }

        // ----- Lineup -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            MiniHeader { text: "Lineup"; }
            HorizontalLayout {
                spacing: Theme.spacing-md;
                alignment: stretch;
                LineupCluster {
                    a: "OG";
                    b: "PR";
                    c: "AR";
                    more: "6";
                }
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Text {
                        text: "Olivia Goh, Priya Rao, Anika Ravi";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-caption;
                        font-weight: 600;
                        overflow: elide;
                    }
                    Text {
                        text: "+ 6 more speakers";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }
            }
        }

        Divider { }

        // ----- About -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            MiniHeader { text: "About"; }
            Text {
                text: root.about;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
        }

        // ----- Venue -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            MiniHeader { text: "Venue"; }
            Text {
                text: root.venue-blurb;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
        }

        // ----- Policies -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            MiniHeader { text: "Policies & extras"; }
            Text {
                text: root.policies-blurb;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }
        }

        Rectangle { vertical-stretch: 1; }

        // ----- Sticky CTA -----
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    spacing: 2px;
                    Text {
                        text: root.price-from;
                        color: Theme.on-surface;
                        font-size: Theme.font-size-title;
                        font-weight: 800;
                    }
                    Text {
                        text: "84 tickets left at this price";
                        color: Theme.accent-warning;
                        font-size: Theme.font-size-caption;
                        font-weight: 600;
                    }
                }
                MobileButton {
                    text: "Buy tickets";
                    tone: Tone.info;
                    horizontal-stretch: 0;
                    min-width: 160px;
                    max-height: 48px;
                    clicked => { root.buy-pressed(); }
                }
            }
        }
    }
}
