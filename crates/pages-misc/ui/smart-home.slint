// SmartHomePage
// =====================================================================
//
// Whole-home control dashboard. A row of four StatTiles (indoor,
// outdoor, air quality, power), then FormSections for ROOMS (SettingRow
// with device-count + chevron trailing), SCENES (SettingRow with
// chevron trailing), and AUTOMATIONS (SettingRow + MobileSwitch).

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component SmartHomePage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> sunset-automation: true;
    in-out property <bool> leave-automation: true;

    callback back-pressed();
    callback add-pressed();
    callback room-pressed(string);
    callback scene-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "My home";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.add-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Vitals row --------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;

                    StatTile { value: "21°"; label: "INDOOR"; }
                    StatTile { value: "12°"; label: "OUTDOOR"; tone: Tone.info; }
                    StatTile { value: "76%"; label: "AIR QUAL"; tone: Tone.success; }
                    StatTile { value: "245 W"; label: "POWER"; tone: Tone.warning; }
                }

                // ----- Rooms ------------------------------------------
                FormSection {
                    title: "ROOMS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.info;
                        title: "Living room";
                        subtitle: "21° · 4 lights on · TV";
                        clicked => { root.room-pressed("living"); }
                        Text {
                            text: "5";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.warning;
                        title: "Kitchen";
                        subtitle: "23° · oven idle · 2 lights on";
                        clicked => { root.room-pressed("kitchen"); }
                        Text {
                            text: "4";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.success;
                        title: "Bedroom";
                        subtitle: "19° · blinds closed";
                        clicked => { root.room-pressed("bedroom"); }
                        Text {
                            text: "3";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        tone: Tone.danger;
                        title: "Office";
                        subtitle: "22° · desk lamp on";
                        clicked => { root.room-pressed("office"); }
                        Text {
                            text: "2";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/home.svg");
                        title: "Garage";
                        subtitle: "11° · door closed";
                        clicked => { root.room-pressed("garage"); }
                        Text {
                            text: "1";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Scenes -----------------------------------------
                FormSection {
                    title: "SCENES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Movie night";
                        subtitle: "Tap to activate";
                        clicked => { root.scene-pressed("movie"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Goodnight";
                        subtitle: "Tap to activate";
                        clicked => { root.scene-pressed("goodnight"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.success;
                        title: "Wake up";
                        subtitle: "Tap to activate";
                        clicked => { root.scene-pressed("wake"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Automations ------------------------------------
                FormSection {
                    title: "AUTOMATIONS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.info;
                        title: "Sunset → close blinds";
                        subtitle: "Every day · about 21:14";
                        MobileSwitch { checked <=> root.sunset-automation; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.success;
                        title: "Leave home → arm security";
                        subtitle: "When all phones leave geofence";
                        MobileSwitch { checked <=> root.leave-automation; }
                    }
                }
            }
        }
    }
}
