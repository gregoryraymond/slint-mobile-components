// AchievementsPage
// =====================================================================
//
// Game / app achievements gallery. Top: three StatTiles summarise the
// totals. Then a "Recent" FormSection with rows for unlocked badges
// (tone-tinted leading tile + a small success-coloured check Image
// trailing) and an "In progress" FormSection for partially-completed
// achievements (percentage Text trailing).
//
// Pure showcase of SettingRow + StatTile alignment: every row in both
// sections inherits the same 56 px floor and 16 px leading-tile, so
// titles, subtitles, and trailing slots line up vertically regardless
// of which type of trailing widget appears.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component AchievementsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback row-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Achievements";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Totals row ------------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;

                    StatTile { value: "23 / 60"; label: "EARNED"; }
                    StatTile { value: "4"; label: "RARE"; tone: Tone.info; }
                    StatTile { value: "1.2K"; label: "POINTS"; tone: Tone.warning; }
                }

                // ----- Recent ---------------------------------------------
                FormSection {
                    title: "RECENT";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "First steps";
                        subtitle: "Earned May 12 · 50 pts";
                        clicked => { root.row-pressed("first-steps"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.danger;
                        title: "Heart of gold";
                        subtitle: "Earned May 11 · 100 pts";
                        clicked => { root.row-pressed("heart-of-gold"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "Streak holder";
                        subtitle: "Earned May 09 · 75 pts";
                        clicked => { root.row-pressed("streak"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.info;
                        title: "Explorer";
                        subtitle: "Earned May 07 · 50 pts";
                        clicked => { root.row-pressed("explorer"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Globe trotter";
                        subtitle: "Earned May 03 · 200 pts";
                        clicked => { root.row-pressed("globe"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                        }
                    }
                }

                // ----- In progress ----------------------------------------
                FormSection {
                    title: "IN PROGRESS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        title: "Power user";
                        subtitle: "3 / 10 · 30 %";
                        clicked => { root.row-pressed("power-user"); }
                        Text {
                            text: "30%";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        title: "Marathoner";
                        subtitle: "12 / 25 · 48 %";
                        clicked => { root.row-pressed("marathoner"); }
                        Text {
                            text: "48%";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        title: "Community pillar";
                        subtitle: "7 / 20 · 35 %";
                        clicked => { root.row-pressed("community"); }
                        Text {
                            text: "35%";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Cartographer";
                        subtitle: "4 / 50 · 8 %";
                        clicked => { root.row-pressed("cartographer"); }
                        Text {
                            text: "8%";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
