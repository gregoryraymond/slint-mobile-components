// LiveSportsScorePage
// =====================================================================
//
// Live football match — dark hero block with the two teams + score
// either side of a "vs" divider. Below: a SegmentedControl for the
// match-detail tabs, a FormSection of SettingRows for the goals, and a
// FormSection of KeyValueRows for the key match stats.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Chip } from "@mobile-components/chip.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

// Single team block in the hero — square initial avatar, name, score.
component TeamBlock inherits Rectangle {
    in property <string> initial;
    in property <string> name;
    in property <string> score;

    horizontal-stretch: 1;

    VerticalLayout {
        spacing: Theme.spacing-sm;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: Theme.radius-md;
                background: Theme.surface-2;

                Text {
                    width: parent.width;
                    height: parent.height;
                    text: root.initial;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-title;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                }
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: center;
            }
        }
        HorizontalLayout {
            alignment: center;
            Heading {
                text: root.score;
                style: HeadingStyle.bold-impact;
                color: Theme.on-surface;
                horizontal-alignment: center;
            }
        }
    }
}

export component LiveSportsScorePage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> tab-index: 0;
    callback back-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Dark hero ---------------------------------------
                Rectangle {
                    background: Theme.surface-2;
                    horizontal-stretch: 1;

                    VerticalLayout {
                        padding-top: Theme.spacing-lg;
                        padding-bottom: Theme.spacing-lg;
                        spacing: Theme.spacing-md;
                        alignment: stretch;

                        // LIVE pill
                        HorizontalLayout {
                            alignment: center;
                            spacing: Theme.spacing-sm;
                            Chip { label: "LIVE"; selected: true; }
                            Text {
                                text: "67' · UEFA Group A";
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                                font-weight: 600;
                                vertical-alignment: center;
                            }
                        }

                        // Teams + score
                        HorizontalLayout {
                            padding-left: Theme.spacing-md;
                            padding-right: Theme.spacing-md;
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            TeamBlock {
                                initial: "B";
                                name: "Belgium";
                                score: "2";
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "vs";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-title;
                                    font-weight: 600;
                                    horizontal-alignment: center;
                                }
                            }
                            TeamBlock {
                                initial: "N";
                                name: "Norway";
                                score: "1";
                            }
                        }
                    }
                }

                // ----- Tab switcher ------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Summary", "Stats", "Lineups", "Commentary"];
                        selected-index <=> root.tab-index;
                    }
                }

                // ----- Goals -------------------------------------------
                FormSection {
                    title: "GOALS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "12' · A. Lukaku";
                        subtitle: "Belgium · 1-0 (assist: De Bruyne)";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "27' · K. De Bruyne";
                        subtitle: "Belgium · 2-0 (assist: Hazard)";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "54' · E. Haaland";
                        subtitle: "Norway · 2-1 (penalty)";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "67' · M. Ødegaard";
                        subtitle: "Norway · 2-2 (assist: Sørloth)";
                    }
                }

                // ----- Key moments -------------------------------------
                FormSection {
                    title: "KEY MOMENTS";

                    KeyValueRow {
                        label: "Possession";
                        value: "62% / 38%";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Shots on target";
                        value: "8 / 4";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Corners";
                        value: "6 / 3";
                    }
                }
            }
        }
    }
}
