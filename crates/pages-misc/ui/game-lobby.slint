// GameLobbyPage
// =====================================================================
//
// Multiplayer match lobby — countdown hero, two team sections of
// SettingRows with READY/WAITING Chips in the trailing slot, a row of
// StatTiles describing the match parameters, and a primary "Ready up"
// + danger "Leave" pair at the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component GameLobbyPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback ready-pressed();
    callback leave-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Lobby · Storm Quad";
            title-style: HeadingStyle.grotesk-bold;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Countdown hero -----------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        VerticalLayout {
                            spacing: 2px;
                            alignment: center;

                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "00:42";
                                    color: Theme.on-surface;
                                    font-family: "JetBrains Mono";
                                    font-size: Theme.font-size-headline;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }
                            }
                            HorizontalLayout {
                                alignment: center;
                                Text {
                                    text: "Match starts in";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                    font-weight: 600;
                                    letter-spacing: 1px;
                                    horizontal-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ----- Team Alpha ---------------------------------------
                FormSection {
                    title: "TEAM ALPHA";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "@nightowl";
                        subtitle: "level 47 · K/D 2.4";
                        Chip { label: "READY"; selected: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "@violet_storm";
                        subtitle: "level 52 · K/D 1.9";
                        Chip { label: "READY"; selected: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "@axolotl_99";
                        subtitle: "level 31 · K/D 1.3";
                        Chip { label: "WAITING"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@you";
                        subtitle: "level 44 · K/D 1.7";
                        Chip { label: "WAITING"; }
                    }
                }

                // ----- Team Bravo ---------------------------------------
                FormSection {
                    title: "TEAM BRAVO";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "@blackcat";
                        subtitle: "level 60 · K/D 3.1";
                        Chip { label: "READY"; selected: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "@oslo_runner";
                        subtitle: "level 48 · K/D 2.0";
                        Chip { label: "READY"; selected: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@sparrow.84";
                        subtitle: "level 39 · K/D 1.5";
                        Chip { label: "READY"; selected: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "@quicksilver";
                        subtitle: "level 42 · K/D 1.8";
                        Chip { label: "WAITING"; }
                    }
                }

                // ----- Match parameters --------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;

                    StatTile { value: "EU-W"; label: "REGION"; }
                    StatTile { value: "Ranked"; label: "MODE"; tone: Tone.info; }
                    StatTile { value: "Dust III"; label: "MAP"; }
                }

                // ----- Actions -----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Ready up";
                        tone: Tone.success;
                        clicked => { root.ready-pressed(); }
                    }
                    TextButton {
                        text: "Leave lobby";
                        clicked => { root.leave-pressed(); }
                    }
                }
            }
        }
    }
}
