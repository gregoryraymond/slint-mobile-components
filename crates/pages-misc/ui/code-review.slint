// CodeReviewPage
// =====================================================================
//
// GitHub / GitLab-style pull-request review surface for mobile.
// Demonstrates a developer-facing template that the catalogue otherwise
// lacks:
//
//   - PR title + status pill (Open / Approved / Merged) + branch arrow
//     ("feature/tone-enum → main").
//   - Reviewer row: avatar cluster + reviewer-status glyphs (✓ approved,
//     ◐ pending, ↻ requested changes), each tone-tinted.
//   - Tab strip ("Conversation · 8" / "Files changed · 12" / "Checks").
//   - Diff lines: each line carries a sign glyph (+ / - / blank), a
//     line number, and monospaced source code with appropriate
//     background tint (`accent-success` at 14% alpha for additions,
//     `accent-danger` at 14% for deletions).
//   - Inline thread underneath one diff hunk — the canonical "Conversa-
//     tion thread anchored to a line" pattern.
//   - Sticky review footer with Approve / Comment / Request changes
//     pill row + Submit CTA.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { TabBar, Tab } from "@mobile-components/tab-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Chip } from "@mobile-components/chip.slint";
import { MobileButton } from "@mobile-components/button.slint";

// One diff line.
//
// `state`:
//   0 = context (no fill, dim line number)
//   1 = addition (success tint, "+" glyph)
//   2 = deletion (danger tint, "-" glyph)
component DiffLine inherits Rectangle {
    in property <int> line-no;
    in property <int> state: 0;
    in property <string> code;

    horizontal-stretch: 1;
    min-height: 22px;
    background:
          root.state == 1 ? #22c55e22
        : root.state == 2 ? #ef444422
        : transparent;

    HorizontalLayout {
        spacing: 0;

        // Line number column.
        VerticalLayout {
            alignment: center;
            width: 36px;
            Text {
                text: root.line-no;
                color: Theme.muted;
                font-size: 11px;
                font-family: "Menlo";
                horizontal-alignment: right;
                width: parent.width - 6px;
            }
        }
        // Sign column.
        VerticalLayout {
            alignment: center;
            width: 18px;
            Text {
                text:
                      root.state == 1 ? "+"
                    : root.state == 2 ? "−"
                    : " ";
                color:
                      root.state == 1 ? Theme.accent-success
                    : root.state == 2 ? Theme.accent-danger
                    : Theme.muted;
                font-size: 12px;
                font-family: "Menlo";
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
        // Code.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: root.code;
                color: Theme.on-surface;
                font-size: 12px;
                font-family: "Menlo";
                overflow: elide;
            }
        }
    }
}

// One reviewer row inside the reviewers strip.
component ReviewerChip inherits Rectangle {
    in property <string> initials;
    in property <string> status-glyph;
    in property <Tone> tone: Tone.default;

    width: 40px;
    height: 40px;

    Avatar {
        x: 0;
        y: 0;
        width: 36px;
        height: 36px;
        fallback: root.initials;
        size: 36px;
    }
    // Status glyph in the bottom-right corner.
    Rectangle {
        x: parent.width - 16px;
        y: parent.height - 16px;
        width: 16px;
        height: 16px;
        border-radius: 8px;
        background:
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : Theme.surface-2;
        border-width: 2px;
        border-color: Theme.background;
        Text {
            text: root.status-glyph;
            color: #ffffff;
            font-size: 9px;
            font-weight: 800;
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }
    }
}

// One inline review-thread comment under a diff hunk.
component ThreadComment inherits Rectangle {
    in property <string> initials;
    in property <string> author;
    in property <string> when;
    in property <string> body;

    horizontal-stretch: 1;
    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-sm;
        alignment: stretch;
        VerticalLayout {
            alignment: start;
            padding-top: 2px;
            Avatar {
                fallback: root.initials;
                size: 28px;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                Text {
                    text: root.author;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-caption;
                    font-weight: 700;
                }
                Text {
                    text: root.when;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                }
            }
            Text {
                text: root.body;
                color: Theme.on-surface;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
            }
        }
    }
}

export component CodeReviewPage inherits Rectangle {
    in property <string> repo-pr: "slint-mobile-components #312";
    in property <string> pr-title: "Drawer primitive + Tone-enum migration";
    in property <string> branch-from: "feature/tone-enum";
    in property <string> branch-to: "main";
    in property <string> diff-stats: "+412 / −287 across 12 files";
    in-out property <int> active-tab: 1;
    callback back-pressed();
    callback overflow-pressed();
    callback approve-pressed();
    callback comment-pressed();
    callback request-changes-pressed();
    callback submit-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.repo-pr;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.overflow-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            // Title row.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: start;
                Rectangle {
                    width: status-text.preferred-width + 14px;
                    height: 22px;
                    border-radius: 11px;
                    background: Theme.accent-success;
                    status-text := Text {
                        text: "OPEN";
                        color: Theme.on-primary;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
                Text {
                    text: root.diff-stats;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.pr-title;
                color: Theme.on-background;
                font-size: Theme.font-size-title;
                font-weight: 700;
                wrap: word-wrap;
            }

            // Branches.
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                Rectangle {
                    width: from-text.preferred-width + 16px;
                    height: 24px;
                    border-radius: 4px;
                    background: Theme.surface-variant;
                    from-text := Text {
                        text: root.branch-from;
                        color: Theme.on-surface;
                        font-size: 11px;
                        font-family: "Menlo";
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "→";
                        color: Theme.muted;
                        font-size: 14px;
                        font-weight: 800;
                    }
                }
                Rectangle {
                    width: to-text.preferred-width + 16px;
                    height: 24px;
                    border-radius: 4px;
                    background: Theme.surface-variant;
                    to-text := Text {
                        text: root.branch-to;
                        color: Theme.on-surface;
                        font-size: 11px;
                        font-family: "Menlo";
                        font-weight: 600;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }

            // Reviewers strip.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: start;
                padding-top: 4px;
                Text {
                    text: "Reviewers";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 700;
                    vertical-alignment: center;
                }
                ReviewerChip {
                    initials: "PR";
                    status-glyph: "✓";
                    tone: Tone.success;
                }
                ReviewerChip {
                    initials: "AR";
                    status-glyph: "✓";
                    tone: Tone.success;
                }
                ReviewerChip {
                    initials: "DV";
                    status-glyph: "↻";
                    tone: Tone.danger;
                }
                ReviewerChip {
                    initials: "MK";
                    status-glyph: "·";
                    tone: Tone.warning;
                }
            }
        }

        // Tab strip.
        TabBar {
            Tab { label: "Conversation · 8"; }
            Tab { label: "Files · 12"; active: true; }
            Tab { label: "Checks"; }
        }

        // ----- Diff hunk -----
        Rectangle {
            background: Theme.surface-1;
            HorizontalLayout {
                padding: Theme.spacing-sm;
                Text {
                    text: "ui/dialog.slint";
                    color: Theme.muted;
                    font-size: 11px;
                    font-family: "Menlo";
                    font-weight: 700;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                Text {
                    text: "+38 / −12";
                    color: Theme.muted;
                    font-size: 11px;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
        }
        Divider { }

        DiffLine {
            line-no: 67;
            state: 0;
            code: "    in property <string> secondary-label;";
        }
        DiffLine {
            line-no: 68;
            state: 2;
            code: "    in property <bool> danger: false;";
        }
        DiffLine {
            line-no: 68;
            state: 1;
            code: "    in property <Tone> tone: Tone.default;";
        }
        DiffLine {
            line-no: 69;
            state: 0;
            code: "    callback primary-pressed();";
        }
        DiffLine {
            line-no: 70;
            state: 0;
            code: "    callback secondary-pressed();";
        }

        // Inline comment thread under the hunk.
        Rectangle {
            background: Theme.surface-2;
            VerticalLayout {
                spacing: 0;
                ThreadComment {
                    initials: "PR";
                    author: "Priya Rao";
                    when: "2h";
                    body: "Nice — and the existing `danger: true` call sites all get a tone:Tone.danger migration in the same PR, right?";
                }
                Divider { }
                ThreadComment {
                    initials: "GR";
                    author: "Greg Raymond";
                    when: "1h";
                    body: "Yes, see tests/snapshot_scenes.slint:266 — SnapDialog scene was the only caller and it's already on the new API.";
                }
                Divider { }
                ThreadComment {
                    initials: "DV";
                    author: "Devika Sharma";
                    when: "23m";
                    body: "Resolve — looks good.";
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Sticky review action footer.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-sm;
                spacing: Theme.spacing-sm;
                MobileButton {
                    text: "Comment";
                    primary: false;
                    horizontal-stretch: 1;
                    max-height: 44px;
                    clicked => { root.comment-pressed(); }
                }
                MobileButton {
                    text: "Approve";
                    horizontal-stretch: 1;
                    tone: Tone.success;
                    max-height: 44px;
                    clicked => { root.approve-pressed(); }
                }
                MobileButton {
                    text: "Request";
                    horizontal-stretch: 1;
                    tone: Tone.danger;
                    max-height: 44px;
                    clicked => { root.request-changes-pressed(); }
                }
            }
        }
    }
}
