// SmartTVRemotePage
// =====================================================================
//
// IR / smart-home TV remote — Logitech Harmony / Apple Remote-style.
// Distinct from `SmartHomePage` (multi-device dashboard) and
// `RoomThermostatPage` (single-device dial). Demonstrates a control
// surface with no scrolling — every glyph is a button.
//
// Layout:
//   - Device pill at the top (Sony Bravia · Living room) + status dot.
//   - Source chip strip (Netflix / Apple TV / Switch / HDMI 1).
//   - Big d-pad: four directional discs around a centre OK button.
//   - Volume + Channel rocker pair underneath, each with a + on top
//     and − on bottom.
//   - Power + Home + Mute + Back utility row.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Chip } from "@mobile-components/chip.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";

// A round directional / utility key.
component RoundKey inherits Rectangle {
    in property <image> icon;
    in property <string> letter;
    in property <Tone> tone: Tone.default;
    in property <length> size: 64px;
    in property <bool> dim: false;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    width: root.size;
    height: root.size;
    border-radius: self.width / 2;
    background:
          touch.pressed
        ? Theme.surface-pressed
        : (
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : Theme.surface-1
          );
    border-width: root.tone == Tone.default ? 1px : 0px;
    border-color: Theme.outline;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;
    opacity: root.dim ? 0.55 : 1.0;
    animate background { duration: Theme.motion-fast; }

    if root.letter == "" : Image {
        width: root.size * 0.4;
        height: root.size * 0.4;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize:
              root.tone == Tone.default ? Theme.on-surface
            : Theme.on-primary;
        image-fit: contain;
    }
    if root.letter != "" : Text {
        text: root.letter;
        color:
              root.tone == Tone.default ? Theme.on-surface
            : Theme.on-primary;
        font-size: 18px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// A rectangular rocker key (used for Vol+/Vol−/Ch+/Ch−).
component RockerKey inherits Rectangle {
    in property <string> caption;
    in property <bool> top: true;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    width: 96px;
    height: 64px;
    background:
          touch.pressed ? Theme.surface-pressed
        : Theme.surface-1;
    border-top-left-radius: root.top ? Theme.radius-lg : 0px;
    border-top-right-radius: root.top ? Theme.radius-lg : 0px;
    border-bottom-left-radius: root.top ? 0px : Theme.radius-lg;
    border-bottom-right-radius: root.top ? 0px : Theme.radius-lg;
    border-width: 1px;
    border-color: Theme.outline;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;
    animate background { duration: Theme.motion-fast; }

    Text {
        text: root.caption;
        color: Theme.on-surface;
        font-size: Theme.font-size-headline;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

// Rocker label between top/bottom (e.g. "VOL" / "CH").
component RockerLabel inherits Rectangle {
    in property <string> text;
    width: 96px;
    height: 28px;
    background: transparent;
    Text {
        text: root.text;
        color: Theme.muted;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1px;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

export component SmartTVRemotePage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> device: "Sony Bravia · Living room";
    in property <string> status: "CONNECTED";
    callback back-pressed();
    callback device-pressed();
    callback source-pressed(string);
    callback dir-pressed(string);
    callback rocker-pressed(string);
    callback util-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "REMOTE";
            title-style: HeadingStyle.uppercase-spaced;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // Device pill.
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                height: 56px;
                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 10px;
                            height: 10px;
                            border-radius: 5px;
                            background: Theme.accent-success;
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: root.device;
                            color: Theme.on-surface;
                            font-family: "IBM Plex Sans";
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                        }
                        Text {
                            text: root.status;
                            color: Theme.accent-success;
                            font-size: 10px;
                            font-weight: 800;
                            letter-spacing: 0.5px;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.device-pressed(); }
                            }
                        }
                    }
                }
            }

            // Source chip strip.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Chip { label: "Netflix"; selected: true; }
                Chip { label: "Apple TV"; }
                Chip { label: "HDMI 1"; }
                Chip { label: "Switch"; }
            }
        }

        // Big d-pad.
        VerticalLayout {
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            HorizontalLayout {
                alignment: center;
                RoundKey {
                    icon: @image-url("@mobile-components/icons/arrow-left.svg");
                    size: 64px;
                    clicked => { root.dir-pressed("up"); }
                }
            }
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                RoundKey {
                    icon: @image-url("@mobile-components/icons/arrow-left.svg");
                    size: 64px;
                    clicked => { root.dir-pressed("left"); }
                }
                RoundKey {
                    letter: "OK";
                    tone: Tone.info;
                    size: 80px;
                    clicked => { root.dir-pressed("ok"); }
                }
                RoundKey {
                    icon: @image-url("@mobile-components/icons/chevron-right.svg");
                    size: 64px;
                    clicked => { root.dir-pressed("right"); }
                }
            }
            HorizontalLayout {
                alignment: center;
                RoundKey {
                    icon: @image-url("@mobile-components/icons/chevron-right.svg");
                    size: 64px;
                    clicked => { root.dir-pressed("down"); }
                }
            }
        }

        // Rockers + utility row.
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;

            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-xl;
                // Volume rocker.
                VerticalLayout {
                    spacing: 0;
                    alignment: center;
                    RockerKey {
                        caption: "+";
                        top: true;
                        clicked => { root.rocker-pressed("vol-up"); }
                    }
                    RockerLabel { text: "VOL"; }
                    RockerKey {
                        caption: "−";
                        top: false;
                        clicked => { root.rocker-pressed("vol-down"); }
                    }
                }
                // Channel rocker.
                VerticalLayout {
                    spacing: 0;
                    alignment: center;
                    RockerKey {
                        caption: "+";
                        top: true;
                        clicked => { root.rocker-pressed("ch-up"); }
                    }
                    RockerLabel { text: "CH"; }
                    RockerKey {
                        caption: "−";
                        top: false;
                        clicked => { root.rocker-pressed("ch-down"); }
                    }
                }
            }

            // Utility row.
            HorizontalLayout {
                alignment: center;
                spacing: Theme.spacing-md;
                RoundKey {
                    icon: @image-url("@mobile-components/icons/lock.svg");
                    tone: Tone.danger;
                    size: 56px;
                    clicked => { root.util-pressed("power"); }
                }
                RoundKey {
                    icon: @image-url("@mobile-components/icons/home.svg");
                    size: 56px;
                    clicked => { root.util-pressed("home"); }
                }
                RoundKey {
                    icon: @image-url("@mobile-components/icons/bell.svg");
                    size: 56px;
                    clicked => { root.util-pressed("mute"); }
                }
                RoundKey {
                    icon: @image-url("@mobile-components/icons/arrow-left.svg");
                    size: 56px;
                    clicked => { root.util-pressed("back"); }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
