// LeaderboardPage
// =====================================================================
//
// Top-N ranked players. Period switcher (SegmentedControl), then a Card
// showing the current user's row, and a FormSection of SettingRows for
// the top 10. Top-3 rows use a warning-tinted star leading tile; the
// rest use a default profile tile. Trailing slot in each row carries
// the rank number, which keeps the column aligned across every row.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component LeaderboardPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> period-index: 1;
    callback back-pressed();
    callback row-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Leaderboard";
            title-style: HeadingStyle.grotesk-bold;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Period switcher ---------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Today", "Week", "All-time"];
                        selected-index <=> root.period-index;
                    }
                }

                // ----- Current user hero -------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "#42";
                                    color: Theme.primary;
                                    font-family: "JetBrains Mono";
                                    font-size: Theme.font-size-headline;
                                    font-weight: 700;
                                    horizontal-alignment: center;
                                }
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Heading {
                                    text: "@you";
                                    style: HeadingStyle.plex-medium;
                                    color: Theme.on-surface;
                                    font-size: 18px;
                                }
                                Text {
                                    text: "984 pts · Belgium";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                                Text {
                                    text: "+12 this week";
                                    color: Theme.accent-success;
                                    font-size: Theme.font-size-caption;
                                    font-weight: 600;
                                }
                            }
                        }
                    }
                }

                // ----- Top 10 ------------------------------------------
                FormSection {
                    title: "TOP 10";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "@blackcat";
                        subtitle: "Norway · 2,481 pts";
                        clicked => { root.row-pressed("1"); }
                        Text {
                            text: "#1";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "@nightowl";
                        subtitle: "Belgium · 2,210 pts";
                        clicked => { root.row-pressed("2"); }
                        Text {
                            text: "#2";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "@oslo_runner";
                        subtitle: "Norway · 2,047 pts";
                        clicked => { root.row-pressed("3"); }
                        Text {
                            text: "#3";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@violet_storm";
                        subtitle: "Sweden · 1,894 pts";
                        clicked => { root.row-pressed("4"); }
                        Text {
                            text: "#4";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@sparrow.84";
                        subtitle: "Germany · 1,712 pts";
                        clicked => { root.row-pressed("5"); }
                        Text {
                            text: "#5";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@axolotl_99";
                        subtitle: "Mexico · 1,604 pts";
                        clicked => { root.row-pressed("6"); }
                        Text {
                            text: "#6";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@quicksilver";
                        subtitle: "France · 1,521 pts";
                        clicked => { root.row-pressed("7"); }
                        Text {
                            text: "#7";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@petra.l";
                        subtitle: "Sweden · 1,447 pts";
                        clicked => { root.row-pressed("8"); }
                        Text {
                            text: "#8";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@hedy.l";
                        subtitle: "Austria · 1,389 pts";
                        clicked => { root.row-pressed("9"); }
                        Text {
                            text: "#9";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "@grace.h";
                        subtitle: "USA · 1,304 pts";
                        clicked => { root.row-pressed("10"); }
                        Text {
                            text: "#10";
                            color: Theme.on-surface;
                            font-family: "JetBrains Mono";
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}
