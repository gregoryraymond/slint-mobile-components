// DeliveryDriverPage
// =====================================================================
//
// Courier route view — progress meter at the top, then a single "next
// stop" SettingRow, the remaining stops, and the completed stops, each
// in their own FormSection. Bottom actions: primary "Open in maps" +
// secondary "Mark stop complete".
//
// All three sections use SettingRow as the row primitive so the leading
// icon tiles, titles, subtitles and chevron trailing slots all align
// vertically across the page.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { ProgressBar } from "@mobile-components/progress-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component DeliveryDriverPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback maps-pressed();
    callback complete-pressed();
    callback stop-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Tour · #487";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Hero progress card -------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        VerticalLayout {
                            spacing: Theme.spacing-sm;
                            Text {
                                text: "3 of 8 stops";
                                color: Theme.on-surface;
                                font-size: Theme.font-size-title;
                                font-weight: 700;
                            }
                            Text {
                                text: "On schedule · ETA 16:10";
                                color: Theme.muted;
                                font-size: Theme.font-size-body;
                            }
                            ProgressBar {
                                value: 0.375;
                            }
                        }
                    }
                }

                // ----- Next stop ----------------------------------------
                FormSection {
                    title: "NEXT STOP";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Mme Sophie · 4B";
                        subtitle: "Rue de la Loi 110 · 1.2 km · ETA 14:32";
                        clicked => { root.stop-pressed("next"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Remaining ----------------------------------------
                FormSection {
                    title: "REMAINING";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "M. Dupont · 12A";
                        subtitle: "Avenue Louise 240 · 2.1 km";
                        clicked => { root.stop-pressed("4"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Atlas Coffee Co.";
                        subtitle: "Place du Châtelain 8 · 3.4 km";
                        clicked => { root.stop-pressed("5"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "P. Lindquist · 7C";
                        subtitle: "Rue Antoine Dansaert 31 · 4.0 km";
                        clicked => { root.stop-pressed("6"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Studio K · loading dock";
                        subtitle: "Quai aux Briques 62 · 5.3 km";
                        clicked => { root.stop-pressed("7"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Mme van Acker · 2B";
                        subtitle: "Rue Royale 145 · 6.1 km";
                        clicked => { root.stop-pressed("8"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Done ---------------------------------------------
                FormSection {
                    title: "DONE";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "Depot pickup";
                        subtitle: "Completed 13:08";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/check.svg");
                        tone: Tone.success;
                        title: "M. Hubert · 1A";
                        subtitle: "Completed 13:42";
                    }
                }

                // ----- Actions ------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Open in maps";
                        clicked => { root.maps-pressed(); }
                    }
                    TextButton {
                        text: "Mark stop complete";
                        clicked => { root.complete-pressed(); }
                    }
                }
            }
        }
    }
}
