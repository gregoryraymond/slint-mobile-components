// TVShowDetailPage
// =====================================================================
//
// Netflix / Disney+ / Max-style TV-show detail. Demonstrates:
//
//   - Full-bleed hero gradient (240 px) at the top with the show
//     title overlaid in giant typography + meta caption (Year · 18+ ·
//     5 seasons) + match-score chip.
//   - Action row right below: huge Play button (white background) +
//     My-list (+) + Download arrow + Share — the "primary CTA + three
//     icon affordances" pattern Netflix uses.
//   - Season picker chip strip ("Season 1" / "Season 2" / "Latest").
//   - Episode list — thumbnail-left, title + length + sub-text right,
//     a thin info-tone progress strip beneath the row title showing
//     how far the user got into that episode.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

// One transport / action button (icon + label stacked).
component HeroAction inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <color> tint: #ffffff;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 56px;

    VerticalLayout {
        spacing: 2px;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                width: 22px;
                height: 22px;
                source: root.icon;
                colorize: root.tint;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: root.tint;
                font-size: 11px;
                font-weight: 600;
            }
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

// One episode row.
component EpisodeRow inherits Rectangle {
    in property <int> position;
    in property <string> title;
    in property <string> length;
    in property <string> synopsis;
    in property <bool> watched: false;
    in property <float> progress: 0.0;
    in property <brush> thumb-fill;

    horizontal-stretch: 1;
    min-height: 104px;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Thumb + play disc overlay.
        VerticalLayout {
            alignment: start;
            Rectangle {
                width: 120px;
                height: 72px;
                border-radius: Theme.radius-sm;
                background: root.thumb-fill;
                clip: true;
                Rectangle {
                    width: 28px;
                    height: 28px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    border-radius: self.width / 2;
                    background: #00000099;
                    Image {
                        width: 12px;
                        height: 12px;
                        x: (parent.width - self.width) / 2 + 1px;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/play.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                }
                // Progress strip across the bottom of the thumb.
                if root.progress > 0: Rectangle {
                    x: 0;
                    y: parent.height - 4px;
                    width: parent.width;
                    height: 4px;
                    background: #ffffff33;
                    Rectangle {
                        x: 0;
                        y: 0;
                        width: parent.width * root.progress;
                        height: parent.height;
                        background: Theme.accent-danger;
                    }
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: stretch;
                Text {
                    text: root.position + ". " + root.title;
                    color: root.watched ? Theme.muted : Theme.on-surface;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Text {
                    text: root.length;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                }
            }
            Text {
                text: root.synopsis;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
            }
        }
    }
}

export component TVShowDetailPage inherits Rectangle {
    in property <string> show: "Severance";
    in property <string> meta: "2026 · 18+ · 3 Seasons · TV-MA";
    in property <string> match-score: "98% Match";
    in property <string> tagline: "Outie Greg has no idea what's in the basement.";
    in property <string> description:
        "Mark leads a team whose memories of work and personal life are surgically divided. When a mysterious colleague appears outside the office, every assumption about who they are starts to come apart.";
    callback back-pressed();
    callback play-pressed();
    callback list-pressed();
    callback download-pressed();
    callback share-pressed();
    callback episode-pressed(int);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Hero -----
        Rectangle {
            height: 280px;
            background: @linear-gradient(180deg, #0a4d3a 0%, #0a0d12 100%);
            clip: true;

            // Translucent back button.
            Rectangle {
                x: Theme.spacing-md;
                y: Theme.spacing-md;
                width: 36px;
                height: 36px;
                border-radius: self.width / 2;
                background: #00000066;
                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/arrow-left.svg");
                    colorize: #ffffff;
                    image-fit: contain;
                }
                TouchArea {
                    clicked => { root.back-pressed(); }
                }
            }

            // Title block — bottom-anchored.
            VerticalLayout {
                x: 0;
                y: parent.height - 140px;
                width: parent.width;
                height: 132px;
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: 4px;
                alignment: end;
                Text {
                    text: root.show;
                    color: #ffffff;
                    font-size: 36px;
                    font-weight: 800;
                    horizontal-alignment: left;
                }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    Rectangle {
                        width: score-text.preferred-width + 12px;
                        height: 22px;
                        border-radius: 4px;
                        background: Theme.accent-success;
                        score-text := Text {
                            text: root.match-score;
                            color: #ffffff;
                            font-size: 10px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                    Text {
                        text: root.meta;
                        color: #ffffffcc;
                        font-size: Theme.font-size-caption;
                        font-weight: 600;
                        vertical-alignment: center;
                    }
                }
                Text {
                    text: root.tagline;
                    color: #ffffff;
                    font-size: Theme.font-size-body;
                    font-weight: 500;
                }
            }
        }

        // ----- Play hero + action icons -----
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            // Huge Play button.
            Rectangle {
                height: 48px;
                border-radius: Theme.radius-md;
                background: play-touch.pressed ? #e5e7eb : #ffffff;
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: center;
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/play.svg");
                            colorize: #0a0d12;
                            image-fit: contain;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Text {
                            text: "Continue · S2 E3";
                            color: #0a0d12;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                        }
                    }
                }
                play-touch := TouchArea {
                    clicked => { root.play-pressed(); }
                }
            }

            // My list / Download / Share icon row.
            HorizontalLayout {
                HeroAction {
                    icon: @image-url("@mobile-components/icons/plus.svg");
                    label: "My list";
                    clicked => { root.list-pressed(); }
                }
                HeroAction {
                    icon: @image-url("@mobile-components/icons/queue.svg");
                    label: "Download";
                    clicked => { root.download-pressed(); }
                }
                HeroAction {
                    icon: @image-url("@mobile-components/icons/send.svg");
                    label: "Share";
                    clicked => { root.share-pressed(); }
                }
            }

            // Description.
            Text {
                text: root.description;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                wrap: word-wrap;
            }

            // Season picker.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-xs;
                Chip { label: "Season 1"; }
                Chip { label: "Season 2"; selected: true; }
                Chip { label: "Latest"; }
            }
        }

        // ----- Episodes -----
        EpisodeRow {
            position: 1;
            title: "Hello, Outie";
            length: "52 min";
            synopsis: "Mark wakes up on the severed floor with no memory of the basement break-in.";
            watched: true;
            progress: 1.0;
            thumb-fill: @linear-gradient(135deg, #0a4d3a 0%, #052218 100%);
        }
        Divider { }
        EpisodeRow {
            position: 2;
            title: "Cold Harbor";
            length: "47 min";
            synopsis: "Helly investigates a project that everyone else has been told to forget.";
            watched: true;
            progress: 1.0;
            thumb-fill: @linear-gradient(135deg, #2c1d61 0%, #160d33 100%);
        }
        Divider { }
        EpisodeRow {
            position: 3;
            title: "The Wellness Centre";
            length: "49 min";
            synopsis: "Irving discovers an outie connection that puts him on a collision course with security.";
            progress: 0.42;
            thumb-fill: @linear-gradient(135deg, #6b1d1d 0%, #2d0d0d 100%);
        }
        Divider { }
        EpisodeRow {
            position: 4;
            title: "Reciprocity";
            length: "55 min";
            synopsis: "Dylan tries an experiment that breaks every rule.";
            thumb-fill: @linear-gradient(135deg, #5a4d1a 0%, #2d260a 100%);
        }

        Rectangle { vertical-stretch: 1; }
    }
}
