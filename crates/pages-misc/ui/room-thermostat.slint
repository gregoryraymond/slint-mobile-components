// RoomThermostatPage
// =====================================================================
//
// Single-room thermostat control. Large circular dial visual at the top
// (a Rectangle with a thick primary border + the current temp inside),
// a row of StatTiles summarising now / target / humidity, a mode
// SegmentedControl inside a SettingRow, schedule KeyValueRows, and
// device toggles via SettingRow + MobileSwitch.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component RoomThermostatPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> mode-index: 0;
    in-out property <bool> eco-on: true;
    in-out property <bool> vacation-on: false;
    in-out property <bool> auto-away-on: true;
    callback back-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Living Room";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-lg;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: start;

                // ----- Dial -------------------------------------------
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 240px;
                        height: 240px;
                        border-radius: 120px;
                        background: Theme.surface-2;
                        border-width: 8px;
                        border-color: Theme.primary;

                        VerticalLayout {
                            spacing: Theme.spacing-xs;
                            alignment: center;

                            Text {
                                text: "21°";
                                color: Theme.on-surface;
                                font-size: 56px;
                                font-weight: 200;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "HEATING TO 22°";
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                                font-weight: 700;
                                letter-spacing: 1.5px;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // ----- Stat row ---------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;

                    StatTile { value: "21°"; label: "NOW"; }
                    StatTile { value: "22°"; label: "TARGET"; }
                    StatTile { value: "48%"; label: "HUMIDITY"; }
                }

                // ----- Mode -------------------------------------------
                FormSection {
                    title: "MODE";

                    SettingRow {
                        title: "Mode";
                        SegmentedControl {
                            width: 240px;
                            options: ["Heat", "Cool", "Auto", "Off"];
                            selected-index <=> root.mode-index;
                        }
                    }
                }

                // ----- Schedule ---------------------------------------
                FormSection {
                    title: "SCHEDULE";

                    KeyValueRow {
                        label: "Wake · 06:30";
                        value: "21°";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Day · 09:00";
                        value: "19°";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Evening · 17:30";
                        value: "22°";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Sleep · 22:30";
                        value: "18°";
                    }
                }

                // ----- Device -----------------------------------------
                FormSection {
                    title: "DEVICE";

                    SettingRow {
                        title: "Eco mode";
                        subtitle: "Trim 1° from setpoints to save energy.";
                        MobileSwitch { checked <=> root.eco-on; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Vacation hold";
                        subtitle: "Hold a low setpoint until you return.";
                        MobileSwitch { checked <=> root.vacation-on; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Auto-away";
                        subtitle: "Detect when nobody's home and pause.";
                        MobileSwitch { checked <=> root.auto-away-on; }
                    }
                }
            }
        }
    }
}
