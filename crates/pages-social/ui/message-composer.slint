// MessageComposerPage
// =====================================================================
//
// New-message draft. TO section with chips-as-rows for recipients,
// FormField for the subject, BODY section with a multi-line input area
// (a tall SettingRow placeholder — caller swaps for a real multi-line
// TextField when adopted), and an ATTACHMENTS section listing files.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { TextButton } from "@mobile-components/button.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component MessageComposerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> subject;
    callback back-pressed();
    callback send-pressed();
    callback add-recipient-pressed();
    callback remove-recipient-pressed();
    callback remove-attachment-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "New message";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
            // Trailing slot: tap area only — text label below.
        }
        // Send action — kept inline as a TextButton anchored to the bar's
        // trailing edge via a small overlay row so it can be a text label.
        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            alignment: end;
            TextButton {
                text: "Send";
                clicked => { root.send-pressed(); }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- TO ---------------------------------------------------
                FormSection {
                    title: "TO";

                    SettingRow {
                        title: "Ada Lovelace";
                        subtitle: "+32 478 12 34 · ada@analyticalengine.uk";
                        clicked => { root.remove-recipient-pressed(); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/plus.svg");
                        tone: Tone.info;
                        title: "Add recipient";
                        clicked => { root.add-recipient-pressed(); }
                    }
                }

                // ----- Subject ----------------------------------------------
                FormField {
                    label: "Subject";
                    TextField {
                        placeholder: "Subject";
                        text <=> root.subject;
                    }
                }

                // ----- BODY -------------------------------------------------
                FormSection {
                    title: "BODY";

                    SettingRow {
                        title: "Write your message…";
                        subtitle: "Use this space for a longer note. The text will wrap and grow vertically as you type — most adopters drop a real multi-line TextField in here at integration time.";
                    }
                }

                // ----- ATTACHMENTS ------------------------------------------
                FormSection {
                    title: "ATTACHMENTS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.info;
                        title: "report.pdf";
                        subtitle: "412 KB";
                        clicked => { root.remove-attachment-pressed("report.pdf"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.success;
                        title: "screenshot.png";
                        subtitle: "88 KB";
                        clicked => { root.remove-attachment-pressed("screenshot.png"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
