// ContactDetailPage
// =====================================================================
//
// A single contact's full detail page. Hero block with large Avatar,
// name and supporting line, then a chip-style MetaRow with stats,
// then a row of 4 quick-action IconButton-styled tiles, then grouped
// KeyValueRow + SettingRow sections for CONTACT / NOTES / SHARED.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

component QuickAction inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-width: 0;
    height: 72px;
    border-radius: Theme.radius-md;
    background: touch.pressed ? Theme.surface-pressed : Theme.surface-1;
    animate background { duration: Theme.motion-fast; }

    VerticalLayout {
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-xs;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Image {
                width: 22px;
                height: 22px;
                source: root.icon;
                colorize: Theme.primary;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: Theme.muted;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.5px;
            }
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component ContactDetailPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback edit-pressed();
    callback action-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Contact";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/pencil.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.edit-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: stretch;

                // ----- Hero --------------------------------------------------
                VerticalLayout {
                    spacing: Theme.spacing-sm;

                    HorizontalLayout {
                        alignment: center;
                        Avatar {
                            fallback: "AL";
                            size: 96px;
                        }
                    }

                    HorizontalLayout {
                        alignment: center;
                        Heading {
                            text: "Ada Lovelace";
                            style: HeadingStyle.serif-display;
                            color: Theme.on-background;
                            font-size: 24px;
                            horizontal-alignment: center;
                        }
                    }
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "Mathematician · Brussels";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            horizontal-alignment: center;
                        }
                    }

                    MetaRow {
                        items: [
                            { icon: @image-url("@mobile-components/icons/profile.svg"), text: "12 mutual" },
                            { icon: @image-url("@mobile-components/icons/star.svg"), text: "since 2024" },
                        ];
                    }
                }

                // ----- Quick actions ----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    HorizontalLayout {
                        spacing: Theme.spacing-lg;
                        alignment: stretch;
                        QuickAction {
                            icon: @image-url("@mobile-components/icons/bell.svg");
                            label: "CALL";
                            clicked => { root.action-pressed("call"); }
                        }
                        QuickAction {
                            icon: @image-url("@mobile-components/icons/inbox.svg");
                            label: "MSG";
                            clicked => { root.action-pressed("message"); }
                        }
                        QuickAction {
                            icon: @image-url("@mobile-components/icons/send.svg");
                            label: "SEND";
                            clicked => { root.action-pressed("send"); }
                        }
                        QuickAction {
                            icon: @image-url("@mobile-components/icons/star.svg");
                            label: "STAR";
                            clicked => { root.action-pressed("star"); }
                        }
                    }
                }

                // ----- CONTACT ----------------------------------------------
                FormSection {
                    title: "CONTACT";
                    KeyValueRow { label: "Phone"; value: "+32 478 12 34"; }
                    Divider { }
                    KeyValueRow { label: "Email"; value: "ada@analyticalengine.uk"; }
                    Divider { }
                    KeyValueRow { label: "Address"; value: "Avenue Louise, BE"; }
                }

                // ----- NOTES ------------------------------------------------
                FormSection {
                    title: "NOTES";
                    SettingRow {
                        title: "Ada's birthday is in December";
                        subtitle: "Send a hand-written card before the 10th — she still keeps the wall above her writing desk reserved for paper.";
                    }
                }

                // ----- SHARED -----------------------------------------------
                FormSection {
                    title: "SHARED";
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.info;
                        title: "Slint design group";
                        subtitle: "8 members · joined 2024";
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "Iteration 13 review";
                        subtitle: "Event · May 6 2026";
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.warning;
                        title: "drawer-shadow-fix.pdf";
                        subtitle: "Shared file · 88 KB";
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
