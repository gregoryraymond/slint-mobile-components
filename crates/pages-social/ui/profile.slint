// ProfilePage
// =====================================================================
//
// Composite template — user profile screen. Demonstrates how the
// catalogue composes hero content (large Avatar, headline, role) with
// stats, primary + secondary actions, and a SegmentedControl driving a
// content sub-view. Useful as scaffolding for social-app profiles,
// settings → account screens, contact details pages, etc.
//
// The content under the SegmentedControl is intentionally a placeholder
// `Skeleton` block — slot in real content per app.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Skeleton } from "@mobile-components/skeleton.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { ScrollView } from "std-widgets.slint";

component StatColumn inherits Rectangle {
    in property <string> count;
    in property <string> label;

    horizontal-stretch: 1;

    VerticalLayout {
        alignment: center;
        spacing: 2px;
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.count;
                color: Theme.on-background;
                font-family: "JetBrains Mono";
                font-size: Theme.font-size-title;
                font-weight: 700;
                horizontal-alignment: center;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: Theme.muted;
                font-family: "Inter";
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1.5px;
                horizontal-alignment: center;
            }
        }
    }
}

export component ProfilePage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> display-name: "Petra Lindquist";
    in property <string> handle: "@petra · Design Engineer";
    in property <string> bio: "Building the slint-mobile-components design system. Ex-Linear. Ferments hot sauce on weekends.";
    in property <string> posts-count: "248";
    in property <string> following-count: "184";
    in property <string> followers-count: "2.6k";
    in property <string> avatar-initials: "PL";
    in-out property <int> tab-index: 0;
    callback back-pressed();
    callback more-pressed();
    callback edit-pressed();
    callback share-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Profile";
            title-style: HeadingStyle.serif-light;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.more-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding: Theme.spacing-lg;
                spacing: Theme.spacing-lg;

                // ----- Hero block: avatar + name + handle + bio -----
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    HorizontalLayout {
                        alignment: center;
                        Avatar {
                            fallback: root.avatar-initials;
                            size: 88px;
                        }
                    }

                    VerticalLayout {
                        spacing: Theme.spacing-xs;
                        HorizontalLayout {
                            alignment: center;
                            Heading {
                                style: HeadingStyle.serif-display;
                                text: root.display-name;
                                horizontal-alignment: center;
                            }
                        }
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: root.handle;
                                color: Theme.muted;
                                font-size: Theme.font-size-body;
                                horizontal-alignment: center;
                            }
                        }
                    }

                    Text {
                        text: root.bio;
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body-large;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                // ----- Stats row -----
                HorizontalLayout {
                    alignment: stretch;
                    spacing: Theme.spacing-md;
                    StatColumn { count: root.posts-count; label: "POSTS"; }
                    StatColumn { count: root.following-count; label: "FOLLOWING"; }
                    StatColumn { count: root.followers-count; label: "FOLLOWERS"; }
                }

                // ----- Actions -----
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    MobileButton {
                        text: "Edit profile";
                        primary: true;
                        clicked => { root.edit-pressed(); }
                    }
                    MobileButton {
                        text: "Share";
                        primary: false;
                        clicked => { root.share-pressed(); }
                    }
                }

                // ----- Sub-view selector -----
                SegmentedControl {
                    options: ["Posts", "Replies", "Likes"];
                    selected-index <=> root.tab-index;
                }

                // ----- Placeholder content under the sub-tabs -----
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    for _ in [0, 1, 2]: VerticalLayout {
                        spacing: Theme.spacing-sm;
                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            Skeleton {
                                width: 40px;
                                height: 40px;
                                border-radius: Theme.radius-lg;
                            }
                            VerticalLayout {
                                spacing: Theme.spacing-sm;
                                alignment: center;
                                horizontal-stretch: 1;
                                Skeleton { height: 14px; }
                                Skeleton { height: 12px; }
                            }
                        }
                    }
                }
            }
        }
    }
}
