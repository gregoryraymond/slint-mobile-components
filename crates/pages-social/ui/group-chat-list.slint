// GroupChatListPage
// =====================================================================
//
// List of group conversations — the Messages / WhatsApp / Telegram
// inbox screen for groups specifically (distinct from `InboxPage` and
// the single-conversation `ChatPage`). Demonstrates:
//
//   - "Stacked avatar cluster" leading column: each group row leads
//     with up to three avatars overlapping each other at -8 px offsets
//     so the cluster reads as "these are the people in the group" at
//     a glance.
//   - Per-row meta: group name + last-message preview (with sender
//     prefix), trailing timestamp + unread Badge count.
//   - Pinned / muted state tone-cues: a pin glyph on the meta row for
//     pinned groups, a muted-bell glyph for muted ones.
//   - Search field anchored to the top + Fab to compose a new group
//     chat anchored to the bottom-right.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Badge } from "@mobile-components/badge.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Fab } from "@mobile-components/button.slint";

// 3-avatar stacked cluster — first avatar in the standard position,
// second offset right -8 px (overlapping), third offset right -16 px.
// All three are 36 × 36 with a 2 px background-coloured ring so they
// read as distinct discs against each other.
component AvatarCluster inherits Rectangle {
    in property <string> a-initials;
    in property <string> b-initials;
    in property <string> c-initials;

    width: 64px;
    height: 44px;

    // Third (back).
    Rectangle {
        x: 28px;
        y: 4px;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.c-initials;
            size: 32px;
        }
    }
    // Second.
    Rectangle {
        x: 14px;
        y: 4px;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.b-initials;
            size: 32px;
        }
    }
    // First (front).
    Rectangle {
        x: 0;
        y: 4px;
        width: 36px;
        height: 36px;
        border-radius: self.width / 2;
        background: Theme.background;
        Avatar {
            x: 2px;
            y: 2px;
            width: 32px;
            height: 32px;
            fallback: root.a-initials;
            size: 32px;
        }
    }
}

// One group row.
component GroupRow inherits Rectangle {
    in property <string> group-name;
    in property <string> sender;
    in property <string> message;
    in property <string> when;
    in property <int> unread: 0;
    in property <bool> pinned: false;
    in property <bool> muted: false;
    in property <bool> typing: false;
    in property <string> a-initials;
    in property <string> b-initials;
    in property <string> c-initials;
    callback clicked();

    accessible-role: button;
    accessible-label: root.group-name;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-height: 72px;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Avatar cluster.
        VerticalLayout {
            alignment: center;
            AvatarCluster {
                a-initials: root.a-initials;
                b-initials: root.b-initials;
                c-initials: root.c-initials;
            }
        }

        // Meta block.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                alignment: stretch;
                Text {
                    text: root.group-name;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body;
                    font-weight: root.unread > 0 ? 700 : 600;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                if root.pinned: Image {
                    width: 14px;
                    height: 14px;
                    source: @image-url("@mobile-components/icons/pin.svg");
                    colorize: Theme.muted;
                    image-fit: contain;
                    vertical-alignment: center;
                }
                if root.muted: Image {
                    width: 14px;
                    height: 14px;
                    source: @image-url("@mobile-components/icons/bell.svg");
                    colorize: Theme.muted;
                    image-fit: contain;
                    vertical-alignment: center;
                    opacity: 0.5;
                }
            }
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                Text {
                    text: root.sender + ": ";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                }
                Text {
                    text: root.message;
                    color: root.typing ? Theme.accent-success : (root.unread > 0 ? Theme.on-surface : Theme.muted);
                    font-size: Theme.font-size-caption;
                    overflow: elide;
                    horizontal-stretch: 1;
                    font-weight: root.unread > 0 ? 500 : 400;
                }
            }
        }

        // Right column: when + badge.
        VerticalLayout {
            alignment: center;
            spacing: 4px;
            Text {
                text: root.when;
                color: root.unread > 0 ? Theme.accent-info : Theme.muted;
                font-size: Theme.font-size-caption;
                font-weight: root.unread > 0 ? 700 : 500;
                horizontal-alignment: right;
            }
            HorizontalLayout {
                alignment: end;
                if root.unread > 0: Badge {
                    count: root.unread;
                }
            }
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component GroupChatListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    callback back-pressed();
    callback new-group-pressed();
    callback group-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Groups";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
        }

        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-sm;
            padding-bottom: Theme.spacing-sm;
            TextField {
                label: "";
                placeholder: "Search groups…";
            }
        }

        SectionHeader { text: "PINNED"; }
        GroupRow {
            group-name: "Slint mobile-components";
            sender: "Priya";
            message: "Approved the Tone-enum PR. Ship it 🚀";
            when: "14:32";
            unread: 3;
            pinned: true;
            a-initials: "PR";
            b-initials: "AR";
            c-initials: "DV";
            clicked => { root.group-pressed(self.group-name); }
        }
        Divider { }
        GroupRow {
            group-name: "Family · Raymonds";
            sender: "Mum";
            message: "is typing…";
            when: "13:48";
            unread: 0;
            pinned: true;
            typing: true;
            a-initials: "M";
            b-initials: "D";
            c-initials: "ER";
            clicked => { root.group-pressed(self.group-name); }
        }

        SectionHeader { text: "ALL GROUPS"; }
        GroupRow {
            group-name: "Slint Conf 2026 organisers";
            sender: "Tomás";
            message: "Catered lunch confirmed for Thursday — 80 covers.";
            when: "11:02";
            unread: 12;
            a-initials: "TM";
            b-initials: "LE";
            c-initials: "MK";
            clicked => { root.group-pressed(self.group-name); }
        }
        Divider { }
        GroupRow {
            group-name: "Friday hike crew";
            sender: "Léa";
            message: "Trail report: Mt Tam fire road still washed out from the storm.";
            when: "yesterday";
            unread: 0;
            muted: true;
            a-initials: "LE";
            b-initials: "GR";
            c-initials: "SY";
            clicked => { root.group-pressed(self.group-name); }
        }
        Divider { }
        GroupRow {
            group-name: "Patagonia design review";
            sender: "Devika";
            message: "Sketch link → figma exported, FYI.";
            when: "yesterday";
            unread: 0;
            a-initials: "DV";
            b-initials: "AR";
            c-initials: "PR";
            clicked => { root.group-pressed(self.group-name); }
        }
        Divider { }
        GroupRow {
            group-name: "Lisbon trip · May 14–19";
            sender: "Marco";
            message: "Anyone got reco for fado in Alfama? Mesa de Frades good?";
            when: "Mon";
            unread: 5;
            a-initials: "MK";
            b-initials: "GR";
            c-initials: "LE";
            clicked => { root.group-pressed(self.group-name); }
        }
        Divider { }
        GroupRow {
            group-name: "Book club — May read";
            sender: "Sarah";
            message: "Voted: The Origin of Programming Languages. Discussion Thu.";
            when: "Sun";
            unread: 0;
            muted: true;
            a-initials: "SY";
            b-initials: "AR";
            c-initials: "GR";
            clicked => { root.group-pressed(self.group-name); }
        }

        Rectangle { vertical-stretch: 1; }
    }

    Fab {
        x: root.width - self.width - Theme.spacing-md;
        y: root.height - self.height - Theme.spacing-md;
        accessible-label: "New group";
        clicked => { root.new-group-pressed(); }
    }
}
