// GroupChatListPage
// =====================================================================
//
// List of group conversations. Search field at the top, then two
// FormSection groups (PINNED, ALL CHATS), each row a SettingRow with
// a trailing unread-count Chip — guaranteed to align across rows.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component GroupChatListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> query;
    callback back-pressed();
    callback new-pressed();
    callback chat-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Groups";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.new-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                FormField {
                    label: "";
                    TextField {
                        placeholder: "Search groups";
                        text <=> root.query;
                    }
                }

                // ----- PINNED -----------------------------------------------
                FormSection {
                    title: "PINNED";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "Family group";
                        subtitle: "Sarah: see you Sunday! · 12:42";
                        clicked => { root.chat-pressed("family"); }
                        Chip { label: "3"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "Saturday hikers";
                        subtitle: "Bao: trail starts at 08:00 sharp · 11:08";
                        clicked => { root.chat-pressed("hikers"); }
                        Chip { label: "1"; }
                    }
                }

                // ----- ALL CHATS --------------------------------------------
                FormSection {
                    title: "ALL CHATS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Slint design crew";
                        subtitle: "Petra: pushed the Tone enum branch · 10:34";
                        clicked => { root.chat-pressed("design"); }
                        Chip { label: "12"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Brussels marathon 2026";
                        subtitle: "Camille: registration opens Monday · 09:12";
                        clicked => { root.chat-pressed("marathon"); }
                        Chip { label: "2"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Vinyl swap";
                        subtitle: "Chen: photo of the Ryo Fukui original · Yest";
                        clicked => { root.chat-pressed("vinyl"); }
                        Chip { label: "5"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Office logistics";
                        subtitle: "Anika: coffee machine is on the blink · Mon";
                        clicked => { root.chat-pressed("office"); }
                        Chip { label: "1"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Book club — autumn";
                        subtitle: "Cosmin: chapter 12 by Friday · Sun";
                        clicked => { root.chat-pressed("book"); }
                        Chip { label: "8"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Apartment building";
                        subtitle: "Beatriz: lift maintenance Wednesday · Sat";
                        clicked => { root.chat-pressed("apartment"); }
                        Chip { label: "4"; }
                    }
                }
            }
        }
    }
}
