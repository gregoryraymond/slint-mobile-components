// NewsArticleFeedPage
// =====================================================================
//
// Headlines feed — six articles below a category SegmentedControl.
// Articles need more visual space than a SettingRow can offer, so each
// is rendered as a Card with title, source/timestamp, teaser body, and
// a MetaRow of small chips. The Cards stack with `spacing-md` so their
// outer edges align at the standard 16px page inset.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Card } from "@mobile-components/card.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { ScrollView } from "std-widgets.slint";

component Article inherits Card {
    in property <string> headline;
    in property <string> source-line;
    in property <string> teaser;
    in property <string> read-time;
    in property <string> category;

    Heading {
        text: root.headline;
        style: HeadingStyle.plex-medium;
        color: Theme.on-surface;
        font-size: 18px;
        wrap: word-wrap;
    }
    Text {
        text: root.source-line;
        color: Theme.muted;
        font-size: Theme.font-size-caption;
    }
    Text {
        text: root.teaser;
        color: Theme.on-surface;
        font-size: Theme.font-size-body;
        wrap: word-wrap;
    }
    MetaRow {
        items: [
            { icon: @image-url("@mobile-components/icons/star.svg"), text: root.read-time },
            { icon: @image-url("@mobile-components/icons/pin.svg"), text: root.category },
        ];
    }
}

export component NewsArticleFeedPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> category-index: 0;
    callback back-pressed();
    callback search-pressed();
    callback article-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Headlines";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/search.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.search-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                SegmentedControl {
                    options: ["Top", "Local", "Tech", "Sport", "World"];
                    selected-index <=> root.category-index;
                }

                Article {
                    headline: "Quiet streets see unexpected return of commuter cyclists";
                    source-line: "BBC · 2 hours ago";
                    teaser: "New counters in three boroughs show double-digit growth — planners credit pop-up lanes that survived the winter.";
                    read-time: "5 min read";
                    category: "World";
                }
                Article {
                    headline: "Slint releases mobile-components 0.4 — Tone enum lands";
                    source-line: "The Register · 3 hours ago";
                    teaser: "Status colours across 31 widgets now flow from a single source. Adopters report cleaner code and tidier design reviews.";
                    read-time: "4 min read";
                    category: "Tech";
                }
                Article {
                    headline: "Brussels marathon opens 2026 registration on Monday";
                    source-line: "RTBF · 5 hours ago";
                    teaser: "Course tweaks add a kilometre through the Bois de la Cambre. Organisers expect 28 000 runners by closing day.";
                    read-time: "3 min read";
                    category: "Sport";
                }
                Article {
                    headline: "Why Android 15's edge-to-edge default broke half the apps you love";
                    source-line: "The Verge · 8 hours ago";
                    teaser: "The system-bar overlay rule is now opt-out — many developers haven't noticed yet, and users are starting to see clipped UIs.";
                    read-time: "6 min read";
                    category: "Tech";
                }
                Article {
                    headline: "Independent bookshops post fourth straight year of growth";
                    source-line: "The Guardian · 11 hours ago";
                    teaser: "Children's titles and translated literary fiction lead the surge. Average shop revenue up 7.4 % on 2024.";
                    read-time: "5 min read";
                    category: "Local";
                }
                Article {
                    headline: "Open-source typeface revival: Fraunces gets a numerals refresh";
                    source-line: "Type Network · 1 day ago";
                    teaser: "Designer Phaedra Charles has shipped a long-promised tabular numerals pass, making the family viable for data-heavy UIs.";
                    read-time: "4 min read";
                    category: "Tech";
                }
            }
        }
    }
}
