// VideoCallPage
// =====================================================================
//
// Active video-call screen. No standard AppBar — a tiny transparent
// top strip carries the call timer and a close icon. Main body is a
// large faux remote-video Rectangle filling most of the viewport, with
// a small picture-in-picture self-video tile floated in the top-right.
// Bottom controls bar holds five round IconButton-style actions.

import { Theme } from "@mobile-theme/theme.slint";

component CallControl inherits Rectangle {
    in property <image> icon;
    in property <bool> danger: false;
    in property <string> a11y-label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.a11y-label;
    accessible-action-default => { root.clicked(); }

    width: 56px;
    height: 56px;
    border-radius: self.width / 2;
    background: root.danger
        ? (touch.pressed ? Theme.accent-danger.darker(0.15) : Theme.accent-danger)
        : (touch.pressed ? Theme.surface-pressed : Theme.surface-1);
    animate background { duration: Theme.motion-fast; }

    Image {
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.danger ? Theme.on-primary : Theme.on-surface;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component VideoCallPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in property <string> partner-name: "Ada Lovelace";
    in property <string> timer: "00:12:47";

    callback hangup-pressed();
    callback toggle-mic();
    callback toggle-video();
    callback share-pressed();
    callback more-pressed();
    callback close-pressed();

    background: Theme.background;

    // ----- Remote video (full-screen background) ---------------------
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-3;

        Text {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            text: root.partner-name;
            color: Theme.on-surface;
            font-size: Theme.font-size-headline;
            font-weight: 700;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // ----- Top strip: timer + close ----------------------------------
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: 48px;
        background: transparent;

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            alignment: stretch;

            Text {
                text: root.timer;
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 600;
                vertical-alignment: center;
                horizontal-stretch: 1;
            }

            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: self.width / 2;
                background: close-touch.pressed ? Theme.surface-pressed : transparent;
                animate background { duration: Theme.motion-fast; }

                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/close.svg");
                    colorize: Theme.on-background;
                    image-fit: contain;
                }

                close-touch := TouchArea {
                    clicked => { root.close-pressed(); }
                }
            }
        }
    }

    // ----- PiP self video --------------------------------------------
    Rectangle {
        x: parent.width - self.width - Theme.spacing-md;
        y: Theme.spacing-md + 48px;
        width: 120px;
        height: 160px;
        background: Theme.surface-2;
        border-radius: Theme.radius-md;
        clip: true;

        Text {
            x: 0;
            y: 0;
            width: parent.width;
            height: parent.height;
            text: "You";
            color: Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 600;
            horizontal-alignment: center;
            vertical-alignment: center;
        }
    }

    // ----- Bottom controls -------------------------------------------
    Rectangle {
        x: Theme.spacing-md;
        y: parent.height - self.height - Theme.spacing-lg;
        width: parent.width - 2 * Theme.spacing-md;
        height: 80px;
        background: Theme.surface-2.with-alpha(0.5);
        border-radius: Theme.radius-lg;

        HorizontalLayout {
            padding: Theme.spacing-sm;
            spacing: Theme.spacing-md;
            alignment: center;

            CallControl {
                icon: @image-url("@mobile-components/icons/pause.svg");
                a11y-label: "Mute microphone";
                clicked => { root.toggle-mic(); }
            }
            CallControl {
                icon: @image-url("@mobile-components/icons/play.svg");
                a11y-label: "Toggle video";
                clicked => { root.toggle-video(); }
            }
            CallControl {
                icon: @image-url("@mobile-components/icons/send.svg");
                a11y-label: "Share screen";
                clicked => { root.share-pressed(); }
            }
            CallControl {
                icon: @image-url("@mobile-components/icons/more-vertical.svg");
                a11y-label: "More options";
                clicked => { root.more-pressed(); }
            }
            CallControl {
                icon: @image-url("@mobile-components/icons/close.svg");
                danger: true;
                a11y-label: "End call";
                clicked => { root.hangup-pressed(); }
            }
        }
    }
}
