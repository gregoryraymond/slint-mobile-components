// PostDetailPage
// =====================================================================
//
// Single post with replies. Hero Card carries the author row, post
// body, MetaRow of stats, then a row of three action IconButtons.
// Replies live in a FormSection of SettingRows (avatar tile + author
// timestamp + reply body + heart count trailing). A sticky composer
// is anchored to the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Card } from "@mobile-components/card.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { BottomBar } from "@mobile-components/bottom-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

component PostAction inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-width: 0;
    height: 48px;
    border-radius: Theme.radius-md;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        spacing: Theme.spacing-xs;
        alignment: center;
        Image {
            width: 18px;
            height: 18px;
            source: root.icon;
            colorize: Theme.primary;
            image-fit: contain;
        }
        Text {
            text: root.label;
            color: Theme.primary;
            font-size: Theme.font-size-body;
            font-weight: 600;
            vertical-alignment: center;
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component LikeTrailing inherits HorizontalLayout {
    in property <string> count;
    spacing: Theme.spacing-xs;
    alignment: center;

    Image {
        width: 14px;
        height: 14px;
        source: @image-url("@mobile-components/icons/heart.svg");
        colorize: Theme.muted;
        image-fit: contain;
    }
    Text {
        text: root.count;
        color: Theme.muted;
        font-size: Theme.font-size-caption;
        vertical-alignment: center;
    }
}

export component PostDetailPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> draft;
    callback back-pressed();
    callback like-pressed();
    callback reply-pressed();
    callback share-pressed();
    callback send-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Post";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Hero post -------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        HorizontalLayout {
                            spacing: Theme.spacing-sm;
                            alignment: stretch;
                            Avatar { fallback: "PL"; size: 40px; }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Text {
                                    text: "Petra Lindquist";
                                    color: Theme.on-surface;
                                    font-size: Theme.font-size-body;
                                    font-weight: 600;
                                }
                                Text {
                                    text: "@petra · Design Engineer";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                            }
                        }

                        Text {
                            text: "Shipped the Tone enum refactor today. Every status colour in the catalogue now flows from one source — Snackbar, Banner, MobileButton, the leading-icon tile on every SettingRow. Reviewers can finally just point at one symbol. Fewer surprises in the design review meeting tomorrow, hopefully.";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            wrap: word-wrap;
                        }

                        MetaRow {
                            items: [
                                { text: "5 May" },
                                { icon: @image-url("@mobile-components/icons/heart.svg"), text: "245 likes" },
                                { icon: @image-url("@mobile-components/icons/inbox.svg"), text: "12 replies" },
                            ];
                        }

                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;
                            PostAction {
                                icon: @image-url("@mobile-components/icons/heart.svg");
                                label: "Like";
                                clicked => { root.like-pressed(); }
                            }
                            PostAction {
                                icon: @image-url("@mobile-components/icons/send.svg");
                                label: "Reply";
                                clicked => { root.reply-pressed(); }
                            }
                            PostAction {
                                icon: @image-url("@mobile-components/icons/chevron-right.svg");
                                label: "Share";
                                clicked => { root.share-pressed(); }
                            }
                        }
                    }
                }

                // ----- Top replies ------------------------------------------
                FormSection {
                    title: "TOP REPLIES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "@ada · 4h";
                        subtitle: "Beautiful — and now the design review checklist is half its old length because we don't enumerate per-component status colours.";
                        LikeTrailing { count: "32"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "@anika · 5h";
                        subtitle: "Going to point my team at this on Monday. We have a near-identical refactor lined up for our internal component library.";
                        LikeTrailing { count: "18"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "@bao · 9h";
                        subtitle: "Does the Tone enum also drive the Banner action-label colour now, or is that follow-up work?";
                        LikeTrailing { count: "7"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "@cyril · 12h";
                        subtitle: "Bookmarking — please write up the migration notes when you get a chance.";
                        LikeTrailing { count: "4"; }
                    }
                }
            }
        }

        // ----- Sticky composer ------------------------------------------
        BottomBar {
            HorizontalLayout {
                padding: Theme.spacing-sm;
                spacing: Theme.spacing-sm;
                alignment: stretch;

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    TextField {
                        placeholder: "Reply…";
                        text <=> root.draft;
                    }
                }

                Rectangle {
                    width: 48px;
                    height: 48px;
                    border-radius: self.width / 2;
                    background: send-touch.pressed ? Theme.primary-pressed : Theme.primary;
                    accessible-role: button;
                    accessible-label: "Send reply";
                    accessible-action-default => { root.send-pressed(root.draft); }
                    animate background { duration: Theme.motion-fast; }

                    Image {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: Theme.on-primary;
                        image-fit: contain;
                    }

                    send-touch := TouchArea {
                        clicked => { root.send-pressed(root.draft); }
                    }
                }
            }
        }
    }
}
