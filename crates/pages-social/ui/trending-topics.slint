// TrendingTopicsPage
// =====================================================================
//
// Trending hashtags / topics. Two FormSection groups (TRENDING NEAR
// YOU, GLOBAL), each row a SettingRow with a small rank-text trailing
// so the rank column lines up at one shared right margin.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

component RankText inherits Text {
    color: Theme.muted;
    font-size: Theme.font-size-body;
    font-weight: 700;
    vertical-alignment: center;
    horizontal-alignment: right;
}

export component TrendingTopicsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> window-index: 0;
    callback back-pressed();
    callback topic-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Trending";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Now", "Today", "Week"];
                        selected-index <=> root.window-index;
                    }
                }

                // ----- TRENDING NEAR YOU -----------------------------------
                FormSection {
                    title: "TRENDING NEAR YOU";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "#brusselsmarathon";
                        subtitle: "Sport · 12.4K posts";
                        clicked => { root.topic-pressed("brusselsmarathon"); }
                        RankText { text: "#1"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "#metrol2";
                        subtitle: "City · 8.1K posts";
                        clicked => { root.topic-pressed("metrol2"); }
                        RankText { text: "#2"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.danger;
                        title: "#frietfest";
                        subtitle: "Food · 6.5K posts";
                        clicked => { root.topic-pressed("frietfest"); }
                        RankText { text: "#3"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "#parclouise";
                        subtitle: "Local · 5.2K posts";
                        clicked => { root.topic-pressed("parclouise"); }
                        RankText { text: "#4"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.default;
                        title: "#stibstrike";
                        subtitle: "News · 4.8K posts";
                        clicked => { root.topic-pressed("stibstrike"); }
                        RankText { text: "#5"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.info;
                        title: "#kunstenfestival";
                        subtitle: "Culture · 3.9K posts";
                        clicked => { root.topic-pressed("kunstenfestival"); }
                        RankText { text: "#6"; }
                    }
                }

                // ----- GLOBAL ----------------------------------------------
                FormSection {
                    title: "GLOBAL";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.info;
                        title: "#worldcup2026";
                        subtitle: "Sport · 2.4M posts";
                        clicked => { root.topic-pressed("worldcup2026"); }
                        RankText { text: "#1"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "#climatecop";
                        subtitle: "Politics · 1.8M posts";
                        clicked => { root.topic-pressed("climatecop"); }
                        RankText { text: "#2"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.danger;
                        title: "#designsystems";
                        subtitle: "Tech · 942K posts";
                        clicked => { root.topic-pressed("designsystems"); }
                        RankText { text: "#3"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "#rustlang";
                        subtitle: "Tech · 814K posts";
                        clicked => { root.topic-pressed("rustlang"); }
                        RankText { text: "#4"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.default;
                        title: "#bakeoff";
                        subtitle: "Entertainment · 624K posts";
                        clicked => { root.topic-pressed("bakeoff"); }
                        RankText { text: "#5"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.info;
                        title: "#sundaylongread";
                        subtitle: "Culture · 318K posts";
                        clicked => { root.topic-pressed("sundaylongread"); }
                        RankText { text: "#6"; }
                    }
                }
            }
        }
    }
}
