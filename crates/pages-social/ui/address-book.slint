// AddressBookPage
// =====================================================================
//
// Contacts list with alphabet section headers acting as the implicit
// jump index. Every contact row is a `SettingRow` so the leading-tile
// width, title baseline, subtitle alignment, and trailing chevron all
// line up across the whole list.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component AddressBookPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> query;
    callback back-pressed();
    callback add-pressed();
    callback contact-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Contacts";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.add-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Search ------------------------------------------------
                FormField {
                    label: "";
                    TextField {
                        placeholder: "Search";
                        text <=> root.query;
                    }
                }

                // ----- A -----------------------------------------------------
                FormSection {
                    title: "A";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Ada Lovelace";
                        subtitle: "+32 478 12 34 · ada@analyticalengine.uk";
                        clicked => { root.contact-pressed("ada"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "Anika Ravi";
                        subtitle: "+44 207 555 18 · anika@slint.dev";
                        clicked => { root.contact-pressed("anika"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "Aurélien Mercier";
                        subtitle: "+33 6 12 88 04 · a.mercier@beton.fr";
                        clicked => { root.contact-pressed("aurelien"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- B -----------------------------------------------------
                FormSection {
                    title: "B";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.default;
                        title: "Bao Nguyen";
                        subtitle: "+84 28 3927 11 · bao@ricecreek.vn";
                        clicked => { root.contact-pressed("bao"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "Beatriz Salgado";
                        subtitle: "+351 21 887 02 · beatriz@porto.pt";
                        clicked => { root.contact-pressed("beatriz"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- C -----------------------------------------------------
                FormSection {
                    title: "C";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Camille Dupont";
                        subtitle: "+32 478 41 22 · camille@brussels.be";
                        clicked => { root.contact-pressed("camille"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "Chen Wei";
                        subtitle: "+86 138 0011 23 · chen@shanghai.cn";
                        clicked => { root.contact-pressed("chen"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "Cosmin Ardelean";
                        subtitle: "+40 730 22 19 · cosmin@cluj.ro";
                        clicked => { root.contact-pressed("cosmin"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.default;
                        title: "Cyril Mortemarte";
                        subtitle: "+33 1 47 22 80 · cyril@cinq.fr";
                        clicked => { root.contact-pressed("cyril"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
