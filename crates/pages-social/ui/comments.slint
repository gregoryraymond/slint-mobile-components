// CommentsPage
// =====================================================================
//
// Comment thread under a single post. Parent-post snippet sits in a
// small Card at the top, then a SegmentedControl filter, then a
// FormSection-wrapped list of comments rendered as SettingRows so the
// avatar tile, username/timestamp, comment body, and like count line
// up at the same gutters as every other settings-style page. A sticky
// composer is anchored to the bottom.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Card } from "@mobile-components/card.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { TextButton } from "@mobile-components/button.slint";
import { BottomBar } from "@mobile-components/bottom-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

component LikeTrailing inherits HorizontalLayout {
    in property <string> count;
    spacing: Theme.spacing-xs;
    alignment: center;

    Image {
        width: 14px;
        height: 14px;
        source: @image-url("@mobile-components/icons/heart.svg");
        colorize: Theme.muted;
        image-fit: contain;
    }
    Text {
        text: root.count;
        color: Theme.muted;
        font-size: Theme.font-size-caption;
        vertical-alignment: center;
    }
}

export component CommentsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> filter-index: 0;
    in-out property <string> draft;
    callback back-pressed();
    callback original-pressed();
    callback send-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Comments · 47";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Parent post snippet ----------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        title: "@petra";
                        subtitle: "Shipped the Tone enum refactor today — every status colour now flows from one source.";
                        TextButton {
                            text: "View original";
                            clicked => { root.original-pressed(); }
                        }
                    }
                }

                // ----- Filter -----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Top", "New", "Oldest"];
                        selected-index <=> root.filter-index;
                    }
                }

                // ----- Comments ---------------------------------------------
                FormSection {
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "@ada · 2h";
                        subtitle: "Finally — the Snackbar action button picking up tone is the bit I kept tripping over. Beautiful.";
                        LikeTrailing { count: "24"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "@anika · 4h";
                        subtitle: "Does this mean the Banner action label respects tone now too? That was the one off-by-one I kept seeing on Wallet.";
                        LikeTrailing { count: "12"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.warning;
                        title: "@bao · 6h";
                        subtitle: "Yes, please follow up with a migration note in DESIGN.md so the next contributor doesn't re-grep for the old patterns.";
                        LikeTrailing { count: "8"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.danger;
                        title: "@cyril · 9h";
                        subtitle: "Question: how do you reconcile this with the older accent-pressed tokens? Don't they need a matching tone-aware variant?";
                        LikeTrailing { count: "5"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.default;
                        title: "@chen · 12h";
                        subtitle: "The MetaRow upgrade is also lovely — chips finally line up on a single baseline across recipe / event / contact pages.";
                        LikeTrailing { count: "3"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "@cosmin · 1d";
                        subtitle: "Bookmarking this thread for the next design system review at work.";
                        LikeTrailing { count: "2"; }
                    }
                }
            }
        }

        // ----- Sticky composer ------------------------------------------
        BottomBar {
            HorizontalLayout {
                padding: Theme.spacing-sm;
                spacing: Theme.spacing-sm;
                alignment: stretch;

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    TextField {
                        placeholder: "Add a comment…";
                        text <=> root.draft;
                    }
                }

                Rectangle {
                    width: 48px;
                    height: 48px;
                    border-radius: self.width / 2;
                    background: send-touch.pressed ? Theme.primary-pressed : Theme.primary;
                    accessible-role: button;
                    accessible-label: "Send";
                    accessible-action-default => { root.send-pressed(root.draft); }
                    animate background { duration: Theme.motion-fast; }

                    Image {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: Theme.on-primary;
                        image-fit: contain;
                    }

                    send-touch := TouchArea {
                        clicked => { root.send-pressed(root.draft); }
                    }
                }
            }
        }
    }
}
