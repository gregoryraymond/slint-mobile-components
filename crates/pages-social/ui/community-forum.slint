// CommunityForumPage
// =====================================================================
//
// Forum / message-board listing. Two grouped sections (PINNED, RECENT)
// of topics rendered as SettingRows so the icon tile, title, metadata
// subtitle, and reply-count Chip line up at the same edges as every
// other settings-style page in the catalogue.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component CommunityForumPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> filter-index: 0;
    callback back-pressed();
    callback new-topic-pressed();
    callback topic-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Forum";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.new-topic-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Filter -----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["All", "Unread", "Bookmarks"];
                        selected-index <=> root.filter-index;
                    }
                }

                // ----- PINNED -----------------------------------------------
                FormSection {
                    title: "PINNED";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Welcome — read me first";
                        subtitle: "by Mods · 247 replies · 3.2K views";
                        clicked => { root.topic-pressed("welcome"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Community guidelines & code of conduct";
                        subtitle: "by Mods · 88 replies · 1.4K views";
                        clicked => { root.topic-pressed("guidelines"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- RECENT -----------------------------------------------
                FormSection {
                    title: "RECENT";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.info;
                        title: "Best snapshot threshold for OLED panels?";
                        subtitle: "@petra · 12m ago · 8 replies";
                        clicked => { root.topic-pressed("snapshot"); }
                        Chip { label: "8"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Tone enum vs. per-component variants";
                        subtitle: "@ada · 1h ago · 14 replies";
                        clicked => { root.topic-pressed("tone"); }
                        Chip { label: "14"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.warning;
                        title: "Cargo apk2 vs xbuild on M1 / M3";
                        subtitle: "@bao · 3h ago · 6 replies";
                        clicked => { root.topic-pressed("apk"); }
                        Chip { label: "6"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.danger;
                        title: "Drawer perforation clipping on portrait";
                        subtitle: "@cyril · 5h ago · 22 replies";
                        clicked => { root.topic-pressed("drawer"); }
                        Chip { label: "22"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.default;
                        title: "Best practices for FormField on tablets";
                        subtitle: "@anika · 8h ago · 3 replies";
                        clicked => { root.topic-pressed("formfield"); }
                        Chip { label: "3"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.info;
                        title: "Shipping the catalogue as a Maven library?";
                        subtitle: "@chen · 1d ago · 11 replies";
                        clicked => { root.topic-pressed("maven"); }
                        Chip { label: "11"; }
                    }
                }
            }
        }
    }
}
