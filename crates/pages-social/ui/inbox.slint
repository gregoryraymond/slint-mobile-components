// InboxPage
// =====================================================================
//
// List-view template — works as scaffolding for any inbox / activity /
// message-feed / notification-centre screen. Driven by the shared
// `ContactRow` primitive: Avatar + 2-line text + trailing timestamp +
// unread Badge. Plus an AppBar and compose FAB.
//
// The message data is supplied as a Slint model so consuming apps drive
// it from Rust state; for the demo / snapshot we instantiate the page
// with an inline array literal carrying ~6 sample messages.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Fab } from "@mobile-components/button.slint";
import { ContactRow } from "@mobile-components/contact-row.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { ScrollView } from "std-widgets.slint";

export struct InboxMessage {
    sender: string,
    initials: string,
    preview: string,
    time: string,
    unread: int,   // 0 = read; >0 = unread count
}

export component InboxPage inherits Rectangle {
    in property <[InboxMessage]> messages: [
        { sender: "GitHub", initials: "GH", preview: "tronical commented on slint#5710 — backdrop blur on Android", time: "2m", unread: 3 },
        { sender: "Petra Lindquist", initials: "PL", preview: "Re: design tokens — okay with the surface tier names but…", time: "14m", unread: 1 },
        { sender: "Maestro CI", initials: "MC", preview: "gallery-tabs flow passed on emulator-5554", time: "32m", unread: 0 },
        { sender: "Stripe", initials: "S", preview: "Receipt for your subscription · $20.00 · Oct 28 2026", time: "2h", unread: 0 },
        { sender: "Marco · ops", initials: "MO", preview: "I bumped the snapshot threshold to 0.5 % — let me know if it's", time: "9h", unread: 0 },
        { sender: "Linear", initials: "L", preview: "ENG-218 was moved to In Review by Petra", time: "Mon", unread: 0 },
    ];
    callback message-pressed(InboxMessage);
    callback compose-pressed();
    callback menu-pressed();
    callback search-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Inbox";
            leading-icon: @image-url("@mobile-components/icons/menu.svg");
            trailing-icon: @image-url("@mobile-components/icons/search.svg");
            leading-pressed => { root.menu-pressed(); }
            trailing-pressed => { root.search-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                alignment: start;
                padding-top: Theme.spacing-sm;

                SectionHeader { text: "TODAY"; }

                for msg in root.messages: ContactRow {
                    initials: msg.initials;
                    avatar-size: 44px;
                    title: msg.sender;
                    subtitle: msg.preview;
                    trailing-text: msg.time;
                    badge-count: msg.unread;
                    emphasized: msg.unread > 0;
                    clicked => { root.message-pressed(msg); }
                }
            }
        }
    }

    Fab {
        x: parent.width - self.width - Theme.spacing-md;
        y: parent.height - self.height - Theme.spacing-md;
        icon: @image-url("@mobile-components/icons/pencil.svg");
        accessible-label: "Compose";
        clicked => { root.compose-pressed(); }
    }
}
