// PostCreatorPage
// =====================================================================
//
// New social post editor. Close + Post text-button in the bar, a tiny
// audience-selector hero row, a long-form FormField text input,
// ATTACHMENTS section with one tile, OPTIONS section with three toggle
// SettingRows + MobileSwitch trailing, and a row of 4 attach IconTiles.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { TextButton } from "@mobile-components/button.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

component AttachTile inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-width: 0;
    height: 64px;
    border-radius: Theme.radius-md;
    background: touch.pressed ? Theme.surface-pressed : Theme.surface-1;
    animate background { duration: Theme.motion-fast; }

    VerticalLayout {
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-xs;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Image {
                width: 22px;
                height: 22px;
                source: root.icon;
                colorize: Theme.primary;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: Theme.muted;
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 0.5px;
            }
        }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component PostCreatorPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> body;
    in-out property <bool> allow-replies: true;
    in-out property <bool> show-profile: true;
    in-out property <bool> schedule: false;
    callback close-pressed();
    callback post-pressed();
    callback audience-pressed();
    callback attach-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            leading-icon: @image-url("@mobile-components/icons/close.svg");
            leading-pressed => { root.close-pressed(); }
        }

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            alignment: end;
            TextButton {
                text: "Post";
                clicked => { root.post-pressed(); }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Hero row ---------------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    Avatar { fallback: "GR"; size: 40px; }

                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: "Greg Raymond";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 600;
                        }
                        Text {
                            text: "@greg";
                            color: Theme.muted;
                            font-size: Theme.font-size-caption;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Chip {
                            label: "Public";
                            leading-icon: @image-url("@mobile-components/icons/profile.svg");
                            clicked => { root.audience-pressed(); }
                        }
                    }
                }

                // ----- Body input -------------------------------------------
                FormField {
                    label: "Post";
                    helper: "280 characters";
                    TextField {
                        placeholder: "What's happening?";
                        text <=> root.body;
                    }
                }

                // ----- ATTACHMENTS ------------------------------------------
                FormSection {
                    title: "ATTACHMENTS";
                    SettingRow {
                        title: "Add a photo / video";
                        subtitle: "JPEG · PNG · MP4 · up to 200 MB";
                        clicked => { root.attach-pressed("media"); }
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/plus.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                }

                // ----- OPTIONS ----------------------------------------------
                FormSection {
                    title: "OPTIONS";
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.info;
                        title: "Allow replies";
                        subtitle: "Anyone can reply to this post.";
                        MobileSwitch { checked <=> root.allow-replies; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.success;
                        title: "Show on profile";
                        subtitle: "Pin to your profile feed.";
                        MobileSwitch { checked <=> root.show-profile; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.warning;
                        title: "Schedule for later";
                        subtitle: "Pick a date and time before sending.";
                        MobileSwitch { checked <=> root.schedule; }
                    }
                }

                // ----- Attach row -------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    HorizontalLayout {
                        spacing: Theme.spacing-lg;
                        alignment: stretch;
                        AttachTile {
                            icon: @image-url("@mobile-components/icons/photo-coral.svg");
                            label: "IMAGE";
                            clicked => { root.attach-pressed("image"); }
                        }
                        AttachTile {
                            icon: @image-url("@mobile-components/icons/play.svg");
                            label: "GIF";
                            clicked => { root.attach-pressed("gif"); }
                        }
                        AttachTile {
                            icon: @image-url("@mobile-components/icons/queue.svg");
                            label: "POLL";
                            clicked => { root.attach-pressed("poll"); }
                        }
                        AttachTile {
                            icon: @image-url("@mobile-components/icons/pin.svg");
                            label: "PLACE";
                            clicked => { root.attach-pressed("place"); }
                        }
                    }
                }
            }
        }
    }
}
