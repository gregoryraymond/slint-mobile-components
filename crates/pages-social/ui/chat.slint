// ChatPage
// =====================================================================
//
// Conversation template — direct-message / customer-support / 1:1 chat
// screen. Demonstrates a distinct visual pattern (alternating bubbles
// with rounded corners on opposite sides) that none of the other
// templates exercise. Useful scaffolding for messengers, AI-chat
// interfaces, and support inboxes.
//
// Specification
// -------------
//
// Geometry
//   - `AppBar` with back + more, the title carrying the partner's name
//     plus a tiny presence line below.
//   - Scrollable conversation area filling the middle.
//   - Input row pinned to the bottom — `TextField` + send button.
//
// Bubble shape
//   - Incoming (from: "them"): left-aligned, `surface-2` fill, tail at
//     bottom-left (smaller radius there so the bubble visually "points"
//     toward the avatar).
//   - Outgoing (from: "me"): right-aligned, `Theme.primary` fill,
//     `on-primary` text, tail at bottom-right.
//   - Bubble width capped at ~70 % of viewport so very long messages
//     wrap rather than stretch corner-to-corner.

import { Theme } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { BottomBar } from "@mobile-components/bottom-bar.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { ScrollView } from "std-widgets.slint";

export enum ChatSender {
    me,
    them,
}

export struct ChatMessage {
    from: ChatSender,
    text: string,
    time: string,
}

component MessageBubble inherits Rectangle {
    in property <ChatSender> sender;
    in property <string> text;
    in property <string> time;
    in property <string> partner-initials: "P";

    horizontal-stretch: 1;

    HorizontalLayout {
        alignment: root.sender == ChatSender.me ? end : start;
        spacing: Theme.spacing-sm;
        padding-left: root.sender == ChatSender.me ? 56px : 0px;
        padding-right: root.sender == ChatSender.them ? 56px : 0px;

        if root.sender == ChatSender.them: VerticalLayout {
            alignment: end;
            Avatar {
                fallback: root.partner-initials;
                size: 28px;
            }
        }

        VerticalLayout {
            spacing: 2px;
            Rectangle {
                background: root.sender == ChatSender.me
                    ? Theme.primary
                    : Theme.surface-2;
                border-radius: Theme.radius-md;
                // Tail corner — points toward the speaker.
                border-bottom-left-radius:
                    root.sender == ChatSender.them ? 4px : Theme.radius-md;
                border-bottom-right-radius:
                    root.sender == ChatSender.me ? 4px : Theme.radius-md;

                VerticalLayout {
                    padding: Theme.spacing-sm + 2px;
                    Text {
                        text: root.text;
                        color: root.sender == ChatSender.me
                            ? Theme.on-primary
                            : Theme.on-surface;
                        font-size: Theme.font-size-body-large;
                        wrap: word-wrap;
                    }
                }
            }

            HorizontalLayout {
                alignment: root.sender == ChatSender.me ? end : start;
                Text {
                    text: root.time;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                }
            }
        }
    }
}

export component ChatPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> partner-name: "Petra Lindquist";
    in property <string> partner-status: "online · typing…";
    in property <string> partner-initials: "PL";
    in property <[ChatMessage]> messages: [
        { from: ChatSender.them, text: "Hey — got time to look at the surface tier naming today?", time: "10:32" },
        { from: ChatSender.me, text: "Yeah, just finishing the InboxPage refinement. 10 min.", time: "10:34" },
        { from: ChatSender.them, text: "No rush. I'm leaning toward `surface-1 / -2 / -3` over the longer names. Shorter is better when you read it twenty times a screen.", time: "10:35" },
        { from: ChatSender.me, text: "Agree. Locked it in DESIGN.md.", time: "10:41" },
        { from: ChatSender.them, text: "Perfect. Coffee at 11?", time: "10:42" },
        { from: ChatSender.me, text: "👍", time: "10:42" },
    ];
    in-out property <string> draft;
    callback back-pressed();
    callback more-pressed();
    callback send-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.partner-name;
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.more-pressed(); }
        }

        // Presence/status line under the bar.
        Rectangle {
            height: 20px;
            HorizontalLayout {
                padding-left: Theme.spacing-md;
                Text {
                    text: root.partner-status;
                    color: Theme.muted;
                    font-family: "IBM Plex Sans";
                    font-size: Theme.font-size-caption;
                    font-italic: true;
                    vertical-alignment: center;
                }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                alignment: start;
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;

                for msg in root.messages: MessageBubble {
                    sender: msg.from;
                    text: msg.text;
                    time: msg.time;
                    partner-initials: root.partner-initials;
                }
            }
        }

        BottomBar {
            HorizontalLayout {
                padding: Theme.spacing-sm;
                spacing: Theme.spacing-sm;
                alignment: stretch;

                VerticalLayout {
                    alignment: center;
                    horizontal-stretch: 1;
                    TextField {
                        placeholder: "Message";
                        text <=> root.draft;
                    }
                }

                Rectangle {
                    width: 48px;
                    height: 48px;
                    border-radius: self.width / 2;
                    background: send-touch.pressed
                        ? Theme.primary-pressed
                        : Theme.primary;

                    accessible-role: button;
                    accessible-label: "Send";
                    accessible-action-default => { root.send-pressed(root.draft); }

                    animate background { duration: Theme.motion-fast; }

                    Image {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/send.svg");
                        colorize: Theme.on-primary;
                        image-fit: contain;
                    }

                    send-touch := TouchArea {
                        clicked => { root.send-pressed(root.draft); }
                    }
                }
            }
        }
    }
}
