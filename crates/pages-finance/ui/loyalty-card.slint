// LoyaltyCardPage
// =====================================================================
//
// Coffee-shop / cafe loyalty card — the "buy 9, get the 10th free"
// stamp screen. Distinct from `GiftCardPage` (stored balance),
// `WalletPage` (cards list), and `SubscriptionsPage` (recurring
// billing). Demonstrates a progress-by-collection surface:
//
//   - Branded card hero with the shop name + the user's name.
//   - Stamp grid: a 5x2 grid of disc slots, filled discs show a cup
//     glyph, the next-to-fill slot is highlighted, empties are faint.
//   - "Reward available" success banner once the card is full, or a
//     "N more to go" progress line otherwise.
//   - Redeem-history rows.
//   - Sticky "Show code at till" CTA.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";

// One stamp slot. `state`: 0 empty, 1 filled, 2 next-to-fill.
component StampSlot inherits Rectangle {
    in property <int> state: 0;

    width: 52px;
    height: 52px;
    border-radius: self.width / 2;
    background:
          root.state == 1 ? Theme.primary
        : root.state == 2 ? Theme.surface-2
        : Theme.surface-2;
    border-width: root.state == 2 ? 2px : 0px;
    border-color: Theme.primary;
    opacity: root.state == 0 ? 0.45 : 1.0;

    Image {
        width: 24px;
        height: 24px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: @image-url("@mobile-components/icons/heart.svg");
        colorize: root.state == 1 ? Theme.on-primary : Theme.muted;
        image-fit: contain;
        visible: root.state == 1;
    }
    Text {
        text: root.state == 2 ? "★" : "";
        color: Theme.primary;
        font-size: 18px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

// One redeem-history row.
component HistoryRow inherits Rectangle {
    in property <string> label;
    in property <string> date;
    in property <string> detail;

    horizontal-stretch: 1;
    min-height: 56px;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background: Theme.accent-success;
                Image {
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/check.svg");
                    colorize: Theme.on-primary;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            Text {
                text: root.date;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.detail;
                color: Theme.accent-success;
                font-size: Theme.font-size-caption;
                font-weight: 800;
            }
        }
    }
}

export component LoyaltyCardPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> shop: "Foundry Coffee";
    in property <string> holder: "Greg Raymond";
    in property <int> stamps: 7;
    in property <int> total: 10;
    callback back-pressed();
    callback show-code-pressed();
    callback find-store-pressed();

    property <bool> full: root.stamps >= root.total;

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Loyalty";
            title-style: HeadingStyle.grotesk-bold;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Branded card hero.
            Rectangle {
                height: 132px;
                border-radius: Theme.radius-lg;
                background: @linear-gradient(135deg, #6f4e37 0%, #2d1b0e 100%);
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                clip: true;
                // Faint oversized glyph in the corner.
                Image {
                    width: 140px;
                    height: 140px;
                    x: parent.width - 70px;
                    y: -30px;
                    source: @image-url("@mobile-components/icons/heart.svg");
                    colorize: #ffffff;
                    opacity: 0.08;
                    image-fit: contain;
                }
                VerticalLayout {
                    padding: Theme.spacing-md;
                    alignment: space-between;
                    HorizontalLayout {
                        Heading {
                            text: root.shop;
                            style: HeadingStyle.bold-impact;
                            color: Theme.on-primary;
                            font-size: 26px;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: "REWARDS";
                            color: #ffffff99;
                            font-size: 10px;
                            font-weight: 800;
                            letter-spacing: 1px;
                        }
                    }
                    VerticalLayout {
                        spacing: 2px;
                        Text {
                            text: root.holder;
                            color: Theme.on-primary;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                        }
                        Text {
                            text: root.stamps + " / " + root.total + " stamps";
                            color: #ffffffcc;
                            font-size: Theme.font-size-caption;
                            font-weight: 600;
                        }
                    }
                }
            }

            // Status banner / progress line.
            Rectangle {
                height: 48px;
                border-radius: Theme.radius-md;
                background: root.full ? Theme.accent-success : Theme.surface-1;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 18px;
                            height: 18px;
                            source: root.full
                                ? @image-url("@mobile-components/icons/check.svg")
                                : @image-url("@mobile-components/icons/heart.svg");
                            colorize: root.full ? Theme.on-primary : Theme.primary;
                            image-fit: contain;
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        Text {
                            text: root.full
                                ? "Free drink ready — redeem at the till!"
                                : (root.total - root.stamps) + " more to go for a free drink";
                            color: root.full ? Theme.on-primary : Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                        }
                    }
                }
            }

            // Stamp grid (5 x 2).
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    for row in 2: HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        alignment: space-between;
                        for col in 5: StampSlot {
                            property <int> idx: row * 5 + col;
                            state:
                                  idx < root.stamps ? 1
                                : idx == root.stamps ? 2
                                : 0;
                        }
                    }
                }
            }
        }

        SectionHeader { text: "REWARD  HISTORY"; }
        HistoryRow {
            label: "Free flat white";
            date: "Redeemed · 28 Apr 2026";
            detail: "−10";
        }
        Divider { }
        HistoryRow {
            label: "Free cappuccino";
            date: "Redeemed · 2 Mar 2026";
            detail: "−10";
        }
        Divider { }
        HistoryRow {
            label: "Free cortado";
            date: "Redeemed · 14 Jan 2026";
            detail: "−10";
        }

        Rectangle {
            min-height: Theme.spacing-md;
            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                Rectangle {
                    background: transparent;
                    Text {
                        text: "Find a store near you";
                        color: Theme.accent-info;
                        font-size: Theme.font-size-body;
                        font-weight: 700;
                    }
                    TouchArea {
                        clicked => { root.find-store-pressed(); }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Sticky CTA.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                MobileButton {
                    text: "Show code at till";
                    primary: true;
                    clicked => { root.show-code-pressed(); }
                }
            }
        }
    }
}
