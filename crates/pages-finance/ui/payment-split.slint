// PaymentSplitPage
// =====================================================================
//
// Group bill-split — a meal has been paid, now we divide the cost among
// friends. Pure showcase of shared-row discipline: every row uses one of
// the canonical components (SettingRow / KeyValueRow / FormSection), so
// the leading-icon column, the title column, and the trailing-value
// column all line up across the entire screen.
//
// Layout
// ------
//
//   AppBar — "Split bill" with back arrow.
//   Hero Card — amount paid (large mono numeral) + restaurant + date.
//   FormSection "SPLIT EVENLY" — one SettingRow with a Stepper trailing.
//   FormSection "PEOPLE" — one SettingRow per person, leading is a
//     profile tile tinted Tone.info (same 32 × 32 footprint as every
//     other leading tile in the library), trailing is the share value
//     in accent-info colour.
//   FormSection "TOTALS" — KeyValueRows for subtotal / tip / total
//     (last with emphasis: true).
//   Actions — primary "Send requests" + secondary "Adjust manually".

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Stepper } from "@mobile-components/stepper.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component PaymentSplitPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback send-pressed();
    callback adjust-pressed();
    callback people-changed(int);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Split bill";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Hero card: amount paid -------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        VerticalLayout {
                            spacing: Theme.spacing-xs;
                            alignment: center;

                            Heading {
                                text: "€ 184.20";
                                style: HeadingStyle.mono;
                                color: Theme.on-surface;
                                font-size: 44px;
                                font-weight: 700;
                                horizontal-alignment: center;
                            }
                            Text {
                                text: "Caffè San Carlo · 2026-05-15";
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                                horizontal-alignment: center;
                            }
                        }
                    }
                }

                // ----- Split evenly -----------------------------------------
                FormSection {
                    title: "SPLIT EVENLY";

                    SettingRow {
                        title: "Among 4 people";
                        subtitle: "Tap +/− to change the head count";

                        Stepper {
                            value: 4;
                            minimum: 1;
                            maximum: 12;
                            changed(v) => { root.people-changed(v); }
                        }
                    }
                }

                // ----- People -----------------------------------------------
                FormSection {
                    title: "PEOPLE";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Ada";
                        subtitle: "owes you";

                        Text {
                            text: "€ 46.05";
                            color: Theme.accent-info;
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            horizontal-alignment: right;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Brent";
                        subtitle: "owes you";

                        Text {
                            text: "€ 46.05";
                            color: Theme.accent-info;
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            horizontal-alignment: right;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Cy";
                        subtitle: "owes you";

                        Text {
                            text: "€ 46.05";
                            color: Theme.accent-info;
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            horizontal-alignment: right;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Devi";
                        subtitle: "owes you";

                        Text {
                            text: "€ 46.05";
                            color: Theme.accent-info;
                            font-size: Theme.font-size-body-large;
                            font-weight: 700;
                            horizontal-alignment: right;
                        }
                    }
                }

                // ----- Totals -----------------------------------------------
                FormSection {
                    title: "TOTALS";

                    KeyValueRow {
                        label: "Subtotal";
                        value: "€ 160.17";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Tip · 15 %";
                        value: "€ 24.03";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Total";
                        value: "€ 184.20";
                        emphasis: true;
                    }
                }

                // ----- Actions ----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Send requests";
                        clicked => { root.send-pressed(); }
                    }
                    TextButton {
                        text: "Adjust manually";
                        clicked => { root.adjust-pressed(); }
                    }
                }
            }
        }
    }
}
