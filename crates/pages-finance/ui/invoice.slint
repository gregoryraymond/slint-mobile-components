// InvoicePage
// =====================================================================
//
// Single-invoice detail view (issuer / recipient / line items / totals
// / actions). Pure showcase of `KeyValueRow` discipline: every label/
// value pair on the receipt — line item, subtotal, tax, total — uses
// the SAME row component, so the value column lines up at one shared
// right margin no matter how long the labels get.
//
// What this screen does
//   - AppBar with back + share trailing.
//   - Issuer block (Card): logo (Avatar fallback), business name,
//     invoice number, status pill (PAID / DUE / OVERDUE rendered as a
//     Chip with status tone).
//   - "Billed to" block: customer name + email + address (KeyValueRows
//     are wrong here — addresses are multi-line — so use plain Text in
//     a Card; rest of the page is KeyValueRow).
//   - Line items section (FormSection title "ITEMS"): one KeyValueRow
//     per item, label = item name + qty, value = subtotal.
//   - Totals section (FormSection title "TOTALS"): subtotal, tax,
//     discount (Tone.success), then a Divider and an `emphasis: true`
//     KeyValueRow for the grand total.
//   - Actions: "Download PDF" primary button, "Send reminder" text
//     button.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Card } from "@mobile-components/card.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component InvoicePage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback share-pressed();
    callback download-pressed();
    callback remind-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Invoice #2147";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Issuer header card -----------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            Avatar {
                                fallback: "AC";
                                size: 56px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: 2px;
                                Heading {
                                    text: "Atlas Coffee Co.";
                                    style: HeadingStyle.plex-medium;
                                    color: Theme.on-surface;
                                    font-size: 18px;
                                }
                                Text {
                                    text: "Issued · 2026-05-12";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                                Text {
                                    text: "Due · 2026-05-26";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Text {
                                    text: "PAID";
                                    color: Theme.accent-success;
                                    font-size: 10px;
                                    font-weight: 800;
                                    letter-spacing: 0.5px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                    }
                }

                // ----- Billed-to card ---------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    Card {
                        title: "Billed to";

                        Text {
                            text: "Greg Raymond";
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                        }
                        Text {
                            text: "greg@slint.dev";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                        }
                        Text {
                            text: "440 Avenue Louise\n1050 Brussels, BE";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            wrap: word-wrap;
                        }
                    }
                }

                // ----- Items ------------------------------------------------
                FormSection {
                    title: "ITEMS";

                    KeyValueRow {
                        label: "House blend · 250 g × 2";
                        value: "€ 28.00";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Single-origin Yirgacheffe · 250 g";
                        value: "€ 19.50";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Cold-brew kit";
                        value: "€ 42.00";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Express shipping";
                        value: "€  9.95";
                    }
                }

                // ----- Totals -----------------------------------------------
                FormSection {
                    title: "TOTALS";

                    KeyValueRow {
                        label: "Subtotal";
                        value: "€ 99.45";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Tax · 21 %";
                        value: "€ 20.88";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Loyalty discount";
                        value: "− € 5.00";
                        value-tone: Tone.success;
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Total";
                        value: "€ 115.33";
                        emphasis: true;
                    }
                }

                // ----- Actions ----------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Download PDF";
                        clicked => { root.download-pressed(); }
                    }
                    TextButton {
                        text: "Send payment reminder";
                        clicked => { root.remind-pressed(); }
                    }
                }
            }
        }
    }
}
