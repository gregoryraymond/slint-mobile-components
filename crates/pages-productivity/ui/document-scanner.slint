// DocumentScannerPage
// =====================================================================
//
// Camera-style document scanner. Big viewfinder rectangle with a
// dashed-look inner frame, transport row with a chunky shutter button
// in the centre, and a "RECENT SCANS" section below.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";

export component DocumentScannerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback close-pressed();
    callback gallery-pressed();
    callback shutter-pressed();
    callback flash-pressed();
    callback recent-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Scan document";
            title-style: HeadingStyle.caps-tight;
            leading-icon: @image-url("@mobile-components/icons/close.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            bar-background: transparent;
            leading-pressed => { root.close-pressed(); }
        }

        // ----- Viewfinder -----------------------------------------------
        Rectangle {
            background: Theme.surface-3;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            min-height: 420px;

            // Outer frame container.
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2;
                width: 280px;
                height: 360px;
                background: transparent;
                border-width: 2px;
                border-color: Theme.primary;
                border-radius: Theme.radius-sm;

                // Corner brackets — four small filled squares that give
                // the dashed-frame feel without faking dashes.
                Rectangle { x: -2px; y: -2px; width: 24px; height: 24px;
                    background: transparent;
                    border-color: Theme.primary; border-width: 4px;
                    border-top-left-radius: Theme.radius-sm;
                }
                Rectangle { x: parent.width - 22px; y: -2px; width: 24px; height: 24px;
                    background: transparent;
                    border-color: Theme.primary; border-width: 4px;
                    border-top-right-radius: Theme.radius-sm;
                }
                Rectangle { x: -2px; y: parent.height - 22px; width: 24px; height: 24px;
                    background: transparent;
                    border-color: Theme.primary; border-width: 4px;
                    border-bottom-left-radius: Theme.radius-sm;
                }
                Rectangle { x: parent.width - 22px; y: parent.height - 22px; width: 24px; height: 24px;
                    background: transparent;
                    border-color: Theme.primary; border-width: 4px;
                    border-bottom-right-radius: Theme.radius-sm;
                }

                // Centred hint text.
                Text {
                    x: Theme.spacing-md;
                    y: (parent.height - self.height) / 2;
                    width: parent.width - 2 * Theme.spacing-md;
                    text: "Align document inside frame";
                    color: Theme.on-background;
                    font-size: Theme.font-size-body;
                    font-weight: 500;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }
            }
        }

        // ----- Transport row --------------------------------------------
        HorizontalLayout {
            padding: Theme.spacing-lg;
            spacing: Theme.spacing-lg;
            alignment: center;

            // Gallery toggle.
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: self.width / 2;
                background: gallery-touch.pressed ? Theme.surface-pressed : Theme.surface-1;
                Image {
                    width: 24px;
                    height: 24px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/photo-ocean.svg");
                    image-fit: contain;
                }
                gallery-touch := TouchArea {
                    clicked => { root.gallery-pressed(); }
                }
            }

            // Shutter — chunky white circle.
            Rectangle {
                width: 72px;
                height: 72px;
                border-radius: 36px;
                background: shutter-touch.pressed ? Theme.muted : Theme.on-surface;
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                // Inner ring.
                Rectangle {
                    x: 6px; y: 6px;
                    width: parent.width - 12px;
                    height: parent.height - 12px;
                    border-radius: self.width / 2;
                    background: transparent;
                    border-width: 3px;
                    border-color: Theme.background;
                }
                shutter-touch := TouchArea {
                    clicked => { root.shutter-pressed(); }
                }
            }

            // Flash toggle.
            Rectangle {
                width: 56px;
                height: 56px;
                border-radius: self.width / 2;
                background: flash-touch.pressed ? Theme.surface-pressed : Theme.surface-1;
                Image {
                    width: 24px;
                    height: 24px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/star.svg");
                    colorize: Theme.accent-warning;
                    image-fit: contain;
                }
                flash-touch := TouchArea {
                    clicked => { root.flash-pressed(); }
                }
            }
        }

        // ----- Recent scans ---------------------------------------------
        VerticalLayout {
            padding-bottom: Theme.spacing-xl;
            spacing: Theme.spacing-md;

            FormSection {
                title: "RECENT SCANS";

                SettingRow {
                    icon: @image-url("@mobile-components/icons/menu.svg");
                    tone: Tone.info;
                    title: "Tax_return_2025.pdf";
                    subtitle: "scanned today · 3 pages · 412 KB";
                    clicked => { root.recent-pressed("tax"); }
                    Image {
                        width: 16px;
                        height: 16px;
                        source: @image-url("@mobile-components/icons/chevron-right.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                }
                Divider { }
                SettingRow {
                    icon: @image-url("@mobile-components/icons/menu.svg");
                    tone: Tone.success;
                    title: "Receipt_5814.pdf";
                    subtitle: "scanned yesterday · 1 page · 118 KB";
                    clicked => { root.recent-pressed("receipt"); }
                    Image {
                        width: 16px;
                        height: 16px;
                        source: @image-url("@mobile-components/icons/chevron-right.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                }
            }
        }
    }
}
