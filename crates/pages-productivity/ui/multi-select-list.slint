// MultiSelectListPage
// =====================================================================
//
// Contextual selection mode. AppBar shows "N selected" instead of the
// usual title, with a close (cancel selection) leading and overflow
// trailing. Each row is a SettingRow with a `Checkbox` dropped into the
// trailing slot so the boxes line up at a single shared right margin.
// A bottom action bar holds archive / star / delete.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Checkbox } from "@mobile-components/checkbox.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

// A bare check-box square (no label, no row min-height) — used in the
// SettingRow trailing slot. The full Checkbox component is a 48-px row;
// here we want JUST the indicator.
component CheckSquare inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled(bool);

    width: 22px;
    height: 22px;
    border-radius: Theme.radius-sm;
    background: root.checked ? Theme.primary : transparent;
    border-width: root.checked ? 0px : 2px;
    border-color: Theme.outline;

    animate background { duration: Theme.motion-fast; }

    if root.checked: Image {
        width: 14px;
        height: 14px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: @image-url("@mobile-components/icons/check.svg");
        colorize: Theme.on-primary;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

// Bottom action button — icon-over-label, full-width stretch cell.
component ActionCell inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <Tone> tone: Tone.default;
    callback clicked();

    horizontal-stretch: 1;
    min-height: Theme.touch-target;
    background: touch.pressed ? Theme.surface-pressed : transparent;

    property <color> tint:
          root.tone == Tone.danger ? Theme.accent-danger
        : root.tone == Tone.info   ? Theme.accent-info
        : Theme.on-surface;

    VerticalLayout {
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        spacing: 2px;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Image {
                width: 22px;
                height: 22px;
                source: root.icon;
                colorize: tint;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: tint;
                font-size: Theme.font-size-caption;
                font-weight: 600;
            }
        }
    }

    touch := TouchArea { clicked => { root.clicked(); } }
}

export component MultiSelectListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> selected-count: 3;

    callback close-pressed();
    callback overflow-pressed();
    callback archive-pressed();
    callback star-pressed();
    callback delete-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.selected-count + " selected";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/close.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.close-pressed(); }
            trailing-pressed => { root.overflow-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: start;

                FormSection {
                    title: "INBOX";

                    SettingRow {
                        title: "Iteration 14 review notes";
                        subtitle: "Atlas · 2 days ago";
                        CheckSquare { checked: true; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Q3 OKR proposal";
                        subtitle: "Planning · 2 days ago";
                        CheckSquare { checked: true; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Field test report";
                        subtitle: "Mobile · 3 days ago";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        title: "API redesign draft";
                        subtitle: "Backend · 3 days ago";
                        CheckSquare { checked: true; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Calendar invite — Brussels offsite";
                        subtitle: "Travel · 4 days ago";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        title: "Slint 2.0 launch checklist";
                        subtitle: "Release · 5 days ago";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        title: "Tax document upload";
                        subtitle: "Admin · 6 days ago";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        title: "Team retro notes";
                        subtitle: "People · 7 days ago";
                        CheckSquare { }
                    }
                }
            }
        }

        // ----- Bottom action bar ------------------------------------
        Rectangle {
            background: Theme.surface-2;
            min-height: Theme.touch-target + Theme.spacing-sm;
            horizontal-stretch: 1;

            HorizontalLayout {
                spacing: 0;
                alignment: stretch;
                ActionCell {
                    label: "Archive";
                    icon: @image-url("@mobile-components/icons/menu.svg");
                    tone: Tone.info;
                    clicked => { root.archive-pressed(); }
                }
                ActionCell {
                    label: "Star";
                    icon: @image-url("@mobile-components/icons/star.svg");
                    clicked => { root.star-pressed(); }
                }
                ActionCell {
                    label: "Delete";
                    icon: @image-url("@mobile-components/icons/close.svg");
                    tone: Tone.danger;
                    clicked => { root.delete-pressed(); }
                }
            }
        }
    }
}
