// DownloadManagerPage
// =====================================================================
//
// A download manager — the "what's downloading" screen. Distinct from
// `StorageManagerPage` (category breakdown of used disk) and
// `FileBrowserPage` (a file tree). Demonstrates a progress-list
// surface:
//
//   - A storage strip showing what downloads are using.
//   - An ACTIVE section: rows with a type icon, name, a progress bar,
//     a "downloaded / total · speed" line, and a pause/resume disc.
//   - A COMPLETED section: rows with a success check, size + when.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";

// Type-tinted icon disc. `kind`: 0 video / 1 audio / 2 doc / 3 app.
component TypeIcon inherits Rectangle {
    in property <int> kind: 0;

    width: 40px;
    height: 40px;
    border-radius: Theme.radius-sm;
    background:
          root.kind == 0 ? Theme.accent-danger.with-alpha(0.18)
        : root.kind == 1 ? Theme.primary.with-alpha(0.18)
        : root.kind == 2 ? Theme.accent-info.with-alpha(0.18)
        : Theme.accent-success.with-alpha(0.18);
    Image {
        width: 20px;
        height: 20px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source:
              root.kind == 0 ? @image-url("@mobile-components/icons/play.svg")
            : root.kind == 1 ? @image-url("@mobile-components/icons/play.svg")
            : root.kind == 2 ? @image-url("@mobile-components/icons/inbox.svg")
            : @image-url("@mobile-components/icons/queue.svg");
        colorize:
              root.kind == 0 ? Theme.accent-danger
            : root.kind == 1 ? Theme.primary
            : root.kind == 2 ? Theme.accent-info
            : Theme.accent-success;
        image-fit: contain;
    }
}

// One active-download row.
component ActiveRow inherits Rectangle {
    in property <int> kind: 0;
    in property <string> name;
    in property <string> meta;
    in property <float> progress: 0.4;
    in property <bool> paused: false;
    callback toggle-pressed();

    horizontal-stretch: 1;
    vertical-stretch: 0;
    height: 88px;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            TypeIcon {
                kind: root.kind;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 6px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 700;
                overflow: elide;
            }
            Rectangle {
                height: 5px;
                border-radius: 2.5px;
                background: Theme.surface-variant;
                Rectangle {
                    x: 0;
                    width: parent.width * root.progress;
                    height: parent.height;
                    border-radius: 2.5px;
                    background: root.paused ? Theme.muted : Theme.accent-info;
                }
            }
            Text {
                text: root.paused ? "Paused · " + root.meta : root.meta;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: 18px;
                background: touch.pressed ? Theme.surface-pressed : Theme.surface-2;
                animate background { duration: Theme.motion-fast; }
                Image {
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: root.paused
                        ? @image-url("@mobile-components/icons/play.svg")
                        : @image-url("@mobile-components/icons/pause.svg");
                    colorize: Theme.on-surface;
                    image-fit: contain;
                }
                touch := TouchArea {
                    clicked => { root.toggle-pressed(); }
                }
            }
        }
    }
}

// One completed-download row.
component CompletedRow inherits Rectangle {
    in property <int> kind: 0;
    in property <string> name;
    in property <string> meta;
    callback clicked();

    accessible-role: button;
    accessible-label: root.name;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-height: 60px;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            TypeIcon {
                kind: root.kind;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.meta;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 24px;
                height: 24px;
                border-radius: 12px;
                background: Theme.accent-success;
                Image {
                    width: 12px;
                    height: 12px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/check.svg");
                    colorize: Theme.on-primary;
                    image-fit: contain;
                }
            }
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component DownloadManagerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    callback back-pressed();
    callback clear-pressed();
    callback toggle-pressed(string);
    callback completed-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Downloads";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.clear-pressed(); }
        }

        // Storage strip.
        Rectangle {
            background: Theme.surface-1;
            height: 56px;
            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 36px;
                        height: 36px;
                        border-radius: 8px;
                        background: Theme.accent-info.with-alpha(0.18);
                        Image {
                            width: 18px;
                            height: 18px;
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            source: @image-url("@mobile-components/icons/inbox.svg");
                            colorize: Theme.accent-info;
                            image-fit: contain;
                        }
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    spacing: 2px;
                    Text {
                        text: "Downloads using 6.2 GB";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-caption;
                        font-weight: 800;
                    }
                    Text {
                        text: "2 active · 4 completed";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }
            }
        }

        SectionHeader { text: "ACTIVE"; }
        ActiveRow {
            kind: 0;
            name: "Coastline — S2E4.mp4";
            meta: "612 MB of 1.4 GB · 8.2 MB/s";
            progress: 0.43;
            paused: false;
            toggle-pressed => { root.toggle-pressed("Coastline S2E4"); }
        }
        Divider { }
        ActiveRow {
            kind: 3;
            name: "studio-app-2.4.0.apk";
            meta: "44 MB of 96 MB";
            progress: 0.46;
            paused: true;
            toggle-pressed => { root.toggle-pressed("studio-app"); }
        }

        SectionHeader { text: "COMPLETED"; }
        CompletedRow {
            kind: 1;
            name: "Deep Focus — full album.zip";
            meta: "184 MB · finished 10 min ago";
            clicked => { root.completed-pressed("Deep Focus"); }
        }
        Divider { }
        CompletedRow {
            kind: 2;
            name: "Q2 board pack.pdf";
            meta: "12 MB · finished today";
            clicked => { root.completed-pressed("Q2 board pack"); }
        }
        Divider { }
        CompletedRow {
            kind: 0;
            name: "Onboarding walkthrough.mov";
            meta: "320 MB · finished yesterday";
            clicked => { root.completed-pressed("Onboarding walkthrough"); }
        }
        Divider { }
        CompletedRow {
            kind: 2;
            name: "Tax documents 2025.zip";
            meta: "8 MB · finished 3 days ago";
            clicked => { root.completed-pressed("Tax documents"); }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
