// ReadingListPage
// =====================================================================
//
// Saved-articles list — Pocket / Instapaper / Reader-style "stuff
// you've saved for later" surface. Distinct from `EReaderPage` (single
// article reading) and `NewsArticleFeedPage` (browse new content).
// Demonstrates:
//
//   - Filter chip strip: All / Unread / Favourites / Archive / Tags.
//   - Per-article card: cover gradient thumbnail + headline + source +
//     read-time + a small status row (FAV star / Archived / unread
//     dot). Cards alternate between landscape (thumb-left) and
//     portrait-hero (thumb-on-top) layouts to keep the rhythm.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Divider } from "@mobile-components/divider.slint";

// Hero card — full-width thumb above the meta block.
component HeroArticle inherits Rectangle {
    in property <string> headline;
    in property <string> source;
    in property <string> read-time;
    in property <string> excerpt;
    in property <brush> thumb;
    in property <bool> favourite: false;
    in property <bool> unread: true;

    horizontal-stretch: 1;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;
    clip: true;

    VerticalLayout {
        spacing: 0;
        Rectangle {
            height: 140px;
            background: root.thumb;
            clip: true;
            if root.favourite: Rectangle {
                x: parent.width - self.width - 12px;
                y: 12px;
                width: 36px;
                height: 36px;
                border-radius: self.width / 2;
                background: #00000088;
                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("@mobile-components/icons/star.svg");
                    colorize: Theme.accent-warning;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-xs;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                alignment: start;
                if root.unread: Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: Theme.accent-info;
                    y: 6px;
                }
                Text {
                    text: root.source;
                    color: Theme.accent-info;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
                Text {
                    text: "·";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    vertical-alignment: center;
                }
                Text {
                    text: root.read-time;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.headline;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 700;
                wrap: word-wrap;
            }
            Text {
                text: root.excerpt;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
            }
        }
    }
}

// Compact row — thumb-left, meta-right.
component ArticleRow inherits Rectangle {
    in property <string> headline;
    in property <string> source;
    in property <string> read-time;
    in property <brush> thumb;
    in property <bool> favourite: false;
    in property <bool> archived: false;
    in property <bool> unread: false;

    horizontal-stretch: 1;
    min-height: 104px;
    opacity: root.archived ? 0.55 : 1.0;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;

        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 96px;
                height: 80px;
                border-radius: Theme.radius-sm;
                background: root.thumb;
                clip: true;
                if root.favourite: Rectangle {
                    x: parent.width - 20px;
                    y: 4px;
                    width: 16px;
                    height: 16px;
                    border-radius: 8px;
                    background: #00000088;
                    Image {
                        width: 10px;
                        height: 10px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("@mobile-components/icons/star.svg");
                        colorize: Theme.accent-warning;
                        image-fit: contain;
                    }
                }
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 4px;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                if root.unread: Rectangle {
                    width: 8px;
                    height: 8px;
                    border-radius: 4px;
                    background: Theme.accent-info;
                    y: 6px;
                }
                Text {
                    text: root.source;
                    color:
                          root.archived ? Theme.muted
                        : Theme.accent-info;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                    vertical-alignment: center;
                }
            }
            Text {
                text: root.headline;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
                wrap: word-wrap;
            }
            Text {
                text: root.read-time + (root.archived ? " · archived" : "");
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
    }
}

export component ReadingListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    callback back-pressed();
    callback compose-pressed();
    callback article-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Reading list";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.compose-pressed(); }
        }

        // Filter chip strip.
        HorizontalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            Chip { label: "All · 42"; selected: true; }
            Chip { label: "Unread · 8"; }
            Chip { label: "Favourites · 12"; }
            Chip { label: "Archive · 22"; }
        }

        // Hero card.
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            HeroArticle {
                source: "STRATECHERY";
                read-time: "12 min · saved yesterday";
                headline: "Why pure-Rust GUIs are eating the mobile stack";
                excerpt: "A look at how the declarative-UI wave reshaped the mobile toolkit market — and why the next chapter happens in Rust.";
                thumb: @linear-gradient(135deg, #16a34a 0%, #14532d 100%);
                favourite: true;
                unread: true;
            }
        }

        SectionHeader { text: "TO READ"; }

        ArticleRow {
            source: "RUST WEEKLY";
            headline: "Cargo-apk gains live-reload on Apple Silicon";
            read-time: "6 min · saved 2 days ago";
            thumb: @linear-gradient(135deg, #f59e0b 0%, #b45309 100%);
            unread: true;
        }
        Divider { }
        ArticleRow {
            source: "WIRED";
            headline: "Anthropic ships Claude 5: API + Code updates land Tuesday";
            read-time: "8 min · saved 3 days ago";
            thumb: @linear-gradient(135deg, #6b7280 0%, #1f2937 100%);
            unread: true;
        }
        Divider { }
        ArticleRow {
            source: "FRONTEND TIMES";
            headline: "Tailwind drops v5 — JIT mode becomes default";
            read-time: "5 min · saved Sunday";
            thumb: @linear-gradient(135deg, #06b6d4 0%, #0e7490 100%);
            favourite: true;
            unread: true;
        }

        SectionHeader { text: "ARCHIVED"; }

        ArticleRow {
            source: "OPINION · LE BERNARD";
            headline: "The case against WebViews: a security retrospective";
            read-time: "14 min";
            thumb: @linear-gradient(135deg, #dc2626 0%, #7f1d1d 100%);
            archived: true;
        }
        Divider { }
        ArticleRow {
            source: "SLINT NEWSLETTER";
            headline: "Slint 2.0 announced — full Android Q1 release";
            read-time: "9 min";
            thumb: @linear-gradient(135deg, #1e3a8a 0%, #4f8cff 100%);
            favourite: true;
            archived: true;
        }

        Rectangle { vertical-stretch: 1; }
    }
}
