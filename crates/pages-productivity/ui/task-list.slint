// TaskListPage
// =====================================================================
//
// A todo list. SegmentedControl across the top, then morning / afternoon
// FormSections of SettingRows. A small "check square" in each row's
// trailing slot keeps the checkboxes lined up at a single right margin.
// FAB-styled "New task" button anchored bottom-right.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Fab } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

// Standalone check-box square (no row chrome) — sits in SettingRow's
// trailing slot so the boxes column-align across the whole list.
component CheckSquare inherits Rectangle {
    in-out property <bool> checked: false;
    callback toggled(bool);

    width: 22px;
    height: 22px;
    border-radius: Theme.radius-sm;
    background: root.checked ? Theme.primary : transparent;
    border-width: root.checked ? 0px : 2px;
    border-color: Theme.outline;

    animate background { duration: Theme.motion-fast; }

    if root.checked: Image {
        width: 14px;
        height: 14px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: @image-url("@mobile-components/icons/check.svg");
        colorize: Theme.on-primary;
        image-fit: contain;
    }

    touch := TouchArea {
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}

export component TaskListPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> view-index: 0;

    callback back-pressed();
    callback add-pressed();
    callback new-task-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Today";
            title-style: HeadingStyle.serif-display;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.add-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl + 56px;  // leave room for FAB
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- View switcher --------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Today", "Upcoming", "Anytime", "Done"];
                        selected-index <=> root.view-index;
                    }
                }

                // ----- Morning --------------------------------------
                FormSection {
                    title: "MORNING";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Stand-up";
                        subtitle: "due 09:30 · ~15 min";
                        CheckSquare { checked: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Review iteration 14 PRs";
                        subtitle: "due 10:30 · ~45 min";
                        CheckSquare { checked: true; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Draft Slint 2.0 release notes";
                        subtitle: "due 11:00 · ~30 min";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.danger;
                        title: "Tax document upload";
                        subtitle: "due noon · ~10 min";
                        CheckSquare { }
                    }
                }

                // ----- Afternoon ------------------------------------
                FormSection {
                    title: "AFTERNOON";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Lunch with Sam";
                        subtitle: "due 13:00 · ~60 min";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.warning;
                        title: "Field-test the document scanner";
                        subtitle: "due 15:00 · ~45 min";
                        CheckSquare { }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.success;
                        title: "1:1 with Maya";
                        subtitle: "due 16:00 · ~30 min";
                        CheckSquare { }
                    }
                }
            }
        }
    }

    // ----- FAB ----------------------------------------------------------
    Fab {
        x: root.width - self.width - Theme.spacing-md;
        y: root.height - self.height - Theme.spacing-md;
        accessible-label: "New task";
        clicked => { root.new-task-pressed(); }
    }
}
