// FileBrowserPage
// =====================================================================
//
// Hierarchical file listing. Breadcrumb + sort segmented control on
// top, then a FOLDERS section and a FILES section — both built from
// `SettingRow` so every leading icon, title, subtitle, and trailing
// glyph aligns to the same grid.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component FileBrowserPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> sort-index: 0;

    callback back-pressed();
    callback overflow-pressed();
    callback folder-pressed(string);
    callback file-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Documents";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.overflow-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Breadcrumb -----------------------------------
                MetaRow {
                    items: [
                        { icon: @image-url("@mobile-components/icons/home.svg"), text: "Home" },
                        { text: "Documents" },
                        { text: "Tax 2025" },
                    ];
                    separator: "/";
                }

                // ----- Sort -----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["Name", "Date", "Size"];
                        selected-index <=> root.sort-index;
                    }
                }

                // ----- Folders --------------------------------------
                FormSection {
                    title: "FOLDERS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.info;
                        title: "Receipts";
                        subtitle: "23 items · 4.2 MB";
                        clicked => { root.folder-pressed("receipts"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.warning;
                        title: "Invoices";
                        subtitle: "14 items · 2.1 MB";
                        clicked => { root.folder-pressed("invoices"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.success;
                        title: "Statements";
                        subtitle: "9 items · 1.3 MB";
                        clicked => { root.folder-pressed("statements"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- Files ----------------------------------------
                FormSection {
                    title: "FILES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.info;
                        title: "Tax_return_2025.pdf";
                        subtitle: "PDF · 412 KB · today 14:32";
                        clicked => { root.file-pressed("tax"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        title: "P60_employer.pdf";
                        subtitle: "PDF · 98 KB · today 09:15";
                        clicked => { root.file-pressed("p60"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Charity_donations.xlsx";
                        subtitle: "XLSX · 64 KB · yesterday 17:48";
                        clicked => { root.file-pressed("charity"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "Investment_summary.csv";
                        subtitle: "CSV · 22 KB · 12 May 11:02";
                        clicked => { root.file-pressed("invest"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.success;
                        title: "Receipt_amazon.pdf";
                        subtitle: "PDF · 38 KB · 09 May 13:21";
                        clicked => { root.file-pressed("amazon"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.danger;
                        title: "Notes_to_accountant.txt";
                        subtitle: "TXT · 4 KB · 02 May 08:10";
                        clicked => { root.file-pressed("notes"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/more-vertical.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
