// QRScannerPage
// =====================================================================
//
// Camera viewfinder for scanning QR codes. Dark background, a 280×280
// transparent square with four primary-tinted corner brackets, and a
// "RECENT" FormSection near the bottom for previously-scanned codes.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";

// One L-shaped corner bracket.
component Corner inherits Rectangle {
    in property <bool> top: true;
    in property <bool> left: true;

    width: 28px;
    height: 28px;
    background: transparent;

    // Horizontal arm.
    Rectangle {
        x: 0;
        y: root.top ? 0px : (parent.height - self.height);
        width: parent.width;
        height: 4px;
        background: Theme.primary;
        border-radius: 2px;
    }
    // Vertical arm.
    Rectangle {
        x: root.left ? 0px : (parent.width - self.width);
        y: 0;
        width: 4px;
        height: parent.height;
        background: Theme.primary;
        border-radius: 2px;
    }
}

export component QRScannerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback close-pressed();
    callback flash-pressed();
    callback recent-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Scan QR";
            title-style: HeadingStyle.caps-tight;
            leading-icon: @image-url("@mobile-components/icons/close.svg");
            trailing-icon: @image-url("@mobile-components/icons/star.svg");
            bar-background: transparent;
            leading-pressed => { root.close-pressed(); }
            trailing-pressed => { root.flash-pressed(); }
        }

        // ----- Viewfinder -----------------------------------------------
        Rectangle {
            background: Theme.background;
            horizontal-stretch: 1;
            vertical-stretch: 1;
            min-height: 420px;

            // 280×280 transparent square centred.
            Rectangle {
                x: (parent.width - self.width) / 2;
                y: (parent.height - self.height) / 2 - 24px;
                width: 280px;
                height: 280px;
                background: transparent;

                Corner { x: 0;                     y: 0;                       top: true;  left: true;  }
                Corner { x: parent.width - self.width; y: 0;                   top: true;  left: false; }
                Corner { x: 0;                     y: parent.height - self.height; top: false; left: true; }
                Corner { x: parent.width - self.width; y: parent.height - self.height; top: false; left: false; }
            }

            // Caption below the viewfinder.
            VerticalLayout {
                x: 0;
                y: parent.height / 2 + 140px;
                width: parent.width;
                alignment: start;
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: "Point camera at a QR code";
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        font-weight: 500;
                        horizontal-alignment: center;
                    }
                }
            }
        }

        // ----- Recent --------------------------------------------------
        VerticalLayout {
            padding-bottom: Theme.spacing-xl;
            spacing: Theme.spacing-md;

            FormSection {
                title: "RECENT";

                SettingRow {
                    icon: @image-url("@mobile-components/icons/queue.svg");
                    tone: Tone.info;
                    title: "atlas-coffee.com/menu";
                    subtitle: "scanned 2 hours ago";
                    clicked => { root.recent-pressed("atlas"); }
                    Image {
                        width: 16px;
                        height: 16px;
                        source: @image-url("@mobile-components/icons/chevron-right.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                }
                Divider { }
                SettingRow {
                    icon: @image-url("@mobile-components/icons/queue.svg");
                    tone: Tone.success;
                    title: "wifi://atlas-guest";
                    subtitle: "scanned yesterday";
                    clicked => { root.recent-pressed("wifi"); }
                    Image {
                        width: 16px;
                        height: 16px;
                        source: @image-url("@mobile-components/icons/chevron-right.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                }
            }
        }
    }
}
