// CalendarPage
// =====================================================================
//
// Month-grid calendar + a same-day agenda strip. Demonstrates the 7-
// column repeating grid pattern (a hole in the catalogue's layout
// vocabulary up to this point) and how a tone-tinted dot can mark
// "events on this day" without disrupting the cell typography.
//
// Layout
// ------
//
//   AppBar — month/year + nav arrows
//   Weekday header (S M T W T F S)
//   Day grid (6 rows × 7 columns)
//   Section header: "Today, May 14"
//   Stack of Event cards
//
// The grid is rendered as a 6-row × 7-column GridLayout. Days from the
// previous / next month are dimmed (`opacity: 0.4`); the "today" cell
// gets a filled circle in `Theme.primary`. Cells with one or more
// events show a 4 px tone-tinted dot under the date number.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Card } from "@mobile-components/card.slint";

// One day cell in the month grid.
component DayCell inherits Rectangle {
    in property <int> day;
    in property <bool> in-month: true;
    in property <bool> today: false;
    in property <Tone> event-tone: Tone.default;
    in property <bool> has-event: false;
    callback clicked();

    accessible-role: button;
    accessible-label: "Day " + root.day;
    accessible-action-default => { root.clicked(); }

    width: 44px;
    height: 44px;
    background: transparent;

    // Today highlight — filled disc behind the date number.
    if root.today: Rectangle {
        width: 32px;
        height: 32px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2 - 3px;
        border-radius: self.width / 2;
        background: Theme.primary;
    }

    Text {
        text: root.day;
        x: 0;
        y: 4px;
        width: parent.width;
        height: parent.height - 12px;
        color: root.today
            ? Theme.on-primary
            : (root.in-month ? Theme.on-surface : Theme.muted);
        opacity: root.in-month ? 1.0 : 0.5;
        font-size: Theme.font-size-body;
        font-weight: root.today ? 700 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Event dot — bottom-centre.
    if root.has-event: Rectangle {
        width: 4px;
        height: 4px;
        x: (parent.width - self.width) / 2;
        y: parent.height - self.height - 6px;
        border-radius: 2px;
        background:
              root.event-tone == Tone.success ? Theme.accent-success
            : root.event-tone == Tone.warning ? Theme.accent-warning
            : root.event-tone == Tone.danger  ? Theme.accent-danger
            : root.event-tone == Tone.info    ? Theme.accent-info
            : Theme.primary;
    }

    TouchArea {
        clicked => { root.clicked(); }
    }
}

// A single agenda card — coloured tone-bar on the leading edge gives
// the agenda list a Trello/Notion-like at-a-glance categorization.
component AgendaCard inherits Rectangle {
    in property <string> when;
    in property <string> title;
    in property <string> location;
    in property <Tone> tone: Tone.default;

    height: 72px;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    clip: true;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    // Leading tone bar (4 px-wide colour strip).
    Rectangle {
        x: 0;
        y: 0;
        width: 4px;
        height: parent.height;
        background:
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : Theme.primary;
    }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Time column.
        VerticalLayout {
            alignment: center;
            width: 64px;
            Text {
                text: root.when;
                color: Theme.muted;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
        }

        // Title + location.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.title;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 600;
                overflow: elide;
            }
            Text {
                text: root.location;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
                overflow: elide;
            }
        }
    }
}

export component CalendarPage inherits Rectangle {
    in property <string> month-label: "May 2026";
    callback back-pressed();
    callback prev-month-pressed();
    callback next-month-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.month-label;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/plus.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { /* new event */ }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            vertical-stretch: 1;

            // ----- Weekday header -----
            HorizontalLayout {
                spacing: 0;
                for label in ["S", "M", "T", "W", "T", "F", "S"]: VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: label;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                        font-weight: 600;
                        horizontal-alignment: center;
                    }
                }
            }

            // ----- Month grid (6 weeks × 7 days) -----
            //
            // May 2026 starts on a Friday and runs 31 days. The grid is
            // padded with the trailing days of April (last week: 26→30)
            // and the leading days of June (first week: 1→6).
            //
            // event-flag arrays mark which days carry events. Today is
            // the 14th; tone-tinted dots accent a handful of other days
            // to show the multi-tone capability.
            for week-index in 6 : HorizontalLayout {
                spacing: 0;
                for day-index in 7 : VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    property <int> cell-position: week-index * 7 + day-index;
                    // Friday May 1 = position 5 (Sun=0..Sat=6, so Fri=5)
                    // → start-offset = 5.
                    property <int> day-number:
                        cell-position < 5 ? 26 + cell-position
                      : cell-position > 35 ? cell-position - 35
                      : cell-position - 4;
                    property <bool> in-may:
                        cell-position >= 5 && cell-position <= 35;

                    DayCell {
                        day: day-number;
                        in-month: in-may;
                        today: in-may && day-number == 14;
                        has-event:
                            in-may && (
                                  day-number == 6
                               || day-number == 14
                               || day-number == 17
                               || day-number == 22
                               || day-number == 28
                            );
                        event-tone:
                              day-number == 6  ? Tone.info
                            : day-number == 14 ? Tone.default
                            : day-number == 17 ? Tone.success
                            : day-number == 22 ? Tone.warning
                            : day-number == 28 ? Tone.danger
                            : Tone.default;
                    }
                }
            }

            // ----- Agenda section -----
            VerticalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-sm;
                Text {
                    text: "Today, May 14";
                    color: Theme.on-background;
                    font-size: Theme.font-size-body-large;
                    font-weight: 600;
                }
                AgendaCard {
                    when: "09:00";
                    title: "Standup";
                    location: "Loom room";
                    tone: Tone.info;
                }
                AgendaCard {
                    when: "11:30";
                    title: "Design review — Tone enum rollout";
                    location: "Conf room B";
                    tone: Tone.default;
                }
                AgendaCard {
                    when: "14:00";
                    title: "1:1 with Priya";
                    location: "Outside coffee bar";
                    tone: Tone.success;
                }
                AgendaCard {
                    when: "16:30";
                    title: "Release cut deadline";
                    location: "—";
                    tone: Tone.warning;
                }
            }

            Rectangle { vertical-stretch: 1; }
        }
    }
}
