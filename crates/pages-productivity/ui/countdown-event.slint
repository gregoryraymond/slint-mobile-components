// CountdownEventPage
// =====================================================================
//
// Countdown to a future event — wedding-countdown / festival / launch
// day app surface. Distinct from `TimerPage` (live timer to zero) and
// `CalendarPage` (full month view). Demonstrates:
//
//   - Hero card with event cover gradient + event name + venue + date.
//   - 4-block countdown grid: Days / Hours / Minutes / Seconds, each
//     block carrying a big numeral + caption + tone-tinted accent
//     border. Days uses success-tone, others fade to muted.
//   - Quick-info card with three rows (location, time-to-arrival,
//     dress code) — each row tone-tinted.
//   - Action button row: Add to calendar (primary), Share, Set reminder.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton } from "@mobile-components/button.slint";

// One block in the days/hours/minutes/seconds countdown.
component CountdownBlock inherits Rectangle {
    in property <string> value;
    in property <string> label;
    in property <Tone> tone: Tone.success;
    in property <bool> ghost: false;

    horizontal-stretch: 1;
    height: 116px;
    background: root.ghost ? Theme.surface-1 : Theme.surface-2;
    border-radius: Theme.radius-md;
    border-width: root.ghost ? 0px : 2px;
    border-color:
          root.tone == Tone.success ? Theme.accent-success
        : root.tone == Tone.warning ? Theme.accent-warning
        : root.tone == Tone.danger  ? Theme.accent-danger
        : root.tone == Tone.info    ? Theme.accent-info
        : Theme.outline;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        spacing: 2px;
        alignment: center;
        Text {
            text: root.value;
            color:
                  root.ghost ? Theme.muted
                : Theme.on-background;
            font-size: 40px;
            font-weight: 800;
            horizontal-alignment: center;
        }
        Text {
            text: root.label;
            color: root.ghost ? Theme.muted : (
                  root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.warning ? Theme.accent-warning
                : root.tone == Tone.danger  ? Theme.accent-danger
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.muted
            );
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.5px;
            horizontal-alignment: center;
        }
    }
}

// Quick-info row.
component QuickInfoRow inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <string> value;
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    min-height: 56px;
    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: self.width / 2;
                background:
                      root.tone == Tone.success ? Theme.accent-success
                    : root.tone == Tone.warning ? Theme.accent-warning
                    : root.tone == Tone.danger  ? Theme.accent-danger
                    : root.tone == Tone.info    ? Theme.accent-info
                    : Theme.surface-variant;
                Image {
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: root.icon;
                    colorize: root.tone == Tone.default ? Theme.on-surface : Theme.on-primary;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.muted;
                font-size: 10px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }
            Text {
                text: root.value;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 700;
            }
        }
    }
}

export component CountdownEventPage inherits Rectangle {
    in property <string> event: "Slint Conf 2026";
    in property <string> venue: "Fort Mason Center · San Francisco";
    in property <string> when: "Thursday, May 22 · 09:00 PT";
    in property <string> days: "08";
    in property <string> hours: "14";
    in property <string> minutes: "37";
    in property <string> seconds: "42";
    callback back-pressed();
    callback share-pressed();
    callback add-calendar-pressed();
    callback set-reminder-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Countdown";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        // Hero gradient card.
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            Rectangle {
                horizontal-stretch: 1;
                height: 144px;
                background: @linear-gradient(135deg, #4f8cff 0%, #2c1d61 100%);
                border-radius: Theme.radius-lg;
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                clip: true;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    alignment: end;
                    Text {
                        text: "UPCOMING";
                        color: #ffffffaa;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 1px;
                    }
                    Text {
                        text: root.event;
                        color: #ffffff;
                        font-size: Theme.font-size-headline;
                        font-weight: 800;
                    }
                    Text {
                        text: root.venue;
                        color: #ffffffcc;
                        font-size: Theme.font-size-caption;
                    }
                    Text {
                        text: root.when;
                        color: #ffffffcc;
                        font-size: Theme.font-size-caption;
                        font-weight: 700;
                    }
                }
            }

            // Countdown grid.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                CountdownBlock {
                    value: root.days;
                    label: "DAYS";
                    tone: Tone.success;
                }
                CountdownBlock {
                    value: root.hours;
                    label: "HOURS";
                    tone: Tone.info;
                }
                CountdownBlock {
                    value: root.minutes;
                    label: "MIN";
                    ghost: true;
                }
                CountdownBlock {
                    value: root.seconds;
                    label: "SEC";
                    ghost: true;
                }
            }

            // Quick info card.
            Rectangle {
                horizontal-stretch: 1;
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                VerticalLayout {
                    spacing: 0;
                    QuickInfoRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        label: "WHERE";
                        value: "Fort Mason · Festival Pavilion";
                        tone: Tone.warning;
                    }
                    Divider { }
                    QuickInfoRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        label: "ARRIVE BY";
                        value: "08:30 · doors open at 09:00";
                        tone: Tone.info;
                    }
                    Divider { }
                    QuickInfoRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        label: "DRESS";
                        value: "Smart casual · indoor venue, layered";
                        tone: Tone.default;
                    }
                    Divider { }
                    QuickInfoRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        label: "BRING";
                        value: "Laptop, badge (mailed), water bottle";
                        tone: Tone.success;
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Footer actions.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 96px;
            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                MobileButton {
                    text: "Add to calendar";
                    tone: Tone.info;
                    max-height: 44px;
                    clicked => { root.add-calendar-pressed(); }
                }
                MobileButton {
                    text: "Set day-before reminder";
                    primary: false;
                    max-height: 36px;
                    clicked => { root.set-reminder-pressed(); }
                }
            }
        }
    }
}
