// CountdownEventPage
// =====================================================================
//
// A big-numeral countdown to a future event, with a precise
// days/hours/min/sec StatTile row and a stack of grouped sections for
// event details, description, and reminder toggles.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { StatTile } from "@mobile-components/stat-tile.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component CountdownEventPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> remind-day: true;
    in-out property <bool> remind-week: true;
    in-out property <bool> remind-month: false;

    callback back-pressed();
    callback share-pressed();
    callback add-calendar-pressed();
    callback share-countdown-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Countdown";
            title-style: HeadingStyle.plex-medium;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/send.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.share-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-lg;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: stretch;

                // ----- Hero numeral -----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    alignment: center;

                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "32";
                            color: Theme.on-background;
                            font-family: "Fraunces 9pt";
                            font-size: 80px;
                            font-weight: 400;
                            horizontal-alignment: center;
                        }
                    }
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "DAYS REMAINING";
                            color: Theme.muted;
                            font-size: 10px;
                            font-weight: 800;
                            letter-spacing: 1px;
                        }
                    }
                    HorizontalLayout {
                        alignment: center;
                        Text {
                            text: "Atlas Conference 2026";
                            color: Theme.on-background;
                            font-size: Theme.font-size-body-large;
                            font-weight: 600;
                        }
                    }
                }

                // ----- StatTile row ----------------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    StatTile { value: "32"; label: "DAYS"; }
                    StatTile { value: "18"; label: "HOURS"; tone: Tone.info; }
                    StatTile { value: "47"; label: "MIN"; }
                    StatTile { value: "12"; label: "SEC"; tone: Tone.warning; }
                }

                // ----- Event details ---------------------------------------
                FormSection {
                    title: "EVENT";

                    KeyValueRow {
                        label: "Date";
                        value: "Sat · 18 Jun 2026";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Time";
                        value: "09:00 — 18:00";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Location";
                        value: "BOZAR, Brussels";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Time zone";
                        value: "Europe/Brussels";
                    }
                }

                // ----- Description -----------------------------------------
                FormSection {
                    title: "DESCRIPTION";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.info;
                        title: "About this event";
                        subtitle: "An all-day gathering for the Atlas community. Keynote, workshops, and an evening reception. Doors open 08:30.";
                    }
                }

                // ----- Reminders -------------------------------------------
                FormSection {
                    title: "REMINDERS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.info;
                        title: "1 day before";
                        subtitle: "Push + email";
                        MobileSwitch { checked <=> root.remind-day; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.warning;
                        title: "1 week before";
                        subtitle: "Push only";
                        MobileSwitch { checked <=> root.remind-week; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        title: "1 month before";
                        subtitle: "Push only";
                        MobileSwitch { checked <=> root.remind-month; }
                    }
                }

                // ----- CTA -------------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Add to calendar";
                        clicked => { root.add-calendar-pressed(); }
                    }
                    TextButton {
                        text: "Share countdown";
                        clicked => { root.share-countdown-pressed(); }
                    }
                }
            }
        }
    }
}
