// JournalEntryPage
// =====================================================================
//
// One day's journal entry editor. Big date heading, MetaRow chips of
// today's context, then a stack of FormFields + FormSections.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { MetaRow, MetaChip } from "@mobile-components/meta-row.slint";
import { Chip } from "@mobile-components/chip.slint";
import { ScrollView } from "std-widgets.slint";

// One mood swatch — coloured pill with a single letter glyph.
component MoodSwatch inherits Rectangle {
    in property <string> glyph;
    in property <color> fill;
    in property <bool> selected: false;

    width: 36px;
    height: 36px;
    border-radius: self.width / 2;
    background: root.selected ? root.fill : Theme.surface-2;
    border-width: root.selected ? 0px : 2px;
    border-color: root.fill;

    Text {
        x: 0; y: 0;
        width: parent.width;
        height: parent.height;
        text: root.glyph;
        color: root.selected ? Theme.on-primary : root.fill;
        font-size: Theme.font-size-body;
        font-weight: 700;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

export component JournalEntryPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> title-text;
    in-out property <string> entry-text;
    in-out property <int> mood-index: 3;

    callback back-pressed();
    callback save-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Journal";
            title-style: HeadingStyle.serif-light;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/check.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.save-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: stretch;

                // ----- Date hero ------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-xs;
                    Heading {
                        text: "Saturday, May 17";
                        style: HeadingStyle.serif-display;
                        color: Theme.on-background;
                    }
                    MetaRow {
                        items: [
                            { icon: @image-url("@mobile-components/icons/star.svg"), text: "Sunny 18°" },
                            { icon: @image-url("@mobile-components/icons/pin.svg"), text: "Brussels" },
                            { icon: @image-url("@mobile-components/icons/pencil.svg"), text: "Day 142" },
                        ];
                    }
                }

                // ----- Mood -----------------------------------------
                FormSection {
                    title: "MOOD";

                    SettingRow {
                        title: "How was today?";
                        subtitle: "Tap a swatch to record your mood.";

                        HorizontalLayout {
                            spacing: Theme.spacing-sm;
                            alignment: end;
                            MoodSwatch {
                                glyph: "M";
                                fill: Theme.accent-danger;
                                selected: root.mood-index == 0;
                            }
                            MoodSwatch {
                                glyph: "B";
                                fill: Theme.accent-warning;
                                selected: root.mood-index == 1;
                            }
                            MoodSwatch {
                                glyph: "O";
                                fill: Theme.muted;
                                selected: root.mood-index == 2;
                            }
                            MoodSwatch {
                                glyph: "G";
                                fill: Theme.accent-info;
                                selected: root.mood-index == 3;
                            }
                            MoodSwatch {
                                glyph: "E";
                                fill: Theme.accent-success;
                                selected: root.mood-index == 4;
                            }
                        }
                    }
                }

                // ----- Fields ---------------------------------------
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    FormField {
                        label: "Title";
                        TextField {
                            placeholder: "Give today a title";
                            text <=> root.title-text;
                        }
                    }
                    FormField {
                        label: "Entry";
                        helper: "Min 50 chars.";
                        TextField {
                            placeholder: "What happened today?";
                            text <=> root.entry-text;
                        }
                    }
                }

                // ----- Tags -----------------------------------------
                FormSection {
                    title: "TAGS";

                    SettingRow {
                        title: "Tags";
                        subtitle: "3 selected";

                        HorizontalLayout {
                            spacing: Theme.spacing-xs;
                            alignment: end;
                            Chip { label: "work"; selected: true; }
                            Chip { label: "family"; selected: true; }
                            Chip { label: "rest"; selected: true; }
                        }
                    }
                }
            }
        }
    }
}
