// SearchResultsPage
// =====================================================================
//
// Search results page. AppBar with query as title, SegmentedControl
// for facets, a result-count caption, then grouped FormSections of
// SettingRows — every row a 56-px floor with consistent leading-icon
// tiles and trailing chevrons.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component SearchResultsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> facet-index: 0;

    callback back-pressed();
    callback close-pressed();
    callback result-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "atlas coffee";
            title-style: HeadingStyle.mono;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/close.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.close-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Facets ---------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["All", "Apps", "Files", "Mail", "Web"];
                        selected-index <=> root.facet-index;
                    }
                }

                // ----- Count caption --------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    alignment: start;
                    Text {
                        text: "247 results · 0.12 s";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }

                // ----- Top hits -------------------------------------
                FormSection {
                    title: "TOP HITS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        tone: Tone.info;
                        title: "Atlas Coffee Co.";
                        subtitle: "440 Avenue Louise · 1.2 km";
                        clicked => { root.result-pressed("place"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.warning;
                        title: "atlas-coffee.com/menu";
                        subtitle: "…order the Atlas Coffee house blend on tap…";
                        clicked => { root.result-pressed("menu"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "Atlas Coffee — review on Foodie";
                        subtitle: "…rated 4.7 by 312 Atlas Coffee regulars…";
                        clicked => { root.result-pressed("review"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        title: "Re: Atlas coffee order";
                        subtitle: "Sam · …picked up the Atlas coffee beans you wanted…";
                        clicked => { root.result-pressed("mail"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- From your files ------------------------------
                FormSection {
                    title: "FROM YOUR FILES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.info;
                        title: "atlas-coffee-receipts.pdf";
                        subtitle: "PDF · 412 KB · contains 14 matches";
                        clicked => { root.result-pressed("receipts"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "Atlas Coffee — meeting notes.md";
                        subtitle: "MD · 12 KB · 3 matches";
                        clicked => { root.result-pressed("notes"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/podcast-cover.svg");
                        tone: Tone.warning;
                        title: "Atlas-coffee-jingle.m4a";
                        subtitle: "Audio · 2.1 MB · 1 match in filename";
                        clicked => { root.result-pressed("audio"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
