// WorldClockPage
// =====================================================================
//
// Multi-timezone clock — iOS Clock / Sundial-style. Demonstrates:
//
//   - A "your location" hero card with big current time + date.
//   - A list of pinned timezones, each row carrying:
//       - day/night sun-or-moon glyph (tone-tinted)
//       - city name + offset chip
//       - big current time on the right + same/yesterday/tomorrow label
//   - A 24-hour day strip beneath the hero showing approximate day/
//     night windows across the time zones in view (each row is a
//     stripe with a sun-arc shaded portion).
//   - FAB to add a city.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { SectionHeader } from "@mobile-components/section-header.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Fab } from "@mobile-components/button.slint";

// One timezone row.
component ClockRow inherits Rectangle {
    in property <string> city;
    in property <string> offset;
    in property <string> time;
    in property <string> day-label;     // "Today" / "Yesterday" / "Tomorrow"
    in property <bool> day-time: true;  // true = sun glyph, false = moon
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    min-height: 72px;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;

        // Sun / moon glyph.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: self.width / 2;
                background:
                      root.day-time ? Theme.accent-warning
                    : Theme.surface-2;
                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source:
                          root.day-time ? @image-url("@mobile-components/icons/star.svg")
                        : @image-url("@mobile-components/icons/heart.svg");
                    colorize:
                          root.day-time ? Theme.on-primary
                        : Theme.muted;
                    image-fit: contain;
                }
            }
        }

        // City + offset.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 4px;
            Text {
                text: root.city;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 600;
            }
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                Rectangle {
                    width: off-text.preferred-width + 10px;
                    height: 18px;
                    border-radius: 4px;
                    background: Theme.surface-variant;
                    off-text := Text {
                        text: root.offset;
                        color: Theme.muted;
                        font-size: 10px;
                        font-weight: 700;
                        letter-spacing: 0.3px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
                Text {
                    text: root.day-label;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    vertical-alignment: center;
                }
            }
        }

        // Current time on the right.
        VerticalLayout {
            alignment: center;
            Text {
                text: root.time;
                color: Theme.on-surface;
                font-size: 28px;
                font-weight: 200;
                horizontal-alignment: right;
            }
        }
    }
}

// A 24-hour day strip — visualises which portion of the day each city
// is currently in (sunrise → sunset shaded warm, night shaded dark).
component DayStrip inherits Rectangle {
    in property <string> city;
    // 0..24 sunrise/sunset hours, 0..24 current-position-hour.
    in property <float> sunrise: 7.0;
    in property <float> sunset: 19.0;
    in property <float> now: 12.0;

    horizontal-stretch: 1;
    height: 28px;

    HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            width: 60px;
            Text {
                text: root.city;
                color: Theme.muted;
                font-size: 11px;
                font-weight: 700;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Rectangle {
                height: 8px;
                border-radius: 4px;
                background: @linear-gradient(90deg, #1f2937 0%, #1f2937 100%);
                clip: true;

                // Daylight stripe (sunrise → sunset).
                Rectangle {
                    x: parent.width * (root.sunrise / 24);
                    y: 0;
                    width: parent.width * ((root.sunset - root.sunrise) / 24);
                    height: parent.height;
                    background: @linear-gradient(90deg, #f59e0b 0%, #fde68a 50%, #f59e0b 100%);
                }

                // Current-time marker.
                Rectangle {
                    x: parent.width * (root.now / 24) - 1px;
                    y: -3px;
                    width: 2px;
                    height: parent.height + 6px;
                    background: Theme.accent-info;
                }
            }
        }
    }
}

export component WorldClockPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    in property <string> here-city: "San Francisco";
    in property <string> here-time: "14:32";
    in property <string> here-date: "Wednesday, May 14";
    callback back-pressed();
    callback add-city-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "World clock";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // ----- Here hero -----
        VerticalLayout {
            padding: Theme.spacing-lg;
            padding-bottom: Theme.spacing-md;
            spacing: 2px;
            alignment: center;
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "HERE · " + root.here-city;
                    color: Theme.muted;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.here-time;
                    color: Theme.on-background;
                    font-size: 80px;
                    font-weight: 200;
                }
            }
            HorizontalLayout {
                alignment: center;
                Text {
                    text: root.here-date;
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
            }
        }

        // ----- Day-strip cluster -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            spacing: 4px;
            DayStrip { city: "SFO"; sunrise: 6.3; sunset: 20.2; now: 14.5; }
            DayStrip { city: "LIS"; sunrise: 6.7; sunset: 20.6; now: 22.5; }
            DayStrip { city: "TYO"; sunrise: 4.6; sunset: 18.7; now: 6.5; }
            DayStrip { city: "SYD"; sunrise: 6.5; sunset: 17.1; now: 7.5; }
        }

        SectionHeader { text: "FAVOURITES"; }

        ClockRow {
            city: "Lisbon";
            offset: "GMT+1";
            time: "22:32";
            day-label: "Today";
            day-time: false;
            tone: Tone.info;
        }
        Divider { }
        ClockRow {
            city: "London";
            offset: "GMT+0";
            time: "21:32";
            day-label: "Today";
            day-time: false;
        }
        Divider { }
        ClockRow {
            city: "Tokyo";
            offset: "GMT+9";
            time: "06:32";
            day-label: "Tomorrow";
            day-time: true;
            tone: Tone.warning;
        }
        Divider { }
        ClockRow {
            city: "Sydney";
            offset: "GMT+10";
            time: "07:32";
            day-label: "Tomorrow";
            day-time: true;
            tone: Tone.warning;
        }
        Divider { }
        ClockRow {
            city: "New York";
            offset: "GMT−4";
            time: "17:32";
            day-label: "Today";
            day-time: true;
        }

        Rectangle { vertical-stretch: 1; }
    }

    Fab {
        x: root.width - self.width - Theme.spacing-md;
        y: root.height - self.height - Theme.spacing-md;
        accessible-label: "Add city";
        clicked => { root.add-city-pressed(); }
    }
}
