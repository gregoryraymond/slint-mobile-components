// FormWizardPage
// =====================================================================
//
// Multi-step form mid-flow. Pure FormField + ProgressBar discipline.
// "Back / Continue" buttons sit at the bottom in a HorizontalLayout.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { HeadingStyle } from "@mobile-components/heading.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { ProgressBar } from "@mobile-components/progress-bar.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component FormWizardPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> first-name;
    in-out property <string> last-name;
    in-out property <string> dob;
    in-out property <string> phone;
    in-out property <bool> product-updates: true;
    in-out property <bool> marketing-emails: false;

    callback back-pressed();
    callback continue-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Step 2 of 4";
            title-style: HeadingStyle.caps-tight;
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // Progress bar directly under the bar — full-width inset matches body.
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-xs;
            padding-bottom: Theme.spacing-sm;
            ProgressBar { value: 0.5; }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-sm;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: start;

                // ----- About you -------------------------------------------
                FormSection {
                    title: "ABOUT YOU";
                    caption: "Step 2 — Your details";
                }

                // The actual FormFields live OUTSIDE the FormSection's card
                // so they get the standard field-stack rhythm rather than
                // being squashed into the card chrome.
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    FormField {
                        label: "First name";
                        required: true;
                        TextField {
                            placeholder: "Ada";
                            text <=> root.first-name;
                        }
                    }
                    FormField {
                        label: "Last name";
                        required: true;
                        TextField {
                            placeholder: "Lovelace";
                            text <=> root.last-name;
                        }
                    }
                    FormField {
                        label: "Date of birth";
                        helper: "We use this to personalise content.";
                        TextField {
                            placeholder: "MM / DD / YYYY";
                            text <=> root.dob;
                        }
                    }
                    FormField {
                        label: "Phone";
                        helper: "Include country code.";
                        TextField {
                            placeholder: "+32 470 12 34 56";
                            text <=> root.phone;
                            input-type: InputType.number;
                        }
                    }
                }

                // ----- Preferences -----------------------------------------
                FormSection {
                    title: "PREFERENCES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.info;
                        title: "Send me product updates";
                        subtitle: "Release notes and new features.";
                        MobileSwitch { checked <=> root.product-updates; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        title: "Allow marketing emails";
                        subtitle: "Occasional newsletters and promos.";
                        MobileSwitch { checked <=> root.marketing-emails; }
                    }
                }

                // ----- Nav bar at bottom -----------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    TextButton {
                        text: "Back";
                        clicked => { root.back-pressed(); }
                    }
                    Rectangle { horizontal-stretch: 1; }
                    MobileButton {
                        text: "Continue";
                        horizontal-stretch: 0;
                        min-width: 160px;
                        enabled: root.first-name != "" && root.last-name != "";
                        clicked => { root.continue-pressed(); }
                    }
                }
            }
        }
    }
}
