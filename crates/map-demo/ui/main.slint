// Re-export every map-using page so the demo binary gets typed Rust
// bindings for each. All six pages share the same `map-*` properties
// + callbacks, so the Rust side uses one macro to wire `MapController`
// against whichever page the user picks from the CLI.

import { Tile } from "@mapping/map.slint";
import { MapPage } from "@mobile-pages-travel/map.slint";
import { TurnByTurnNavPage } from "@mobile-pages-travel/turn-by-turn-nav.slint";
import { DriverOnTheWayPage } from "@mobile-pages-travel/driver-on-the-way.slint";
import { RideShareBookingPage } from "@mobile-pages-travel/ride-share-booking.slint";
import { ParkingSessionPage } from "@mobile-pages-travel/parking-session.slint";
import { StoreLocatorPage } from "@mobile-pages-commerce/store-locator.slint";

export {
    Tile,
    MapPage,
    TurnByTurnNavPage,
    DriverOnTheWayPage,
    RideShareBookingPage,
    ParkingSessionPage,
    StoreLocatorPage,
}
