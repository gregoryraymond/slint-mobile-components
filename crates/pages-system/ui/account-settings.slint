// AccountSettingsPage
// =====================================================================
//
// Profile-card header + grouped settings (account / privacy / notifs /
// danger). Pure showcase of `SettingRow` + `FormSection` discipline —
// every row is the same primitive with a different trailing slot, so
// the leading tiles, titles, dividers and trailing controls line up
// across the whole page.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Chip } from "@mobile-components/chip.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { ScrollView } from "std-widgets.slint";

export component AccountSettingsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> two-factor: true;
    in-out property <bool> activity-log: true;
    in-out property <bool> analytics: false;
    in-out property <bool> push-notifications: true;
    in-out property <bool> email-notifications: true;
    in-out property <bool> marketing-notifications: false;

    callback back-pressed();
    callback row-pressed(string);
    callback profile-pressed();
    callback sign-out-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Account";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Profile hero card ------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        tappable: true;
                        clicked => { root.profile-pressed(); }

                        HorizontalLayout {
                            spacing: Theme.spacing-md;
                            alignment: stretch;

                            Avatar {
                                fallback: "GR";
                                size: 64px;
                            }
                            VerticalLayout {
                                horizontal-stretch: 1;
                                alignment: center;
                                spacing: Theme.spacing-xs;

                                Text {
                                    text: "Greg Raymond";
                                    color: Theme.on-surface;
                                    font-size: 18px;
                                    font-weight: 700;
                                    overflow: elide;
                                }
                                Text {
                                    text: "greg@slint.dev";
                                    color: Theme.muted;
                                    font-size: Theme.font-size-caption;
                                }
                                HorizontalLayout {
                                    alignment: start;
                                    Chip {
                                        label: "PRO";
                                        selected: true;
                                    }
                                }
                            }
                            VerticalLayout {
                                alignment: center;
                                Image {
                                    width: 16px;
                                    height: 16px;
                                    source: @image-url("@mobile-components/icons/chevron-right.svg");
                                    colorize: Theme.muted;
                                    image-fit: contain;
                                }
                            }
                        }
                    }
                }

                // ----- ACCOUNT ----------------------------------------
                FormSection {
                    title: "ACCOUNT";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Personal information";
                        subtitle: "Name, photo, contact details.";
                        clicked => { root.row-pressed("personal"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        title: "Password & sign-in";
                        subtitle: "Update password, security keys, passkeys.";
                        clicked => { root.row-pressed("password"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Subscription";
                        subtitle: "Renews 14 Jun 2026.";
                        clicked => { root.row-pressed("subscription"); }
                        Text {
                            text: "Pro · annual";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        title: "Connected apps";
                        subtitle: "Third-party access to your account.";
                        clicked => { root.row-pressed("connected"); }
                        Text {
                            text: "3";
                            color: Theme.muted;
                            font-size: Theme.font-size-body;
                            vertical-alignment: center;
                        }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- PRIVACY & SECURITY -----------------------------
                FormSection {
                    title: "PRIVACY & SECURITY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.success;
                        title: "Two-factor authentication";
                        subtitle: "Authenticator app · 2 recovery codes left.";
                        MobileSwitch { checked <=> root.two-factor; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "Activity log";
                        subtitle: "Sign-ins and security events.";
                        MobileSwitch { checked <=> root.activity-log; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Personalised analytics";
                        subtitle: "Improve recommendations using your usage.";
                        MobileSwitch { checked <=> root.analytics; }
                    }
                }

                // ----- NOTIFICATIONS ----------------------------------
                FormSection {
                    title: "NOTIFICATIONS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        tone: Tone.info;
                        title: "Push notifications";
                        subtitle: "Mentions, alerts, account events.";
                        MobileSwitch { checked <=> root.push-notifications; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        title: "Email digest";
                        subtitle: "A weekly summary delivered Monday morning.";
                        MobileSwitch { checked <=> root.email-notifications; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        title: "Product updates";
                        subtitle: "New features, releases, tips.";
                        MobileSwitch { checked <=> root.marketing-notifications; }
                    }
                }

                // ----- DANGER ZONE ------------------------------------
                FormSection {
                    title: "DANGER ZONE";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/close.svg");
                        tone: Tone.danger;
                        title: "Sign out everywhere";
                        subtitle: "Ends sessions on all your devices.";
                        destructive: true;
                        clicked => { root.sign-out-pressed(); }
                    }
                }
            }
        }
    }
}
