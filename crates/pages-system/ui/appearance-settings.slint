// AppearanceSettingsPage
// =====================================================================
//
// Theme + text-size + accent-colour preferences. Showcases the trailing
// slot of `SettingRow` carrying very different widgets — `MobileSwitch`,
// `SegmentedControl`, `Slider`, value `Text` + check `Image` — while
// the rows themselves all share the same 56 px floor and 16 px gutters.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Slider } from "@mobile-components/slider.slint";
import { ScrollView } from "std-widgets.slint";

export component AppearanceSettingsPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <bool> match-system: false;
    in-out property <int> theme-mode: 1;
    in-out property <float> text-scale: 0.5;
    in-out property <int> accent-index: 0;
    in-out property <bool> high-contrast: false;
    in-out property <bool> reduce-motion: false;

    callback back-pressed();
    callback accent-pressed(int);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Appearance";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- THEME ------------------------------------------
                FormSection {
                    title: "THEME";

                    SettingRow {
                        title: "Match system";
                        subtitle: "Follow your OS light / dark setting.";
                        MobileSwitch { checked <=> root.match-system; }
                    }
                    Divider { }
                    SettingRow {
                        title: "Theme mode";
                        subtitle: "Override when not matching system.";
                        SegmentedControl {
                            width: 200px;
                            options: ["Light", "Dark", "Auto"];
                            selected-index <=> root.theme-mode;
                        }
                    }
                }

                // ----- TEXT SIZE --------------------------------------
                FormSection {
                    title: "TEXT SIZE";

                    SettingRow {
                        title: "Adjust scaling";
                        subtitle: "Affects all reading surfaces.";
                        Slider {
                            width: 160px;
                            value <=> root.text-scale;
                        }
                    }
                }

                // ----- ACCENT COLOUR ----------------------------------
                FormSection {
                    title: "ACCENT COLOUR";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.info;
                        title: "Blue";
                        clicked => { root.accent-pressed(0); }
                        if root.accent-index == 0: Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "Emerald";
                        clicked => { root.accent-pressed(1); }
                        if root.accent-index == 1: Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Sunset";
                        clicked => { root.accent-pressed(2); }
                        if root.accent-index == 2: Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.danger;
                        title: "Berry";
                        clicked => { root.accent-pressed(3); }
                        if root.accent-index == 3: Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        title: "Slate";
                        clicked => { root.accent-pressed(4); }
                        if root.accent-index == 4: Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/check.svg");
                            colorize: Theme.primary;
                            image-fit: contain;
                        }
                    }
                }

                // ----- ADVANCED ---------------------------------------
                FormSection {
                    title: "ADVANCED";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pencil.svg");
                        title: "High contrast";
                        subtitle: "Stronger separations between surfaces.";
                        MobileSwitch { checked <=> root.high-contrast; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Reduce motion";
                        subtitle: "Disables non-essential animations.";
                        MobileSwitch { checked <=> root.reduce-motion; }
                    }
                }
            }
        }
    }
}
