// NotificationCenterPage
// =====================================================================
//
// A unified inbox for app, mention, mail and system notifications.
// Filter strip at the top (SegmentedControl), then notifications grouped
// by recency (TODAY / YESTERDAY / OLDER). Every row is a `SettingRow`,
// so the leading-icon tiles, titles and timestamps line up at the same
// 16 px gutters across the whole screen.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { TextButton } from "@mobile-components/button.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component NotificationCenterPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <int> filter-index: 0;

    callback back-pressed();
    callback clear-all-pressed();
    callback notification-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Notifications";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            alignment: end;
            TextButton {
                text: "Clear all";
                clicked => { root.clear-all-pressed(); }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-sm;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Filter strip -----------------------------------
                HorizontalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    SegmentedControl {
                        options: ["All", "Mentions", "Mail", "System"];
                        selected-index <=> root.filter-index;
                    }
                }

                // ----- TODAY ------------------------------------------
                FormSection {
                    title: "TODAY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        tone: Tone.info;
                        title: "Léa mentioned you";
                        subtitle: "2h ago · in #design-system thread.";
                        clicked => { root.notification-pressed("lea-mention"); }
                        Image {
                            width: 14px;
                            height: 14px;
                            source: @image-url("@mobile-components/icons/bell.svg");
                            colorize: Theme.accent-info;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        title: "3 new emails";
                        subtitle: "3h ago · from Atlas Coffee, Slint, Stripe.";
                        clicked => { root.notification-pressed("inbox"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.warning;
                        title: "New sign-in from Berlin";
                        subtitle: "5h ago · review if this wasn't you.";
                        clicked => { root.notification-pressed("signin"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.success;
                        title: "Weekly summary ready";
                        subtitle: "8h ago · 4 wins, 2 follow-ups.";
                        clicked => { root.notification-pressed("summary"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        title: "Invoice #2147 paid";
                        subtitle: "11h ago · €115.33 from Atlas Coffee.";
                        clicked => { root.notification-pressed("invoice"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- YESTERDAY --------------------------------------
                FormSection {
                    title: "YESTERDAY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        title: "Background sync completed";
                        subtitle: "1d ago · 42 items updated.";
                        clicked => { root.notification-pressed("sync"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/heart.svg");
                        tone: Tone.danger;
                        title: "Marco liked your post";
                        subtitle: "1d ago · \"Designing for thumbs\".";
                        clicked => { root.notification-pressed("like"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "Update available · 1.4.2";
                        subtitle: "1d ago · bug fixes and improvements.";
                        clicked => { root.notification-pressed("update"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/pin.svg");
                        title: "Pinned thread updated";
                        subtitle: "1d ago · Q3 roadmap.";
                        clicked => { root.notification-pressed("pinned"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- OLDER ------------------------------------------
                FormSection {
                    title: "OLDER";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        title: "Reminder · Renew subscription";
                        subtitle: "3d ago.";
                        clicked => { root.notification-pressed("renew"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Yumi accepted your invite";
                        subtitle: "5d ago.";
                        clicked => { root.notification-pressed("invite"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        title: "Password changed";
                        subtitle: "12d ago · from this device.";
                        clicked => { root.notification-pressed("password"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }
        }
    }
}
