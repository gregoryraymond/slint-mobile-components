// HelpCenterPage
// =====================================================================
//
// FAQ-style help index with a search field, popular articles, and
// contact entry points. Pure showcase of `SettingRow` discipline — every
// "article" / "channel" / "version" row is the same primitive, so the
// leading tiles and titles all line up vertically.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component HelpCenterPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> query;

    callback back-pressed();
    callback search-pressed();
    callback article-pressed(string);
    callback contact-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Help";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            trailing-icon: @image-url("@mobile-components/icons/search.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.search-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Search field -----------------------------------
                FormField {
                    TextField {
                        placeholder: "Search help articles";
                        text <=> root.query;
                    }
                }

                // ----- POPULAR ----------------------------------------
                FormSection {
                    title: "POPULAR";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.info;
                        title: "Getting started checklist";
                        subtitle: "5 min read · updated last week.";
                        clicked => { root.article-pressed("getting-started"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Upgrade to Pro";
                        subtitle: "4 min read · updated last week.";
                        clicked => { root.article-pressed("upgrade"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/bell.svg");
                        title: "Managing notifications";
                        subtitle: "3 min read · updated last week.";
                        clicked => { root.article-pressed("notifications"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.success;
                        title: "Securing your account";
                        subtitle: "7 min read · updated last week.";
                        clicked => { root.article-pressed("security"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- CONTACT US -------------------------------------
                FormSection {
                    title: "CONTACT US";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/send.svg");
                        tone: Tone.info;
                        title: "Email support";
                        subtitle: "Replies in 24 h.";
                        clicked => { root.contact-pressed("email"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.success;
                        title: "Live chat";
                        subtitle: "Mon–Fri 09:00–18:00 CET.";
                        clicked => { root.contact-pressed("chat"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/profile.svg");
                        title: "Community forum";
                        subtitle: "Get help from other users.";
                        clicked => { root.contact-pressed("forum"); }
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("@mobile-components/icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }

                // ----- APP --------------------------------------------
                FormSection {
                    title: "APP";

                    KeyValueRow {
                        label: "Version";
                        value: "1.4.2 · 3187";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Device ID";
                        value: "d8e2-7710";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Locale";
                        value: "en-GB";
                    }
                }
            }
        }
    }
}
