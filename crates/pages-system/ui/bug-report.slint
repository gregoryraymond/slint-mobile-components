// BugReportPage
// =====================================================================
//
// A "report a bug" form. Mixes the form-field stack used by signup with
// the grouped-settings stack used by account-settings — so the labels,
// inputs, attachment rows and toggle rows all share the same gutter
// inset (16 px) and vertical rhythm regardless of slot type.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { FormField } from "@mobile-components/form-field.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { TextButton } from "@mobile-components/button.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component BugReportPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    in-out property <string> bug-title;
    in-out property <string> what-happened;
    in-out property <string> what-should-have-happened;
    in-out property <int> severity: 1;
    in-out property <bool> include-diagnostics: true;

    callback back-pressed();
    callback send-pressed();
    callback add-screenshot-pressed();
    callback remove-attachment(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Report a bug";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // Send action lives just under the bar so it stays reachable.
        HorizontalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            alignment: end;
            TextButton {
                text: "Send";
                clicked => { root.send-pressed(); }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-sm;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: start;

                // ----- Free-text fields -------------------------------
                VerticalLayout {
                    spacing: Theme.spacing-md;
                    alignment: stretch;

                    FormField {
                        label: "Title";
                        required: true;
                        TextField {
                            placeholder: "Brief summary of the issue";
                            text <=> root.bug-title;
                        }
                    }

                    FormField {
                        label: "What happened?";
                        TextField {
                            placeholder: "Tell us what you were doing and what went wrong";
                            text <=> root.what-happened;
                        }
                    }

                    FormField {
                        label: "What should have happened?";
                        TextField {
                            placeholder: "Describe the expected behaviour";
                            text <=> root.what-should-have-happened;
                        }
                    }
                }

                // ----- SEVERITY ---------------------------------------
                FormSection {
                    title: "SEVERITY";

                    SettingRow {
                        title: "How bad is it?";
                        subtitle: "Helps us triage and prioritise.";
                        SegmentedControl {
                            width: 220px;
                            options: ["Minor", "Major", "Crash"];
                            selected-index <=> root.severity;
                        }
                    }
                }

                // ----- ATTACHMENTS ------------------------------------
                FormSection {
                    title: "ATTACHMENTS";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "screenshot-001.png";
                        subtitle: "412 KB";
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.remove-attachment("screenshot-001.png"); }
                            }
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "screenshot-002.png";
                        subtitle: "318 KB";
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.remove-attachment("screenshot-002.png"); }
                            }
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/plus.svg");
                        tone: Tone.info;
                        title: "Add screenshot";
                        clicked => { root.add-screenshot-pressed(); }
                    }
                }

                // ----- DIAGNOSTICS ------------------------------------
                FormSection {
                    title: "DIAGNOSTICS";
                    caption: "Helps engineering find the issue faster.";

                    KeyValueRow {
                        label: "App version";
                        value: "1.4.2 · 3187";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "OS";
                        value: "Android 14";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Device";
                        value: "Pixel 8 Pro";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Locale";
                        value: "en-GB";
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/lock.svg");
                        tone: Tone.info;
                        title: "Include diagnostics in report";
                        subtitle: "Attaches the table above to the bug.";
                        MobileSwitch { checked <=> root.include-diagnostics; }
                    }
                }
            }
        }
    }
}
