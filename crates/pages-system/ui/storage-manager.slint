// StorageManagerPage
// =====================================================================
//
// Phone storage breakdown — a hero card with usage headline + progress,
// a per-category list, a "largest files" list, and free-up actions at
// the bottom. Every list row is a `SettingRow`; the percentage trailing
// uses a `Chip` so the right-edge column stays consistent.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { Card } from "@mobile-components/card.slint";
import { Chip } from "@mobile-components/chip.slint";
import { ProgressBar } from "@mobile-components/progress-bar.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { SettingRow } from "@mobile-components/setting-row.slint";
import { MobileButton } from "@mobile-components/button.slint";
import { Divider } from "@mobile-components/divider.slint";
import { ScrollView } from "std-widgets.slint";

export component StorageManagerPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback category-pressed(string);
    callback file-pressed(string);
    callback delete-file(string);
    callback free-up-pressed();
    callback manage-backups-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Storage";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-md;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-md;
                alignment: stretch;

                // ----- Hero ------------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;

                    Card {
                        VerticalLayout {
                            spacing: Theme.spacing-sm;

                            Heading {
                                text: "64 GB";
                                style: HeadingStyle.bold-impact;
                                color: Theme.on-surface;
                            }
                            Text {
                                text: "of 128 GB used";
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                            }
                            ProgressBar {
                                value: 0.5;
                            }
                        }
                    }
                }

                // ----- BY CATEGORY -----------------------------------
                FormSection {
                    title: "BY CATEGORY";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        tone: Tone.info;
                        title: "Photos & video";
                        subtitle: "12.4 GB · 19 % of total.";
                        clicked => { root.category-pressed("photos"); }
                        Chip { label: "19 %"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        tone: Tone.success;
                        title: "Apps";
                        subtitle: "9.8 GB · 15 % of total.";
                        clicked => { root.category-pressed("apps"); }
                        Chip { label: "15 %"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/star.svg");
                        tone: Tone.warning;
                        title: "Audio";
                        subtitle: "6.1 GB · 9 % of total.";
                        clicked => { root.category-pressed("audio"); }
                        Chip { label: "9 %"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/inbox.svg");
                        tone: Tone.danger;
                        title: "Documents";
                        subtitle: "3.2 GB · 5 % of total.";
                        clicked => { root.category-pressed("documents"); }
                        Chip { label: "5 %"; }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/queue.svg");
                        title: "System & cache";
                        subtitle: "32.5 GB · 52 % of total.";
                        clicked => { root.category-pressed("system"); }
                        Chip { label: "52 %"; }
                    }
                }

                // ----- LARGE FILES -----------------------------------
                FormSection {
                    title: "LARGE FILES";

                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "trip-album-2025.mov";
                        subtitle: "412 MB · last opened 23 days ago.";
                        clicked => { root.file-pressed("trip-album-2025.mov"); }
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.delete-file("trip-album-2025.mov"); }
                            }
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "design-system.sketch";
                        subtitle: "286 MB · last opened 41 days ago.";
                        clicked => { root.file-pressed("design-system.sketch"); }
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.delete-file("design-system.sketch"); }
                            }
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "podcast-archive.zip";
                        subtitle: "204 MB · last opened 67 days ago.";
                        clicked => { root.file-pressed("podcast-archive.zip"); }
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.delete-file("podcast-archive.zip"); }
                            }
                        }
                    }
                    Divider { }
                    SettingRow {
                        icon: @image-url("@mobile-components/icons/menu.svg");
                        title: "vacation-raws.zip";
                        subtitle: "188 MB · last opened 80 days ago.";
                        clicked => { root.file-pressed("vacation-raws.zip"); }
                        Image {
                            width: 18px;
                            height: 18px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                            TouchArea {
                                clicked => { root.delete-file("vacation-raws.zip"); }
                            }
                        }
                    }
                }

                // ----- Actions ---------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Free up space";
                        clicked => { root.free-up-pressed(); }
                    }
                    MobileButton {
                        text: "Manage backups";
                        primary: false;
                        clicked => { root.manage-backups-pressed(); }
                    }
                }
            }
        }
    }
}
