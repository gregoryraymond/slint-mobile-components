// AppErrorPage
// =====================================================================
//
// Full-page error / offline / "something went wrong" state. The
// counterpart to `EmptyState` — but a full-screen surface for the
// canonical scenarios:
//
//   - lost connection
//   - server side-down
//   - permission missing / access denied
//   - rate-limited (try again later)
//
// Demonstrates:
//
//   - A centred hero "illustration" (a large tone-tinted disc with an
//     iconic glyph), title + supporting prose underneath.
//   - Primary "Retry" CTA + secondary "Continue offline" TextButton.
//   - A small system status footer with last-attempt timestamp and a
//     "View status page" affordance.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { Divider } from "@mobile-components/divider.slint";

export component AppErrorPage inherits Rectangle {
    in property <string> headline: "We can't reach our servers";
    in property <string> body:
        "Your internet connection is fine — we're just not getting a response from the backend. Some recent activity has been saved locally and will sync when we reconnect.";
    in property <string> error-code: "ERR_NET_504 · 2 minutes ago";
    in property <Tone> tone: Tone.danger;
    callback back-pressed();
    callback retry-pressed();
    callback continue-offline-pressed();
    callback view-status-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Something went wrong";
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        // Centred hero block.
        Rectangle {
            vertical-stretch: 1;
            horizontal-stretch: 1;

            VerticalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: parent.height;
                alignment: center;
                spacing: Theme.spacing-md;

                // Illustration disc.
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: 160px;
                        height: 160px;
                        border-radius: self.width / 2;
                        background:
                              root.tone == Tone.success ? #22c55e22
                            : root.tone == Tone.warning ? #f59e0b22
                            : root.tone == Tone.danger  ? #ef444422
                            : root.tone == Tone.info    ? #4f8cff22
                            : Theme.surface-2;

                        // Inner accent disc.
                        Rectangle {
                            x: (parent.width - self.width) / 2;
                            y: (parent.height - self.height) / 2;
                            width: 88px;
                            height: 88px;
                            border-radius: self.width / 2;
                            background:
                                  root.tone == Tone.success ? Theme.accent-success
                                : root.tone == Tone.warning ? Theme.accent-warning
                                : root.tone == Tone.danger  ? Theme.accent-danger
                                : root.tone == Tone.info    ? Theme.accent-info
                                : Theme.surface-variant;

                            // Glyph.
                            Text {
                                text:
                                      root.tone == Tone.success ? "✓"
                                    : root.tone == Tone.warning ? "!"
                                    : root.tone == Tone.danger  ? "✕"
                                    : root.tone == Tone.info    ? "i"
                                    : "?";
                                color: Theme.on-primary;
                                font-size: 40px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                }

                // Headline.
                HorizontalLayout {
                    padding-left: Theme.spacing-lg;
                    padding-right: Theme.spacing-lg;
                    alignment: center;
                    Text {
                        text: root.headline;
                        color: Theme.on-background;
                        font-size: Theme.font-size-headline;
                        font-weight: 800;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                // Supporting body.
                HorizontalLayout {
                    padding-left: Theme.spacing-lg;
                    padding-right: Theme.spacing-lg;
                    Text {
                        text: root.body;
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                }

                // Error code chip.
                HorizontalLayout {
                    alignment: center;
                    Rectangle {
                        width: code-text.preferred-width + 20px;
                        height: 24px;
                        border-radius: 12px;
                        background: Theme.surface-variant;
                        code-text := Text {
                            text: root.error-code;
                            color: Theme.muted;
                            font-size: 11px;
                            font-family: "Menlo";
                            font-weight: 600;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }
        }

        // Bottom CTA stack.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 168px;
            VerticalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-sm;
                MobileButton {
                    text: "Retry";
                    tone: Tone.info;
                    max-height: 48px;
                    clicked => { root.retry-pressed(); }
                }
                MobileButton {
                    text: "Continue in offline mode";
                    primary: false;
                    max-height: 44px;
                    clicked => { root.continue-offline-pressed(); }
                }
                Divider { }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: center;
                    Text {
                        text: "Last status check: just now ·";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                        vertical-alignment: center;
                    }
                    TextButton {
                        text: "View status page";
                        clicked => { root.view-status-pressed(); }
                    }
                }
            }
        }
    }
}
