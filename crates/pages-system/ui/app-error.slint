// AppErrorPage
// =====================================================================
//
// Friendly error fallback — what the user sees when something has gone
// catastrophically wrong. Big tinted glyph + apologetic heading + the
// diagnostics block that engineering actually needs, all laid out with
// the shared row/section primitives so the alignment stays honest.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { Heading, HeadingStyle } from "@mobile-components/heading.slint";
import { FormSection } from "@mobile-components/form-section.slint";
import { KeyValueRow } from "@mobile-components/key-value-row.slint";
import { Divider } from "@mobile-components/divider.slint";
import { MobileButton, TextButton } from "@mobile-components/button.slint";
import { ScrollView } from "std-widgets.slint";

export component AppErrorPage inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;

    callback back-pressed();
    callback retry-pressed();
    callback report-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            leading-icon: @image-url("@mobile-components/icons/arrow-left.svg");
            leading-pressed => { root.back-pressed(); }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                padding-top: Theme.spacing-lg;
                padding-bottom: Theme.spacing-xl;
                spacing: Theme.spacing-lg;
                alignment: stretch;

                // ----- Hero block -------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: center;

                    HorizontalLayout {
                        alignment: center;
                        Image {
                            width: 96px;
                            height: 96px;
                            source: @image-url("@mobile-components/icons/close.svg");
                            colorize: Theme.accent-danger;
                            image-fit: contain;
                        }
                    }
                    Heading {
                        text: "Something went wrong";
                        style: HeadingStyle.serif-display;
                        color: Theme.on-background;
                        horizontal-alignment: center;
                    }
                    Text {
                        text: "We hit an unexpected issue. Try again, or report it so we can fix it.";
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }

                // ----- Error details ----------------------------------
                FormSection {
                    title: "ERROR DETAILS";

                    KeyValueRow {
                        label: "Code";
                        value: "E_NETWORK_TIMEOUT";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Request ID";
                        value: "req_8c4e2a91";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Time";
                        value: "2026-05-17 14:08 UTC";
                    }
                    Divider { }
                    KeyValueRow {
                        label: "Build";
                        value: "1.4.2 · 3187";
                    }
                }

                // ----- Actions ----------------------------------------
                VerticalLayout {
                    padding-left: Theme.spacing-md;
                    padding-right: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;

                    MobileButton {
                        text: "Try again";
                        clicked => { root.retry-pressed(); }
                    }
                    MobileButton {
                        text: "Report a bug";
                        primary: false;
                        clicked => { root.report-pressed(); }
                    }
                }
            }
        }
    }
}
