// Snackbar
// =====================================================================
//
// Transient bottom-of-screen toast — the third overlay primitive.
// Used for short confirmations that don't demand a modal ("Item moved
// to trash", "Saved", "No connection — retrying"), with an optional
// single action label ("Undo", "Retry"). Auto-dismissal timing is
// the host page's responsibility; this component renders the visual
// only.
//
// Specification
// -------------
//
// Geometry
//   - Pill-shaped: `border-radius: Theme.radius-md`.
//   - Minimum height 48 px (touch-target floor; the trailing action,
//     when present, must remain comfortably tappable).
//   - `Theme.surface-3` fill — the highest elevation tier in the
//     library, since a Snackbar visually outranks every other surface
//     while it's on screen.
//   - `elevation-3` drop shadow.
//
// Content
//   - `message` (string): the toast text. Single-line by design — wraps
//     would tip the snackbar into "modal" territory; if the message
//     can't fit on one line, the surface should be a Banner instead.
//   - `action-label` (string, optional): when set, a trailing primary-
//     coloured `TextButton`-like control appears.
//   - `tone` (shared `Tone` enum, default `info`): drives a small
//     leading status-coloured dot. Use `success` for "Saved" /
//     "Sent" toasts, `warning` for soft errors, `danger` for hard
//     failures. `default` collapses to `info` since a Snackbar
//     without a tone-cue would be visually indistinguishable from
//     a plain bottom-anchored card.

import { Theme, Tone } from "@mobile-theme/theme.slint";

export component Snackbar inherits Rectangle {
    in property <string> message;
    in property <string> action-label;
    in property <Tone> tone: Tone.info;
    callback action-pressed();

    // Resolved dot colour. `default` reads as `info` (the brand
    // accent) so the dot is always present — the design is
    // "Snackbars always carry severity"; "no severity" isn't a
    // valid Snackbar use case.
    property <color> tone-color:
          root.tone == Tone.success ? Theme.accent-success
        : root.tone == Tone.warning ? Theme.accent-warning
        : root.tone == Tone.danger  ? Theme.accent-danger
        : Theme.accent-info;

    accessible-role: text;
    accessible-label: root.message;

    horizontal-stretch: 1;
    min-height: 48px;
    background: Theme.surface-3;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-3-blur;
    drop-shadow-color: Theme.elevation-3-color;
    drop-shadow-offset-y: Theme.elevation-3-y;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-sm;
        spacing: Theme.spacing-sm;
        alignment: stretch;

        // Tone indicator dot.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 8px;
                height: 8px;
                border-radius: 4px;
                background: root.tone-color;
            }
        }

        // Message text.
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            Text {
                text: root.message;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 500;
                overflow: elide;
            }
        }

        // Optional action.
        if root.action-label != "": Rectangle {
            min-height: 36px;
            min-width: 64px;
            border-radius: Theme.radius-sm;
            background: action-touch.pressed ? Theme.surface-pressed : transparent;

            accessible-role: button;
            accessible-label: root.action-label;
            accessible-action-default => { root.action-pressed(); }

            animate background { duration: Theme.motion-fast; }

            Text {
                x: Theme.spacing-sm;
                y: 0;
                width: parent.width - 2 * Theme.spacing-sm;
                height: parent.height;
                text: root.action-label;
                color: Theme.primary;
                font-size: Theme.font-size-body;
                font-weight: 600;
                horizontal-alignment: center;
                vertical-alignment: center;
            }

            action-touch := TouchArea {
                mouse-cursor: pointer;
                clicked => { root.action-pressed(); }
            }
        }
    }
}
