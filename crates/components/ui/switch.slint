// MobileSwitch
// =====================================================================
//
// iOS-style toggle switch. Two-state, animated knob slides between left
// (off) and right (on) positions when tapped.
//
// Specification
// -------------
//
// Geometry
//   - Fixed 52 × 32 px track, fully pill-shaped (`border-radius =
//     height / 2`). The knob is a 28px white circle with a soft drop
//     shadow; it inset 2px from each edge of the track.
//
// Colour
//   - Off: track = `Theme.surface-variant`, knob = white.
//   - On:  track = `Theme.primary`, knob = white.
//   - Track colour and knob position both animate over `motion-base`
//     (200 ms) for the unmistakable iOS feel.
//
// State
//   - `checked` (in-out bool): the current state. The component flips
//     it on tap; the parent can also drive it programmatically and the
//     animation runs both ways.
//   - `enabled` (bool, default true): when false, opacity → 0.5 and the
//     TouchArea is disabled.
//
// Interaction
//   - Tap anywhere on the track flips `checked` and emits
//     `toggled(bool)` with the new value. Use the callback when you
//     need to react to changes (e.g. persisting a setting).
//
// Composition
//   - Sits in the trailing slot of a settings row alongside the row's
//     title/subtitle text. See `SettingsPage` for the canonical pattern.
import { Theme } from "@mobile-theme/theme.slint";

export component MobileSwitch inherits Rectangle {
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    accessible-role: switch;
    accessible-checkable: true;
    accessible-checked: root.checked;
    accessible-enabled: root.enabled;
    accessible-action-default => {
        root.checked = !root.checked;
        root.toggled(root.checked);
    }

    width: 52px;
    height: 32px;
    border-radius: self.height / 2;
    background: root.checked ? Theme.primary : Theme.surface-variant;
    opacity: root.enabled ? 1.0 : 0.5;

    animate background { duration: Theme.motion-base; }

    knob := Rectangle {
        width: parent.height - 4px;
        height: parent.height - 4px;
        y: 2px;
        x: root.checked ? parent.width - self.width - 2px : 2px;
        border-radius: self.height / 2;
        background: white;
        drop-shadow-blur: 4px;
        drop-shadow-color: #00000040;
        drop-shadow-offset-y: 1px;

        animate x { duration: Theme.motion-base; easing: ease-out; }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}
