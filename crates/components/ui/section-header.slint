// SectionHeader
// =====================================================================
//
// Small all-caps muted text used to label a vertical group of rows /
// cards / toggles. Recurs in `SettingsPage`, `InboxPage`, the gallery
// Toolbox, and most list-shaped templates. Lifted out so every screen
// has the same vertical rhythm above sectioned content.
//
// Specification
// -------------
//
// Geometry
//   - Height: 32 px (caption text + breathing).
//   - 16 px horizontal padding (lines up with `ListItem` / `Card` left
//     edges).
//   - Full-width by default (`horizontal-stretch: 1`).
//
// Content
//   - `text` (string): the label, typically a single SHOUTED word
//     ("TODAY", "NOTIFICATIONS", "ACCOUNT", "PINNED").
//
// Style
//   - 12 px caption, 600 weight, `Theme.muted` colour.
//   - No background, no border — pure typographic separator.

import { Theme } from "@mobile-theme/theme.slint";

export component SectionHeader inherits Rectangle {
    in property <string> text;

    height: 32px;
    horizontal-stretch: 1;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        alignment: start;
        Text {
            text: root.text;
            color: Theme.muted;
            font-size: Theme.font-size-caption;
            font-weight: 600;
            vertical-alignment: center;
        }
    }
}
