// FormSection
// =====================================================================
//
// Optional `SectionHeader`-like title above a vertical stack of rows
// (`SettingRow`, `KeyValueRow`, `FormField`, `ListItem`, …) wrapped
// in a single rounded surface. Provides the standard "grouped list"
// visual that iOS / Android settings screens use.
//
// Specification
// -------------
//
// Geometry
//   - Full width (`horizontal-stretch: 1`).
//   - Outer padding: 16 px left/right (matches `Theme.spacing-md`).
//   - Inner card: 12 px border-radius (`Theme.radius-md`),
//     `Theme.surface-1` background, tier-1 elevation.
//   - Rows inside the card stack flush (no inner padding) so each row's
//     own 16 px gutters provide a consistent edge inset.
//
// Slots
//   - `title` (string, optional): ALL-CAPS caption rendered above the
//     card, matching `SectionHeader` styling. Omitted when empty.
//   - `caption` (string, optional): muted body text below the card —
//     for fine print like "Used to verify your identity. Never shared."
//   - `@children`: the rows. Should be SettingRow / KeyValueRow /
//     FormField / ListItem etc. — anything that obeys the 16 px
//     horizontal gutter rule will line up flush with the card edge.

import { Theme } from "@mobile-theme/theme.slint";

export component FormSection inherits Rectangle {
    in property <string> title;
    in property <string> caption;

    horizontal-stretch: 1;

    VerticalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-sm;
        alignment: stretch;

        if root.title != "": Text {
            text: root.title;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.5px;
            horizontal-alignment: left;
        }

        Rectangle {
            background: Theme.surface-1;
            border-radius: Theme.radius-md;
            drop-shadow-blur: Theme.elevation-1-blur;
            drop-shadow-color: Theme.elevation-1-color;
            drop-shadow-offset-y: Theme.elevation-1-y;
            horizontal-stretch: 1;
            clip: true;

            VerticalLayout {
                spacing: 0;
                alignment: stretch;
                @children
            }
        }

        if root.caption != "": Text {
            text: root.caption;
            color: Theme.muted;
            font-size: Theme.font-size-caption;
            wrap: word-wrap;
        }
    }
}
