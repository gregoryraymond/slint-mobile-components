// Divider
// =====================================================================
//
// Hairline separator — a 1 px line in `Theme.outline`. Use to separate
// groups of `ListItem`s within a `Card`, sections within a settings
// page, or content blocks where a `Card`'s elevation would be too
// heavy.
//
// Specification
// -------------
//
// Geometry
//   - Height: 1 px (the hairline standard).
//   - Width: stretches to fill its layout cell.
//   - No padding / inset — wrap in a layout if you want indent.
//
// Style
//   - Colour: `Theme.outline`. Adopts the theme's outline rebind, so
//     consumers that retune the palette get a coherent divider for free.

import { Theme } from "@mobile-theme/theme.slint";

export component Divider inherits Rectangle {
    height: 1px;
    horizontal-stretch: 1;
    background: Theme.outline;
}
