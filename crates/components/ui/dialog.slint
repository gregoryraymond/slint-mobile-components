// Dialog
// =====================================================================
//
// Centered modal overlay — the second overlay primitive in the
// catalogue. Use for confirmations ("Delete account?"), short forms
// that don't merit a full page, and any "demand the user's attention
// before they continue" moment.
//
// This component renders ONLY the dialog card itself. The host page is
// responsible for the dim scrim that covers the page beneath; the
// recommended recipe (also used in `SnapDialog`):
//
//   if dialog-open: Rectangle {
//       // Scrim
//       width: parent.width;
//       height: parent.height;
//       background: #00000099;
//       TouchArea {
//           clicked => { dialog-open = false; }
//       }
//       // Dialog
//       Dialog {
//           x: (parent.width  - self.width)  / 2;
//           y: (parent.height - self.height) / 2;
//           title: "Delete account?";
//           body:  "This will permanently delete your data.";
//           primary-label: "Delete";
//           secondary-label: "Cancel";
//           tone: Tone.danger;
//           primary-pressed => { … }
//           secondary-pressed => { dialog-open = false; }
//       }
//   }
//
// Specification
// -------------
//
// Geometry
//   - 320 px wide by default (caller can override via `width`). Height
//     grows naturally with content.
//   - `Theme.radius-lg` corners; `Theme.surface-2` fill (raised tier —
//     one level above any Card the dialog is opened over).
//   - `elevation-2` shadow tokens.
//
// Content
//   - `title` (string): bold headline at `font-size-title`.
//   - `body` (string): wrapped body text at `font-size-body-large`.
//   - `primary-label` (string): primary action button text. Defaults
//     to "OK".
//   - `secondary-label` (string, optional): when set, a secondary
//     `TextButton` appears to the left of the primary action.
//   - `tone` (Tone, default `default`): re-tints the primary action.
//     Use `Tone.danger` for destructive confirmations ("Delete",
//     "Discard", "Sign out"); the other tones are available for
//     positive ("Confirm purchase" with `success`) or cautionary
//     ("Sign out everywhere" with `warning`) prompts.
//
// Accessibility
//   - `accessible-role: dialog` so screen readers announce the modal
//     context shift.
//   - `accessible-label: title` so the headline is what the user hears.

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { MobileButton, TextButton } from "button.slint";

export component Dialog inherits Rectangle {
    in property <string> title;
    in property <string> body;
    in property <string> primary-label: "OK";
    in property <string> secondary-label;
    in property <Tone> tone: Tone.default;
    callback primary-pressed();
    callback secondary-pressed();

    accessible-role: text;
    accessible-label: root.title;
    accessible-description: root.body;

    width: 320px;
    background: Theme.surface-2;
    border-radius: Theme.radius-lg;
    drop-shadow-blur: Theme.elevation-2-blur;
    drop-shadow-color: Theme.elevation-2-color;
    drop-shadow-offset-y: Theme.elevation-2-y;

    VerticalLayout {
        padding: Theme.spacing-lg;
        spacing: Theme.spacing-md;

        Text {
            text: root.title;
            color: Theme.on-surface;
            font-size: Theme.font-size-title;
            font-weight: 600;
            wrap: word-wrap;
        }

        Text {
            text: root.body;
            color: Theme.muted;
            font-size: Theme.font-size-body-large;
            wrap: word-wrap;
        }

        HorizontalLayout {
            spacing: Theme.spacing-sm;
            padding-top: Theme.spacing-sm;
            alignment: end;

            if root.secondary-label != "": TextButton {
                text: root.secondary-label;
                clicked => { root.secondary-pressed(); }
            }

            // Primary action — `tone` flows through to MobileButton so
            // a `Tone.danger` Dialog renders its CTA in `accent-danger`,
            // and so on for the other status tones.
            MobileButton {
                text: root.primary-label;
                tone: root.tone;
                horizontal-stretch: 0;
                vertical-stretch: 0;
                min-width: 96px;
                max-height: 48px;
                clicked => { root.primary-pressed(); }
            }
        }
    }
}
