// IconButton
// =====================================================================
//
// A fixed-size, square tap target containing a 24×24 icon stacked above
// a short text label. Use this as the atom for tab strips (BottomNav,
// top tabs), action grids, and any case where a labelled glyph needs to
// be tappable at a consistent size.
//
// Specification
// -------------
//
// Geometry
//   - Square: width == height == `size`. `size` defaults to 72px (1.5 ×
//     the 48dp Material touch-target floor — comfortable for thumbs and
//     leaves room for a short label below the icon).
//   - The button is clipped to its bounds; long labels are elided.
//
// Content
//   - `icon` (image): rendered at exactly 24×24, centered horizontally,
//     tinted via `colorize` so the SVG colour doesn't matter.
//   - `label` (string): caption-sized text centered horizontally below
//     the icon, with 4px of vertical spacing between the two. Eliding
//     applies if the label outgrows the button width.
//   - Icon and label share the same vertical centerline regardless of
//     label width — each is wrapped in a `HorizontalLayout { alignment:
//     center; ... }` so the cross-axis is explicit.
//
// State
//   - `active` (bool, default false): when true, both icon and label
//     switch from `Theme.on-surface` to `Theme.primary` and the label
//     font-weight changes to 600. Animated over `Theme.motion-fast`.
//   - `enabled` (bool, default true): when false, the button is dimmed
//     (opacity 0.5) and TouchArea is disabled.
//
// Interaction
//   - The TouchArea fills the entire square — tap registers anywhere
//     inside the button bounds.
//   - Emits `clicked()` on tap. Press feedback: background tints to
//     `Theme.surface-pressed`.
//
// Composition
//   - Designed to be a child of `BottomNav` (see bottom-nav.slint),
//     which arranges multiple IconButtons in a horizontal strip with a
//     configurable distribution. Standalone use is also fine — drop it
//     into any layout.

import { Theme } from "@mobile-theme/theme.slint";

export component IconButton inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <bool> active: false;
    in property <bool> enabled: true;
    in property <length> size: 72px;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-enabled: root.enabled;
    accessible-action-default => { root.clicked(); }

    width: root.size;
    height: root.size;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    border-radius: Theme.radius-md;
    opacity: root.enabled ? 1.0 : 0.5;
    clip: true;

    animate background { duration: Theme.motion-fast; }

    VerticalLayout {
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        padding-left: Theme.spacing-xs;
        padding-right: Theme.spacing-xs;
        spacing: 4px;
        alignment: center;

        HorizontalLayout {
            alignment: center;
            Image {
                width: 24px;
                height: 24px;
                source: root.icon;
                colorize: root.active ? Theme.primary : Theme.on-surface;
                image-fit: contain;
                animate colorize { duration: Theme.motion-fast; }
            }
        }

        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: root.active ? Theme.primary : Theme.on-surface;
                font-size: Theme.font-size-caption;
                font-weight: root.active ? 600 : 400;
                overflow: elide;
                animate color { duration: Theme.motion-fast; }
            }
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}
