// MobileButton tones — five stacked variants (default + four status tones)
// so the Tone enum's primary-variant fills are locked into a baseline.
export component SnapButtonTones inherits Window {
    preferred-width: 320px;
    preferred-height: 360px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-sm;
        MobileButton { text: "Default";  tone: Tone.default; height: 48px; }
        MobileButton { text: "Success";  tone: Tone.success; height: 48px; }
        MobileButton { text: "Warning";  tone: Tone.warning; height: 48px; }
        MobileButton { text: "Danger";   tone: Tone.danger;  height: 48px; }
        MobileButton { text: "Info";     tone: Tone.info;    height: 48px; }
    }
}

// Banner tones — four stacked variants so the leading-icon tinting via
// `tone-color` is locked into a baseline alongside the default neutral.
export component SnapBannerTones inherits Window {
    preferred-width: 360px;
    preferred-height: 320px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Banner {
            icon: @image-url("../ui/icons/check.svg");
            message: "Sync complete — all your changes are uploaded.";
            tone: Tone.success;
        }
        Banner {
            icon: @image-url("../ui/icons/star.svg");
            message: "Low storage — free up 1 GB to keep syncing photos.";
            tone: Tone.warning;
        }
        Banner {
            icon: @image-url("../ui/icons/close.svg");
            message: "Couldn't connect — we'll retry automatically when you're back online.";
            tone: Tone.danger;
        }
        Banner {
            icon: @image-url("../ui/icons/bell.svg");
            message: "New version available — restart the app to apply the update.";
            tone: Tone.info;
        }
    }
}

// Drawer — open against the left edge, with a faux page beneath darkened
// by the scrim, so the inner-edge shadow + rounded inner corners are
// captured.
export component SnapDrawer inherits Window {
    preferred-width: 412px;
    preferred-height: 480px;
    background: Theme.background;
    // Faux page content (a placeholder strip), so the drawer's shadow
    // visibly falls onto something.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-1;
    }
    // Scrim.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000099;
    }
    Drawer {
        x: 0;
        y: 0;
        edge: DrawerEdge.left;
        height: parent.height;
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            Text {
                text: "Navigation";
                color: Theme.on-surface;
                font-size: Theme.font-size-title;
                font-weight: 600;
            }
            ListItem { title: "Home";     leading-icon: @image-url("../ui/icons/home.svg"); }
            ListItem { title: "Search";   leading-icon: @image-url("../ui/icons/search.svg"); }
            ListItem { title: "Inbox";    leading-icon: @image-url("../ui/icons/inbox.svg"); }
            ListItem { title: "Profile";  leading-icon: @image-url("../ui/icons/profile.svg"); }
        }
    }
}
