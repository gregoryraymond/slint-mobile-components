// Snapshot scenes — one Window-rooted component per `<component, state>`
// pair we want to lock down as a baseline image. The snapshot runner
// (`tests/snapshots.rs`) instantiates each scene, renders it to a pixel
// buffer via Slint's software renderer, and either writes the baseline
// (`SLINT_CREATE_SCREENSHOTS=1`) or diffs against the existing one.
//
// Add new scenes here. Each scene must:
//   - inherit Window
//   - set explicit `preferred-width` and `preferred-height` matching the
//     dimensions in the snapshot! entry in `tests/snapshots.rs`
//   - render the component once at a known state (no animations in
//     flight; press / focus pseudo-states should be driven by setting
//     properties, not by simulated input)

import { Theme, Tone } from "@mobile-theme/theme.slint";
import { MobileButton, TextButton, Fab } from "@mobile-components/button.slint";
import { Card } from "@mobile-components/card.slint";
import { AppBar } from "@mobile-components/app-bar.slint";
import { BottomNav, BottomNavDistribution } from "@mobile-components/bottom-nav.slint";
import { IconButton } from "@mobile-components/icon-button.slint";
import { ListItem } from "@mobile-components/list-item.slint";
import { TextField } from "@mobile-components/text-field.slint";
import { MobileSwitch } from "@mobile-components/switch.slint";
import { Chip } from "@mobile-components/chip.slint";
import { Avatar } from "@mobile-components/avatar.slint";
import { Badge } from "@mobile-components/badge.slint";
import { ProgressBar } from "@mobile-components/progress-bar.slint";
import { Spinner } from "@mobile-components/spinner.slint";
import { Checkbox } from "@mobile-components/checkbox.slint";
import { Slider } from "@mobile-components/slider.slint";
import { TabBar, Tab } from "@mobile-components/tab-bar.slint";
import { Divider } from "@mobile-components/divider.slint";
import { Banner } from "@mobile-components/banner.slint";
import { Radio } from "@mobile-components/radio.slint";
import { SegmentedControl } from "@mobile-components/segmented-control.slint";
import { Stepper } from "@mobile-components/stepper.slint";
import { Skeleton } from "@mobile-components/skeleton.slint";
import { EmptyState } from "@mobile-components/empty-state.slint";

import { Dialog } from "@mobile-components/dialog.slint";
import { Snackbar } from "@mobile-components/snackbar.slint";
import { Drawer, DrawerEdge } from "@mobile-components/drawer.slint";

// MobileButton — primary, full width.
export component SnapMobileButtonPrimary inherits Window {
    preferred-width: 320px;
    preferred-height: 80px;
    background: Theme.background;
    MobileButton {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        height: 48px;
        text: "Primary action";
        primary: true;
    }
}

// MobileButton — secondary (outlined) variant.
export component SnapMobileButtonSecondary inherits Window {
    preferred-width: 320px;
    preferred-height: 80px;
    background: Theme.background;
    MobileButton {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        height: 48px;
        text: "Secondary action";
        primary: false;
    }
}

// Card with title + subtitle.
export component SnapCardWithSubtitle inherits Window {
    preferred-width: 320px;
    preferred-height: 140px;
    background: Theme.background;
    Card {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        title: "Today's brief";
        subtitle: "Three updates from the projects you follow.";
    }
}

// IconButton — active state.
export component SnapIconButtonActive inherits Window {
    preferred-width: 96px;
    preferred-height: 96px;
    background: Theme.surface-1;
    IconButton {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        label: "Home";
        icon: @image-url("@mobile-components/icons/home.svg");
        active: true;
    }
}

// Chip row — selected + leading-icon + dismissible variants.
export component SnapChipRow inherits Window {
    preferred-width: 360px;
    preferred-height: 56px;
    background: Theme.background;
    HorizontalLayout {
        x: Theme.spacing-md;
        y: 12px;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-sm;
        Chip { label: "All"; selected: true; }
        Chip { label: "Tagged"; leading-icon: @image-url("@mobile-components/icons/star.svg"); }
        Chip { label: "Today"; dismissible: true; }
    }
}

// Avatar — three sizes, all initials fallback.
export component SnapAvatarSizes inherits Window {
    preferred-width: 200px;
    preferred-height: 80px;
    background: Theme.background;
    HorizontalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: start;
        Avatar { fallback: "AB"; size: 32px; }
        Avatar { fallback: "CD"; }
        Avatar { fallback: "EF"; size: 56px; }
    }
}

// Badge — overlaid on an icon, with count.
export component SnapBadgeOnIcon inherits Window {
    preferred-width: 72px;
    preferred-height: 56px;
    background: Theme.background;
    Rectangle {
        x: Theme.spacing-md;
        y: Theme.spacing-sm;
        width: 32px;
        height: 32px;
        Image {
            width: 24px;
            height: 24px;
            x: 0;
            y: 4px;
            source: @image-url("@mobile-components/icons/bell.svg");
            colorize: Theme.on-surface;
            image-fit: contain;
        }
        Badge { x: 14px; y: 0; count: 4; }
    }
}

// ProgressBar — determinate at 65 %.
export component SnapProgressDeterminate inherits Window {
    preferred-width: 320px;
    preferred-height: 32px;
    background: Theme.background;
    ProgressBar {
        x: Theme.spacing-md;
        y: 14px;
        width: parent.width - 2 * Theme.spacing-md;
        value: 0.65;
    }
}

// Spinner — frozen at rotation 0 so the snapshot is deterministic.
export component SnapSpinnerStatic inherits Window {
    preferred-width: 96px;
    preferred-height: 96px;
    background: Theme.background;
    Spinner {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        running: false;
    }
}

// Checkbox — one checked, one unchecked.
export component SnapCheckboxPair inherits Window {
    preferred-width: 320px;
    preferred-height: 112px;
    background: Theme.background;
    VerticalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        Checkbox { label: "Subscribe to newsletter"; checked: true; }
        Checkbox { label: "Send anonymous analytics"; }
    }
}

// Slider at 35 % — thumb mid-track, filled portion left of thumb.
export component SnapSliderAt35 inherits Window {
    preferred-width: 320px;
    preferred-height: 64px;
    background: Theme.background;
    Slider {
        x: Theme.spacing-md;
        y: 8px;
        width: parent.width - 2 * Theme.spacing-md;
        value: 0.35;
    }
}

// TabBar with three tabs, "Photos" active.
export component SnapTabBar inherits Window {
    preferred-width: 360px;
    preferred-height: 48px;
    background: Theme.background;
    TabBar {
        Tab { label: "Photos"; active: true; }
        Tab { label: "Videos"; }
        Tab { label: "Albums"; }
    }
}

// Banner with icon + message + action.
export component SnapBanner inherits Window {
    preferred-width: 360px;
    preferred-height: 96px;
    background: Theme.background;
    Banner {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        icon: @image-url("@mobile-components/icons/bell.svg");
        message: "You're working offline. Changes will sync when you reconnect.";
        action-label: "Retry";
    }
}

// Dialog — destructive confirmation, centered on a dimmed scrim.
export component SnapDialog inherits Window {
    preferred-width: 412px;
    preferred-height: 360px;
    background: Theme.background;
    // Dim scrim covering the faux page beneath.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000099;
    }
    Dialog {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        title: "Delete account?";
        body: "This will permanently delete your data. This action cannot be undone.";
        primary-label: "Delete";
        secondary-label: "Cancel";
        tone: Tone.danger;
    }
}

// Snackbar tones — info / success / warning / danger stacked.
export component SnapSnackbarTones inherits Window {
    preferred-width: 360px;
    preferred-height: 280px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Snackbar {
            message: "Saved to drafts";
            tone: Tone.info;
            action-label: "Open";
        }
        Snackbar {
            message: "Message sent";
            tone: Tone.success;
        }
        Snackbar {
            message: "Sync is slow on this network";
            tone: Tone.warning;
        }
        Snackbar {
            message: "Couldn't connect — tap to retry";
            tone: Tone.danger;
            action-label: "Retry";
        }
    }
}

// Radio group — three radios, middle one selected.
export component SnapRadioGroup inherits Window {
    preferred-width: 320px;
    preferred-height: 168px;
    background: Theme.background;
    VerticalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        Radio { label: "Quarterly"; }
        Radio { label: "Monthly"; selected: true; }
        Radio { label: "Weekly"; }
    }
}

// SegmentedControl — three options, middle selected.
export component SnapSegmentedThree inherits Window {
    preferred-width: 320px;
    preferred-height: 56px;
    background: Theme.background;
    SegmentedControl {
        x: Theme.spacing-md;
        y: 10px;
        width: parent.width - 2 * Theme.spacing-md;
        options: ["All", "Active", "Done"];
        selected-index: 1;
    }
}

// Stepper at value 3.
export component SnapStepperAt3 inherits Window {
    preferred-width: 200px;
    preferred-height: 56px;
    background: Theme.background;
    Stepper {
        x: Theme.spacing-md;
        y: 8px;
        value: 3;
        minimum: 0;
        maximum: 10;
    }
}

// Skeleton — pulse frozen at full brightness so the snapshot is
// deterministic (we can't pause the Timer mid-animation, but the
// snapshot is taken before the first 800 ms tick).
export component SnapSkeletonRow inherits Window {
    preferred-width: 320px;
    preferred-height: 64px;
    background: Theme.background;
    HorizontalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Skeleton {
            width: 40px;
            height: 40px;
            border-radius: 20px;
        }
        VerticalLayout {
            spacing: Theme.spacing-sm;
            alignment: center;
            horizontal-stretch: 1;
            Skeleton { height: 14px; }
            Skeleton { height: 12px; }
        }
    }
}

// EmptyState — full content.
export component SnapEmptyState inherits Window {
    preferred-width: 360px;
    preferred-height: 320px;
    background: Theme.background;
    EmptyState {
        icon: @image-url("@mobile-components/icons/inbox.svg");
        title: "Inbox is empty";
        description: "Threads you star or get @mentioned in will show up here.";
        action-label: "Browse channels";
    }
}

// BottomNav — spaced distribution with 4 IconButtons.
export component SnapBottomNavSpaced inherits Window {
    preferred-width: 412px;
    preferred-height: 72px;
    background: Theme.background;
    BottomNav {
        distribution: BottomNavDistribution.spaced;
        IconButton { label: "Home"; icon: @image-url("@mobile-components/icons/home.svg"); active: true; }
        IconButton { label: "Search"; icon: @image-url("@mobile-components/icons/search.svg"); }
        IconButton { label: "Inbox"; icon: @image-url("@mobile-components/icons/inbox.svg"); }
        IconButton { label: "Profile"; icon: @image-url("@mobile-components/icons/profile.svg"); }
    }
}

// MobileButton tones — five stacked variants (default + four status tones)
// so the Tone enum's primary-variant fills are locked into a baseline.
export component SnapButtonTones inherits Window {
    preferred-width: 320px;
    preferred-height: 360px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-sm;
        MobileButton { text: "Default";  tone: Tone.default; height: 48px; }
        MobileButton { text: "Success";  tone: Tone.success; height: 48px; }
        MobileButton { text: "Warning";  tone: Tone.warning; height: 48px; }
        MobileButton { text: "Danger";   tone: Tone.danger;  height: 48px; }
        MobileButton { text: "Info";     tone: Tone.info;    height: 48px; }
    }
}

// Banner tones — four stacked variants so the leading-icon tinting via
// `tone-color` is locked into a baseline alongside the default neutral.
export component SnapBannerTones inherits Window {
    preferred-width: 360px;
    preferred-height: 320px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Banner {
            icon: @image-url("@mobile-components/icons/check.svg");
            message: "Sync complete — all your changes are uploaded.";
            tone: Tone.success;
        }
        Banner {
            icon: @image-url("@mobile-components/icons/star.svg");
            message: "Low storage — free up 1 GB to keep syncing photos.";
            tone: Tone.warning;
        }
        Banner {
            icon: @image-url("@mobile-components/icons/close.svg");
            message: "Couldn't connect — we'll retry automatically when you're back online.";
            tone: Tone.danger;
        }
        Banner {
            icon: @image-url("@mobile-components/icons/bell.svg");
            message: "New version available — restart the app to apply the update.";
            tone: Tone.info;
        }
    }
}

// Drawer — open against the left edge, with a faux page beneath darkened
// by the scrim, so the inner-edge shadow + rounded inner corners are
// captured.
export component SnapDrawer inherits Window {
    preferred-width: 412px;
    preferred-height: 480px;
    background: Theme.background;
    // Faux page content (a placeholder strip), so the drawer's shadow
    // visibly falls onto something.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: Theme.surface-1;
    }
    // Scrim.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000099;
    }
    Drawer {
        x: 0;
        y: 0;
        edge: DrawerEdge.left;
        height: parent.height;
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-sm;
            Text {
                text: "Navigation";
                color: Theme.on-surface;
                font-size: Theme.font-size-title;
                font-weight: 600;
            }
            ListItem { title: "Home";     leading-icon: @image-url("@mobile-components/icons/home.svg"); }
            ListItem { title: "Search";   leading-icon: @image-url("@mobile-components/icons/search.svg"); }
            ListItem { title: "Inbox";    leading-icon: @image-url("@mobile-components/icons/inbox.svg"); }
            ListItem { title: "Profile";  leading-icon: @image-url("@mobile-components/icons/profile.svg"); }
        }
    }
}
