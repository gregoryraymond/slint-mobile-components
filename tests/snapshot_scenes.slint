export component SnapSliderAt35 inherits Window {
    preferred-width: 320px;
    preferred-height: 64px;
    background: Theme.background;
    Slider {
        x: Theme.spacing-md;
        y: 8px;
        width: parent.width - 2 * Theme.spacing-md;
        value: 0.35;
    }
}

// TabBar with three tabs, "Photos" active.
export component SnapTabBar inherits Window {
    preferred-width: 360px;
    preferred-height: 48px;
    background: Theme.background;
    TabBar {
        Tab { label: "Photos"; active: true; }
        Tab { label: "Videos"; }
        Tab { label: "Albums"; }
    }
}

// Banner with icon + message + action.
export component SnapBanner inherits Window {
    preferred-width: 360px;
    preferred-height: 96px;
    background: Theme.background;
    Banner {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        icon: @image-url("../ui/icons/bell.svg");
        message: "You're working offline. Changes will sync when you reconnect.";
        action-label: "Retry";
    }
}

// Dialog — destructive confirmation, centered on a dimmed scrim.
export component SnapDialog inherits Window {
    preferred-width: 412px;
    preferred-height: 360px;
    background: Theme.background;
    // Dim scrim covering the faux page beneath.
    Rectangle {
        x: 0;
        y: 0;
        width: parent.width;
        height: parent.height;
        background: #00000099;
    }
    Dialog {
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        title: "Delete account?";
        body: "This will permanently delete your data. This action cannot be undone.";
        primary-label: "Delete";
        secondary-label: "Cancel";
        tone: Tone.danger;
    }
}

// Snackbar tones — info / success / warning / danger stacked.
export component SnapSnackbarTones inherits Window {
    preferred-width: 360px;
    preferred-height: 280px;
    background: Theme.background;
    VerticalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Snackbar {
            message: "Saved to drafts";
            tone: Tone.info;
            action-label: "Open";
        }
        Snackbar {
            message: "Message sent";
            tone: Tone.success;
        }
        Snackbar {
            message: "Sync is slow on this network";
            tone: Tone.warning;
        }
        Snackbar {
            message: "Couldn't connect — tap to retry";
            tone: Tone.danger;
            action-label: "Retry";
        }
    }
}

// Radio group — three radios, middle one selected.
export component SnapRadioGroup inherits Window {
    preferred-width: 320px;
    preferred-height: 168px;
    background: Theme.background;
    VerticalLayout {
        x: 0;
        y: 0;
        width: parent.width;
        Radio { label: "Quarterly"; }
        Radio { label: "Monthly"; selected: true; }
        Radio { label: "Weekly"; }
    }
}

// SegmentedControl — three options, middle selected.
export component SnapSegmentedThree inherits Window {
    preferred-width: 320px;
    preferred-height: 56px;
    background: Theme.background;
    SegmentedControl {
        x: Theme.spacing-md;
        y: 10px;
        width: parent.width - 2 * Theme.spacing-md;
        options: ["All", "Active", "Done"];
        selected-index: 1;
    }
}

// Stepper at value 3.
export component SnapStepperAt3 inherits Window {
    preferred-width: 200px;
    preferred-height: 56px;
    background: Theme.background;
    Stepper {
        x: Theme.spacing-md;
        y: 8px;
        value: 3;
        minimum: 0;
        maximum: 10;
    }
}

// Skeleton — pulse frozen at full brightness so the snapshot is
// deterministic (we can't pause the Timer mid-animation, but the
// snapshot is taken before the first 800 ms tick).
export component SnapSkeletonRow inherits Window {
    preferred-width: 320px;
    preferred-height: 64px;
    background: Theme.background;
    HorizontalLayout {
        x: Theme.spacing-md;
        y: Theme.spacing-md;
        width: parent.width - 2 * Theme.spacing-md;
        spacing: Theme.spacing-md;
        Skeleton {
            width: 40px;
            height: 40px;
            border-radius: 20px;
        }
        VerticalLayout {
            spacing: Theme.spacing-sm;
            alignment: center;
            horizontal-stretch: 1;
            Skeleton { height: 14px; }
            Skeleton { height: 12px; }
        }
    }
}

