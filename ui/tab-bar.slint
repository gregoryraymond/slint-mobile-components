// TabBar + Tab
// =====================================================================
//
// Horizontal strip of text-only tabs anchored to the top of a content
// area (or the bottom of an AppBar). Sibling concept to BottomNav, but
// for in-page navigation between sub-views of the same screen (think
// the "Photos / Videos / Albums" strip on a gallery screen).
//
// Specification — TabBar
// ----------------------
//
// Geometry
//   - 48 px tall, full width (`horizontal-stretch: 1`).
//   - `Theme.surface` background, with a 1 px `Theme.outline` divider
//     along the bottom edge.
//
// Layout
//   - Hosts 2-5 `Tab` children via `@children`. Each Tab gets equal
//     horizontal share (`horizontal-stretch: 1`); when the row would
//     overflow on narrow screens, callers should switch to a scrollable
//     tab pattern (out of scope here).
//
// State
//   - `current-index` (in-out int): index of the selected Tab. The bar
//     itself does NOT update this — the parent listens to each Tab's
//     `clicked` and assigns the index plus the matching `active` flag.
//
// Specification — Tab
// -------------------
//
// Geometry
//   - Fills its parent layout cell (one of N equal slots in TabBar).
//   - Min-width: 0 so equal-width slots stay equal regardless of
//     individual label length.
//
// Content
//   - `label` (string): the tab's caption. Centred vertically.
//
// State
//   - `active` (bool, default false): when true, the label colour
//     switches to `Theme.primary` and a 2 px primary-coloured underline
//     appears along the bottom edge.
//
// Accessibility
//   - `accessible-role: tab`, `accessible-label: root.label`, default
//     action emits `clicked`.

import { Theme } from "theme.slint";

export component Tab inherits Rectangle {
    in property <string> label;
    in property <bool> active: false;
    callback clicked();

    accessible-role: tab;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-width: 0;
    height: 48px;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    clip: true;

    animate background { duration: Theme.motion-fast; }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.active ? Theme.primary : Theme.muted;
        font-size: Theme.font-size-body;
        font-weight: root.active ? 600 : 500;
        horizontal-alignment: center;
        vertical-alignment: center;
        overflow: elide;
        animate color { duration: Theme.motion-fast; }
    }

    // Active-tab underline.
    if root.active: Rectangle {
        x: 0;
        y: parent.height - 2px;
        width: parent.width;
        height: 2px;
        background: Theme.primary;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component TabBar inherits Rectangle {
    in-out property <int> current-index: 0;

    height: 48px;
    horizontal-stretch: 1;
    background: Theme.surface;

    HorizontalLayout {
        @children
    }

    // Bottom hairline divider.
    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.outline;
    }
}
