// Gallery — a desktop preview Window that switches between the example
// pages and a "Toolbox" of every individual component. Used by the
// `gallery` example (`cargo run --example gallery --features gallery`)
// and doubles as the slint-build compilation entry: because Gallery is
// Window-rooted and uses every component, `cargo check` validates the
// entire library without slint-build emitting "no code will be generated"
// advisories on non-Window exports.
//
// Consumers never import this file — they configure `library_paths` to
// point at `ui/` and import individual components by path.

import { Theme } from "theme.slint";
import { MobileButton, TextButton, Fab } from "button.slint";
import { Card } from "card.slint";
import { AppBar } from "app-bar.slint";
import { BottomNav, BottomNavDistribution } from "bottom-nav.slint";
import { IconButton } from "icon-button.slint";
import { ListItem } from "list-item.slint";
import { TextField } from "text-field.slint";
import { MobileSwitch } from "switch.slint";
import { Chip } from "chip.slint";
import { Avatar } from "avatar.slint";
import { Badge } from "badge.slint";
import { ProgressBar } from "progress-bar.slint";
import { Spinner } from "spinner.slint";
import { Checkbox } from "checkbox.slint";
import { Slider } from "slider.slint";
import { TabBar, Tab } from "tab-bar.slint";
import { Divider } from "divider.slint";
import { Banner } from "banner.slint";
import { HomePage } from "pages/home.slint";
import { SettingsPage } from "pages/settings.slint";
import { LoginPage } from "pages/login.slint";
import { ScrollView } from "std-widgets.slint";

component GalleryTab inherits Rectangle {
    in property <string> label;
    in property <bool> selected;
    callback clicked();

    horizontal-stretch: 1;
    background: touch.pressed ? Theme.surface-pressed : Theme.surface;

    animate background { duration: Theme.motion-fast; }

    Text {
        width: parent.width;
        height: parent.height;
        text: root.label;
        color: root.selected ? Theme.primary : Theme.muted;
        font-size: Theme.font-size-body;
        font-weight: root.selected ? 600 : 400;
        horizontal-alignment: center;
        vertical-alignment: center;
    }

    // Active-tab underline.
    if root.selected: Rectangle {
        x: 0;
        y: parent.height - 2px;
        width: parent.width;
        height: 2px;
        background: Theme.primary;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

component SectionLabel inherits Text {
    color: Theme.muted;
    font-size: Theme.font-size-caption;
    font-weight: 600;
}

// "Toolbox" — every component rendered once, captioned, scrollable.
component Toolbox inherits Rectangle {
    background: Theme.background;

    in-out property <string> sample-text;
    in-out property <bool> sample-switch: true;

    ScrollView {
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-lg;

            // ---- AppBar ------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "APP BAR"; }
                AppBar { title: "Title only"; show-divider: false; }
                AppBar {
                    title: "With actions";
                    leading-icon: @image-url("icons/arrow-left.svg");
                    trailing-icon: @image-url("icons/more-vertical.svg");
                    show-divider: false;
                }
            }

            // ---- Buttons -----------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "BUTTONS"; }
                MobileButton { text: "Primary"; }
                MobileButton { text: "Secondary"; primary: false; }
                MobileButton { text: "Disabled"; enabled: false; }
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    TextButton { text: "Text action"; }
                    Fab { }
                }
            }

            // ---- Card --------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "CARD"; }
                Card { title: "Title only"; }
                Card {
                    title: "With subtitle";
                    subtitle: "A short description that wraps across two lines if it needs to.";
                }
                Card {
                    title: "Tappable";
                    subtitle: "Press feedback enabled.";
                    tappable: true;
                }
            }

            // ---- List items --------------------------------------------
            VerticalLayout {
                spacing: 0;
                SectionLabel { text: "LIST ITEMS"; }
                Rectangle {
                    background: Theme.surface;
                    border-radius: Theme.radius-md;
                    VerticalLayout {
                        ListItem { title: "Title only"; }
                        ListItem { title: "With subtitle"; subtitle: "Secondary line of text"; }
                        ListItem {
                            title: "Leading + trailing";
                            subtitle: "Both icon slots used";
                            leading-icon: @image-url("icons/star.svg");
                            trailing-icon: @image-url("icons/chevron-right.svg");
                            show-divider: false;
                        }
                    }
                }
            }

            // ---- TextField ---------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-md;
                SectionLabel { text: "TEXT FIELD"; }
                TextField { label: "Empty"; placeholder: "Type something"; }
                TextField {
                    label: "Bound";
                    placeholder: "Sample text";
                    text <=> root.sample-text;
                }
                TextField {
                    label: "Password";
                    placeholder: "••••••••";
                    input-type: InputType.password;
                }
            }

            // ---- Switch ------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "SWITCH"; }
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    MobileSwitch { checked: false; }
                    MobileSwitch { checked <=> root.sample-switch; }
                    MobileSwitch { checked: true; enabled: false; }
                }
            }

            // ---- Chip --------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "CHIP"; }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    alignment: start;
                    Chip { label: "All"; selected: true; }
                    Chip { label: "Mentions"; }
                    Chip { label: "Tagged"; leading-icon: @image-url("icons/star.svg"); }
                    Chip { label: "Today"; dismissible: true; }
                }
            }

            // ---- Avatar ------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "AVATAR"; }
                HorizontalLayout {
                    spacing: Theme.spacing-md;
                    alignment: start;
                    Avatar { fallback: "AB"; size: 32px; }
                    Avatar { fallback: "CD"; }
                    Avatar { fallback: "EF"; size: 56px; }
                }
            }

            // ---- Badge -------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "BADGE — overlaid on icons"; }
                HorizontalLayout {
                    spacing: Theme.spacing-lg;
                    alignment: start;
                    Rectangle {
                        width: 32px;
                        height: 32px;
                        Image {
                            width: 24px;
                            height: 24px;
                            x: 0;
                            y: 4px;
                            source: @image-url("icons/inbox.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        Badge { x: 18px; y: 0; }
                    }
                    Rectangle {
                        width: 32px;
                        height: 32px;
                        Image {
                            width: 24px;
                            height: 24px;
                            x: 0;
                            y: 4px;
                            source: @image-url("icons/bell.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        Badge { x: 14px; y: 0; count: 4; }
                    }
                    Rectangle {
                        width: 40px;
                        height: 32px;
                        Image {
                            width: 24px;
                            height: 24px;
                            x: 0;
                            y: 4px;
                            source: @image-url("icons/inbox.svg");
                            colorize: Theme.on-surface;
                            image-fit: contain;
                        }
                        Badge { x: 12px; y: 0; count: 128; }
                    }
                }
            }

            // ---- ProgressBar -------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-md;
                SectionLabel { text: "PROGRESS BAR"; }
                ProgressBar { value: 0.25; }
                ProgressBar { value: 0.65; }
                ProgressBar { indeterminate: true; }
            }

            // ---- Spinner -----------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "SPINNER"; }
                HorizontalLayout {
                    spacing: Theme.spacing-lg;
                    alignment: start;
                    Spinner { size: 16px; }
                    Spinner { }
                    Spinner { size: 40px; }
                }
            }

            // ---- Banner ------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "BANNER"; }
                Banner {
                    icon: @image-url("icons/bell.svg");
                    message: "You're working offline. Changes will sync when you reconnect.";
                    action-label: "Retry";
                }
            }

            // ---- Tab bar -----------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "TAB BAR"; }
                Rectangle {
                    height: 48px;
                    border-radius: Theme.radius-md;
                    clip: true;
                    TabBar {
                        Tab { label: "Photos"; active: true; }
                        Tab { label: "Videos"; }
                        Tab { label: "Albums"; }
                    }
                }
            }

            // ---- Checkbox ----------------------------------------------
            VerticalLayout {
                spacing: 0;
                SectionLabel { text: "CHECKBOX"; }
                Checkbox { label: "Subscribe to newsletter"; checked: true; }
                Checkbox { label: "Send anonymous analytics"; }
                Checkbox { label: "Disabled option"; enabled: false; }
            }

            // ---- Slider ------------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-md;
                SectionLabel { text: "SLIDER"; }
                Slider { value: 0.25; }
                Slider { value: 0.65; }
            }

            // ---- Divider -----------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "DIVIDER"; }
                Text {
                    text: "Used to separate stacks of items inside a Card";
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                }
                Divider { }
                Text {
                    text: "or full-bleed sections in a page";
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                }
            }

            // ---- Bottom nav --------------------------------------------
            VerticalLayout {
                spacing: Theme.spacing-sm;
                SectionLabel { text: "BOTTOM NAV — SPACED (default)"; }
                Rectangle {
                    border-radius: Theme.radius-md;
                    clip: true;
                    height: 72px;
                    BottomNav {
                        distribution: BottomNavDistribution.spaced;
                        IconButton { label: "Home"; icon: @image-url("icons/home.svg"); active: true; }
                        IconButton { label: "Search"; icon: @image-url("icons/search.svg"); }
                        IconButton { label: "Inbox"; icon: @image-url("icons/inbox.svg"); }
                        IconButton { label: "Profile"; icon: @image-url("icons/profile.svg"); }
                    }
                }

                SectionLabel { text: "BOTTOM NAV — CENTERED"; }
                Rectangle {
                    border-radius: Theme.radius-md;
                    clip: true;
                    height: 72px;
                    BottomNav {
                        distribution: BottomNavDistribution.centered;
                        IconButton { label: "Home"; icon: @image-url("icons/home.svg"); active: true; }
                        IconButton { label: "Search"; icon: @image-url("icons/search.svg"); }
                        IconButton { label: "Profile"; icon: @image-url("icons/profile.svg"); }
                    }
                }
            }
        }
    }
}

export component Gallery inherits Window {
    title: "slint-mobile-components — Gallery";
    preferred-width: 412px;
    preferred-height: 892px;
    min-width: 360px;
    min-height: 640px;
    background: Theme.background;

    in-out property <int> selected: 0;

    VerticalLayout {
        spacing: 0;

        // Tab strip
        Rectangle {
            height: 48px;
            background: Theme.surface;
            HorizontalLayout {
                spacing: 0;
                GalleryTab {
                    label: "Home";
                    selected: root.selected == 0;
                    clicked => { root.selected = 0; }
                }
                GalleryTab {
                    label: "Settings";
                    selected: root.selected == 1;
                    clicked => { root.selected = 1; }
                }
                GalleryTab {
                    label: "Login";
                    selected: root.selected == 2;
                    clicked => { root.selected = 2; }
                }
                GalleryTab {
                    label: "Toolbox";
                    selected: root.selected == 3;
                    clicked => { root.selected = 3; }
                }
            }
            Rectangle {
                x: 0;
                y: parent.height - 1px;
                width: parent.width;
                height: 1px;
                background: Theme.outline;
            }
        }

        // Content area — fills the rest of the window.
        Rectangle {
            background: Theme.background;
            vertical-stretch: 1;

            if root.selected == 0: HomePage {
                width: parent.width;
                height: parent.height;
            }
            if root.selected == 1: SettingsPage {
                width: parent.width;
                height: parent.height;
            }
            if root.selected == 2: LoginPage {
                width: parent.width;
                height: parent.height;
            }
            if root.selected == 3: Toolbox {
                width: parent.width;
                height: parent.height;
            }
        }
    }
}
