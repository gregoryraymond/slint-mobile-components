// NetWorthPage
// =====================================================================
//
// A net-worth dashboard — the "everything I own minus everything I
// owe" screen. Distinct from `BudgetOverviewPage` (monthly spend),
// `ExpenseReportPage` (spend history), and `InvestmentDetailPage`
// (one instrument). Demonstrates an assets-vs-liabilities surface:
//
//   - Net-worth hero: the headline figure + a tone-tinted month-over-
//     month change + a bar-strip trend.
//   - A split bar showing the assets / liabilities proportion.
//   - Grouped account rows: ASSETS (values in success tone) then
//     LIABILITIES (values in danger tone), each with an icon disc.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { SectionHeader } from "../section-header.slint";
import { Divider } from "../divider.slint";

// One account row. `liability` flips the value to danger tone.
component AccountRow inherits Rectangle {
    in property <image> icon;
    in property <Tone> tone: Tone.default;
    in property <string> name;
    in property <string> institution;
    in property <string> value;
    in property <bool> liability: false;
    callback clicked();

    accessible-role: button;
    accessible-label: root.name;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    min-height: 64px;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 40px;
                height: 40px;
                border-radius: Theme.radius-sm;
                background:
                      root.tone == Tone.success ? Theme.accent-success.with-alpha(0.18)
                    : root.tone == Tone.info    ? Theme.accent-info.with-alpha(0.18)
                    : root.tone == Tone.warning ? Theme.accent-warning.with-alpha(0.18)
                    : root.tone == Tone.danger  ? Theme.accent-danger.with-alpha(0.18)
                    : Theme.surface-variant;
                Image {
                    width: 20px;
                    height: 20px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: root.icon;
                    colorize:
                          root.tone == Tone.success ? Theme.accent-success
                        : root.tone == Tone.info    ? Theme.accent-info
                        : root.tone == Tone.warning ? Theme.accent-warning
                        : root.tone == Tone.danger  ? Theme.accent-danger
                        : Theme.on-surface;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 700;
            }
            Text {
                text: root.institution;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.value;
                color: root.liability ? Theme.accent-danger : Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 800;
                horizontal-alignment: right;
            }
        }
    }
    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component NetWorthPage inherits Rectangle {
    in property <string> net-worth: "$142,580";
    in property <string> change: "+$3,240 this month";
    in property <string> assets-total: "$198,400";
    in property <string> liabilities-total: "$55,820";
    in property <float> assets-fraction: 0.78;
    callback back-pressed();
    callback history-pressed();
    callback account-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Net worth";
            leading-icon: @image-url("../icons/arrow-left.svg");
            trailing-icon: @image-url("../icons/more-vertical.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.history-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Hero.
            Rectangle {
                border-radius: Theme.radius-lg;
                background: @linear-gradient(135deg, #1f6f4d 0%, #0b2f20 100%);
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    Text {
                        text: "TOTAL NET WORTH";
                        color: #ffffff99;
                        font-size: 10px;
                        font-weight: 800;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: root.net-worth;
                        color: #ffffff;
                        font-size: 44px;
                        font-weight: 800;
                    }
                    HorizontalLayout {
                        spacing: 5px;
                        alignment: start;
                        Image {
                            width: 14px;
                            height: 14px;
                            source: @image-url("../icons/check.svg");
                            colorize: #4ade80;
                            image-fit: contain;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.change;
                            color: #4ade80;
                            font-size: Theme.font-size-caption;
                            font-weight: 800;
                            vertical-alignment: center;
                        }
                    }
                    // Trend bar-strip.
                    HorizontalLayout {
                        height: 40px;
                        spacing: 3px;
                        alignment: space-between;
                        for h in [0.4, 0.45, 0.42, 0.5, 0.55, 0.52, 0.6, 0.58, 0.66, 0.7, 0.74, 0.82]: Rectangle {
                            horizontal-stretch: 1;
                            Rectangle {
                                width: parent.width;
                                height: parent.height * h;
                                y: parent.height - self.height;
                                border-radius: 2px;
                                background: #ffffff;
                                opacity: 0.5;
                            }
                        }
                    }
                }
            }

            // Assets / liabilities split.
            Rectangle {
                border-radius: Theme.radius-md;
                background: Theme.surface-1;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    HorizontalLayout {
                        VerticalLayout {
                            horizontal-stretch: 1;
                            spacing: 2px;
                            Text {
                                text: "ASSETS";
                                color: Theme.muted;
                                font-size: 10px;
                                font-weight: 800;
                                letter-spacing: 0.3px;
                            }
                            Text {
                                text: root.assets-total;
                                color: Theme.accent-success;
                                font-size: Theme.font-size-body-large;
                                font-weight: 800;
                            }
                        }
                        VerticalLayout {
                            spacing: 2px;
                            Text {
                                text: "LIABILITIES";
                                color: Theme.muted;
                                font-size: 10px;
                                font-weight: 800;
                                letter-spacing: 0.3px;
                                horizontal-alignment: right;
                            }
                            Text {
                                text: root.liabilities-total;
                                color: Theme.accent-danger;
                                font-size: Theme.font-size-body-large;
                                font-weight: 800;
                                horizontal-alignment: right;
                            }
                        }
                    }
                    // Split bar.
                    HorizontalLayout {
                        height: 10px;
                        spacing: 3px;
                        Rectangle {
                            width: parent.width * root.assets-fraction;
                            border-radius: 5px;
                            background: Theme.accent-success;
                        }
                        Rectangle {
                            horizontal-stretch: 1;
                            border-radius: 5px;
                            background: Theme.accent-danger;
                        }
                    }
                }
            }
        }

        SectionHeader { text: "ASSETS"; }
        AccountRow {
            icon: @image-url("../icons/inbox.svg");
            tone: Tone.success;
            name: "Everyday Checking";
            institution: "Northwind Bank";
            value: "$8,420";
            clicked => { root.account-pressed("Everyday Checking"); }
        }
        Divider { }
        AccountRow {
            icon: @image-url("../icons/star.svg");
            tone: Tone.success;
            name: "High-Yield Savings";
            institution: "Northwind Bank";
            value: "$32,180";
            clicked => { root.account-pressed("High-Yield Savings"); }
        }
        Divider { }
        AccountRow {
            icon: @image-url("../icons/queue.svg");
            tone: Tone.info;
            name: "Brokerage";
            institution: "Vanguard";
            value: "$94,800";
            clicked => { root.account-pressed("Brokerage"); }
        }
        Divider { }
        AccountRow {
            icon: @image-url("../icons/home.svg");
            tone: Tone.warning;
            name: "Home equity";
            institution: "Estimated";
            value: "$63,000";
            clicked => { root.account-pressed("Home equity"); }
        }

        SectionHeader { text: "LIABILITIES"; }
        AccountRow {
            icon: @image-url("../icons/home.svg");
            tone: Tone.danger;
            name: "Mortgage";
            institution: "Northwind Home Loans";
            value: "-$48,600";
            liability: true;
            clicked => { root.account-pressed("Mortgage"); }
        }
        Divider { }
        AccountRow {
            icon: @image-url("../icons/inbox.svg");
            tone: Tone.danger;
            name: "Credit card";
            institution: "Northwind Platinum";
            value: "-$2,840";
            liability: true;
            clicked => { root.account-pressed("Credit card"); }
        }
        Divider { }
        AccountRow {
            icon: @image-url("../icons/pin.svg");
            tone: Tone.danger;
            name: "Auto loan";
            institution: "DriveFast Finance";
            value: "-$4,380";
            liability: true;
            clicked => { root.account-pressed("Auto loan"); }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
