// SavingsGoalPage
// =====================================================================
//
// Savings goal tracker — the "round-up jar" / Monzo Pot / Qapital
// screen. Distinct from `ExpenseReportPage` (spend breakdown) and
// `InvestmentDetailPage` (market instrument). Demonstrates a
// progress-toward-target surface:
//
//   - Goal hero card: emoji-ish glyph tile + goal name + saved / target
//     amounts + a thick progress bar + a projected-completion line.
//   - A 3-up stat strip: monthly contribution, this-month total,
//     streak.
//   - Contribution history rows — auto-saves and manual top-ups,
//     each with a tone-tinted icon and a +amount.
//   - Sticky "Add money" CTA.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { SectionHeader } from "../section-header.slint";
import { Divider } from "../divider.slint";
import { MobileButton } from "../button.slint";

// One stat in the 3-up strip.
component StatCell inherits Rectangle {
    in property <string> value;
    in property <string> label;
    in property <Tone> tone: Tone.default;

    horizontal-stretch: 1;
    height: 72px;
    border-radius: Theme.radius-md;
    background: Theme.surface-1;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        alignment: center;
        spacing: 3px;
        Text {
            text: root.value;
            color:
                  root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.on-surface;
            font-size: Theme.font-size-body-large;
            font-weight: 800;
            horizontal-alignment: center;
        }
        Text {
            text: root.label;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 700;
            letter-spacing: 0.3px;
            horizontal-alignment: center;
        }
    }
}

// One contribution-history row. `tone` tints the icon disc; auto vs
// manual is conveyed by the icon + label.
component ContributionRow inherits Rectangle {
    in property <bool> auto: true;
    in property <string> label;
    in property <string> date;
    in property <string> amount;

    horizontal-stretch: 1;
    min-height: 60px;

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 36px;
                height: 36px;
                border-radius: self.width / 2;
                background: root.auto
                    ? Theme.accent-info.with-alpha(0.18)
                    : Theme.accent-success.with-alpha(0.18);
                Image {
                    width: 18px;
                    height: 18px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: root.auto
                        ? @image-url("../icons/spinner-arc.svg")
                        : @image-url("../icons/plus.svg");
                    colorize: root.auto ? Theme.accent-info : Theme.accent-success;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            Text {
                text: root.date;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: "+" + root.amount;
                color: Theme.accent-success;
                font-size: Theme.font-size-body;
                font-weight: 800;
            }
        }
    }
}

export component SavingsGoalPage inherits Rectangle {
    in property <string> goal: "Iceland trip";
    in property <string> saved: "$3,180";
    in property <string> target: "$5,000";
    in property <float> progress: 0.636;
    in property <string> progress-label: "64%";
    in property <string> projected: "On track — fully funded by Oct 2026";
    callback back-pressed();
    callback edit-pressed();
    callback add-money-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Savings goal";
            leading-icon: @image-url("../icons/arrow-left.svg");
            trailing-icon: @image-url("../icons/pencil.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.edit-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Goal hero.
            Rectangle {
                border-radius: Theme.radius-lg;
                background: Theme.surface-1;
                drop-shadow-blur: Theme.elevation-2-blur;
                drop-shadow-color: Theme.elevation-2-color;
                drop-shadow-offset-y: Theme.elevation-2-y;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    HorizontalLayout {
                        spacing: Theme.spacing-md;
                        alignment: stretch;
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: 52px;
                                height: 52px;
                                border-radius: Theme.radius-md;
                                background: @linear-gradient(135deg, #38bdf8 0%, #0c4a6e 100%);
                                Image {
                                    width: 26px;
                                    height: 26px;
                                    x: (parent.width - self.width) / 2;
                                    y: (parent.height - self.height) / 2;
                                    source: @image-url("../icons/pin.svg");
                                    colorize: #ffffff;
                                    image-fit: contain;
                                }
                            }
                        }
                        VerticalLayout {
                            horizontal-stretch: 1;
                            alignment: center;
                            spacing: 2px;
                            Text {
                                text: root.goal;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-title;
                                font-weight: 800;
                            }
                            HorizontalLayout {
                                spacing: 4px;
                                alignment: start;
                                Text {
                                    text: root.saved;
                                    color: Theme.accent-success;
                                    font-size: Theme.font-size-body;
                                    font-weight: 800;
                                }
                                Text {
                                    text: "of " + root.target;
                                    color: Theme.muted;
                                    font-size: Theme.font-size-body;
                                    font-weight: 600;
                                }
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Text {
                                text: root.progress-label;
                                color: Theme.accent-success;
                                font-size: Theme.font-size-title;
                                font-weight: 800;
                            }
                        }
                    }
                    // Progress bar.
                    Rectangle {
                        height: 12px;
                        border-radius: 6px;
                        background: Theme.surface-variant;
                        Rectangle {
                            x: 0;
                            width: parent.width * root.progress;
                            height: parent.height;
                            border-radius: 6px;
                            background: @linear-gradient(90deg, #34d399 0%, #059669 100%);
                        }
                    }
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: start;
                        Image {
                            width: 14px;
                            height: 14px;
                            source: @image-url("../icons/check.svg");
                            colorize: Theme.accent-success;
                            image-fit: contain;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.projected;
                            color: Theme.muted;
                            font-size: Theme.font-size-caption;
                            font-weight: 600;
                            vertical-alignment: center;
                        }
                    }
                }
            }

            // Stat strip.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                StatCell {
                    value: "$320";
                    label: "PER MONTH";
                }
                StatCell {
                    value: "$285";
                    label: "THIS MONTH";
                    tone: Tone.info;
                }
                StatCell {
                    value: "14 wks";
                    label: "STREAK";
                    tone: Tone.success;
                }
            }
        }

        SectionHeader { text: "CONTRIBUTIONS"; }
        ContributionRow {
            auto: true;
            label: "Round-up auto-save";
            date: "Today · 6 transactions";
            amount: "4.80";
        }
        Divider { }
        ContributionRow {
            auto: false;
            label: "Manual top-up";
            date: "Yesterday";
            amount: "150.00";
        }
        Divider { }
        ContributionRow {
            auto: true;
            label: "Weekly transfer";
            date: "Mon · automatic";
            amount: "80.00";
        }
        Divider { }
        ContributionRow {
            auto: false;
            label: "Birthday gift";
            date: "3 May";
            amount: "100.00";
        }
        Divider { }
        ContributionRow {
            auto: true;
            label: "Round-up auto-save";
            date: "2 May · 9 transactions";
            amount: "7.20";
        }

        Rectangle { vertical-stretch: 1; }

        // Sticky CTA.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                MobileButton {
                    text: "Add money";
                    primary: true;
                    max-height: 48px;
                    clicked => { root.add-money-pressed(); }
                }
            }
        }
    }
}
