// FormWizardPage
// =====================================================================
//
// Multi-step form / onboarding wizard. The skeleton applies to any
// "fill these out across several screens" flow: KYC checks, new-user
// onboarding, post-signup setup, structured intake forms, etc.
// Demonstrates:
//
//   - A stepped progress strip at the top — 5 pill segments where each
//     completed segment is filled green (`accent-success`), the
//     current segment is filled blue (`primary`), and pending segments
//     are muted. The current step's label is also rendered below the
//     strip so the user knows where they are.
//   - A mixed field block — TextField, Checkboxes, Chip-based "pick
//     one" radio, all wrapped in a ScrollView so long forms don't
//     truncate.
//   - Sticky Back + Continue button pair anchored to the bottom — the
//     pattern shared across every multi-step form.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { TextField } from "../text-field.slint";
import { Checkbox } from "../checkbox.slint";
import { Chip } from "../chip.slint";
import { Divider } from "../divider.slint";
import { MobileButton, TextButton } from "../button.slint";
import { ScrollView } from "std-widgets.slint";

// One step in the progress strip.
component StepSegment inherits Rectangle {
    in property <int> state;     // 0=pending, 1=current, 2=completed
    horizontal-stretch: 1;
    height: 4px;
    border-radius: 2px;
    background:
          root.state == 2 ? Theme.accent-success
        : root.state == 1 ? Theme.primary
        : Theme.surface-variant;
    animate background { duration: Theme.motion-base; }
}

// One labeled checkbox row (Checkbox component already pairs label +
// box, but we wrap it here so we can add a description sub-text per
// option in the "communication preferences" example block).
component LabeledCheckboxRow inherits Rectangle {
    in property <string> label;
    in property <string> description;
    in-out property <bool> checked: false;

    min-height: 48px;
    HorizontalLayout {
        padding-top: Theme.spacing-xs;
        padding-bottom: Theme.spacing-xs;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: start;
            padding-top: 2px;
            Checkbox {
                checked <=> root.checked;
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            Text {
                text: root.description;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
                wrap: word-wrap;
            }
        }
    }
}

export component FormWizardPage inherits Rectangle {
    in property <int> current-step: 2;
    in property <int> total-steps: 5;
    callback back-pressed();
    callback close-pressed();
    callback continue-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Set up your account";
            leading-icon: @image-url("../icons/close.svg");
            leading-pressed => { root.close-pressed(); }
        }

        // ----- Stepper strip -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-sm;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            HorizontalLayout {
                spacing: Theme.spacing-sm;
                for index in 5 : StepSegment {
                    state:
                          index < root.current-step ? 2
                        : index == root.current-step ? 1
                        : 0;
                }
            }
            HorizontalLayout {
                Text {
                    text: "Step " + (root.current-step + 1) + " of " + root.total-steps;
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-stretch: 1;
                }
                Text {
                    text: "Communication preferences";
                    color: Theme.on-surface;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-alignment: right;
                }
            }
        }

        // ----- Field block -----
        // Plain VerticalLayout (no ScrollView wrapper) — at the
        // current content footprint everything fits within the 892 px
        // mobile target. Re-introduce the ScrollView only if the form
        // grows past the visible area.
        Rectangle {
            vertical-stretch: 1;
            VerticalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-md;
                alignment: start;

                // Hero question.
                Text {
                    text: "How should we reach you?";
                    color: Theme.on-background;
                    font-size: Theme.font-size-title;
                    font-weight: 700;
                    wrap: word-wrap;
                }
                Text {
                    text: "We'll only send what you turn on. You can change these later from Settings → Notifications.";
                    color: Theme.muted;
                    font-size: Theme.font-size-body;
                    wrap: word-wrap;
                }

                // Contact fields.
                TextField {
                    label: "Email";
                    placeholder: "you@example.com";
                    text: "greg@example.com";
                }
                TextField {
                    label: "Mobile (optional)";
                    placeholder: "+1 555 000 0000";
                }

                Divider { }

                // Channel selector chips ("How often should we send digests?")
                Text {
                    text: "Digest cadence";
                    color: Theme.on-background;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
                HorizontalLayout {
                    spacing: Theme.spacing-sm;
                    Chip { label: "Daily"; }
                    Chip { label: "Weekly"; selected: true; }
                    Chip { label: "Monthly"; }
                    Chip { label: "Never"; }
                }

                Divider { }

                // Communication preferences checkboxes.
                Text {
                    text: "Which updates do you want?";
                    color: Theme.on-background;
                    font-size: Theme.font-size-body;
                    font-weight: 600;
                }
                LabeledCheckboxRow {
                    label: "Product news";
                    description: "Releases, new features, and changelog summaries.";
                    checked: true;
                }
                LabeledCheckboxRow {
                    label: "Tips & tutorials";
                    description: "Short how-tos for getting more out of the product.";
                    checked: true;
                }
                LabeledCheckboxRow {
                    label: "Marketing";
                    description: "Promotions, partner offers, and survey requests.";
                }
                LabeledCheckboxRow {
                    label: "Critical alerts";
                    description: "Security incidents and account-impacting events. Can't be turned off.";
                    checked: true;
                }
            }
        }

        // ----- Sticky footer -----
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                spacing: Theme.spacing-md;
                MobileButton {
                    text: "Back";
                    primary: false;
                    horizontal-stretch: 1;
                    max-height: 48px;
                    clicked => { root.back-pressed(); }
                }
                MobileButton {
                    text: "Continue";
                    horizontal-stretch: 1;
                    max-height: 48px;
                    clicked => { root.continue-pressed(); }
                }
            }
        }
    }
}
