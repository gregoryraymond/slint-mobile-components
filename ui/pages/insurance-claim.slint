// InsuranceClaimPage
// =====================================================================
//
// File-an-insurance-claim form — Lemonade / Geico / state-government
// app pattern. Distinct from `BugReportPage` (in-app issue),
// `WriteReviewPage` (product feedback) and `OrderTrackingPage`
// (delivery). Demonstrates a high-stakes form template:
//
//   - Policy summary card at the top (logo + plan name + ID + status).
//   - Incident-type chip grid (Auto / Home / Theft / Medical / Travel)
//     with tone-tinted icons.
//   - Date picker pill + Location pill.
//   - 4-photo evidence grid (1 filled + 3 add tiles).
//   - Multi-line description body (prefilled) with a small recording-
//     attached chip showing an attached voice memo.
//   - Estimated payout banner (success-tone) + Submit CTA.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { SectionHeader } from "../section-header.slint";
import { Chip } from "../chip.slint";
import { Divider } from "../divider.slint";
import { Banner } from "../banner.slint";
import { MobileButton, TextButton } from "../button.slint";

// One incident-type tile.
component IncidentTile inherits Rectangle {
    in property <image> icon;
    in property <string> label;
    in property <Tone> tone;
    in property <bool> selected: false;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 88px;
    background:
          root.selected
        ? (
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : Theme.primary
          )
        : Theme.surface-1;
    border-radius: Theme.radius-md;
    border-width: 1px;
    border-color:
          root.selected
        ? (
              root.tone == Tone.success ? Theme.accent-success
            : root.tone == Tone.warning ? Theme.accent-warning
            : root.tone == Tone.danger  ? Theme.accent-danger
            : root.tone == Tone.info    ? Theme.accent-info
            : Theme.primary
          )
        : Theme.outline;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        spacing: 4px;
        alignment: center;
        HorizontalLayout {
            alignment: center;
            Image {
                width: 24px;
                height: 24px;
                source: root.icon;
                colorize: root.selected ? Theme.on-primary : Theme.on-surface;
                image-fit: contain;
            }
        }
        HorizontalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: root.selected ? Theme.on-primary : Theme.on-surface;
                font-size: 11px;
                font-weight: 800;
                letter-spacing: 0.3px;
            }
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

// Date / location pill that the user taps to edit.
component CriteriaPill inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <Tone> tone: Tone.default;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 64px;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;

    VerticalLayout {
        padding: Theme.spacing-sm;
        spacing: 2px;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        Text {
            text: root.value;
            color:
                  root.tone == Tone.success ? Theme.accent-success
                : root.tone == Tone.warning ? Theme.accent-warning
                : root.tone == Tone.danger  ? Theme.accent-danger
                : root.tone == Tone.info    ? Theme.accent-info
                : Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 700;
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component InsuranceClaimPage inherits Rectangle {
    in property <string> policy: "Auto Comprehensive · GR-44219-K";
    in property <string> coverage-status: "Active · renewed 2026-01-12";
    in property <int> selected-incident: 0;     // 0..4
    in property <string> description:
        "Side-swiped while parked on Hayes Street last night. Driver-side mirror cracked, paint chipped in two places. Note left under wiper — driver took photos but no insurance details exchanged.";
    callback close-pressed();
    callback incident-pressed(int);
    callback edit-criteria-pressed(string);
    callback attach-pressed();
    callback submit-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "File a claim";
            leading-icon: @image-url("../icons/close.svg");
            leading-pressed => { root.close-pressed(); }
        }

        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Policy summary card.
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                height: 84px;
                HorizontalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-md;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: center;
                        Rectangle {
                            width: 40px;
                            height: 40px;
                            border-radius: 10px;
                            background: Theme.accent-info;
                            Text {
                                text: "GI";
                                color: Theme.on-primary;
                                font-size: 14px;
                                font-weight: 800;
                                horizontal-alignment: center;
                                vertical-alignment: center;
                                width: parent.width;
                                height: parent.height;
                            }
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        alignment: center;
                        spacing: 2px;
                        Text {
                            text: root.policy;
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                        }
                        Text {
                            text: root.coverage-status;
                            color: Theme.accent-success;
                            font-size: Theme.font-size-caption;
                            font-weight: 600;
                        }
                    }
                    VerticalLayout {
                        alignment: center;
                        Image {
                            width: 16px;
                            height: 16px;
                            source: @image-url("../icons/chevron-right.svg");
                            colorize: Theme.muted;
                            image-fit: contain;
                        }
                    }
                }
            }

            // Incident-type grid.
            Text {
                text: "What happened?";
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 700;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                IncidentTile {
                    icon: @image-url("../icons/pin.svg");
                    label: "AUTO";
                    tone: Tone.info;
                    selected: root.selected-incident == 0;
                    clicked => { root.incident-pressed(0); }
                }
                IncidentTile {
                    icon: @image-url("../icons/home.svg");
                    label: "HOME";
                    tone: Tone.success;
                    selected: root.selected-incident == 1;
                    clicked => { root.incident-pressed(1); }
                }
                IncidentTile {
                    icon: @image-url("../icons/lock.svg");
                    label: "THEFT";
                    tone: Tone.danger;
                    selected: root.selected-incident == 2;
                    clicked => { root.incident-pressed(2); }
                }
                IncidentTile {
                    icon: @image-url("../icons/heart.svg");
                    label: "MEDICAL";
                    tone: Tone.warning;
                    selected: root.selected-incident == 3;
                    clicked => { root.incident-pressed(3); }
                }
            }

            // Date + location pills.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                CriteriaPill {
                    label: "WHEN";
                    value: "Tue, May 13 · 22:40";
                    tone: Tone.info;
                    clicked => { root.edit-criteria-pressed("when"); }
                }
                CriteriaPill {
                    label: "WHERE";
                    value: "Hayes St · SF, CA";
                    tone: Tone.warning;
                    clicked => { root.edit-criteria-pressed("where"); }
                }
            }

            // Evidence grid.
            Text {
                text: "Photos · attach up to 8";
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 700;
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Rectangle {
                    width: 80px;
                    height: 80px;
                    border-radius: Theme.radius-sm;
                    background: @linear-gradient(135deg, #506b8e 0%, #1f2a3b 100%);
                    clip: true;
                    Rectangle {
                        x: parent.width - 18px;
                        y: 2px;
                        width: 16px;
                        height: 16px;
                        border-radius: 8px;
                        background: #00000099;
                        Text {
                            text: "✕";
                            color: #ffffff;
                            font-size: 9px;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
                for index in 3 : Rectangle {
                    width: 80px;
                    height: 80px;
                    border-radius: Theme.radius-sm;
                    background: Theme.surface-variant;
                    Image {
                        width: 22px;
                        height: 22px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("../icons/plus.svg");
                        colorize: Theme.muted;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.attach-pressed(); }
                    }
                }
            }

            // Description card.
            Text {
                text: "What happened (in your words)";
                color: Theme.on-background;
                font-size: Theme.font-size-body;
                font-weight: 700;
            }
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;
                    Text {
                        text: root.description;
                        color: Theme.on-surface;
                        font-size: Theme.font-size-body;
                        wrap: word-wrap;
                    }
                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        Rectangle {
                            width: vm-row.preferred-width + 14px;
                            height: 26px;
                            border-radius: 13px;
                            background: Theme.accent-info;
                            vm-row := HorizontalLayout {
                                spacing: 4px;
                                padding-left: 8px;
                                padding-right: 6px;
                                alignment: center;
                                Image {
                                    width: 12px;
                                    height: 12px;
                                    source: @image-url("../icons/play.svg");
                                    colorize: Theme.on-primary;
                                    image-fit: contain;
                                    vertical-alignment: center;
                                }
                                Text {
                                    text: "VOICE MEMO · 0:48";
                                    color: Theme.on-primary;
                                    font-size: 9px;
                                    font-weight: 800;
                                    letter-spacing: 0.3px;
                                    vertical-alignment: center;
                                }
                            }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        TextButton { text: "Re-record"; }
                    }
                }
            }

            // Estimated payout.
            Banner {
                icon: @image-url("../icons/check.svg");
                message: "Estimated payout · $1,200–$1,650 · 5–7 business days";
                tone: Tone.success;
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Submit footer.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 80px;
            HorizontalLayout {
                padding: Theme.spacing-md;
                MobileButton {
                    text: "Submit claim";
                    tone: Tone.info;
                    max-height: 48px;
                    clicked => { root.submit-pressed(); }
                }
            }
        }
    }
}
