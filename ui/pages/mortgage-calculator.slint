// MortgageCalculatorPage
// =====================================================================
//
// A mortgage / loan calculator — the "what will it cost per month"
// screen. Distinct from `CurrencyConverterPage` (FX) and
// `BudgetOverviewPage` (spend tracking). Demonstrates an input-driven
// result surface:
//
//   - A result hero: the estimated monthly payment, big and centred.
//   - Input rows — home price, down payment, interest rate, term —
//     each a labelled value with a Stepper to nudge it.
//   - A payment-breakdown card: a stacked split bar (principal /
//     interest / tax+insurance) with a legend.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { SectionHeader } from "../section-header.slint";
import { Divider } from "../divider.slint";
import { Stepper } from "../stepper.slint";

// One input row: label + current value + a Stepper.
component InputRow inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in-out property <int> step-value;
    in property <int> step-min: 0;
    in property <int> step-max: 100;

    horizontal-stretch: 1;
    min-height: 68px;

    HorizontalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.label;
                color: Theme.muted;
                font-size: 10px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }
            Text {
                text: root.value;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 800;
            }
        }
        VerticalLayout {
            alignment: center;
            Stepper {
                value <=> root.step-value;
                minimum: root.step-min;
                maximum: root.step-max;
            }
        }
    }
}

// One breakdown legend entry.
component BreakdownLegend inherits HorizontalLayout {
    in property <string> label;
    in property <string> amount;
    in property <brush> swatch;

    spacing: 6px;
    Rectangle {
        width: 12px;
        height: 12px;
        y: (parent.height - self.height) / 2;
        border-radius: 3px;
        background: root.swatch;
    }
    VerticalLayout {
        spacing: 1px;
        Text {
            text: root.label;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 700;
        }
        Text {
            text: root.amount;
            color: Theme.on-surface;
            font-size: Theme.font-size-caption;
            font-weight: 800;
        }
    }
}

export component MortgageCalculatorPage inherits Rectangle {
    in property <string> monthly: "$2,184";
    in-out property <int> price-k: 540;
    in-out property <int> down-pct: 20;
    in-out property <int> rate-bps: 62;
    in-out property <int> term-years: 30;
    in property <float> principal-frac: 0.46;
    in property <float> interest-frac: 0.39;
    callback back-pressed();
    callback save-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Mortgage calculator";
            leading-icon: @image-url("../icons/arrow-left.svg");
            trailing-icon: @image-url("../icons/star.svg");
            leading-pressed => { root.back-pressed(); }
            trailing-pressed => { root.save-pressed(); }
        }

        // Result hero.
        Rectangle {
            background: @linear-gradient(135deg, #1e3a8a 0%, #0c1a3a 100%);
            height: 156px;
            VerticalLayout {
                alignment: center;
                spacing: 6px;
                Text {
                    text: "ESTIMATED MONTHLY PAYMENT";
                    color: #ffffff99;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 1px;
                    horizontal-alignment: center;
                }
                Text {
                    text: root.monthly;
                    color: #ffffff;
                    font-size: 56px;
                    font-weight: 800;
                    horizontal-alignment: center;
                }
                Text {
                    text: "Principal, interest, tax & insurance";
                    color: #ffffffcc;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                    horizontal-alignment: center;
                }
            }
        }

        SectionHeader { text: "LOAN DETAILS"; }
        InputRow {
            label: "HOME PRICE";
            value: "$540,000";
            step-value <=> root.price-k;
            step-min: 50;
            step-max: 2000;
        }
        Divider { }
        InputRow {
            label: "DOWN PAYMENT";
            value: "20%  ·  $108,000";
            step-value <=> root.down-pct;
            step-min: 0;
            step-max: 100;
        }
        Divider { }
        InputRow {
            label: "INTEREST RATE";
            value: "6.2% APR";
            step-value <=> root.rate-bps;
            step-min: 0;
            step-max: 200;
        }
        Divider { }
        InputRow {
            label: "LOAN TERM";
            value: "30 years";
            step-value <=> root.term-years;
            step-min: 5;
            step-max: 40;
        }

        SectionHeader { text: "PAYMENT BREAKDOWN"; }
        Rectangle {
            VerticalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                padding-bottom: Theme.spacing-md;
                spacing: Theme.spacing-md;
                // Stacked split bar.
                HorizontalLayout {
                    height: 14px;
                    spacing: 3px;
                    Rectangle {
                        width: parent.width * root.principal-frac;
                        border-radius: 7px;
                        background: Theme.accent-info;
                    }
                    Rectangle {
                        width: parent.width * root.interest-frac;
                        border-radius: 7px;
                        background: Theme.accent-warning;
                    }
                    Rectangle {
                        horizontal-stretch: 1;
                        border-radius: 7px;
                        background: Theme.accent-danger;
                    }
                }
                HorizontalLayout {
                    alignment: space-between;
                    BreakdownLegend {
                        label: "PRINCIPAL";
                        amount: "$1,005";
                        swatch: Theme.accent-info;
                    }
                    BreakdownLegend {
                        label: "INTEREST";
                        amount: "$852";
                        swatch: Theme.accent-warning;
                    }
                    BreakdownLegend {
                        label: "TAX + INS.";
                        amount: "$327";
                        swatch: Theme.accent-danger;
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
