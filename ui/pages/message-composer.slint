// MessageComposerPage
// =====================================================================
//
// Twitter / Threads / Bluesky-style compose-a-post screen. Distinct
// from `PostCreatorPage` (Instagram media-first), `EmailThreadPage`
// (long-form reply), and `CommentsPage` (inline thread). Demonstrates:
//
//   - Top AppBar with Cancel left + audience pill + Drafts right.
//   - Author row: avatar + name + audience chip with chevron-right.
//   - Multi-paragraph text body (prefilled) + a tone-tinted character
//     counter that flips from muted → warning → danger as it
//     approaches the cap. Renders an inline progress ring in the
//     bottom-right of the body.
//   - Inline reply-to summary card showing what the user is replying to.
//   - Bottom tool row: media / GIF / poll / location / schedule icons,
//     plus the primary Post pill on the right.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { Avatar } from "../avatar.slint";
import { MobileButton, TextButton } from "../button.slint";
import { Divider } from "../divider.slint";

// One tool icon in the bottom strip.
component ToolIcon inherits Rectangle {
    in property <image> icon;
    in property <bool> disabled: false;
    callback clicked();

    accessible-role: button;
    accessible-action-default => { root.clicked(); }

    width: 40px;
    height: 40px;
    Image {
        width: 22px;
        height: 22px;
        x: (parent.width - self.width) / 2;
        y: (parent.height - self.height) / 2;
        source: root.icon;
        colorize: root.disabled ? Theme.muted : Theme.accent-info;
        image-fit: contain;
        opacity: root.disabled ? 0.5 : 1.0;
    }
    TouchArea {
        enabled: !root.disabled;
        clicked => { root.clicked(); }
    }
}

// Character-count progress ring (just a thin colour ring with a tone).
component CharCountRing inherits Rectangle {
    in property <int> used: 184;
    in property <int> cap: 280;

    property <Tone> tone:
          root.used > root.cap ? Tone.danger
        : root.used > root.cap * 9 / 10 ? Tone.warning
        : Tone.info;

    property <color> tint:
          tone == Tone.danger ? Theme.accent-danger
        : tone == Tone.warning ? Theme.accent-warning
        : Theme.accent-info;

    width: 36px;
    height: 36px;

    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: 3px;
        border-color: Theme.surface-variant;
        background: transparent;
    }
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: 3px;
        border-color: tint;
        background: transparent;
        opacity: root.used / root.cap;
    }
    Text {
        text: (root.cap - root.used);
        color: tint;
        font-size: 11px;
        font-weight: 800;
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

export component MessageComposerPage inherits Rectangle {
    in property <string> author: "Greg Raymond";
    in property <string> handle: "@graymond";
    in property <string> audience: "Public";
    in property <string> body:
        "Iteration 25 of the slint-mobile-components catalogue is in: composer, calculator, recipe, multi-select, tip-jar. Snapshot diffing is keeping me honest — 111 baselines and counting.";
    in property <int> used-chars: 184;
    in property <int> cap-chars: 280;
    in property <string> reply-to-author: "Anika Ravi";
    in property <string> reply-to-handle: "@anika.ravi";
    in property <string> reply-to-body: "How's the design-system rollout going?";
    callback cancel-pressed();
    callback drafts-pressed();
    callback audience-pressed();
    callback post-pressed();
    callback tool-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Replying";
            leading-icon: @image-url("../icons/close.svg");
            trailing-icon: @image-url("../icons/queue.svg");
            leading-pressed => { root.cancel-pressed(); }
            trailing-pressed => { root.drafts-pressed(); }
        }

        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-sm;
            spacing: Theme.spacing-sm;

            // Reply-to summary.
            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;
                HorizontalLayout {
                    padding: Theme.spacing-sm;
                    spacing: Theme.spacing-sm;
                    alignment: stretch;
                    VerticalLayout {
                        alignment: start;
                        padding-top: 2px;
                        Avatar {
                            fallback: "AR";
                            size: 28px;
                        }
                    }
                    VerticalLayout {
                        horizontal-stretch: 1;
                        spacing: 2px;
                        HorizontalLayout {
                            spacing: Theme.spacing-xs;
                            Text {
                                text: root.reply-to-author;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-caption;
                                font-weight: 700;
                            }
                            Text {
                                text: root.reply-to-handle + " · 2h";
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                            }
                        }
                        Text {
                            text: root.reply-to-body;
                            color: Theme.muted;
                            font-size: Theme.font-size-caption;
                            wrap: word-wrap;
                        }
                    }
                }
            }

            // Author + audience chip.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: stretch;
                padding-top: Theme.spacing-sm;
                VerticalLayout {
                    alignment: start;
                    padding-top: 2px;
                    Avatar {
                        fallback: "GR";
                        size: 40px;
                    }
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;
                    HorizontalLayout {
                        spacing: Theme.spacing-xs;
                        Text {
                            text: root.author;
                            color: Theme.on-surface;
                            font-size: Theme.font-size-body;
                            font-weight: 700;
                            vertical-alignment: center;
                        }
                        Text {
                            text: root.handle;
                            color: Theme.muted;
                            font-size: Theme.font-size-caption;
                            vertical-alignment: center;
                        }
                    }
                    // Audience pill.
                    Rectangle {
                        width: aud-row.preferred-width + 14px;
                        height: 22px;
                        border-radius: 11px;
                        background: Theme.accent-info;
                        aud-row := HorizontalLayout {
                            spacing: 4px;
                            padding-left: 8px;
                            padding-right: 6px;
                            alignment: center;
                            Image {
                                width: 12px;
                                height: 12px;
                                source: @image-url("../icons/profile.svg");
                                colorize: Theme.on-primary;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                            Text {
                                text: root.audience;
                                color: Theme.on-primary;
                                font-size: 10px;
                                font-weight: 800;
                                letter-spacing: 0.3px;
                                vertical-alignment: center;
                            }
                            Image {
                                width: 10px;
                                height: 10px;
                                source: @image-url("../icons/chevron-right.svg");
                                colorize: Theme.on-primary;
                                image-fit: contain;
                                vertical-alignment: center;
                            }
                        }
                        TouchArea {
                            clicked => { root.audience-pressed(); }
                        }
                    }

                    // Body text.
                    Rectangle {
                        horizontal-stretch: 1;
                        height: 200px;
                        VerticalLayout {
                            padding-top: Theme.spacing-sm;
                            Text {
                                text: root.body;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-body-large;
                                wrap: word-wrap;
                            }
                        }
                    }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        Divider { }

        // Bottom tool row.
        Rectangle {
            background: Theme.surface-1;
            height: 72px;
            HorizontalLayout {
                padding-left: Theme.spacing-md;
                padding-right: Theme.spacing-md;
                spacing: Theme.spacing-xs;
                alignment: stretch;
                ToolIcon {
                    icon: @image-url("../icons/photo-ocean.svg");
                    clicked => { root.tool-pressed("media"); }
                }
                ToolIcon {
                    icon: @image-url("../icons/play.svg");
                    clicked => { root.tool-pressed("gif"); }
                }
                ToolIcon {
                    icon: @image-url("../icons/menu.svg");
                    clicked => { root.tool-pressed("poll"); }
                }
                ToolIcon {
                    icon: @image-url("../icons/pin.svg");
                    clicked => { root.tool-pressed("location"); }
                }
                ToolIcon {
                    icon: @image-url("../icons/bell.svg");
                    clicked => { root.tool-pressed("schedule"); }
                }
                Rectangle { horizontal-stretch: 1; }
                VerticalLayout {
                    alignment: center;
                    CharCountRing {
                        used: root.used-chars;
                        cap: root.cap-chars;
                    }
                }
                VerticalLayout {
                    alignment: center;
                    MobileButton {
                        text: "Post";
                        tone: Tone.info;
                        horizontal-stretch: 0;
                        vertical-stretch: 0;
                        min-width: 88px;
                        max-height: 40px;
                        clicked => { root.post-pressed(); }
                    }
                }
            }
        }
    }
}
