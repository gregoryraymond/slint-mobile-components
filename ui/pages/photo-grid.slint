// PhotoGridPage
// =====================================================================
//
// Densest grid template in the catalogue — a 3-column tile sheet with
// 1-px gaps between tiles (Instagram / camera-roll style). No borders,
// no shadows on the tiles themselves; the grid IS the surface.
//
// Specification
// -------------
//
// Geometry
//   - AppBar with menu + search.
//   - Small TabBar-style sub-nav (Recents / Albums / Shared) below the
//     bar, reusing the existing TabBar primitive.
//   - 3-column grid filling the rest of the page. Each tile is
//     `(page_width - 2) / 3` wide (1px gap between cells × 2 gaps in
//     each row).
//
// Hardcoding
//   - Tile width is hardcoded to 136 px (412 − 4 ≈ 408 / 3 = 136).
//     Per the MusicLibraryPage lesson, computing tile size from page
//     width via `parent.width / 3` triggers Slint's binding-loop
//     detector when wrapped in a ScrollView. The mobile target is
//     fixed-width 412 so this is safe.

import { Theme } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { TabBar, Tab } from "../tab-bar.slint";
import { ScrollView } from "std-widgets.slint";

export struct PhotoEntry {
    cover: image,
}

component PhotoTile inherits Rectangle {
    in property <PhotoEntry> photo;
    callback clicked();

    accessible-role: button;
    accessible-label: "Photo";
    accessible-action-default => { root.clicked(); }

    width: 136px;
    height: 136px;
    clip: true;

    Image {
        width: parent.width;
        height: parent.height;
        source: root.photo.cover;
        image-fit: ImageFit.cover;
    }

    // Subtle press-state overlay, mid-translucent so it reads on any
    // underlying photo colour.
    Rectangle {
        width: parent.width;
        height: parent.height;
        background: touch.pressed ? #00000040 : transparent;
        animate background { duration: Theme.motion-fast; }
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}

export component PhotoGridPage inherits Rectangle {
    in-out property <int> tab-index: 0;
    in property <[PhotoEntry]> photos: [
        { cover: @image-url("../icons/album-blue.svg") },
        { cover: @image-url("../icons/photo-ocean.svg") },
        { cover: @image-url("../icons/album-emerald.svg") },
        { cover: @image-url("../icons/photo-coral.svg") },
        { cover: @image-url("../icons/album-sunset.svg") },
        { cover: @image-url("../icons/photo-forest.svg") },
        { cover: @image-url("../icons/photo-ocean.svg") },
        { cover: @image-url("../icons/album-blue.svg") },
        { cover: @image-url("../icons/photo-coral.svg") },
        { cover: @image-url("../icons/album-emerald.svg") },
        { cover: @image-url("../icons/photo-forest.svg") },
        { cover: @image-url("../icons/album-sunset.svg") },
    ];
    callback menu-pressed();
    callback search-pressed();
    callback photo-pressed(PhotoEntry);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "Photos";
            leading-icon: @image-url("../icons/menu.svg");
            trailing-icon: @image-url("../icons/search.svg");
            leading-pressed => { root.menu-pressed(); }
            trailing-pressed => { root.search-pressed(); }
        }

        TabBar {
            current-index <=> root.tab-index;
            Tab {
                label: "Recents";
                active: root.tab-index == 0;
                clicked => { root.tab-index = 0; }
            }
            Tab {
                label: "Albums";
                active: root.tab-index == 1;
                clicked => { root.tab-index = 1; }
            }
            Tab {
                label: "Shared";
                active: root.tab-index == 2;
                clicked => { root.tab-index = 2; }
            }
        }

        ScrollView {
            vertical-stretch: 1;

            VerticalLayout {
                alignment: start;
                spacing: 1px;
                padding-top: 1px;

                // 12 photos → 4 rows of 3.
                for row in [
                    {a: root.photos[0],  b: root.photos[1],  c: root.photos[2]},
                    {a: root.photos[3],  b: root.photos[4],  c: root.photos[5]},
                    {a: root.photos[6],  b: root.photos[7],  c: root.photos[8]},
                    {a: root.photos[9],  b: root.photos[10], c: root.photos[11]},
                ]: HorizontalLayout {
                    spacing: 1px;
                    alignment: center;
                    PhotoTile {
                        photo: row.a;
                        clicked => { root.photo-pressed(row.a); }
                    }
                    PhotoTile {
                        photo: row.b;
                        clicked => { root.photo-pressed(row.b); }
                    }
                    PhotoTile {
                        photo: row.c;
                        clicked => { root.photo-pressed(row.c); }
                    }
                }
            }
        }
    }
}
