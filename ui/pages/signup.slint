// SignupPage
// =====================================================================
//
// Sign-up landing screen — distinct from the existing `LoginPage`
// (returning user) and `FormWizardPage` (multi-step onboarding form).
// Demonstrates the canonical "create an account" surface with:
//
//   - Brand hero block at the top (gradient disc + product name +
//     value-prop tagline).
//   - Two TextFields (email + password) with a "Show password" toggle
//     row beneath them.
//   - "Or continue with" social-auth row: 3 pill buttons (Apple /
//     Google / email-only) each branded with its logo glyph.
//   - Terms + privacy checkbox + Sign-up CTA + "Already have an
//     account? Log in" footer.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { TextField } from "../text-field.slint";
import { Checkbox } from "../checkbox.slint";
import { Divider } from "../divider.slint";
import { MobileButton, TextButton } from "../button.slint";

// One social-auth pill.
component SocialPill inherits Rectangle {
    in property <string> label;
    in property <image> icon;
    in property <color> bg;
    in property <color> fg;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 48px;
    background: root.bg;
    border-radius: 24px;
    border-width: root.bg == #ffffff ? 1px : 0px;
    border-color: Theme.outline;

    HorizontalLayout {
        spacing: 8px;
        padding-left: 12px;
        padding-right: 12px;
        alignment: center;
        VerticalLayout {
            alignment: center;
            Image {
                width: 18px;
                height: 18px;
                source: root.icon;
                colorize: root.fg;
                image-fit: contain;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text: root.label;
                color: root.fg;
                font-size: Theme.font-size-caption;
                font-weight: 800;
                letter-spacing: 0.3px;
            }
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

export component SignupPage inherits Rectangle {
    in property <string> brand: "Slint Mobile";
    in property <string> tagline: "Build native mobile apps in Rust — no WebView, no compromises.";
    in-out property <bool> show-password: false;
    in-out property <bool> agreed: true;
    callback close-pressed();
    callback signup-pressed();
    callback social-pressed(string);
    callback switch-to-login-pressed();
    callback terms-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: "";
            leading-icon: @image-url("../icons/close.svg");
            leading-pressed => { root.close-pressed(); }
        }

        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-md;
            alignment: start;

            // Brand hero.
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 72px;
                    height: 72px;
                    border-radius: 18px;
                    background: @linear-gradient(135deg, #4f8cff 0%, #1f4eaa 100%);
                    Text {
                        text: "SM";
                        color: Theme.on-primary;
                        font-size: 28px;
                        font-weight: 800;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
            VerticalLayout {
                spacing: Theme.spacing-xs;
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: "Create your " + root.brand + " account";
                        color: Theme.on-background;
                        font-size: Theme.font-size-headline;
                        font-weight: 800;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
                HorizontalLayout {
                    alignment: center;
                    Text {
                        text: root.tagline;
                        color: Theme.muted;
                        font-size: Theme.font-size-body;
                        horizontal-alignment: center;
                        wrap: word-wrap;
                    }
                }
            }

            // Form fields.
            TextField {
                label: "Email";
                placeholder: "you@example.com";
                text: "greg@example.com";
            }
            TextField {
                label: "Password";
                placeholder: "At least 12 characters";
                text: "••••••••••••";
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                Checkbox {
                    checked <=> root.show-password;
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: "Show password";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-caption;
                    }
                }
                TextButton {
                    text: "Strength · Good";
                }
            }

            // Terms.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-xs;
                Checkbox {
                    checked <=> root.agreed;
                }
                VerticalLayout {
                    horizontal-stretch: 1;
                    alignment: center;
                    Text {
                        text: "I agree to the Terms of Service and Privacy Policy.";
                        color: Theme.on-surface;
                        font-size: Theme.font-size-caption;
                        wrap: word-wrap;
                        TouchArea {
                            clicked => { root.terms-pressed(); }
                        }
                    }
                }
            }

            // Primary CTA.
            MobileButton {
                text: "Create account";
                tone: Tone.info;
                max-height: 48px;
                clicked => { root.signup-pressed(); }
            }

            Divider { }

            // Social auth.
            HorizontalLayout {
                alignment: center;
                Text {
                    text: "Or continue with";
                    color: Theme.muted;
                    font-size: Theme.font-size-caption;
                    font-weight: 600;
                }
            }
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                SocialPill {
                    label: "Apple";
                    icon: @image-url("../icons/heart.svg");
                    bg: #000000;
                    fg: #ffffff;
                    clicked => { root.social-pressed("apple"); }
                }
                SocialPill {
                    label: "Google";
                    icon: @image-url("../icons/check.svg");
                    bg: #ffffff;
                    fg: #4285f4;
                    clicked => { root.social-pressed("google"); }
                }
                SocialPill {
                    label: "GitHub";
                    icon: @image-url("../icons/menu.svg");
                    bg: #24292e;
                    fg: #ffffff;
                    clicked => { root.social-pressed("github"); }
                }
            }
        }

        Rectangle { vertical-stretch: 1; }

        // Footer switch to log-in.
        Rectangle {
            background: Theme.surface-1;
            drop-shadow-blur: Theme.elevation-2-blur;
            drop-shadow-color: Theme.elevation-2-color;
            drop-shadow-offset-y: -4px;
            height: 64px;
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                alignment: center;
                VerticalLayout {
                    alignment: center;
                    Text {
                        text: "Already have an account?";
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }
                TextButton {
                    text: "Log in";
                    clicked => { root.switch-to-login-pressed(); }
                }
            }
        }
    }
}
