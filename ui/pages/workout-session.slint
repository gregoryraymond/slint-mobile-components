// WorkoutSessionPage
// =====================================================================
//
// Mid-session workout screen — Strong / Hevy / Apple Fitness-style.
// Distinct from `ActivityRingsPage` (daily ring summary) and
// `TimerPage` (single pomodoro). This is the live "you're in set 2
// of 4" surface. Demonstrates:
//
//   - Top header strip: workout name + total elapsed + abandon (×).
//   - Big rest-timer ring with seconds remaining when between sets;
//     when actively lifting, the ring slot is replaced by a "REPS"
//     counter card.
//   - Current-exercise card: exercise name + tone-tinted set-number
//     pill ("SET 2 / 4") + weight × reps fields + Done / Skip buttons.
//   - Set log table for the exercise (Set 1: 80 kg × 8, Set 2: 80 kg ×
//     8 done, Set 3: pending).
//   - Upcoming exercises list at the bottom.

import { Theme, Tone } from "../theme.slint";
import { AppBar } from "../app-bar.slint";
import { SectionHeader } from "../section-header.slint";
import { Divider } from "../divider.slint";
import { MobileButton } from "../button.slint";

// Reusable ring band (also used elsewhere — kept local so this page
// doesn't reach across into TimerPage's internals).
component RingBand inherits Rectangle {
    in property <length> radius;
    in property <length> stroke: 14px;
    in property <color> track-color: #ffffff14;
    in property <color> fill-color: Theme.primary;
    in property <float> progress: 1.0;

    width: 2 * root.radius;
    height: 2 * root.radius;
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: root.stroke;
        border-color: root.track-color;
        background: transparent;
    }
    Rectangle {
        width: parent.width;
        height: parent.height;
        border-radius: self.width / 2;
        border-width: root.stroke;
        border-color: root.fill-color;
        opacity: root.progress;
        background: transparent;
    }
}

// One set row in the log.
component SetRow inherits Rectangle {
    in property <int> set-no;
    in property <string> weight;
    in property <string> reps;
    in property <int> state: 0;     // 0 pending, 1 in-progress, 2 done

    horizontal-stretch: 1;
    min-height: 44px;
    background:
          root.state == 2 ? #22c55e1a
        : root.state == 1 ? #4f8cff1a
        : transparent;
    border-radius: Theme.radius-sm;

    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        VerticalLayout {
            alignment: center;
            width: 32px;
            Text {
                text: "SET " + root.set-no;
                color:
                      root.state == 2 ? Theme.accent-success
                    : root.state == 1 ? Theme.accent-info
                    : Theme.muted;
                font-size: 10px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }
        }
        VerticalLayout {
            alignment: center;
            horizontal-stretch: 1;
            Text {
                text: root.weight + " · " + root.reps + " reps";
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
        }
        VerticalLayout {
            alignment: center;
            Text {
                text:
                      root.state == 2 ? "DONE"
                    : root.state == 1 ? "NOW"
                    : "—";
                color:
                      root.state == 2 ? Theme.accent-success
                    : root.state == 1 ? Theme.accent-info
                    : Theme.muted;
                font-size: 10px;
                font-weight: 800;
                letter-spacing: 0.5px;
            }
        }
    }
}

// One upcoming-exercise row.
component UpcomingRow inherits Rectangle {
    in property <string> name;
    in property <string> meta;
    in property <Tone> tone: Tone.default;

    min-height: 56px;
    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: stretch;
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 32px;
                height: 32px;
                border-radius: 8px;
                background:
                      root.tone == Tone.success ? Theme.accent-success
                    : root.tone == Tone.warning ? Theme.accent-warning
                    : root.tone == Tone.danger  ? Theme.accent-danger
                    : root.tone == Tone.info    ? Theme.accent-info
                    : Theme.surface-variant;
                Image {
                    width: 16px;
                    height: 16px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("../icons/play.svg");
                    colorize: root.tone == Tone.default ? Theme.on-surface : Theme.on-primary;
                    image-fit: contain;
                }
            }
        }
        VerticalLayout {
            horizontal-stretch: 1;
            alignment: center;
            spacing: 2px;
            Text {
                text: root.name;
                color: Theme.on-surface;
                font-size: Theme.font-size-body;
                font-weight: 600;
            }
            Text {
                text: root.meta;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
        }
    }
}

export component WorkoutSessionPage inherits Rectangle {
    in property <string> workout-name: "Push day · A2";
    in property <string> elapsed: "27:14";
    in property <string> exercise: "Bench press";
    in property <int> set-current: 2;
    in property <int> set-total: 4;
    in property <string> rest-remaining: "1:18";
    in property <float> rest-progress: 0.42;
    callback abandon-pressed();
    callback done-pressed();
    callback skip-pressed();
    callback adjust-pressed();

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        AppBar {
            title: root.workout-name;
            leading-icon: @image-url("../icons/close.svg");
            trailing-icon: @image-url("../icons/more-vertical.svg");
            leading-pressed => { root.abandon-pressed(); }
        }

        // ----- Hero: elapsed + rest ring -----
        VerticalLayout {
            padding-top: Theme.spacing-sm;
            spacing: Theme.spacing-sm;

            HorizontalLayout {
                alignment: center;
                Text {
                    text: "ELAPSED · " + root.elapsed;
                    color: Theme.muted;
                    font-size: 10px;
                    font-weight: 800;
                    letter-spacing: 0.5px;
                }
            }
            HorizontalLayout {
                alignment: center;
                Rectangle {
                    width: 200px;
                    height: 200px;
                    RingBand {
                        x: 0;
                        y: 0;
                        radius: 100px;
                        stroke: 14px;
                        fill-color: Theme.accent-warning;
                        progress: root.rest-progress;
                    }
                    VerticalLayout {
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        width: parent.width - 60px;
                        height: parent.height - 60px;
                        alignment: center;
                        spacing: 2px;
                        HorizontalLayout {
                            alignment: center;
                            Rectangle {
                                width: rest-text.preferred-width + 12px;
                                height: 18px;
                                border-radius: 9px;
                                background: Theme.surface-2;
                                rest-text := Text {
                                    text: "REST";
                                    color: Theme.accent-warning;
                                    font-size: 10px;
                                    font-weight: 800;
                                    letter-spacing: 0.5px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }
                        }
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: root.rest-remaining;
                                color: Theme.on-background;
                                font-size: 48px;
                                font-weight: 300;
                            }
                        }
                        HorizontalLayout {
                            alignment: center;
                            Text {
                                text: "Next: Set " + root.set-current + " of " + root.set-total;
                                color: Theme.muted;
                                font-size: Theme.font-size-caption;
                            }
                        }
                    }
                }
            }
        }

        // ----- Current exercise card -----
        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-top: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            Rectangle {
                background: Theme.surface-1;
                border-radius: Theme.radius-md;
                drop-shadow-blur: Theme.elevation-1-blur;
                drop-shadow-color: Theme.elevation-1-color;
                drop-shadow-offset-y: Theme.elevation-1-y;

                VerticalLayout {
                    padding: Theme.spacing-md;
                    spacing: Theme.spacing-sm;

                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        alignment: stretch;
                        VerticalLayout {
                            horizontal-stretch: 1;
                            Text {
                                text: root.exercise;
                                color: Theme.on-surface;
                                font-size: Theme.font-size-title;
                                font-weight: 700;
                            }
                        }
                        VerticalLayout {
                            alignment: center;
                            Rectangle {
                                width: set-text.preferred-width + 14px;
                                height: 22px;
                                border-radius: 11px;
                                background: Theme.accent-info;
                                set-text := Text {
                                    text: "SET " + root.set-current + " / " + root.set-total;
                                    color: Theme.on-primary;
                                    font-size: 10px;
                                    font-weight: 800;
                                    letter-spacing: 0.5px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    width: parent.width;
                                    height: parent.height;
                                }
                            }
                        }
                    }

                    SetRow { set-no: 1; weight: "80 kg"; reps: "8"; state: 2; }
                    SetRow { set-no: 2; weight: "80 kg"; reps: "8"; state: 2; }
                    SetRow { set-no: 3; weight: "82.5 kg"; reps: "—"; state: 1; }
                    SetRow { set-no: 4; weight: "82.5 kg"; reps: "—"; state: 0; }

                    HorizontalLayout {
                        spacing: Theme.spacing-sm;
                        padding-top: 4px;
                        MobileButton {
                            text: "Skip rest";
                            primary: false;
                            horizontal-stretch: 1;
                            max-height: 44px;
                            clicked => { root.skip-pressed(); }
                        }
                        MobileButton {
                            text: "Done · log set";
                            horizontal-stretch: 2;
                            tone: Tone.success;
                            max-height: 44px;
                            clicked => { root.done-pressed(); }
                        }
                    }
                }
            }
        }

        // ----- Upcoming exercises -----
        SectionHeader { text: "UP NEXT"; }
        UpcomingRow {
            name: "Overhead press";
            meta: "4 × 6 · 50 kg target";
            tone: Tone.info;
        }
        Divider { }
        UpcomingRow {
            name: "Dumbbell row";
            meta: "3 × 10 · 30 kg target";
        }
        Divider { }
        UpcomingRow {
            name: "Tricep cable pushdown";
            meta: "3 × 12 · 40 kg target";
            tone: Tone.warning;
        }

        Rectangle { vertical-stretch: 1; }
    }
}
