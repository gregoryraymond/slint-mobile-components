// HotelBookingPage
// =====================================================================
//
// Booking.com / Airbnb-style hotel detail. Distinct from
// `TripItineraryPage` (multi-day plan) and `BoardingPassPage` (flight).
// Demonstrates:
//
//   - Cover hero with translucent back + share buttons + photo-count
//     pill (much like ProductDetailPage's hero pattern).
//   - Meta block: hotel name + star rating + city/area + rating
//     score box.
//   - Dates / guests strip — three inline pills (Check-in / Check-out /
//     Guests) that the user taps to edit.
//   - Amenities chip row (Wi-Fi / Breakfast / Pool / Pet-friendly).
//   - Room list — each room card carries: thumb, name + size, perks
//     (e.g. "Breakfast included", "Free cancellation"), price/night,
//     and a "Reserve" CTA inline.

import { Theme, Tone } from "../theme.slint";
import { SectionHeader } from "../section-header.slint";
import { Chip } from "../chip.slint";
import { Divider } from "../divider.slint";
import { MobileButton } from "../button.slint";

// One booking criterion pill (Check-in / Check-out / Guests).
component CriteriaPill inherits Rectangle {
    in property <string> label;
    in property <string> value;
    in property <bool> emphasize: false;
    callback clicked();

    accessible-role: button;
    accessible-label: root.label;
    accessible-action-default => { root.clicked(); }

    horizontal-stretch: 1;
    height: 60px;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    border-width: root.emphasize ? 1px : 0px;
    border-color: Theme.accent-info;

    VerticalLayout {
        padding: Theme.spacing-sm;
        spacing: 2px;
        alignment: center;
        Text {
            text: root.label;
            color: Theme.muted;
            font-size: 10px;
            font-weight: 800;
            letter-spacing: 0.5px;
        }
        Text {
            text: root.value;
            color: Theme.on-surface;
            font-size: Theme.font-size-body;
            font-weight: 700;
        }
    }
    TouchArea {
        clicked => { root.clicked(); }
    }
}

// One room card.
component RoomCard inherits Rectangle {
    in property <string> name;
    in property <string> size;
    in property <string> perks;
    in property <string> price;
    in property <bool> recommended: false;
    in property <brush> thumb-fill;
    callback reserve-pressed();

    horizontal-stretch: 1;
    background: Theme.surface-1;
    border-radius: Theme.radius-md;
    drop-shadow-blur: Theme.elevation-1-blur;
    drop-shadow-color: Theme.elevation-1-color;
    drop-shadow-offset-y: Theme.elevation-1-y;
    border-width: root.recommended ? 1px : 0px;
    border-color: Theme.accent-success;

    HorizontalLayout {
        padding: Theme.spacing-sm;
        spacing: Theme.spacing-sm;
        alignment: stretch;

        // Thumb.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 88px;
                height: 88px;
                border-radius: Theme.radius-sm;
                background: root.thumb-fill;
                clip: true;
            }
        }

        // Meta.
        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            HorizontalLayout {
                spacing: Theme.spacing-xs;
                alignment: start;
                Text {
                    text: root.name;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body;
                    font-weight: 700;
                    horizontal-stretch: 1;
                }
                if root.recommended: Rectangle {
                    width: best-text.preferred-width + 12px;
                    height: 18px;
                    border-radius: 4px;
                    background: Theme.accent-success;
                    best-text := Text {
                        text: "BEST VALUE";
                        color: Theme.on-primary;
                        font-size: 9px;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        width: parent.width;
                        height: parent.height;
                    }
                }
            }
            Text {
                text: root.size;
                color: Theme.muted;
                font-size: Theme.font-size-caption;
            }
            Text {
                text: root.perks;
                color: Theme.accent-success;
                font-size: Theme.font-size-caption;
                font-weight: 600;
                wrap: word-wrap;
            }
            HorizontalLayout {
                padding-top: 2px;
                Text {
                    text: root.price;
                    color: Theme.on-surface;
                    font-size: Theme.font-size-body-large;
                    font-weight: 700;
                    horizontal-stretch: 1;
                    vertical-alignment: center;
                }
                MobileButton {
                    text: "Reserve";
                    tone: Tone.info;
                    horizontal-stretch: 0;
                    min-width: 96px;
                    max-height: 36px;
                    clicked => { root.reserve-pressed(); }
                }
            }
        }
    }
}

export component HotelBookingPage inherits Rectangle {
    in property <string> hotel: "Memmo Alfama";
    in property <string> location: "Travessa das Merceeiras 27 · Alfama, Lisbon";
    in property <string> rating: "★★★★ · Boutique";
    in property <string> score: "9.4";
    in property <string> score-label: "Exceptional · 2,184 reviews";
    callback back-pressed();
    callback share-pressed();
    callback heart-pressed();
    callback edit-criteria-pressed(string);
    callback reserve-pressed(string);

    background: Theme.background;

    VerticalLayout {
        spacing: 0;

        // ----- Hero -----
        Rectangle {
            height: 240px;
            background: @linear-gradient(135deg, #b45309 0%, #451a03 100%);
            clip: true;

            // Translucent action buttons.
            HorizontalLayout {
                x: 0;
                y: 0;
                width: parent.width;
                height: 64px;
                padding: Theme.spacing-md;
                alignment: stretch;
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("../icons/arrow-left.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.back-pressed(); }
                    }
                }
                Rectangle { horizontal-stretch: 1; }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("../icons/send.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.share-pressed(); }
                    }
                }
                Rectangle { width: Theme.spacing-sm; }
                Rectangle {
                    width: 36px;
                    height: 36px;
                    border-radius: self.width / 2;
                    background: #00000066;
                    Image {
                        width: 18px;
                        height: 18px;
                        x: (parent.width - self.width) / 2;
                        y: (parent.height - self.height) / 2;
                        source: @image-url("../icons/heart.svg");
                        colorize: #ffffff;
                        image-fit: contain;
                    }
                    TouchArea {
                        clicked => { root.heart-pressed(); }
                    }
                }
            }

            // Photo counter.
            Rectangle {
                x: parent.width - self.width - Theme.spacing-md;
                y: parent.height - self.height - Theme.spacing-md;
                width: counter-text.preferred-width + 18px;
                height: 24px;
                border-radius: 12px;
                background: #00000099;
                counter-text := Text {
                    text: "1 / 48";
                    color: #ffffff;
                    font-size: Theme.font-size-caption;
                    font-weight: 700;
                    horizontal-alignment: center;
                    vertical-alignment: center;
                    width: parent.width;
                    height: parent.height;
                }
            }
        }

        // ----- Meta -----
        VerticalLayout {
            padding: Theme.spacing-md;
            spacing: Theme.spacing-xs;

            HorizontalLayout {
                spacing: Theme.spacing-md;
                alignment: stretch;
                VerticalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;
                    Text {
                        text: root.rating;
                        color: Theme.accent-warning;
                        font-size: Theme.font-size-caption;
                        font-weight: 700;
                        letter-spacing: 0.5px;
                    }
                    Text {
                        text: root.hotel;
                        color: Theme.on-background;
                        font-size: Theme.font-size-headline;
                        font-weight: 700;
                    }
                    Text {
                        text: root.location;
                        color: Theme.muted;
                        font-size: Theme.font-size-caption;
                    }
                }

                // Score box.
                VerticalLayout {
                    alignment: center;
                    Rectangle {
                        width: 56px;
                        height: 56px;
                        border-radius: Theme.radius-sm;
                        background: Theme.accent-success;
                        Text {
                            text: root.score;
                            color: Theme.on-primary;
                            font-size: Theme.font-size-title;
                            font-weight: 800;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            width: parent.width;
                            height: parent.height;
                        }
                    }
                }
            }

            Text {
                text: root.score-label;
                color: Theme.accent-success;
                font-size: Theme.font-size-caption;
                font-weight: 600;
            }

            // Dates + guests strip.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-sm;
                CriteriaPill {
                    label: "CHECK-IN";
                    value: "Fri, May 14";
                    emphasize: true;
                    clicked => { root.edit-criteria-pressed("check-in"); }
                }
                CriteriaPill {
                    label: "CHECK-OUT";
                    value: "Mon, May 19";
                    clicked => { root.edit-criteria-pressed("check-out"); }
                }
                CriteriaPill {
                    label: "GUESTS";
                    value: "2 adults";
                    clicked => { root.edit-criteria-pressed("guests"); }
                }
            }

            // Amenities chips.
            HorizontalLayout {
                spacing: Theme.spacing-sm;
                padding-top: Theme.spacing-sm;
                Chip { label: "Wi-Fi"; selected: true; }
                Chip { label: "Breakfast"; }
                Chip { label: "Pool"; }
                Chip { label: "Pet-friendly"; }
            }
        }

        SectionHeader { text: "AVAILABLE ROOMS · 5 NIGHTS"; }

        VerticalLayout {
            padding-left: Theme.spacing-md;
            padding-right: Theme.spacing-md;
            padding-bottom: Theme.spacing-md;
            spacing: Theme.spacing-sm;

            RoomCard {
                name: "Classic double";
                size: "20 m² · 1 queen bed";
                perks: "Free cancellation · breakfast included";
                price: "€820 / 5 nights";
                recommended: true;
                thumb-fill: @linear-gradient(135deg, #b45309 0%, #451a03 100%);
                reserve-pressed => { root.reserve-pressed(self.name); }
            }
            RoomCard {
                name: "Deluxe view";
                size: "28 m² · 1 king · Tagus view";
                perks: "Free cancellation · welcome wine";
                price: "€1,140 / 5 nights";
                thumb-fill: @linear-gradient(135deg, #d97706 0%, #92400e 100%);
                reserve-pressed => { root.reserve-pressed(self.name); }
            }
            RoomCard {
                name: "Garden suite";
                size: "42 m² · separate sitting room";
                perks: "Free cancellation · suite breakfast in room";
                price: "€1,720 / 5 nights";
                thumb-fill: @linear-gradient(135deg, #16a34a 0%, #14532d 100%);
                reserve-pressed => { root.reserve-pressed(self.name); }
            }
        }

        Rectangle { vertical-stretch: 1; }
    }
}
