// Checkbox
// =====================================================================
//
// Square multi-select form control. Use for "agree to terms", filter
// option groups, settings that toggle independently of one another.
// For mutually-exclusive choices use a radio group; for an on/off
// preference at the row level prefer `MobileSwitch`.
//
// Specification
// -------------
//
// Geometry
//   - 20 × 20 px box, vertically centred in a 48 px (touch-target) row.
//   - Label sits to the right of the box with `Theme.spacing-md`
//     between them. Tapping anywhere on the row toggles the state — the
//     entire row is the hit zone.
//
// State
//   - `checked` (in-out bool, default false): the current state.
//   - `enabled` (bool, default true): dims to 0.5 and disables touch.
//
// Style
//   - Unchecked: 2 px `Theme.outline` border, transparent fill.
//   - Checked: filled `Theme.primary`, no border, white check glyph
//     sized 14 × 14 centred inside.
//   - Background transitions over `Theme.motion-fast` for the press
//     hint; the check glyph appears immediately when state flips.
//
// Interaction
//   - Tap → flips `checked`, emits `toggled(bool)` with the new value.
//   - `accessible-role: checkbox` + `accessible-checkable: true` +
//     `accessible-checked: root.checked` so screen readers (and the
//     behavior-test harness) can read state.

import { Theme } from "theme.slint";

export component Checkbox inherits Rectangle {
    in property <string> label;
    in-out property <bool> checked: false;
    in property <bool> enabled: true;
    callback toggled(bool);

    accessible-role: checkbox;
    accessible-label: root.label;
    accessible-checkable: true;
    accessible-checked: root.checked;
    accessible-enabled: root.enabled;
    accessible-action-default => {
        root.checked = !root.checked;
        root.toggled(root.checked);
    }

    min-height: Theme.touch-target;
    horizontal-stretch: 1;
    background: touch.pressed ? Theme.surface-pressed : transparent;
    border-radius: Theme.radius-sm;
    opacity: root.enabled ? 1.0 : 0.5;

    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        spacing: Theme.spacing-md;
        alignment: start;

        // The box itself. Wrapped in a VerticalLayout(alignment: center)
        // so it sits in the vertical middle of the 48-px row regardless
        // of the label's intrinsic height — Rectangles can't honour a
        // `vertical-alignment` directly.
        VerticalLayout {
            alignment: center;
            Rectangle {
                width: 20px;
                height: 20px;
                border-radius: Theme.radius-sm;
                background: root.checked ? Theme.primary : transparent;
                border-width: root.checked ? 0px : 2px;
                border-color: Theme.outline;

                animate background { duration: Theme.motion-fast; }

                if root.checked: Image {
                    width: 14px;
                    height: 14px;
                    x: (parent.width - self.width) / 2;
                    y: (parent.height - self.height) / 2;
                    source: @image-url("icons/check.svg");
                    colorize: Theme.on-primary;
                    image-fit: contain;
                }
            }
        }

        Text {
            text: root.label;
            color: Theme.on-surface;
            font-size: Theme.font-size-body-large;
            vertical-alignment: center;
            horizontal-stretch: 1;
        }
    }

    touch := TouchArea {
        enabled: root.enabled;
        mouse-cursor: pointer;
        clicked => {
            root.checked = !root.checked;
            root.toggled(root.checked);
        }
    }
}
