// Theme
// =====================================================================
//
// Single source of truth for visual constants used across the library.
// Every other component imports `Theme` and reads tokens by name —
// nothing hard-codes a colour, spacing, font size, or duration.
//
// Specification
// -------------
//
// Type
//   - Global. Accessible from any `.slint` file in the library and from
//     consuming code via `ComponentHandle::global::<Theme>()`.
//
// Properties
//   - All properties are `in-out`: a consuming app may rebind them at
//     startup or runtime to switch palettes:
//
//         ui.global::<Theme>().set_primary(slint::Color::from_rgb_u8(
//             0xff, 0x6b, 0x35,
//         ));
//
// Token groups
//   - Colour palette (15 tokens): background / surface / surface-variant
//     / surface-pressed for fills; primary / primary-pressed / on-primary
//     for the brand control set; on-background / on-surface / muted for
//     foreground text; outline for hairline dividers; danger / success
//     for status states.
//   - Spacing scale (5 tokens, 4–32 px): spacing-xs through spacing-xl.
//     Use these on layout `padding` and `spacing` properties so vertical
//     rhythm stays consistent.
//   - Typography (5 tokens, 12–28 px): font-size-caption / -body /
//     -body-large / -title / -headline.
//   - Touch + radii: `touch-target` is 48px — the Material minimum and
//     the floor every tappable component honours. `radius-sm / -md / -lg`
//     are 6 / 12 / 20 px.
//   - Motion: `motion-fast` (120 ms) for tap state transitions,
//     `motion-base` (200 ms) for switch knobs and layout reflows.
//
// Defaults form a dark theme aligned with the slint-mobile starter's
// `#0f1115` background.

export global Theme {
    // ---- Color palette --------------------------------------------------
    in-out property <color> background: #0f1115;
    in-out property <color> surface: #1a1d24;
    in-out property <color> surface-variant: #232730;
    in-out property <color> surface-pressed: #2a2f3a;
    in-out property <color> primary: #4f8cff;
    in-out property <color> primary-pressed: #3a72e0;
    in-out property <color> on-primary: #ffffff;
    in-out property <color> on-background: #f5f5f7;
    in-out property <color> on-surface: #e4e6eb;
    in-out property <color> muted: #9aa0a6;
    in-out property <color> outline: #2d313a;
    in-out property <color> danger: #ef4444;
    in-out property <color> success: #22c55e;

    // ---- Spacing scale --------------------------------------------------
    in-out property <length> spacing-xs: 4px;
    in-out property <length> spacing-sm: 8px;
    in-out property <length> spacing-md: 16px;
    in-out property <length> spacing-lg: 24px;
    in-out property <length> spacing-xl: 32px;

    // ---- Typography -----------------------------------------------------
    in-out property <length> font-size-caption: 12px;
    in-out property <length> font-size-body: 14px;
    in-out property <length> font-size-body-large: 16px;
    in-out property <length> font-size-title: 20px;
    in-out property <length> font-size-headline: 28px;

    // ---- Touch + radii --------------------------------------------------
    // 48dp is the Material minimum touch target.
    in-out property <length> touch-target: 48px;
    in-out property <length> radius-sm: 6px;
    in-out property <length> radius-md: 12px;
    in-out property <length> radius-lg: 20px;

    // ---- Motion ---------------------------------------------------------
    in-out property <duration> motion-fast: 120ms;
    in-out property <duration> motion-base: 200ms;
}
