import { Theme } from "theme.slint";

// Card — elevated surface used to group related content. Optional title +
// subtitle. Place arbitrary children inside via the @children slot; they
// stack vertically with the standard spacing.
export component Card inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <bool> tappable: false;
    callback clicked();

    background: touch.pressed && root.tappable ? Theme.surface-pressed : Theme.surface;
    border-radius: Theme.radius-md;
    drop-shadow-blur: 8px;
    drop-shadow-color: #00000040;
    drop-shadow-offset-y: 2px;
    horizontal-stretch: 1;

    animate background { duration: Theme.motion-fast; }

    VerticalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-sm;

        if root.title != "": Text {
            text: root.title;
            color: Theme.on-surface;
            font-size: Theme.font-size-title;
            font-weight: 600;
        }

        if root.subtitle != "": Text {
            text: root.subtitle;
            color: Theme.muted;
            font-size: Theme.font-size-body;
            wrap: word-wrap;
        }

        @children
    }

    touch := TouchArea {
        enabled: root.tappable;
        mouse-cursor: pointer;
        clicked => { root.clicked(); }
    }
}
