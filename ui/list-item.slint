// ListItem
// =====================================================================
//
// One row in a vertical list. Standard settings / menu / contact-row
// pattern with optional leading + trailing icons and a two-line text
// block.
//
// Specification
// -------------
//
// Geometry
//   - min-height: `Theme.touch-target + Theme.spacing-sm` (56px) so the
//     row is always tappable even with a single-line title.
//   - Full width (`horizontal-stretch: 1`).
//   - 16px horizontal padding, 8px vertical, 16px gap between leading
//     icon / text block / trailing icon.
//
// Slots
//   - `leading-icon` (image, optional): 24×24, tinted `Theme.muted`.
//     Hidden if empty.
//   - Text block (centre): `title` (16px, weight-500, on-surface) above
//     `subtitle` (14px, muted). The subtitle row is omitted entirely
//     when empty; the title alone vertically centres in the row.
//   - `trailing-icon` (image, optional): mirror of leading. Typical
//     glyphs: `chevron-right.svg` for nav rows, `check.svg` for select
//     state, etc.
//
// Divider
//   - `show-divider` (bool, default true) draws a 1px `Theme.outline`
//     hairline along the bottom edge, inset by the horizontal padding
//     so it doesn't reach the screen edges. Set false on the last item
//     in a section.
//
// Interaction
//   - Press feedback: background → `Theme.surface-pressed`. Emits
//     `clicked()`. Tap area = full row.
//
// Composition
//   - Stack inside a `Card` (rounded section) or a bare `Rectangle`
//     (flush-edge section) inside a `ScrollView`. See `SettingsPage`.
import { Theme } from "theme.slint";

export component ListItem inherits Rectangle {
    in property <string> title;
    in property <string> subtitle;
    in property <image> leading-icon;
    in property <image> trailing-icon;
    // Default false per DESIGN.md (no borders). Set true (or interleave
    // explicit `Divider` components) when classic list-row separators
    // are wanted.
    in property <bool> show-divider: false;
    callback clicked();

    accessible-role: list-item;
    accessible-label: root.title;
    accessible-description: root.subtitle;
    accessible-action-default => { root.clicked(); }

    min-height: Theme.touch-target + Theme.spacing-sm;
    horizontal-stretch: 1;
    background: touch.pressed ? Theme.surface-pressed : transparent;

    animate background { duration: Theme.motion-fast; }

    HorizontalLayout {
        padding-left: Theme.spacing-md;
        padding-right: Theme.spacing-md;
        padding-top: Theme.spacing-sm;
        padding-bottom: Theme.spacing-sm;
        spacing: Theme.spacing-md;
        alignment: stretch;

        if root.leading-icon.width > 0: Image {
            width: 24px;
            height: 24px;
            source: root.leading-icon;
            colorize: Theme.muted;
            image-fit: contain;
            vertical-alignment: center;
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;
            alignment: center;

            Text {
                text: root.title;
                color: Theme.on-surface;
                font-size: Theme.font-size-body-large;
                font-weight: 500;
            }

            if root.subtitle != "": Text {
                text: root.subtitle;
                color: Theme.muted;
                font-size: Theme.font-size-body;
            }
        }

        if root.trailing-icon.width > 0: Image {
            width: 24px;
            height: 24px;
            source: root.trailing-icon;
            colorize: Theme.muted;
            image-fit: contain;
            vertical-alignment: center;
        }
    }

    if root.show-divider: Rectangle {
        x: Theme.spacing-md;
        y: parent.height - 1px;
        width: parent.width - 2 * Theme.spacing-md;
        height: 1px;
        background: Theme.outline;
    }

    touch := TouchArea {
        clicked => { root.clicked(); }
    }
}
