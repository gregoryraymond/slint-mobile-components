// Skeleton
// =====================================================================
//
// Animated placeholder for content that's still loading. Drop one (or
// several stacked) where a Card / ListItem / Avatar would sit; the
// shimmer reassures users that the page is loading rather than empty.
//
// Specification
// -------------
//
// Geometry
//   - Sized entirely by the caller. Default is `horizontal-stretch: 1`
//     and `min-height: 16 px` (one line of body text). Callers set
//     explicit `width` / `height` for an avatar (40 × 40, circular via
//     border-radius), a title bar (60 % wide), etc.
//
// Style
//   - `Theme.surface-variant` background. `border-radius` defaults to
//     `Theme.radius-sm` — override to `width / 2` for a circular
//     skeleton (avatar placeholder).
//
// Animation
//   - Pulses between full and 0.4 opacity on a 800 ms cycle. The pulse
//     phase is driven by a Timer toggling a bool; `animate opacity`
//     interpolates smoothly between the two values.

import { Theme } from "theme.slint";

export component Skeleton inherits Rectangle {
    horizontal-stretch: 1;
    min-height: 16px;
    background: Theme.surface-variant;
    border-radius: Theme.radius-sm;
    opacity: root.pulse-bright ? 1.0 : 0.4;

    animate opacity { duration: 800ms; easing: ease-in-out; }

    property <bool> pulse-bright: true;

    Timer {
        interval: 800ms;
        running: true;
        triggered => {
            root.pulse-bright = !root.pulse-bright;
        }
    }
}
