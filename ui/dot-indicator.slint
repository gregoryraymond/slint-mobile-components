// DotIndicator
// =====================================================================
//
// Compact horizontal pagination indicator — a row of small circles
// where one is "active" (wider and primary-coloured). Used in
// onboarding flows, swipeable card carousels, image galleries, and
// anywhere paginated content has a small fixed page count (~ ≤ 8).
//
// For larger page counts use a numeric or progress-bar indicator
// instead — a row of 30 dots loses meaning fast.
//
// Specification
// -------------
//
// Geometry
//   - Height: 12 px (the active dot plus breathing room).
//   - Inactive dots: 8 × 8 px circles.
//   - Active dot: 24 × 8 px pill (wider, same height).
//   - 8 px gap between dots.
//
// Style
//   - Inactive: `Theme.surface-variant`.
//   - Active: `Theme.primary`.
//   - Both width and background animate over `Theme.motion-base` for
//     a smooth transition when `active` changes.
//
// Accessibility
//   - Decorative — no `accessible-role` set. The page itself carries
//     the semantic state ("page 2 of 4"). If the surrounding flow needs
//     to announce page changes, do it on the page component, not here.

import { Theme } from "theme.slint";

export component DotIndicator inherits Rectangle {
    in property <int> count: 4;
    in property <int> active: 0;

    height: 12px;

    HorizontalLayout {
        spacing: Theme.spacing-sm;
        alignment: center;
        for i in root.count: Rectangle {
            width: i == root.active ? 24px : 8px;
            height: 8px;
            border-radius: 4px;
            background: i == root.active ? Theme.primary : Theme.surface-variant;
            animate width { duration: Theme.motion-base; easing: ease-out; }
            animate background { duration: Theme.motion-base; }
        }
    }
}
