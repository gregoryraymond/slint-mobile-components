// CI compile-time validation entry. build.rs compiles this single file so
// every component in the library has its `.slint` syntax type-checked on
// every build. The file is Window-rooted and instantiates each component
// once, which silences slint-build's "Exported component doesn't inherit
// Window. No code will be generated for it" advisory.
//
// Consumers don't see this file: their `library_paths` configuration points
// at the `ui/` directory and they import individual components by path
// (`@mobile-components/button.slint` etc.).

import { Theme } from "theme.slint";
import { MobileButton, TextButton, Fab } from "button.slint";
import { Card } from "card.slint";
import { AppBar } from "app-bar.slint";
import { BottomNav, BottomNavItem } from "bottom-nav.slint";
import { ListItem } from "list-item.slint";
import { TextField } from "text-field.slint";
import { MobileSwitch } from "switch.slint";
import { HomePage } from "pages/home.slint";
import { SettingsPage } from "pages/settings.slint";
import { LoginPage } from "pages/login.slint";

export component _Check inherits Window {
    preferred-width: 412px;
    preferred-height: 892px;
    background: Theme.background;

    in property <int> page-index: 0;

    if page-index == 0: HomePage {
        width: 100%;
        height: 100%;
    }
    if page-index == 1: SettingsPage {
        width: 100%;
        height: 100%;
    }
    if page-index == 2: LoginPage {
        width: 100%;
        height: 100%;
    }
    if page-index == 3: VerticalLayout {
        padding: Theme.spacing-md;
        spacing: Theme.spacing-md;
        AppBar { title: "Components"; trailing-icon: "⋮"; }
        MobileButton { text: "Primary"; }
        MobileButton { text: "Secondary"; primary: false; }
        TextButton { text: "Text action"; }
        Card { title: "Card"; subtitle: "A surface for grouped content."; }
        ListItem { title: "List item"; subtitle: "with a subtitle"; trailing-icon: "›"; }
        TextField { label: "Label"; placeholder: "Type here"; }
        HorizontalLayout {
            spacing: Theme.spacing-md;
            alignment: start;
            MobileSwitch { checked: true; }
            Fab { }
        }
        BottomNav {
            BottomNavItem { label: "A"; icon-text: "⌂"; active: true; }
            BottomNavItem { label: "B"; icon-text: "⌕"; }
        }
    }
}
